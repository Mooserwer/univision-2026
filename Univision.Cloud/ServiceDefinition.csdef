<?xml version="1.0" encoding="utf-8"?>
<ServiceDefinition name="Univision.Cloud" xmlns="http://schemas.microsoft.com/ServiceHosting/2008/10/ServiceDefinition" schemaVersion="2015-04.2.6">
  <WebRole name="Univision.Main" vmsize="Standard_D1_v2">
    <Sites>
      <Site name="Web">
        <Bindings>
          <Binding name="Endpoint1" endpointName="Endpoint1" />
        </Bindings>
      </Site>
    </Sites>
    <ConfigurationSettings>
      <Setting name="StorageConnectionString" />
      <Setting name="storageConnectionString-1" />
    </ConfigurationSettings>
    <Endpoints>
      <InputEndpoint name="Endpoint1" protocol="http" port="80" />
    </Endpoints>
    <LocalResources>
      <LocalStorage name="LocalStorage1" cleanOnRoleRecycle="true" />
    </LocalResources>
  </WebRole>
</ServiceDefinition>