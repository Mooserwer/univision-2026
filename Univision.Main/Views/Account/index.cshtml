
@{
  Layout = null;
  string returnUrl = "";
  returnUrl = ViewBag.returnUrl;
  string isExternal = ViewBag.isExternal.ToString();
  string remember_id = String.Empty;
  string remember = String.Empty;
  if (HttpContext.Current.Request.Cookies.AllKeys.Contains("remember"))
  {
    remember = Request.Cookies["remember"].Value;
    if (HttpContext.Current.Request.Cookies.AllKeys.Contains("remember_id"))
    {
      remember_id = Request.Cookies["remember_id"].Value;
    }
  }
}
<!DOCTYPE html>
<html lang="ko">
<head>
    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Sign In | Univision</title>


    <!-- Vendor css -->
    <link rel="stylesheet" href="~/Libs/slim/lib/font-awesome/css/font-awesome.css" />
    <link href="~/Libs/slim/lib/Ionicons/css/ionicons.css" rel="stylesheet">


    <!-- Slim CSS -->
    <link rel="stylesheet" href="~/Libs/slim/css/slim.css">
    <link href="~/Libs/slim/lib/jquery.steps/css/jquery.steps.login.css" rel="stylesheet">
    <link href="~/Libs/alertifyjs/css/alertify.min.css" rel="stylesheet">

    <style>

        .wizard > .content {
            min-height: 27em !important;
        }

        .wizard > .actions > ul > li.disabled {
            display: none !important;
        }

        .btn-signin {
            font-weight: 500;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 40px;
            border: 0;
            min-height: 40px;
            background-image: linear-gradient(to right, #1b84e7 0%, #6f42c1 100%);
            background-repeat: repeat-x;
        }
    </style>
</head>
<body>
    @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { @class = "form-signin", @id = "frmLogin"}))
    {
        @Html.Hidden("isExternal", isExternal)
        <div class="signin-wrapper">

            <div class="signin-box" id="wizard-login">
                <span style="display:none;">step1</span>
                <section>
                    <h2 class="slim-logo"><a href="/">Univision<span>.</span></a></h2>
                    <h2 class="signin-title-primary">Welcome!</h2>
                    <h3 class="signin-title-secondary">Sign in to continue.</h3>
                    <div class="form-group">
                        <input type="text" class="form-control" name="id" id="id" autocomplete="username" placeholder="Enter your ID" value="@remember_id">
                    </div><!-- form-group -->
                    <div class="form-group">
                        <input type="password" class="form-control" name="pwd" id="pwd" autocomplete="current-password" placeholder="Enter your password">
                    </div><!-- form-group -->
                    <div class="form-group mg-b-30" id="chk_remember_id">
                        <label class="ckbox">
                            <input type="checkbox" value="1" id="remember" name="remember" @(remember == "1" ? "checked" : "")><span>Remember ID</span>
                        </label>
                    </div>
                    
    <button class="btn btn-primary btn-block btn-signin d-none">Sign In</button>
        
                </section>

                @if (isExternal == "1")
                {
                    <span style="display:none;">step2</span>
                    <section>
                        <h2 class="slim-logo"><a href="/">Univision<span>.</span></a></h2>
                        <h3 class="signin-title-primary">문자 인증이 필요합니다.</h3>
                        <h5 class="signin-title-secondary">휴대폰으로 발송된 인증코드를 입력해주세요.</h5>
                        <div class="form-group">
                            <input type="text" class="form-control" name="authCode" id="authCode" autocomplete="off" placeholder="Enter Code (****)">
                        </div><!-- form-group -->
                        <!--
                        <button class="btn btn-primary btn-block btn-signin">Sign In</button>
                        -->
                    </section>
                }
                <!--<p class="mg-b-0">Don't have an account? <a href="page-signup.html">Sign Up</a></p>-->
            </div><!-- signin-box -->

        </div><!-- signin-wrapper -->
    }


    <script src="~/Libs/slim/lib/jquery/js/jquery.js"></script>
    <script src="~/Libs/slim/lib/jquery.steps/js/jquery.steps.js"></script>
    <script src="~/Libs/slim/lib/popper.js/js/popper.js"></script>
    <script src="~/Libs/slim/lib/bootstrap/js/bootstrap.js"></script>
    <script src="~/Libs/jquery-loading-overlay-master/dist/loadingoverlay.min.js"></script>
    <script src="~/Libs/alertifyjs/alertify.min.js"></script>
    <script src="~/Libs/slim/js/slim.js"></script>
    <script src="~/Scripts/Common.js?slimv0.0.3"></script>
    <script src="~/Scripts/CommonAlert.js?slimv0.0.2"></script>
    <script>

      @if (isExternal == "1")
      {
        <text>
      var pop_help_title = "<span>현재 접속하신 방식은 VPN 접속이 아닙니다.</span>"
      var pop_help_txt = "<span class='text-danger'>* 현재 접속 중인 OTP 외부접속 방식은 곧 차단 될 예정입니다.</span><br/>사전에 안내드린 VPN방식을 통해 접속 부탁드립니다.<br/>";
      popover_help('login', '#chk_remember_id', pop_help_title, pop_help_txt, 0, "top", 1);
        </text>

        
      }
      
      


        //StopEnterSubmit();
      window.login_url = "@Url.Action("Index", "Dashboard")";
      window.returnUrl = "@returnUrl";
    </script>
    
    <script src="~/Scripts/Account/index.js?slimv0.0.6"></script>
</body>

</html>