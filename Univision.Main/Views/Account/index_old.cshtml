    <!-- Page -->
    @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { @class = "form-signin", id = "frmLogin" }))
    {
        @Html.Hidden("isExternal", isExternal)
        <div class="page vertical-align text-center" data-animsition-in="fade-in" data-animsition-out="fade-out">
            <div class="page-content vertical-align-middle animation-slide-top animation-duration-1">
                <div class="panel">
                    <div class="panel-body">
                        <div class="brand">
                            <h2 class="brand-text font-size-18">UniVision</h2>
                        </div>
                        <div class="form-group form-material floating" data-plugin="formMaterial">
                            <input type="text" class="form-control" name="id" id="id" value="@remember_id" />
                            <label class="floating-label">Id</label>
                        </div>
                        <div class="form-group form-material floating" data-plugin="formMaterial">
                            <input type="password" class="form-control" name="pwd" id="pwd" />
                            <label class="floating-label">Password</label>
                        </div>

                        <div id="smsDiv" class="form-group form-material floating" data-plugin="formMaterial" style="display:none;">
                            <div class="input-group">
                                <input type="text" class="form-control" name="authCode" id="authCode" autocomplete="off" />
                                <label class="floating-label">SMS인증</label>
                                <div class="input-group-btn">
                                    <button type="button" id="btnSendSms" class="btn btn-success btn-block btn-xs">SMS 인증</button>
                                    <button type="button" id="btnCheckCode" class="btn btn-success btn-block btn-xs" style="display:none;">인증 확인</button>
                                </div>
                            </div>
                            <label class="form-control-plaintext red-600 font-size-12 text-left">* 외부 접속시, SMS 인증을 받으셔야 합니다.</label>
                        </div>

                        <div class="form-group clearfix">
                            <div class="checkbox-custom checkbox-inline checkbox-primary checkbox-lg float-left">
                                <input type="checkbox" id="isRemember" name="isRemember" @(remember == "1" ? "checked" : "")>
                                <label for="isRemember">Remember me</label>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary btn-block btn-lg mt-40">Sign in</button>
                    </div>
                </div>

                <footer class="page-copyright page-copyright-inverse">
                    <p>WEBSITE BY UnicoSearch</p>
                    <p>© 2019. All RIGHT RESERVED.</p>
                </footer>
            </div>
        </div>
    }

