@model List<Univision.Core.Models.DTO.appr_doc>
@{
  Layout = "~/Views/Shared/_Layout.cshtml";
  ViewBag.Title = "전자결재 - 결재함";
  int tab = (int)ViewBag.tab;
}

<div class="page-content">
  <div class="panel panel-success panel-line shadow">
    <div class="panel-heading">
      <h3 class="panel-title"><i class="fas fa-stamp"></i> 전자결재 - 결재함</h3>
    </div>
    <div class="panel-body">
      <ul class="nav nav-tabs mb-15">
        <li class="nav-item"><a class="nav-link @(tab == 0 ? "active" : "")" href="@Url.Action("ApprovalList", "Appr", new { tab = 0 })">결재 대기</a></li>
        <li class="nav-item"><a class="nav-link @(tab == 1 ? "active" : "")" href="@Url.Action("ApprovalList", "Appr", new { tab = 1 })">결재 완료</a></li>
        <li class="nav-item"><a class="nav-link @(tab == 2 ? "active" : "")" href="@Url.Action("ApprovalList", "Appr", new { tab = 2 })">참조</a></li>
      </ul>

      <table class="table table-hover">
        <thead>
          <tr>
            <th style="width:100px;">상태</th>
            <th>제목</th>
            <th style="width:120px;">기안자</th>
            <th style="width:160px;">상신일</th>
            <th style="width:70px;">첨부</th>
          </tr>
        </thead>
        <tbody>
          @if (Model.Count == 0)
          {
            <tr><td colspan="5" class="text-center text-muted py-20">문서가 없습니다.</td></tr>
          }
          @foreach (var d in Model)
          {
            <tr style="cursor:pointer;" onclick="location.href='@Url.Action("Detail", "Appr", new { ad_seq = d.ad_seq })'">
              <td>
                @if (d.doc_status == 1) { <span class="badge badge-info">진행중</span> }
                else if (d.doc_status == 2) { <span class="badge badge-success">승인완료</span> }
                else if (d.doc_status == 3) { <span class="badge badge-danger">반려</span> }
                else { <span class="badge badge-secondary">-</span> }
              </td>
              <td>@d.title</td>
              <td>@d.drafter_name</td>
              <td>@(d.submit_date.HasValue ? d.submit_date.Value.ToString("yyyy-MM-dd HH:mm") : "-")</td>
              <td>@(d.file_count > 0 ? "📎 " + d.file_count : "")</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
</div>
