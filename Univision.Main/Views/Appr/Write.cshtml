@model Univision.Core.Models.DTO.ApprDocViewModel
@{
  Layout = "~/Views/Shared/_Layout.cshtml";
  ViewBag.Title = "전자결재 - 기안 작성";
  var usersJson = Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.users ?? new System.Collections.Generic.List<object>());
  var lineJson = Newtonsoft.Json.JsonConvert.SerializeObject(
    Model.lines.Where(l => l.line_type == 0).Select(l => new { l.approver_seq, l.approver_name }));
  var refJson = Newtonsoft.Json.JsonConvert.SerializeObject(
    Model.lines.Where(l => l.line_type == 1).Select(l => new { l.approver_seq, l.approver_name }));
}

<style>
  .appr-chips { display: flex; flex-wrap: wrap; gap: 8px; align-items: stretch; }
  .appr-chip { border: 1px solid #cdd6e0; border-radius: 8px; background: #f7f9fc; padding: 6px 10px; min-width: 96px; text-align: center; position: relative; }
  .appr-chip .ord { font-size: 0.72rem; color: #8a98a8; }
  .appr-chip .nm { font-weight: 600; font-size: 0.92rem; }
  .appr-chip .ctl { margin-top: 2px; font-size: 0.8rem; }
  .appr-chip .ctl a { cursor: pointer; color: #6b7c8f; text-decoration: none; padding: 0 2px; }
  .appr-chip .ctl a.rm { color: #e0564b; }
  .appr-arrow { align-self: center; color: #b0bcc8; }
  .appr-empty { color: #9aa7b3; font-size: 0.88rem; padding: 6px 0; }
  #drop_area { border: 2px dashed #b9c4d0; border-radius: 10px; background: #fafbfd; padding: 22px; text-align: center; color: #7d8b99; cursor: pointer; transition: .15s; }
  #drop_area.drag { border-color: #4b89dc; background: #eef5ff; color: #4b89dc; }
  .file-row { display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #eee; padding: 5px 2px; font-size: 0.9rem; }
  .file-row .rm { color: #e0564b; cursor: pointer; }
  .userpick-item { display: flex; align-items: center; gap: 8px; padding: 6px 4px; border-bottom: 1px solid #f0f0f0; cursor: pointer; }
  .userpick-item:hover { background: #f5f8ff; }
</style>

<div class="page-content">
  <div class="panel panel-primary panel-line shadow">
    <div class="panel-heading"><h3 class="panel-title"><i class="fas fa-pen"></i> 기안 작성</h3></div>
    <div class="panel-body">
      <form id="apprForm" onsubmit="return false;">
        <input type="hidden" id="ad_seq" value="@Model.doc.ad_seq" />
        <input type="hidden" id="del_files" />

        <div class="form-group">
          <label class="form-control-label">제목 <span class="text-danger">*</span></label>
          <input type="text" id="title" class="form-control" maxlength="300" value="@Model.doc.title" placeholder="제목을 입력하세요" autocomplete="off" />
        </div>

        <div class="form-group">
          <label class="form-control-label">결재선 <span class="text-danger">*</span> <small class="text-muted">(왼쪽 → 오른쪽 순서로 결재)</small>
            <button type="button" class="btn btn-xs btn-outline-primary ml-2" onclick="openUserModal('line')">+ 결재자 추가</button>
          </label>
          <div id="line_box" class="appr-chips border rounded p-2" style="min-height:54px;"></div>
        </div>

        <div class="form-group">
          <label class="form-control-label">참조자 <small class="text-muted">(열람만 가능)</small>
            <button type="button" class="btn btn-xs btn-outline-info ml-2" onclick="openUserModal('ref')">+ 참조자 추가</button>
          </label>
          <div id="ref_box" class="appr-chips border rounded p-2" style="min-height:46px;"></div>
        </div>

        <div class="form-group">
          <label class="form-control-label">본문</label>
          <textarea id="content" class="form-control" rows="12" placeholder="본문을 입력하세요">@Model.doc.content</textarea>
        </div>

        <div class="form-group">
          <label class="form-control-label">첨부파일 <small class="text-muted">(드래그&드롭 또는 클릭하여 여러 개 선택)</small></label>
          <div id="drop_area">
            <i class="fa fa-cloud-upload-alt" style="font-size:1.6rem;"></i>
            <div>여기로 파일을 끌어다 놓거나 클릭하여 선택하세요</div>
          </div>
          <input type="file" id="file_input" multiple style="display:none;" />
          <div id="file_list" class="mt-2"></div>
          @if (Model.files != null && Model.files.Count > 0)
          {
            <div class="mt-2" id="exist_files">
              <small class="text-muted">기존 첨부:</small>
              @foreach (var f in Model.files)
              {
                <div class="file-row exist-file" data-af="@f.af_seq">
                  <span><i class="fa fa-paperclip"></i> @f.file_path</span>
                  <span class="rm del-exist" data-af="@f.af_seq">삭제</span>
                </div>
              }
            </div>
          }
        </div>

        <div class="text-right mt-3">
          <a href="@Url.Action("WorkList", "Appr")" class="btn btn-secondary">취소</a>
          <button type="button" class="btn btn-default" id="btn_temp">임시저장</button>
          <button type="button" class="btn btn-primary" id="btn_submit">상신</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- 사용자 검색 팝업 -->
<div class="modal fade" id="userModal" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="userModalTitle">결재자 검색</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
      </div>
      <div class="modal-body">
        <input type="text" id="userSearch" class="form-control mb-2" placeholder="이름으로 검색" autocomplete="off" />
        <div id="userListBox" style="max-height:340px; overflow-y:auto;"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">취소</button>
        <button type="button" class="btn btn-primary" id="userModalOk">추가</button>
      </div>
    </div>
  </div>
</div>

@section scripts {
  <script type="text/javascript">
    var USERS = @Html.Raw(usersJson);
    var LINES = @Html.Raw(lineJson);   // 결재자
    var REFS  = @Html.Raw(refJson);    // 참조자
    var DROPFILES = [];
    var DEL_FILES = [];
    var pickTarget = 'line';

    // ── 결재선/참조 칩 렌더 ───────────────────────────────────────
    function renderChips() {
      var $l = $('#line_box').empty();
      if (LINES.length === 0) { $l.append('<span class="appr-empty">결재자를 추가하세요.</span>'); }
      LINES.forEach(function (u, i) {
        if (i > 0) $l.append('<span class="appr-arrow">▶</span>');
        $l.append(
          '<div class="appr-chip" data-seq="' + u.approver_seq + '">' +
          '<div class="ord">' + (i + 1) + '차</div><div class="nm">' + u.approver_name + '</div>' +
          '<div class="ctl"><a class="mv-l" data-t="line" data-i="' + i + '">◀</a>' +
          '<a class="mv-r" data-t="line" data-i="' + i + '">▶</a>' +
          '<a class="rm" data-t="line" data-i="' + i + '">✕</a></div></div>');
      });

      var $r = $('#ref_box').empty();
      if (REFS.length === 0) { $r.append('<span class="appr-empty">참조자 없음</span>'); }
      REFS.forEach(function (u, i) {
        $r.append(
          '<div class="appr-chip" data-seq="' + u.approver_seq + '">' +
          '<div class="nm">' + u.approver_name + '</div>' +
          '<div class="ctl"><a class="rm" data-t="ref" data-i="' + i + '">✕</a></div></div>');
      });
    }

    // ── 사용자 검색 팝업 ──────────────────────────────────────────
    function openUserModal(target) {
      pickTarget = target;
      $('#userModalTitle').text(target === 'line' ? '결재자 검색' : '참조자 검색');
      $('#userSearch').val('');
      renderUserList('');
      $('#userModal').modal('show');
    }

    function renderUserList(kw) {
      var arr = (pickTarget === 'line') ? LINES : REFS;
      var added = arr.map(function (x) { return x.approver_seq; });
      kw = (kw || '').toLowerCase();
      var $box = $('#userListBox').empty();
      var shown = 0;
      USERS.forEach(function (u) {
        if (added.indexOf(u.uv_seq) >= 0) return;
        if (kw && u.name.toLowerCase().indexOf(kw) < 0) return;
        shown++;
        $box.append(
          '<label class="userpick-item"><input type="checkbox" class="upick" value="' + u.uv_seq + '" data-name="' + u.name + '"> ' +
          '<span>' + u.name + '</span></label>');
      });
      if (shown === 0) $box.append('<div class="text-muted p-2">검색 결과가 없습니다.</div>');
    }

    // ── 첨부 (drag & drop + 다중) ─────────────────────────────────
    function addFiles(fileList) {
      for (var i = 0; i < fileList.length; i++) DROPFILES.push(fileList[i]);
      renderFiles();
    }
    function renderFiles() {
      var $l = $('#file_list').empty();
      DROPFILES.forEach(function (f, i) {
        $l.append('<div class="file-row"><span><i class="fa fa-paperclip"></i> ' + f.name +
          ' <small class="text-muted">(' + Math.round(f.size / 1024) + ' KB)</small></span>' +
          '<span class="rm" data-i="' + i + '">삭제</span></div>');
      });
    }

    $(function () {
      renderChips();

      // 칩 컨트롤
      $('#line_box, #ref_box').on('click', '.rm', function () {
        var t = $(this).data('t'), i = $(this).data('i');
        (t === 'line' ? LINES : REFS).splice(i, 1); renderChips();
      }).on('click', '.mv-l', function () {
        var i = $(this).data('i'); if (i > 0) { var t = LINES[i - 1]; LINES[i - 1] = LINES[i]; LINES[i] = t; renderChips(); }
      }).on('click', '.mv-r', function () {
        var i = $(this).data('i'); if (i < LINES.length - 1) { var t = LINES[i + 1]; LINES[i + 1] = LINES[i]; LINES[i] = t; renderChips(); }
      });

      // 팝업 검색/추가
      $('#userSearch').on('input', function () { renderUserList($(this).val()); });
      $('#userModalOk').click(function () {
        var arr = (pickTarget === 'line') ? LINES : REFS;
        $('#userListBox .upick:checked').each(function () {
          var seq = parseInt($(this).val());
          if (!arr.some(function (x) { return x.approver_seq === seq; }))
            arr.push({ approver_seq: seq, approver_name: $(this).data('name') });
        });
        $('#userModal').modal('hide');
        renderChips();
      });

      // 첨부 drag & drop
      var dropArea = document.getElementById('drop_area');
      dropArea.addEventListener('click', function () { document.getElementById('file_input').click(); });
      dropArea.addEventListener('dragover', function (e) { e.preventDefault(); dropArea.classList.add('drag'); });
      dropArea.addEventListener('dragleave', function () { dropArea.classList.remove('drag'); });
      dropArea.addEventListener('drop', function (e) { e.preventDefault(); dropArea.classList.remove('drag'); addFiles(e.dataTransfer.files); });
      document.getElementById('file_input').addEventListener('change', function (e) { addFiles(e.target.files); e.target.value = ''; });
      $('#file_list').on('click', '.rm', function () { DROPFILES.splice($(this).data('i'), 1); renderFiles(); });

      $('#exist_files').on('click', '.del-exist', function () {
        DEL_FILES.push($(this).data('af')); $('#del_files').val(DEL_FILES.join(','));
        $(this).closest('.exist-file').css('text-decoration', 'line-through').find('.del-exist').remove();
      });

      $('#btn_temp').click(function () { save(0); });
      $('#btn_submit').click(function () { save(1); });
    });

    function save(submit) {
      var title = $('#title').val().trim();
      if (!title) { ErrorAlert('제목을 입력해주세요.'); return; }
      if (submit === 1 && LINES.length === 0) { ErrorAlert('상신하려면 결재선을 1명 이상 지정해야 합니다.'); return; }

      var fd = new FormData();
      fd.append('ad_seq', $('#ad_seq').val());
      fd.append('title', title);
      fd.append('content', $('#content').val());
      fd.append('line_json', JSON.stringify(LINES));
      fd.append('ref_json', JSON.stringify(REFS));
      fd.append('del_files', $('#del_files').val() || '');
      fd.append('submit', submit);
      DROPFILES.forEach(function (f) { fd.append('files', f); });

      if (typeof showLoading === 'function') showLoading();
      $.ajax({
        url: '@Url.Action("SaveDoc", "Appr")',
        type: 'POST', data: fd, processData: false, contentType: false,
        success: function (json) {
          if (typeof hideLoading === 'function') hideLoading();
          if (json.ok) { NormalAlert(json.message, function () { location.href = '@Url.Action("Detail", "Appr")' + '?ad_seq=' + json.ad_seq; }); }
          else { ErrorAlert(json.message); }
        },
        error: function () { if (typeof hideLoading === 'function') hideLoading(); ErrorAlert('저장 중 오류가 발생했습니다.'); }
      });
    }
  </script>
}
