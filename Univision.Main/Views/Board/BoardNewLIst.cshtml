@using Univision.Core.Models;
@using Univision.Core.Models.DTO;
@using Univision.Core.Models.DTO.Response.Board;
@model Univision.Core.Models.DTO.Response.Board.BoardListModel
@{
  //ViewBag.Title = "NoticeList";
  Layout = "~/Views/Shared/_Layout.cshtml";
  string pageTag = ViewBag.pageTag;
}
<link rel="stylesheet" href="~/Libs/remark/global/vendor/tablesaw/tablesaw.min599c.css?v4.0.4">
<div class="page-content">
  <!--검색 Form -->


  <div class="panel panel-primary panel-line animation-scale-up" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms;">
    <!-- 검색 패널 시작 -->
    @using (Html.BeginForm(pageTag + "List", "Board", FormMethod.Get, new { @id = "searchForm" }))
    {
      @Html.HiddenFor(x => x.search.b_type)
      @Html.HiddenFor(x => x.search.b_type_sub1)
      @Html.HiddenFor(x => x.search.b_type_sub2)
      <div class="panel-heading">
        <div class="panel-title">
          <i class="fas fa-info-circle"></i>
          @ViewBag.Title
        </div>
        <div class="panel-actions" style="display:flex">
          <div class="panel-action input-search">
            <select name="search.search_option" id="search_search_option" class="form-control" style="max-width:150px;">
              <option value="title" @(Model.search.search_option == "title" ? "selected" : "")>Title</option>
              <option value="contents" @(Model.search.search_option == "contents" ? "selected" : "")>Contents</option>
              <option value="writer" @(Model.search.search_option == "writer" ? "selected" : "")>Writer</option>
            </select>
          </div>
          <div class="panel-action input-search">
            <button type="submit" class="input-search-btn">
              <i class="icon wb-search" aria-hidden="true"></i>
              &nbsp;&nbsp;
            </button>
            @Html.TextBoxFor(x => x.search.search_txt, new { @class = "form-control", @placeholder = "검색어 입력" })
          </div>
        </div>
      </div>
      <!-- 검색 패널 끝 -->
    }



    <div class="panel panel-line">

      <div class="panel-body">
        <div class="row">
          <div class="col text-right pb-5">
            <a href="@Url.Action(pageTag+"Create", "Board", new { b_type_sub1=Model.search.b_type_sub1, b_type_sub2=Model.search.b_type_sub2})" class="btn btn-sm btn-primary">
              <i class="fas fa-plus"></i>
              Write
            </a>
          </div>
        </div>
        @if (Model.DocumentTypeList != null && Model.DocumentTypeList.Count() > 0 && Univision.Security.AppIdentity.ua_seq < 6)
        {
          <div class="nav-tabs-horizontal">
            <ul class="nav nav-tabs nav-tabs-reverse" role="tablist">


              @foreach (DocumentTypeModel cate in Model.DocumentTypeList)
              {
                <li class="nav-item" role="presentation">
                  <a class="nav-link @(cate.is_select ? "active" : "")" data-toggle="1" href="@cate.href"
                     aria-controls="1" role="tab">@cate.text</a>
                  </li>
                }

            </ul>
            @foreach (DocumentTypeModel cate in Model.DocumentTypeList)
            {
              if (cate.is_select && cate.nodes != null && cate.nodes.Count() > 0)
              {
                <div class="tab-content pt-5 bg-blue-grey-100 small">
                  <div class="row nav nav-pills">
                    @foreach (DocumentTypeModel cate_sub in cate.nodes)
                    {
                      <div class="nav-item nav-fill" role="presentation">
                        <a class="nav-link @(cate_sub.is_select ? "active" : "")" href="@cate_sub.href"
                           aria-controls="1" role="tab">@cate_sub.text</a>
                        </div>
                      }


                  </div>
                </div>
              }
            }
          </div>

        }


        @*
          <div class="col-4">
              <div data-plugin="treeview" data-source="getExampleTreeview" data-expand-icon="icon wb-chevron-right"
                   data-collapse-icon="icon wb-chevron-down" data-node-icon="icon wb-bookmark"
                   id="documentTreeView"></div>
          </div>
        *@

        <div class="mt-10">
          <table class="block_table table table-striped table-hover mt-10" data-tablesaw-mode="columntoggle">
            <thead>
              <tr>
                <th data-tablesaw-priority="5" class="tablesaw-priority-4 text-center tbw60 hidden-sm-down" style="width: 10%">No.</th>
                <th data-tablesaw-priority="persist" class="text-center" style="min-width: 40%">Title</th>
                <th data-tablesaw-priority="4" class="tablesaw-priority-3 text-center hidden-sm-down">Read</th>
                <th data-tablesaw-priority="3" class="tablesaw-priority-2 text-center tbw20">Writer</th>
                <th data-tablesaw-priority="2" class="tablesaw-priority-2 text-center tbw20">File</th>
                <th data-tablesaw-priority="1" class="tablesaw-priority-1 text-center hidden-sm-down">Date</th>
              </tr>
              @if (Model != null && Model.TopBoardList.Count > 0)
              {
                foreach (board bd in Model.TopBoardList)
                {
                  <tr class="table-primary">
                    <th class="tablesaw-priority-4 text-center font-italic hidden-sm-down">N</th>
                    <th><a href="@Url.Action(pageTag+"Detail", "Board", new { b_seq = bd.b_seq})" data-rel="external" class="font-italic">@bd.title</a></th>
                    <th class="tablesaw-priority-3 text-center font-weight-bold hidden-sm-down">@bd.read_cnt</th>
                    <th class="tablesaw-priority-2 text-center font-weight-bold">@bd.user_name</th>
                    <td class="text-center">
                      @if (bd.file_list.Count() > 0)
                      {
                        var file_idx = 0;
                        foreach (var bf in bd.file_list)
                        {
                          if (file_idx >= 5)
                          {
                            break;
                          }

                          <a href="javascript:void(0)" onclick="DownloadFile(@bf.bf_seq, 'board')" title="@bf.file_path">
                            <i class="fas @Utils.ReturnFileExtensionClass(bf.file_extension)"></i>
                          </a>

                          file_idx++;
                        }
                        if (bd.file_list.Count() > 5)
                        {
                          <span>...</span>
                        }
                      }

                    </td>
                    <th class="tablesaw-priority-1 text-center font-weight-bold hidden-sm-down">@(((DateTime)bd.modify_dt).ToString("yyyy-MM-dd"))</th>

                  </tr>
                }
              }
            </thead>
            <tbody>

              @if (Model != null && Model.BoardList.Count > 0)
              {
                int i = (int)Model.PagingInfo.TotalItems - (Model.PagingInfo.ItemsPerPage * (Model.PagingInfo.CurrentPage - 1));
                foreach (board bd in Model.BoardList)
                {
                  <tr>
                    <th class="tablesaw-priority-4 text-center hidden-sm-down">@i</th>
                    <td><a href="@Url.Action(pageTag+"Detail", "Board", new { b_seq = bd.b_seq})" data-rel="external">@bd.title</a></td>
                    <td class="tablesaw-priority-3 text-center hidden-sm-down">@bd.read_cnt</td>
                    <td class="tablesaw-priority-2 text-center">@bd.user_name</td>
                    <td class="text-center">
                      @if (bd.file_list.Count() > 0)
                      {
                        var file_idx2 = 0;
                        foreach (var bf in bd.file_list)
                        {
                          if (file_idx2 >= 5)
                          {
                            break;
                          }

                          <a href="javascript:void(0)" onclick="DownloadFile(@bf.bf_seq, 'board')" title="@bf.file_path">
                            <i class="fas @Utils.ReturnFileExtensionClass(bf.file_extension)"></i>
                          </a>

                          file_idx2++;
                        }
                        if (bd.file_list.Count() > 5)
                        {
                          <span>...</span>
                        }
                      }

                    </td>
                    <td class="tablesaw-priority-1 text-center hidden-sm-down">@(((DateTime)bd.modify_dt).ToString("yyyy-MM-dd"))</td>

                  </tr>
                  i--;
                }
              }
              else
              {
                <tr>
                  <td colspan="6" style="text-align:center;height:200px;vertical-align:middle;"><b>No Data.</b></td>
                </tr>
              }
            </tbody>
          </table>
          @if (Model != null && Model.BoardList.Count > 0)
          {

            @Html.PageAjaxLinks(Model.PagingInfo,
                ViewContext.HttpContext.Request.Url.AbsoluteUri,
                x => Url.Action(pageTag + "List", new
                {
                    page = x
                }))

          }
        </div>

      </div>

    </div>
  </div>
</div>
@section scripts{
  <script src="~/Libs/remark/global/vendor/tablesaw/tablesaw.jquery599c.js?v4.0.4"></script>
  <script src="~/Libs/remark/global/vendor/tablesaw/tablesaw-init599c.js?v4.0.4"></script>

  <script src="~/Libs/remark/global/js/Plugin/tablesaw.min599c.js?v4.0.4"></script>
  <script type="text/javascript" src="~/Scripts/FileDownload.js?v0.0.1"></script>
}
