          buffer = lines.pop(); // 마지막 라인은 버퍼에 남겨둠

          const parsedLines = lines
            .map((line) => line.replace(/^data: /, "").trim()) // "data: " 접두사 제거
            .filter((line) => line !== "" && line !== "[DONE]"); // 빈 줄과 "[DONE]" 제거


          for (const line of parsedLines) {
            try {
              //console.log(line)
              const parsedLine = JSON.parse(line); // JSON 문자열 파싱
              const { choices } = parsedLine;
              const { delta } = choices[0];
              const { content } = delta;
              // Update the UI with the new content
              if (content) {
                ai_summary_stream.value += content;
                openai_stream.value += content;
                openai_stream.scrollTop = openai_stream.scrollHeight;
              }
            } catch (error) {
              console.error('JSON 파싱 오류:', error);
            }
          }

        }
        AddLog("info", "파일 내용 분석 완료");
        result = true;
        //ConvertCandidateCreateModel(ai_summary_stream.value);
      } catch (error) {
        // Handle fetch request errors
        if (signal.aborted) {
          AddLog("danger", "요청이 중지 되었습니다.");
        } else {
          console.error("Error:", error);
          ai_summary_stream.value += "\n분석 중 오류가 발생하였습니다.\n내용:" + error;
        }
        result = false;
      } finally {
        btn_cancel_result.disabled = true;
        controller = null; // Reset the AbortController instance
      }

      return result
    }

    function AddLog(type, contents) {
      if (!type) {
        type = "info";
      }
      var event_time = "[" + new Date().toISOString() + "]";
      var reset_btn = '';
      if (type == "danger") {
        reset_btn = '<button class="btn btn-primary" onclick="ResetUploadPage();">다시 업로드 하기</button> ';
      }
      var card = `<div class='card border border-${type} shadow'>
                                <div class="card-block text-${type} py-2 ">
                                  <span class='text-dark'>${event_time}</span><br/>
                                  ${contents}
                                </div>
                                ${reset_btn}
                              </div>`;
      let temp = document.createElement("div");
      temp.innerHTML = card;
      temp.style.opacity = '0';
      temp.style.transition = 'opacity 500ms';
      document.getElementById('ai_upload_log').prepend(temp);

      setInterval(() => temp.style.opacity = '1', 100);

      if (type == "danger") {
        ai_modal_title.innerText = "오류발생 / 중지";
        ai_modal_contents.innerHTML = contents.replace(/\\n/gi, "<br/>");
        btn_cancel_result.style.display = "none";
      }
    }

    btn_cancel_result.addEventListener('click', function () {
