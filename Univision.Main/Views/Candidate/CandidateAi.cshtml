                ai_summary_busi_stream.value = "";
                await AddLog('warning', '산업 분석 실패(산업을 제외하고 진행합니다.)')
              }
            } else {
              await AddLog('warning', '산업을 제안하기 위한 경력정보가 부족합니다.')
            }

            if (candidate_result.division_name != "" && candidate_result.company_name != "") {
              isprogress_job = await GetJobJsonFromResumeStream(candidate_result.company_name + " / " + candidate_result.division_name);
              //isprogress_job = await GetJobJsonFromResumeProxy(candidate_result.company_name + " / " + candidate_result.division_name);

              if (!isprogress_job) {
                ai_summary_job_stream.value = "";
                await AddLog('warning', '직무 분석 실패(직무를 제외하고 진행합니다.)')
              }
            } else {
              await AddLog('warning', '직무를 제안하기 위한 경력정보가 부족합니다.')
            }

            var rst = await ConvertCandidateCreateModel(ai_summary_stream.value, ai_summary_busi_stream.value, ai_summary_job_stream.value);
            console.log("RST", rst);
            if (!rst.result) {
              
            } else {
