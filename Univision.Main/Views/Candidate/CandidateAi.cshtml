            }

          } else {
            await AddLog('info', '업데이트 건에 대해서는 산업/직무 제안이 불가 합니다.')
            var rst = await ConvertCandidateCreateModel(ai_summary_stream.value);
            console.log("RST", rst);
            if (!rst.result) {

            } else {
              await AddLog('warning', '이력서 등록 준비 완료<br><button class="btn btn-warning btn-block" id="btn-submit-candidate">중복 후보자 무시하고 (신규)이력서 등록하러 가기</button><button class="btn btn-success btn-block" id="btn-update-candidate" data-c="' + progress_flag + '">이력서 업데이트</button>');
              var update = document.getElementById('btn-update-candidate').addEventListener('click', function (e) {
                e.preventDefault();
                var c_seq = document.getElementById('btn-update-candidate').getAttribute('data-c');
                form = document.getElementById('ai_resume_form')
                document.getElementById('c_seq_ai_form').value = c_seq;
                form.action = window.url_candidate_ai_update;
                form.submit();
              })
            }
          }
          var submit = document.getElementById('btn-submit-candidate').addEventListener('click', function (e) {
            e.preventDefault();
            form = document.getElementById('ai_resume_form');
            form.action = window.url_candidate_ai_create;
            form.submit();
          })

          ai_modal_title.innerHTML = "이력서 분석완료"
          ai_modal_contents.innerHTML = "이력서 분석이 완료 되었습니다.<br/>아래에 [이력서 등록하기] 버튼을 눌러 진행해주세요.<br/><span class='text-danger'>분석된 내용이 정확하지 않을 수 있습니다.<br/> 등록 하시기전 꼭 생성된 데이터가 정확한지 꼭 확인하신 후 등록해주세요.</span>"
          btn_cancel_result.style.display = "none";

          isprogress = true;
        } else {
          isprogress = false;
        }
      }





      //console.log("AddLog", isprogress)
    }

    function UploadProgressModal() {
      $('#upload_message').addClass('d-none');
      $('#modal_upload_progress').modal({
        backdrop: 'static',
