                              <option value="">[전공계열(부전공/복수전공)]</option>
                              <option value="인문계열" @(sch.sub_category1_name == "인문계열" ? "selected" : "")>인문계열</option>
                              <option value="사회계열" @(sch.sub_category1_name == "사회계열" ? "selected" : "")>사회계열</option>
                              <option value="공학계열" @(sch.sub_category1_name == "공학계열" ? "selected" : "")>공학계열</option>
                              <option value="자연계열" @(sch.sub_category1_name == "자연계열" ? "selected" : "")>자연계열</option>
                              <option value="교육계열" @(sch.sub_category1_name == "교육계열" ? "selected" : "")>교육계열</option>
                              <option value="의약계열" @(sch.sub_category1_name == "의약계열" ? "selected" : "")>의약계열</option>
                              <option value="예체능계열" @(sch.sub_category1_name == "예체능계열" ? "selected" : "")>예체능계열</option>
                            </select>
                            <input type="text" id="sub_major_name_@(i)" name="sub_major_name" value="@sch.sub_major_name" class="form-control form-control-sm find_major_autocomplete w-sm-full w-md-p75" placeholder="부전공/복수전공">
