                        </div>
                        <div class="form-group col-md-3">
                          @{
                            string division = comp.division_name;
                            if (division != comp.position_str && !String.IsNullOrEmpty(comp.position_str))
                            {
                              division += (!String.IsNullOrEmpty(division) ? " " : "") + comp.position_str;
                            }
                          }
                          <input type="text" id="division_name_@(i)" name="division_name" value="@division" class="form-control form-control-sm" placeholder="부서 / 직급명">
                        </div>
                        <div class="form-group col-md-3">
                          <div class="input-group input-group-sm">
