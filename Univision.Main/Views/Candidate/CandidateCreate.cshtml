                            <option value="100" @(comp.p_code == 100 ? "selected" : "")>신입사원급</option>
                            <option value="90" @(comp.p_code == 90 ? "selected" : "")>경력사원급</option>
                            <option value="80" @(comp.p_code == 80 ? "selected" : "")>대리급</option>
                            <option value="70" @(comp.p_code == 70 ? "selected" : "")>과장급</option>
                            <option value="60" @(comp.p_code == 60 ? "selected" : "")>차장급</option>
                            <option value="50" @(comp.p_code == 50 ? "selected" : "")>부장급</option>
                            <option value="40" @(comp.p_code == 40 ? "selected" : "")>본부장/지사장</option>
                            <option value="30" @(comp.p_code == 30 ? "selected" : "")>임원급</option>
                            <option value="20" @(comp.p_code == 20 ? "selected" : "")>최고재무경영자</option>
                            <option value="10" @(comp.p_code == 10 ? "selected" : "")>최고 경영자</option>
                          </select>
                        </div>
                        <div class="form-group col-md-3">
                          <div class="input-group input-group-sm">
                            <input type="number" id="annual_income_@(i)" name="annual_income" value="@comp.annual_income" class="form-control form-control-sm text-right" placeholder="연봉" step="1">
                            <span class="input-group-addon">만원</span>
                          </div>
                        </div>
                      </div>
                    </div>
                    <div class="text-right">
                      <span class='text-secondary small btn_educomp_more cur_hand pr-10' title="show addtional Information">
                        <i class="fa fa-plus-square"></i> 경력 추가정보 입력
                      </span>

                      <span class='text-secondary small btn_educomp_collapse cur_hand pr-10' title="hide addtional Information">
                        <i class="fa fa-minus-square"></i> 경력 추가정보 숨김
                      </span>
                    </div>
                  </div>
                  i++;
