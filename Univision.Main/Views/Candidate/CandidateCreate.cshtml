@model Univision.Main.Models.Candidate.CandidateCreateModel
@{
  //ViewBag.Title = "후보자 등록 및 수정";
  ViewBag.use_validation = true;

  Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/Libs/dropzone/css/dropzone_cus.css?v=1533562669">
<style>
  .popover {
    max-width: 500px !important;
  }

  .job_list {
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    width: 250px;
    display: inline-block;
  }

  .placeDiv span {
    font-size: 15px;
  }

  .category::after {
    content: " > "
  }

  .catRow {
    margin-top: 3px;
  }

  #normalInfo .form-group {
    margin-bottom: 3px !important;
  }

  #normalInfo .form-control-label {
    margin-bottom: 0px !important;
    padding-bottom: 0px !important;
  }

  .card {
    margin-right: 10px;
  }

  .no-top-line {
    border-top: 0px !important;
  }

  .schoolRow .form-group {
    margin-bottom: 10px !important;
  }

  .dropify-wrapper {
    padding: 0px 15px 0px 15px;
    box-sizing: border-box;
  }

  .extend-box {
    position: absolute !important;
    top: 1.9em;
    right: 1em;
  }

  .no-school-selected .shared-field, .no-school-selected .highschool-field, .no-school-selected .univ-field,
  .high_list .univ-field, .univ_list .highschool-field {
    display: none !important;
  }

  .tokenfield {
    min-height: 2.288rem !important;
  }

  .more_educomp_info, .btn_educomp_collapse, .educomp_more .btn_educomp_more {
    display: none;
  }

  .educomp_more .btn_educomp_collapse {
    display: inline;
  }

  .educomp_more .more_educomp_info {
    display: flex;
  }

  .mainPanel {
    padding-left: 5px !important;
    padding-right: 5px !important;
  }
</style>


<div class="page-content">

  <div class="" id="candidatePanel">
    <div class="mainPanel pb-10">
      @using (Html.BeginForm("CandidateCreate", "Candidate", FormMethod.Post, new { @id = "CreateForm", @autocomplete = "off" }))
      {
        @Html.HiddenFor(x => x.c_seq)
        @Html.HiddenFor(x => x.tempsaved_seq)
        @Html.HiddenFor(x => x.mail_key)
        @Html.HiddenFor(x => x.is_ai_reg)
        @Html.Hidden("uploadFolder")

        if (Model.c_seq == 0)
        {
          <div class="panel shadow panel-primary panel-line animation-scale-up" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms;">
            <div class="panel-heading">
              <h3 class="panel-title py-10">
                <i class="fas fa-upload"></i>
                Files <input type="text" id="resume_chk" name="resume_chk" valid-highlight="#resumeInfo" style="width:1px;height:1px;border:0;" />
              </h3>
              <div class="panel-actions">
                <a class="panel-action icon wb-minus" aria-expanded="true" data-toggle="panel-collapse" aria-hidden="true"></a>
              </div>
            </div>
            <div id="resumeInfo" class="panel-body  pb-10">
              <div class="row">
                <div class="col-12 col-md-6 col-lg-4 pb-10">
                  <div id="kor_file" class="dropzone h-full text-left">
                    <label for="kor_file" class="form-control-label">Resume(Kor)</label>
                    <div class="row py-2">
                      <div class="col">
                        <div class="dz-message"><small>[Drop files here or click to upload]</small></div>
                      </div>
                    </div>
                    <div class="row py-2" id="kor_file_rst">
                      @{
                        var mkorList = Model.resumeList.Where(x => x.file_type == "K").ToList();

                        if (mkorList.Count > 0)
                        {
                          foreach (var data in mkorList)
                          {
                            <div class="py-0 file_div col-12">
                              <input type="hidden" name="file_origin_path" value="@data.file_origin_path">
                              <a href="@data.file_dir" class="file_info text-left text-truncate pointer badge badge-secondary" title="@data.file_path" download style="width:85%;">
                                <i class="@Utils.ReturnFileExtensionClass(data.file_extension)" aria-hidden="true"></i> @data.file_path
                              </a>
                              <a href="javascript:void(0);" class="ml-3 text-truncate badge badge-danger" style="width:10%;" onclick="RemoveCandidate(this);">
                                <i class="fa fa-trash pointer" aria-hidden="true"></i>
                              </a>
                            </div>
                          }
                        }
                      }
                    </div>
                  </div>
                </div>
                <div class="col-12 col-md-6 col-lg-4 pb-10">
                  <div id="eng_file" class="dropzone h-full text-left">
                    <label for="eng_file" class="form-control-label">Resume(Eng)</label>
                    <div class="row py-2">
                      <div class="col">
                        <div class="dz-message"><small>[Drop files here or click to upload]</small></div>
                      </div>
                    </div>
                    <div class="row py-2" id="eng_file_rst">
                      @{
                        var mEngList = Model.resumeList.Where(x => x.file_type == "E").ToList();

                        if (mEngList.Count > 0)
                        {
                          foreach (var data in mEngList)
                          {
                            <div class="py-0 file_div col-12">
                              <input type="hidden" name="file_origin_path" value="@data.file_origin_path">
                              <a href="@data.file_dir" class="file_info text-left text-truncate pointer badge badge-secondary" title="@data.file_path" download style="width:85%;">
                                <i class="@Utils.ReturnFileExtensionClass(data.file_extension)" aria-hidden="true"></i> @data.file_path
                              </a>
                              <a href="javascript:void(0);" class="ml-3 text-truncate badge badge-danger" style="width:10%;" onclick="RemoveCandidate(this);">
                                <i class="fa fa-trash pointer" aria-hidden="true"></i>
                              </a>
                            </div>
                          }
                        }
                      }
                    </div>
                  </div>

                </div>
                <div class="col-12 col-lg-4 pb-10">
                  <div id="etc_file" class="dropzone h-full text-left">
                    <label for="etc_file" class="form-control-label">Resume(Other)  - <small>경력증명서, 포트폴리오 등</small></label>
                    <div class="row py-2">
                      <div class="col">
                        <div class="dz-message"><small>[Drop files here or click to upload]</small></div>
                      </div>
                    </div>
                    <div class="row py-2" id="etc_file_rst">
                      @{
                        var mEtcList = Model.resumeList.Where(x => x.file_type == "O").ToList();

                        if (mEtcList.Count > 0)
                        {
                          foreach (var data in mEtcList)
                          {
                            <div class="py-0 file_div col-12">
                              <input type="hidden" name="file_origin_path" value="@data.file_origin_path">
                              <a href="@data.file_dir" class="file_info text-left text-truncate pointer badge badge-secondary" title="@data.file_path" download style="width:85%;">
                                <i class="@Utils.ReturnFileExtensionClass(data.file_extension)" aria-hidden="true"></i> @data.file_path
                              </a>
                              <a href="javascript:void(0);" class="ml-3 text-truncate badge badge-danger" style="width:10%;" onclick="RemoveCandidate(this);">
                                <i class="fa fa-trash pointer" aria-hidden="true"></i>
                              </a>
                            </div>
                          }
                        }
                      }
                    </div>
                  </div>

                </div>
              </div>

            </div>
          </div>
        }

        <div class="panel panel-primary panel-line animation-scale-up shadow" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms;">
          <div class="panel-heading">
            <h3 class="panel-title py-10">
              <i class="fas fa-address-card"></i>
              Personal Information
            </h3>
            <div class="panel-actions">
              <a class="panel-action icon wb-minus" aria-expanded="true" data-toggle="panel-collapse" aria-hidden="true"></a>
            </div>
          </div>
          <div id="normalInfo" class="panel-body pb-10">
            <div class="row">
              <div class="col-12 col-md-6 col-lg-3 form-group">
                @Html.LabelFor(x => x.kor_name, " Name(Kor)", new { @class = "form-control-label" })
                <span class="label-reqired">*</span>
                <div class="input-group input-group-sm">
                  @Html.TextBoxFor(x => x.kor_name, new { @class = "form-control", @autocomplete = "off", @required = "true" })
                  <div class="input-group-append pl-3">
                    <div class="checkbox-custom checkbox-custom-sm checkbox-primary mb-0" title="외국인 여부">
                      <input type="checkbox" id="is_foreign" name="is_foreign" value="1" @(Model.is_foreign == 1 ? "checked" : "") />
                      <label for="is_foreign">Foreign</label>
                    </div>
                  </div>
                </div>
              </div>
              <div class="col-12 col-md-6 col-lg-2 form-group">
                @Html.LabelFor(x => x.eng_name, " Name(Eng)", new { @class = "form-control-label" })

                @Html.TextBoxFor(x => x.eng_name, new { @class = "form-control form-control-sm" })

              </div>
              <div class="col-12 col-md-6 col-lg-3 form-group">
                @Html.LabelFor(x => x.birth_date, " Dob", new { @class = "form-control-label" })
                <span class="label-reqired">*</span>
                <div class="input-group input-group-sm">
                  @Html.TextBoxFor(x => x.birth_date, Utils.ConvertDateTimeToString(Model.birth_date), new { @class = "form-control", @onkeyup = "return DateFormat(event, this)", @onkeypress = "return DateFormat(event, this)", @placeholder = "YYYY-MM-DD", @required = "true" })
                  <div class="input-group-append pl-3">
                    @{
                      string boolean_desc = "<h5>생년 불확실 여부</h5><b>후보자의 생년이 불확실할 경우 체크합니다.<br/></b><b class='red-600'>※월일이 불확실한 경우 체크 하지 않습니다.<br>(ex 1985년생후보자 생년을 모르는 경우 : <b>1985-01-01</b> 입력) .<br/><b>";
                    }
                    <div class="checkbox-custom checkbox-custom-sm checkbox-primary mb-0" data-html="true" data-toggle="popover" data-trigger="hover" data-content="@Html.Raw(boolean_desc)">
                      <input type="checkbox" id="ex_birthdate" name="ex_birthdate" value="1" @(Model.ex_birthdate == 1 ? "checked" : "") />
                      <label for="ex_birthdate">Uncertain</label>
                    </div>
                  </div>
                </div>
              </div>
              <div class="col-12 col-md-6 col-lg-4 form-group">
                @Html.LabelFor(x => x.gender, " Gender", new { @class = "form-control-label" })
                <span class="label-reqired">*</span>
                <div class="form-inline">
                  <div class="radio-custom radio-custom-sm radio-primary pr-3" style="margin-left:5px;" title="남">
                    @Html.RadioButtonFor(x => x.gender, 1, new { @id = "gender_male", @class = "form-control-label", @required = "true" })
                    <label for="gender_male" class="font-small">Male</label>
                  </div>
                  <div class="radio-custom radio-custom-sm radio-primary pr-3" title="여">
                    @Html.RadioButtonFor(x => x.gender, 2, new { @id = "gender_female", @class = "form-control-label", @required = "true" })
                    <label for="gender_female" class="font-small">Female</label>
                  </div>
                  <div class="radio-custom radio-custom-sm radio-primary" title="성별 모름">
                    @Html.RadioButtonFor(x => x.gender, 0, new { @id = "gender_unknown", @class = "form-control-label", @required = "true" })
                    <label for="gender_unknown" class="font-small">Unknown</label>
                  </div>
                </div>
              </div>
            </div>

            <div class="row">
              <div class="col-12 col-md-2 form-group">
                @Html.LabelFor(x => x.country_name, " Nationality", new { @class = "form-control-label" })
                <div class="input-group input-group-sm">
                  @Html.HiddenFor(x => x.country_code, new { @class = "form-control" })
                  @Html.TextBoxFor(x => x.country_name, new { @class = "form-control form-control-sm", @readonly = "readonly", @placeholder = "후보자 국적" })
                  <span class="input-group-btn">
                    <button type="button" class="btn btn-primary" id="btnNationalitySearch"><i class="icon wb-search" aria-hidden="true"></i></button>
                  </span>
                </div>

              </div>
              <div class="col-md-10 col-12 form-group">
                @Html.LabelFor(x => x.addr1, " Address", new { @class = "form-control-label" })
                <div class="input-group input-group-sm">
                  @Html.TextBoxFor(x => x.addr1, new { @class = "form-control" })
                  <div class="input-group-append pl-3">
                    <div class="checkbox-custom checkbox-custom-sm checkbox-primary mb-0" title="해외 거주 여부">
                      <input type="checkbox" id="ex_addr" name="ex_addr" value="1" @(Model.ex_addr == 1 ? "checked" : "") />
                      <label for="ex_addr">Overseas residence</label>
                    </div>
                  </div>
                </div>

              </div>
            </div>
            <div class="row">
              <div class="col-12 col-md-4 form-group">
                @Html.LabelFor(x => x.cell_phone, "Phone1", new { @class = "form-control-label" })
                <span class="label-reqired">*</span>

                @{
                  string no_phone_desc = "<h5>후보자의 전화번호 정보가 없을 경우 클릭해주세요.</h5><b>전화번호가 없다는 의미의 `0000`이 입력됩니다..</b><br/><b class='red-600'>※ 추후 후보자의 전화번호를 전달받은 경우 업데이트를 꼭 해주세요.<b> <br/><b class='red-600'>※ 전화번호/이메일 중 하나 이상의 정보는 꼭 입력하셔야 합니다.<b>";
                }
                <span>- <a class="badge badge-outline badge-info" href="javascript:setValues('#cell_phone', '0000');" data-html="true" data-toggle="popover" data-trigger="hover" data-content="@Html.Raw(no_phone_desc)">후보자의 전화번호 정보가 없나요?</a></span>


                <div class="input-group input-group-sm">
                  @Html.TextBoxFor(x => x.cell_phone, new { @class = "form-control phone-group", @placeholder = "010-0000-0000" })
                  @if (Model.c_seq > 0)
                  {
                    <div class="input-group-append pl-3">
                      <div class="checkbox-custom checkbox-custom-sm checkbox-primary mb-0">
                        <input type="checkbox" id="wrong_phone2" name="wrong_phone2" value="1" @(Model.wrong_phone2 == 1 ? "checked" : "") />
                        <label for="wrong_phone2" title="Wrong number">(X)</label>
                      </div>
                    </div>
                  }
                </div>
              </div>
              <div class="col-12 col-md-4 form-group">
                @Html.LabelFor(x => x.phone, " Phone2", new { @class = "form-control-label" })
                <div class="input-group input-group-sm">
                  @Html.TextBoxFor(x => x.phone, new { @class = "form-control phone-group", @valid_error_target = "#cell_phone", @placeholder = "010-0000-0000" })

                  @if (Model.c_seq > 0)
                  {
                    <div class="input-group-append pl-3">
                      <div class="checkbox-custom checkbox-custom-sm checkbox-primary mb-0">
                        <input type="checkbox" id="wrong_phone" name="wrong_phone" value="1" @(Model.wrong_phone == 1 ? "checked" : "") />
                        <label for="wrong_phone" title="Wrong number">(X)</label>
                      </div>
                    </div>
                  }

                </div>
              </div>
              <div class="col-12 col-md-4 form-group">

              </div>
            </div>
            <div class="row">
              <div class="col-lg-8 col-12 form-group">
                @Html.LabelFor(x => x.email1, " E-mail", new { @class = "form-control-label" })
                <span class="label-reqired">* </span>

                @{
                  string no_email_desc = "<h5>후보자의 이메일 정보가 없을 경우 클릭해주세요.</h5><b>이메일주소가 없다는 의미의 `no@email`가 입력됩니다..<br/></b><b class='red-600'>※ 추후 후보자의 이메일주소를 전달받은 경우 업데이트를 꼭 해주세요.<b> <br/><b class='red-600'>※ 전화번호/이메일 중 하나 이상의 정보는 꼭 입력하셔야 합니다.<b>";
                }

                <span>- <a class="badge badge-outline badge-info" href="javascript:setValues('#email1', 'no@email');" data-html="true" data-toggle="popover" data-trigger="hover" data-content="@Html.Raw(no_email_desc)">후보자의 이메일 정보가 없나요?</a></span>



                <div class="form-inline">
                  @Html.TextBoxFor(x => x.email1, new { @class = "form-control form-control-sm w-md-p50 w-sm-full", @placeholder = "email@email.com", @required = "true" })

                  @Html.TextBoxFor(x => x.email2, new { @class = "form-control form-control-sm w-md-p50 w-sm-full", @placeholder = "email2@email2.com" })
                </div>
              </div>
              <div class="col-lg-4 col-12 form-group">
                @Html.LabelFor(x => x.manager_seq, "DB 등록자", new { @class = "form-control-label" })
                <span class="label-reqired">*</span>

                <div class="col-md form-group">
                  <div class="input-group input-group-sm">
                    @Html.HiddenFor(x => x.manager_seq)
                    @Html.TextBoxFor(x => x.manager_name, new { @class = "form-control", @placeholder = "Please choose Manager", @readonly = "readonly", @onclick = "FindManager(this)" })
                    <span class="input-group-btn">
                      <a href="javascript:void(0);" class="btn btn-success btn-sm" onclick="FindManager(this)">
                        <i class="icon wb-search" aria-hidden="true"></i>
                      </a>
                    </span>

                  </div>

                </div>
              </div>
            </div>
            <div class="row">
              <div class="col-12 form-group">
                @Html.LabelFor(x => x.sns_link1, "SNS Url (Linkedin, 리멤버커리어 등)", new { @class = "form-control-label" })
                <div class="form-inline">
                  @Html.TextBoxFor(x => x.sns_link1, new { @class = "form-control form-control-sm w-md-p33 w-sm-full", @placeholder = "http://sns.com/exam" })
                  @Html.TextBoxFor(x => x.sns_link2, new { @class = "form-control form-control-sm w-md-p33 w-sm-full", @placeholder = "http://sns.com/exam" })
                  @Html.TextBoxFor(x => x.sns_link3, new { @class = "form-control form-control-sm w-md-p33 w-sm-full", @placeholder = "http://sns.com/exam" })
                </div>
              </div>
            </div>

            <div class="row">
              <div class="col-12 form-group">
                @Html.LabelFor(x => x.reg_type, "Source (후보자 출처)", new { @class = "form-control-label" })<span class="label-reqired">*</span>
                <div class="form-inline">
                  <div class="radio-custom radio-custom-sm radio-primary pt-2">
                    @Html.RadioButtonFor(x => x.reg_type, 1, new { @id = "reg_type_1", @class = "form-control-label", @required = "true" })
                    <label for="reg_type_1" class="pr-10">Out Search <span>(Referral, Cold Call, Market Mapping 등)</span></label>
                  </div>

                  <div class="radio-custom radio-custom-sm radio-primary pt-2">
                    @Html.RadioButtonFor(x => x.reg_type, 21, new { @id = "reg_type_21", @class = "form-control-label", @required = "true" })
                    <label for="reg_type_21" class="pr-10">리멤버<span></span></label>
                  </div>
                  <div class="radio-custom radio-custom-sm radio-primary pt-2">
                    @Html.RadioButtonFor(x => x.reg_type, 22, new { @id = "reg_type_22", @class = "form-control-label", @required = "true" })
                    <label for="reg_type_22" class="pr-10">사람인 <span></span></label>
                  </div>
                  <div class="radio-custom radio-custom-sm radio-primary pt-2">
                    @Html.RadioButtonFor(x => x.reg_type, 23, new { @id = "reg_type_23", @class = "form-control-label", @required = "true" })
                    <label for="reg_type_23" class="pr-10">잡코리아 <span></span></label>
                  </div>
                  <div class="radio-custom radio-custom-sm radio-primary pt-2">
                    @Html.RadioButtonFor(x => x.reg_type, 5, new { @id = "reg_type_5", @class = "form-control-label", @required = "true" })
                    <label for="reg_type_5" class="pr-10">Linkedin</label>
                  </div>
                  <div class="radio-custom radio-custom-sm radio-primary pt-2">
                    @Html.RadioButtonFor(x => x.reg_type, 2, new { @id = "reg_type_2", @class = "form-control-label", @required = "true" })
                    <label for="reg_type_2" class="pr-10">그 외 잡포털</label>
                  </div>
                  <div class="radio-custom radio-custom-sm radio-primary pt-2">
                    @Html.RadioButtonFor(x => x.reg_type, 3, new { @id = "reg_type_3", @class = "form-control-label", @required = "true" })
                    <label for="reg_type_3" class="pr-10">Applicant <span>(공고, 소개 등을 통한 직접지원)</span></label>
                  </div>
                  <div class="radio-custom radio-custom-sm radio-primary pt-2">
                    @Html.RadioButtonFor(x => x.reg_type, 4, new { @id = "reg_type_4", @class = "form-control-label", @required = "true" })
                    <label for="reg_type_4" class="pr-10">Outplacement <span>(전직지원업체)</span></label>
                  </div>
                  <div class="radio-custom radio-custom-sm radio-primary pt-2">
                    @Html.RadioButtonFor(x => x.reg_type, 8, new { @id = "reg_type_8", @class = "form-control-label", @required = "true" })
                    <label for="reg_type_8" class="pr-10">등록자 지인</label>
                  </div>


                  <div class="radio-custom radio-custom-sm radio-primary pt-2">
                    @Html.RadioButtonFor(x => x.reg_type, 9, new { @id = "reg_type_9", @class = "form-control-label", @required = "true" })
                    <label for="reg_type_9" class="pr-10">Etc.</label>
                  </div>
                  @if (Univision.Security.AppIdentity.ua_seq <= 3)
                  {
                    <div class="radio-custom radio-custom-sm radio-primary pt-2">
                      @Html.RadioButtonFor(x => x.reg_type, 91, new { @id = "reg_type_91", @class = "form-control-label", @required = "true" })
                      <label for="reg_type_91" class="pr-10">홈페이지</label>
                    </div>
                  }

                </div>
              </div>
            </div>
            @if (Model.c_seq == 0 || Model.c_seq == null)
            {
              <div class="row">

                <div class="col-3 form-group">
                  @Html.LabelFor(x => x.is_confidential, "Confidential", new { @class = "form-control-label text-primary" })
                  <div class="input-group input-group-sm">
                    <div class="checkbox-custom checkbox-custom-sm checkbox-primary mb-0 pr-10">
