@section scripts{
  <script src="~/Scripts/moment.js"></script>
  <script src="~/Libs/remark/global/vendor/bootstrap-tokenfield/og-bootstrap-tokenfield.js"></script>
  <script src="~/Libs/dropzone/js/dropzone.min.js?v=1533562669"></script>
  <script>
    window.url_email_duplicate_check2 = '@Url.Action("EmailDuplicateCheck2", "Candidate")'
    window.url_phone_duplicate_check2 = '@Url.Action("PhoneDuplicateCheck2", "Candidate")'
    window.url_job_multi_api = '@Url.Action("JobMultiApi", "Partial")'
    window.url_business_multi_api = '@Url.Action("BusinessMultiApi", "Partial")'
    window.url_place_api = '@Url.Action("PlaceApi", "Partial")'
    window.url_find_company_api = '@Url.Action("FindCompanyApi", "Partial")'
    window.url_find_major_api = '@Url.Action("FindMajorApi", "Partial")'
    window.url_find_school_api = '@Url.Action("FindSchoolApi", "Partial")'
    window.url_national_code_search = '@Url.Action("NationalcodeSearch", "Client")'
    window.url_temp_save_candidate = '@Url.Action("TempSaveCandidate", "Candidate")'
    window.url_delete_candidate_temp_resume = '@Url.Action("DeleteCandidateTempResume", "Candidate")';
    window.url_create_temp_resume_file = "@Url.Action("CreateTempResumeFile", "Candidate")"
    window.url_search_candidate_manager = "@Url.Action("SearchCandidateManager", "Candidate")";
    window.url_partial_jobbusisugg = '@Url.Action("JobBusiSugg", "Partial")';
    window.url_partial_findkeyword = '@Url.Action("FindKeyword", "Partial")';
    window.viewbag_uploadfolder = "@ViewBag.uploadFolder";
    window.viewbag_is_pop = "@ViewBag.is_pop";
  </script>
  <script type="text/javascript">
    function getJobBusiSugg(new_val) {
      var keywords = $('#keyword').val()
      if (new_val) {
        keywords += (keywords != "" ? ", " : "") + new_val;
      }
      var data_job_busi = {
        curr_job: getJobData(),
        curr_busi: getBusiData(),
        keywords: keywords.split(", ")
      }

      $.ajax({
        type: 'POST',
        url: window.url_partial_jobbusisugg,
        data: data_job_busi,
        success: function (data) {
          $('.job_busi_sugg').html('');
          $('.job_busi_sugg').html(data);
        }
      });
    }

    $('#keyword').tokenfield({
      autocomplete: {
        source: function (request, response) {
          var data_source = {
            q: request.term,
            old: $('#keyword').val(),
            job: getJobData(),
            busi: getBusiData()
          }

          $.ajax({
            type: 'POST',
            url: window.url_partial_findkeyword,
            data: data_source,
            success: function (data) {
              var old = $('#keyword').val().split(', ');
              response(
                $.map(data.list, function (item) {
                  if (!old.includes(item.name)) {
                    var value = "";
                    value = item.name;

                    return {
                      value: value,
                    }
                  }
                }));
              $(".ui-autocomplete").highlight(request.term);

            }
          })
        },
        delay: 500,
        //autoFocus: false, //첫번째 값을 자동 focus한다
        minLength: 1, //조회를 위한 최소글자수
        search: function (event, ui) {
          var is_select = $(this).attr('is_select');
          is_select = (typeof is_select === "undefined") ? 0 : is_select;
          if (is_select == 1) {
            return false;
          }
        },
        select: function (event, ui) {
          return false;
        },
        focus: function (event, ui) {
          $(this).attr('is_select', 1);
          setTimeout(function (obj) {
            $(obj).attr('is_select', 0);
          }, 1000, this);
        },

      },

      showAutocompleteOnFocus: true
    });

    $('#keyword').on('tokenfield:createtoken', function (event) {
      var existingTokens = $(this).tokenfield('getTokens');
      $.each(existingTokens, function (index, token) {
        if (token.value === event.attrs.value)
          event.preventDefault();
      });
    });

    $('#keyword').on('tokenfield:createdtoken', function (event) {
      getJobBusiSugg(event.attrs.value);
    }).on('tokenfield:editedtoken', function (event) {
      getJobBusiSugg();
    }).on('tokenfield:removedtoken', function (event) {
      getJobBusiSugg();
    })

    $("#keyword-tokenfield").blur(function () {
      $(this).val("");
    })

    function getJobData() {
      var data = [];
      $(".jobRow").each(function () {
        $(this).find(".badge").each(function () {
          //카테고리 직무에 하위 직무가 더 있다면
          if ($(this).closest(".jobRow").find(".badge").length > 1) {
            if ($(this).hasClass("jobCode1badge")) {
              return;
            }
          }
          data.push($(this).attr("code2"));
        });
      });
      return data;
    }

    function getBusiData() {
      var data = [];
      //산업
      $(".busiRow").each(function () {
        $(this).find(".badge").each(function () {
          //카테고리 산업에 하위 산업이 더 있다면
          if ($(this).closest(".busiRow").find(".badge").length > 1) {
            if ($(this).hasClass("busiCode1badge")) {
              return;
            }
          }
          data.push($(this).attr("code2"));
        });
      });

      return data;
    }

    StopEnterSubmit();

    var school_row_cnt = $(".schoolRow").length; //학력 row 갯수 초기화
    var company_row_cnt = $(".companyRow").length; //경력 row 갯수 초기화

    //컨피덴셜 시 사유 입력
    $('#is_confidential').click(function () {
      if ($(this).prop("checked")) {
        $('#col_confi_remark').fadeIn().show();
      } else {
        $('#col_confi_remark').hide();
        $('#confi_remark').val("");
      }
      validator.element('#confi_remark');
    });
    //학력 드래그앤 드롭
    $("#schoolBody").sortable({
      group: 'candidate_edu',
      handle: '.drag_handle',
      onDragStart: function ($item, container, _super) {
        // Duplicate items of the no drop area
        if (!container.options.drop)
          $item.clone().insertAfter($item);
        _super($item, container);
      }
    });

    //경력 드래그앤 드롭
    $("#companyBody").sortable({
      group: 'candidate_exp',
      handle: '.drag_handle',
      onDragStart: function ($item, container, _super) {
        // Duplicate items of the no drop area
        if (!container.options.drop)
          $item.clone().insertAfter($item);
        _super($item, container);
      }
    });

    //DB Owner(등록자) 선택
    function FindManager(e) {
      $.fancybox.open({
        href: window.url_search_candidate_manager,
        ajax: {
          type: "post",
        },
        autoDimensions: false,
        type: 'ajax',
        padding: 5,
        scrolling: 'auto',
        autoSize: true,
        helpers: {
          overlay: {
            closeClick: false
          }
        }
      });
    }

    //이력서 업로드 시 자동 추출 항목 생성
    function SetResumeDatePopover(vtitle, vTitle_kor, id, values) {
      //항목당 추출 갯수가 1개일경우 바로 값을 채워 줌
      if (values.length == 1 && id != '#kor_name') {
        if ($(id).val() == "") {
          setValues(id, values[0]);
        }
      }
      //기존 팝오버 제거
      $(id).popover('dispose');
      //팝오버 생성
      if ($(id).val() == "" && values && values[0] != "") {
        $(id).popover({
          placement: "bottom",
          trigger: 'focus',
          html: true,
          container: 'body',
          title: vtitle + " from Resume",
          content: function () {
            html = "이력서에서 추출된 항목 중 [" + vTitle_kor + "](으)로 판단되는 항목이 있습니다.<br/>입력하실 항목을 클릭하면 자동 입력 됩니다.<br/>";
            for (i = 0; i < values.length; i++) {
              var val = values[i].replace(/e-mail/gi, "");
              //html += "<a href=\"javascript:setValues('#kor_name', '" + obj.info.names[i] + "');\">"+ obj.info.names[i] + "</a>"
              html += "<button class='m-3 btn btn-primary' onclick=\"javascript:setValues('" + id + "', '" + val + "');\">" + val + "</a>"
            }
            return html;
          }
        });
      }
    }

    //이름, 전화번호, 이메일 항목들 팝오버 생성
    function setResumeData(obj) {
      SetResumeDatePopover("Name", "이름", "#kor_name", obj.info.names);
      SetResumeDatePopover("Phone Number", "전화번호", "#cell_phone", obj.info.phone);
      if (obj.info.phone.length > 1) {
        SetResumeDatePopover("Phone Number", "전화번호", "#phone", obj.info.phone);
      }
      SetResumeDatePopover("E-mail", "이메일", "#email1", obj.info.email);
      if (obj.info.email.length > 1) {
        SetResumeDatePopover("E-mail", "이메일", "#email2", obj.info.email);
      }
    }

    //팝오버 버튼 클릭 시 값 자동 채움
    function setValues(id, value) {
      $(id).val(value);

      // 채움 후 validation 재확인
      validator.element(id);
    }

    //파일 업로드 부분 ===============================================================================================
    //파일업로드 컴포넌트 초기화
    if ($('.dropzone').length > 0) {
      var myKorDropzone = new Dropzone("div#kor_file", {
        url: window.url_create_temp_resume_file,
        method: "post",
        params: {
          "file_type": "K",
          "uploadFolder": window.viewbag_uploadfolder
        }
      });

      var myEngDropzone = new Dropzone("div#eng_file", {
        url: window.url_create_temp_resume_file,
        method: "post",
        params: {
          "file_type": "E",
          "uploadFolder": window.viewbag_uploadfolder
        }
      });

      var myEtcDropzone = new Dropzone("div#etc_file", {
        url: window.url_create_temp_resume_file,
        method: "post",
        params: {
          "file_type": "O",
          "uploadFolder": window.viewbag_uploadfolder
        }
      });

      //국문 이력서 업로드 시 중복확인 및 추출 내용 반영
      myKorDropzone.on("success", function (file, response) {
        if (response.ok) {
          file_html = MakeHtmlFileList(response.result);
          $('#kor_file_rst').prepend($(file_html).hide().fadeIn(1000));
          if (response.file_rst.is_dup == 1) {
            alertify.confirm()
              .set({
                'labels': { ok: 'OK', cancel: 'Cancel' },
                'onok': function () {
                  var win = window.open("/Candidate/CandidateDetail?c_seq=" + response.file_rst.dup_c_seq, "candidate_" + response.file_rst.dup_c_seq);
                  win.focus();

                },
                'oncancel': function () {
                  return;
                },
              })
              .setHeader('중복된 후보자 정보 발견')
              .setting({
                message: "[ERROR]중복된 후보자가 있습니다. 기존 등록된 후보자 정보를 확인하시겠습니까?",
              })
              .show();
          }
          setResumeData(response.file_rst);
          this.removeFile(file);
          validator.element('#resume_chk');
        } else {
          ErrorAlert("[ERROR]" + response.message);
        }

      });
      myKorDropzone.on("sending", function (file, xhr, formData) {
        // Will send the filesize along with the file as POST data.
        console.log("filesize1", file);
      });
      myKorDropzone.on("addedfile", function (file, xhr, formData) {
        // Will send the filesize along with the file as POST data.
        console.log("filesize2", file);
      });

      //영문 이력서 업로드 시 중복확인 및 추출 내용 반영
      myEngDropzone.on("success", function (file, response) {
        if (response.ok) {
          file_html = MakeHtmlFileList(response.result);
          $('#eng_file_rst').prepend($(file_html).hide().fadeIn(1000));
          if (response.file_rst.is_dup == 1) {
            alertify.confirm()
              .set({
