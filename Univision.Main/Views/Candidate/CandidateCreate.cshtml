                    {
                      //첫행이 아니면서 code2가 이전 값과 다르다면 이전 div행 닫아줌.
                      if (beforeBusi != 0 && beforeBusi != busi.code1)
                      {
                        @Html.Raw("</div>")
                      }

                      if (busi.code1 != beforeBusi)
                      {
                        @Html.Raw("<div id='busi" + busi.code1 + "' code1='" + busi.code1 + "' class='busiRow catRow'>")
                      }

                      //code3이 0이라는 것은 2만 있는 category를 의미.
                      if (busi.code1 != beforeBusi)
                      {
                        <span class="category">
                          <span class="badge badge-outline badge-default bg-white cur_hand badge-lg busiCode1badge" code1="@busi.code1" name1="@busi.code_name1" onclick="DelCategoryBadge('busi', this)">
                            @busi.code_name1
                            <i class="far fa-times-circle"></i>
                          </span>
                        </span>
                      }

                      <span class="badge badge-outline badge-default bg-white badge-lg cur_hand busiCode2badge" code1="@busi.code1" name1="@busi.code_name1" code2="@busi.code2" id="@busi.code2" busicode2name="@busi.code_name2" onclick="DelBadge('busi', this)">
                        @busi.code_name2
                        <i class="far fa-times-circle"></i>
                      </span>


                      if (busi.code1 != beforeBusi)
                      {
                        beforeBusi = busi.code1;
                      }
                    }
                    if (beforeBusi != 0)
                    {
                      @Html.Raw("</div>")
                    }
                  }


