    //퍼지검색용
    function escapeRegExp(string) {
      return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); // $& means the whole matched string
    }
    //퍼지검색용
    function ch2pattern(ch) {
      const offset = 44032; /* '가'의 코드 */
      // 한국어 음절
      if (/[가-힣]/.test(ch)) {
        const chCode = ch.charCodeAt(0) - offset;
        // 종성이 있으면 문자 그대로를 찾는다.
        if (chCode % 28 > 0) {
          return ch;
        }
        const begin = Math.floor(chCode / 28) * 28 + offset;
        const end = begin + 27;
        return `[\\u${begin.toString(16)}-\\u${end.toString(16)}]`;
      }
      // 한글 자음
      if (/[ㄱ-ㅎ]/.test(ch)) {
        const con2syl = {
          'ㄱ': '가'.charCodeAt(0),
          'ㄲ': '까'.charCodeAt(0),
          'ㄴ': '나'.charCodeAt(0),
          'ㄷ': '다'.charCodeAt(0),
          'ㄸ': '따'.charCodeAt(0),
          'ㄹ': '라'.charCodeAt(0),
          'ㅁ': '마'.charCodeAt(0),
          'ㅂ': '바'.charCodeAt(0),
          'ㅃ': '빠'.charCodeAt(0),
          'ㅅ': '사'.charCodeAt(0),
        };
        const begin = con2syl[ch] || ((ch.charCodeAt(0) - 12613 /* 'ㅅ'의 코드 */) * 588 + con2syl['ㅅ']);
        const end = begin + 587;
        return `[${ch}\\u${begin.toString(16)}-\\u${end.toString(16)}]`;
      }
      // 그 외엔 그대로 내보냄
      // escapeRegExp는 lodash에서 가져옴
      return escapeRegExp(ch);
    }
    //퍼지검색용
    function createFuzzyMatcher(input) {
      const pattern = input
        .split('')
        .map(ch2pattern)
        .map(pattern => '(' + pattern + ')')
        .join('.*?');
      return new RegExp(pattern);
    }

    function BindSchoolAutocomplete2($obj) {
      $obj.autocomplete({
        source: function (request, response) {
          $.ajax({
            type: 'post',
            url: window.url_find_school_api,
            dataType: "json",
            data: findSchoolSetDate($obj, request),
            //request.term = $("#autocomplete").val(),
            success: function (data) {
              //서버에서 json 데이터 response 후 목록에 뿌려주기 위함
              var highlight_term = [];
              const term = request.term.replace(/[`~!@@#$%^&*()_|+\-=?;:'"<>\{\}\[\]\\\/ ]/gi, "").toUpperCase()
              const regex = createFuzzyMatcher(term);
              const resultData = data.list
                .filter((item) => {
                  return regex.test(item.filter_str.toUpperCase());
                })
                .map((item) => {
                  let start = 0;
                  let highlight_match = 1;
                  let full_match = 1;
                  let longestDistance = 0;
                  const school_name = item.schoolName.replace(regex, (match, ...groups) => {
                    if (match == term) {
                      full_match = 0
                    }
                    highlight_match = 0
                    start = groups[groups.length - 2];
                    const letters = groups.slice(0, term.length);
                    let lastIndex = 0;
                    let highlighted = [];
                    for (let i = 0, l = letters.length; i < l; i++) {
                      const idx = match.indexOf(letters[i], lastIndex);
                      highlighted.push(match.substring(lastIndex, idx));
                      highlighted.push(`&&${letters[i]}##`);

                      if (lastIndex > 0) {
                        longestDistance = Math.max(longestDistance, idx - lastIndex);
                      }
                      lastIndex = idx + 1;
                    }
                    //console.log(highlighted.join(""));
                    if (!highlight_term.includes(highlighted.join(""))) {
                      // ✅ only runs if value not in array
                      highlight_term.push(highlighted.join(""));
                    }
                    return highlighted.join("");
                  });
                  //console.log(start);
                  //console.log(highlight_match + String(start).padStart(4, "0") + String(longestDistance).padStart(4, "0"),)
                  return {
                    "schoolName": item.schoolName,
                    "school_name": school_name,
                    "longestDistance": String(full_match) + String(highlight_match) + String(start).padStart(4, "0") + String(longestDistance).padStart(4, "0"),
                    //"longestDistance": String(longestDistance).padStart(4, "0"),
                  };
                });

              resultData.sort((a, b) => {
                //console.log(a.start - b.start , a.longestDistance - b.longestDistance, a.start - b.start || a.longestDistance - b.longestDistance )
                return a.longestDistance - b.longestDistance
              });

              //console.log(resultData)

              var test = $.map(resultData, function (item) {

                return {
                  label: item.school_name,
                  value: item.schoolName,
                  campusName: ""
                }

              })

              response(test);
              $('.ui-autocomplete').find('li').each(function () {
                $(this).html($(this).html().replace(/\&amp;\&amp;/gi, '<span class="highlight">').replace(/\#\#/gi, '</span>'));
              });

            }
          })
        },
        delay: 300,
        autoFocus: false, //첫번째 값을 자동 focus한다
