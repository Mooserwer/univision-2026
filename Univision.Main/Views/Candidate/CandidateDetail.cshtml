@model Univision.Core.Models.DTO.Response.Candidate.CandidateDetailViewModel
@using Univision.Security

@{
  //ViewBag.Title = "후보자 상세보기";
  ViewBag.use_validation = true;
  Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
  .extend-box {
    position: absolute !important;
    top: 1.9em;
    right: 1em;
  }

  .job_list {
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    width: 250px;
    display: inline-block;
  }

  .placeDiv span {
    font-size: 15px;
  }

  .category::after {
    content: " > "
  }

  .catRow {
    margin-top: 3px;
  }

  .form-group {
    margin-bottom: 10px !important;
  }

  .form-control-label {
    margin-bottom: 0px !important;
    padding-bottom: 0px !important;
  }

  .no-top-line {
    border-top: 0px !important;
  }

  .table thead th {
    font-weight: bold;
  }

  #resumeBody h4 {
    font-size: 14px;
    margin-bottom: 0px;
  }

  .page-profile .user-background .timeline-item,
  .page-profile .user-background .timeline-single .page-profile .user-background .timeline-item {
    margin-bottom: 12px;
    padding-left: 10px
  }

  .page-profile .user-background .timeline-dot {
    height: 10px;
    width: 10px;
    margin-left: -5px;
    line-height: 10px;
    background-color: #ccd5db
  }

  .page-profile .user-background .timeline-content > img {
    max-width: 120px
  }

  .pl-2em {
    padding-left: 2em !important;
  }

  .text-strike {
    text-decoration: line-through !important;
  }

  #resumeBody.removal-lock .btn-resume-remove {
    display: none;
  }

  #resumeBody .link-resume {
    width: 85%;
  }

    #resumeBody .link-resume.type-pdf {
      width: 70%;
    }

  #resumeBody.removal-lock .link-resume {
    width: 100% !important;
  }

    #resumeBody.removal-lock .link-resume.type-pdf {
      width: 85% !important;
    }

  .file_rst > div:nth-child(1n+3),
  .timeline > li:nth-child(1n+3),
  .active_list > li:nth-child(1n+11) {
    display: none;
  }

  .file_rst > div:nth-child(1n+4).btn-more, .file_rst.more > div:nth-child(1n+4).btn-collapse,
  .timeline > li:nth-child(1n+4).btn-li-more, .timeline.more > li:nth-child(1n+4).btn-li-collapse,
  .active_list > div:nth-child(1n+12).btn-memo-more, .active_list.more > div:nth-child(1n+12).btn-memo-collapse {
    cursor: pointer;
    display: block;
  }

  .file_rst > div:nth-child(1n+4).btn-collapse, .file_rst.more > div:nth-child(1n+4).btn-more,
  .timeline > li:nth-child(1n+4).btn-li-collapse, .timeline.more > li:nth-child(1n+4).btn-li-more,
  .active_list > div:nth-child(1n+12).btn-memo-collapse, .active_list.more > div:nth-child(1n+12).btn-memo-more {
    display: none;
  }

  .file_rst.more > div.file_div,
  .timeline.more > li.timeline-item,
  .active_list.more > li.can_activities {
    display: block !important;
  }

  .file_rst > div.btn-more, .file_rst > div.btn-collapse,
  .timeline > li.btn-li-more, .timeline > li.btn-li-collapse,
  .active_list > div.btn-memo-more, .active_list > div.btn-memo-collapse {
    display: none;
  }

  .btn-memo-more, .btn-memo-collapse {
    display: none;
  }

  .after_modal_appended {
    position: relative;
  }
</style>
<link rel="stylesheet" href="~/Libs/bootstrap-toggle/css/bootstrap-toggle.min.css">
<link rel="stylesheet" href="~/Libs/remark/base/assets/examples/css/pages/profile.min599c.css?v4.0.4">
<div class="page-profile">
  <div class="page-content container-fluid">

    <p class="py-0 my-0">
      @if (Model.data.is_confidential == 1)
      {
        <div class="alert alert-alt alert-warning alert-dismissible bg-orange-100" role="alert">
          <span class="font-weight-900 text-warning">- Confidential : </span>
          @if (!String.IsNullOrEmpty(Model.data.confi_remark) && Model.data.confi_remark != " ")
          {
            <span class="font-weight-100">@Model.data.confi_remark</span>
          }
          else
          {
            <span class="font-weight-normal">Contact 시 DB등록자에게 먼저 문의 바랍니다.</span>
          }
        </div>
      }

      @if (Model.data.is_inactive == 1)
      {
        <div class="alert alert-alt alert-danger alert-dismissible bg-red-100" role="alert">
          <span class="font-weight-900 text-danger">- Inactive : </span>
          @if (!String.IsNullOrEmpty(Model.data.inactive_remark) && Model.data.inactive_remark != " ")
          {
            <span class="font-weight-normal">@Model.data.inactive_remark</span>
          }
          else
          {
            <span class="font-weight-normal">Contact 시 DB등록자에게 먼저 문의 바랍니다.</span>
          }
        </div>
      }

    </p>
    <span class="py-0 my-0" id="caution_alert">
      @if (Model.data.attention_type > 0)
      {
        <div class="alert alert-alt alert-info alert-dismissible bg-blue-grey-200" role="alert">
          <span class="font-weight-900 text-info">- Attention : </span>
          <span class="font-weight-900">
            [@Utils.ReturnAttentionTypeTxt(Model.data.attention_type)]
          </span>
          <br />
          @Model.data.attention_remark
        </div>
      }

      @if (Model.data.caution_type == 6)
      {
        <div class="alert alert-alt alert-success alert-dismissible bg-green-100" role="alert">
          @(ViewBag.hire_in_year ? "최근 1년 내 " : "") @Utils.ReturnCautionTypeTxt(Model.data.caution_type)  @ViewBag.latest_hire_dt
        </div>
      }

    </span>
    <div class="row">
      <div class="col-md-6 col-xxl-8 pb-10">
        <div class="card-block" id="div_candidate_info">
          <div class="modal fade" id="modal_candidate_warning" tabindex="-1" role="dialog" aria-labelledby="dialog_confirm_mapLabel" aria-hidden="true">
            <div class="modal-dialog">
              <div class="modal-content">
                <div class="modal-title">
                  <h3 class="pl-20">※ 후보자에 대한 주의사항이 있습니다.</h3>
                </div>
                <div class="modal-body">
                  <p>

                    @if (Model.data.is_confidential == 1)
                    {
                      <div class="alert alert-alt alert-warning alert-dismissible bg-orange-100" role="alert">
                        <span class="font-weight-900 text-warning">- Confidential : </span>
                        @if (!String.IsNullOrEmpty(Model.data.confi_remark) && Model.data.confi_remark != " ")
                        {
                          <span class="font-weight-100">@Html.Raw(Model.data.confi_remark.Replace("\r\n", "<br />").Replace("\n", "<br />").Replace("\r", "<br />"))</span>
                        }
                        else
                        {
                          <span class="font-weight-normal">[사유 확인 불가] Contact 시 DB등록자에게 먼저 문의 바랍니다.</span>
                        }
                      </div>
                    }

                    @if (Model.data.is_inactive == 1)
                    {
                      <div class="alert alert-alt alert-danger alert-dismissible bg-red-100" role="alert">
                        <span class="font-weight-900 text-danger">- Inactive : </span>
                        @if (!String.IsNullOrEmpty(Model.data.inactive_remark) && Model.data.inactive_remark != " ")
                        {
                          <span class="font-weight-normal">@Html.Raw(Model.data.inactive_remark.Replace("\r\n", "<br />").Replace("\n", "<br />").Replace("\r", "<br />"))</span>
                        }
                        else
                        {
                          <span class="font-weight-normal">[사유 확인 불가] Contact 시 DB등록자에게 먼저 문의 바랍니다.</span>
                        }
                      </div>
                    }



                    @if (Model.data.attention_type > 0)
                    {
                      <div class="alert alert-alt alert-info alert-dismissible bg-blue-grey-200" role="alert">
                        <span class="font-weight-900 text-info">- Attention : </span>
                        <span class="font-weight-900">
                          [@Utils.ReturnAttentionTypeTxt(Model.data.attention_type)]
                        </span>
                        <br />
                        @Html.Raw(Model.data.attention_remark.Replace("\r\n", "<br />").Replace("\n", "<br />").Replace("\r", "<br />"))
                      </div>
                    }

                    @if (Model.data.caution_type == 6 && ViewBag.hire_in_year == true)
                    {
                      <div class="alert alert-alt alert-success alert-dismissible bg-green-100" role="alert">
                        최근 1년 내 @Utils.ReturnCautionTypeTxt(Model.data.caution_type) @ViewBag.latest_hire_dt
                      </div>
                    }
                    <div>
                      <div class="checkbox-custom checkbox-custom-sm checkbox-primary mb-0" title="확인여부">
                        <input type="checkbox" id="chk_modal_candidate_warning" name="is_foreign" value="1" />
                        <label for="chk_modal_candidate_warning">해당 주의 사항을 확인하고 후보자 Contact 시 주의 하겠습니다.</label>
                      </div>
                    </div>
                  </p>
                </div>
                <div class="modal-footer">
                  <span style="float:right"><button type="button" class="btn btn-primary d-none" id="btn_modal_candidate_warning" data-dismiss="modal">닫기</button></span>
                </div>
              </div>
              <!-- /.modal-content -->
            </div>
            <!-- /.modal-dialog -->
          </div>

          @*
            <div class='ribbon ribbon-danger ribbon-bookmark'>
                <span class='ribbon-inner'>
                    @Utils.Get1ToString(Model.data.is_confidential, "Confidential ")
                </span>
            </div>
            <div class='ribbon ribbon-warning ribbon-reverse'>
                <span class='ribbon-inner'>
                    @Utils.Get1ToString(Model.data.is_inactive, "Inactive ")
                </span>
            </div>
          *@
          <!-- 주요 정보 (Confidential / Inactive )-->

          <div class="float-right">
            @if (Model.data.is_external_lock == 1)
            {
              <a class="btn btn-sm btn-primary mr-10" href="javascript:openCandidateExternalLock('@Model.data.c_seq');" title="Unlock private information">
                <i class="fas fa-unlock-alt"></i> 연락처 확인
              </a>
              @*PMS 오픈 관련 등록기능 제한*@
              if ((Univision.Security.AppIdentity.ua_seq <= 3 && Univision.Security.AppIdentity.ua_seq > 0))
              {
                <a id="btnModify" href="javascript:void(0)" class="btn btn-sm btn-success" onclick="openCandidateExternalLockToHref('@Model.data.c_seq', '@Url.Action("CandidateCreate", "Candidate", new { @c_seq = Model.data.c_seq, @is_pop = ViewBag.is_pop })')"><i class="icon wb-edit"></i> Modify</a>
              }
            }
            else
            {
              @*PMS 오픈 관련 등록기능 제한*@
              if ((Univision.Security.AppIdentity.ua_seq <= 3 && Univision.Security.AppIdentity.ua_seq > 0))
              {
                <a id="btnModify" href="@Url.Action("CandidateCreate", "Candidate", new { @c_seq = Model.data.c_seq, @is_pop = ViewBag.is_pop })" class="btn btn-sm btn-success"><i class="icon wb-edit"></i> Modify</a>
              }
            }
            @if (Model.data.log_cnt > 0)
            {
              <a href="@Url.Action("CandidateLog", "Log", new { c_seq = Model.data.c_seq})" id="btnHisotry" class="btn btn-sm btn-default">Log</a>
            }
          </div>

          <h4 class="profile-user">
            @Model.data.kor_name
            @if (!String.IsNullOrEmpty(Model.data.eng_name) && Model.data.eng_name.Trim() != "")
            {
              <small>[@Model.data.eng_name.Trim()]</small>
            }
            -
            <small>
              @if (Model.data.birth_date.HasValue)
              {
                if (Model.data.birth_date.Value.Year == 1900)
                {
                  <text>[나이 알수 없음]</text>
                }
                else
                {
                  @("만 " + Utils.GetAge(Model.data.birth_date) + "세")
                }

                if (Model.data.ex_birthdate == 1)
                {
                  <i class="fa fa-question-circle text-warning" aria-hidden="true" title="Uncertain birthday"></i>
                }
              }
              @(" (" + Utils.ReturnGenderTxt(Model.data.gender) + ")")
            </small>
          </h4>
          <p class="profile-job mb-1">
            @if (Model.data.country_code != "KR" && !String.IsNullOrEmpty(Model.data.country_code))
            {
              <div class="py-1">
                <i class="fa fa-globe-asia fa-fw" aria-hidden="true" title="Nationality"></i> @Model.data.country_code
              </div>
            }
            <div class="py-1">

              <i class="fa fa-birthday-cake fa-fw" aria-hidden="true" title="Day of birth"></i>
              @Utils.ConvertDateTimeToString(Model.data.birth_date)
              @if (Model.data.ex_birthdate == 1)
              {
                <i class="fa fa-question-circle text-warning" aria-hidden="true" title="Uncertain birthday"></i>
              }
            </div>
            <div class="py-1">
              @if (!string.IsNullOrWhiteSpace(Model.data.email1))
              {

                <i class="fa fa-at fa-fw" aria-hidden="true" title="E-mail"></i>
                <a href="mailto:@(Model.data.email1)">@Model.data.email1</a>
                <a href="javascript:funcCopy('@(Model.data.email1)')" class="text-secondary">
                  <i class="fa fa-copy" aria-hidden="true" title="Copy"></i>
                </a>
                <button type="button" class="btn btn-xs btn-warning" onclick="openPrivacySmsSendModal('EMAIL', '@Model.data.c_seq')" title="개인정보 수집/제공 동의 발송">동의서 발송</button>

              }
              @if (!string.IsNullOrWhiteSpace(Model.data.email2))
              {
                <br />
                <i class="fa fa-at fa-fw invisible" aria-hidden="true" title="E-mail"></i> <a href="mailto:@(Model.data.email2)">@Model.data.email2</a>
                <a href="javascript:funcCopy('@(Model.data.email2)')" class="text-secondary">
                  <i class="fa fa-copy" aria-hidden="true" title="Copy"></i>
                </a>
              }
              <button type="button" class="btn btn-xs btn-primary" id="btn-edit-can-contact" onclick="CandidateContactModal('@Model.data.c_seq')" title="연락처(전화/이메일) 수정하기">연락처 수정</button>
            </div>



            @if (!string.IsNullOrWhiteSpace(Model.data.cell_phone))
            {
              <div class="py-1">
                @if (Model.data.cell_phone.Length > 2 && Model.data.cell_phone.Substring(0, 2) == "01")
                {
                  <i class="fa fa-mobile-alt fa-fw" aria-hidden="true" title="Mobile"></i>
                }
                else
                {
                  <i class="fa fa-phone fa-fw" aria-hidden="true" title="Phone"></i>
                }
                <span class="@(Model.data.wrong_phone2 == 1 ? "text-strike" : "")">@Model.data.cell_phone</span>&nbsp;
                <a href="javascript:funcCopy('@(Model.data.cell_phone)')" class="text-secondary">
                  <i class="fa fa-copy" aria-hidden="true" title="Copy"></i>
                </a>
                @if (Model.data.cell_phone.Length > 2 && Model.data.cell_phone.Substring(0, 2) == "01")
                {
                  <button type="button" class="btn btn-xs btn-success" onclick="openSmsSendModal('@Model.data.cell_phone')" title="이 전화번호로 문자 발송">SMS</button>
                  <button type="button" class="btn btn-xs btn-warning" onclick="openPrivacySmsSendModal('SMS2', '@Model.data.c_seq')" title="개인정보 수집/제공 동의 발송">동의서 발송</button>
                }

                @if (Model.data.wrong_phone2 == 1)
                {
                  <i class="fa fa-times-circle text-warning" aria-hidden="true" title="Wrong number"></i>
                }
                <button type="button" class="btn btn-xs btn-primary" id="btn-edit-can-contact" onclick="CandidateContactModal('@Model.data.c_seq')" title="연락처(전화/이메일) 수정하기">연락처 수정</button>
              </div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.data.phone))
            {
              <div class="py-1">
                @if (Model.data.phone.Length > 2 && Model.data.phone.Substring(0, 2) == "01")
                {
                  <i class="fa fa-mobile-alt fa-fw" aria-hidden="true" title="Mobile"></i>
                }
                else
                {
                  <i class="fa fa-phone fa-fw" aria-hidden="true" title="Phone"></i>
                }
                <span class="@(Model.data.wrong_phone == 1 ? "text-strike" : "")">@Model.data.phone</span>
                <a href="javascript:funcCopy('@(Model.data.phone)')" class="text-secondary">
                  <i class="fa fa-copy" aria-hidden="true" title="Copy"></i>
                </a>

                @if (Model.data.phone.Length > 2 && Model.data.phone.Substring(0, 2) == "01")
                {
                  <button type="button" class="btn btn-xs btn-success" onclick="openSmsSendModal('@Model.data.phone')" title="이 전화번호로 문자 발송">SMS</button>
                  <button type="button" class="btn btn-xs btn-warning" onclick="openPrivacySmsSendModal('SMS1', '@Model.data.c_seq')" title="개인정보 수집/제공 동의 발송">동의서 발송</button>


                }
                @if (Model.data.wrong_phone == 1)
                {
                  <i class="fa fa-times-circle text-warning" aria-hidden="true" title="Wrong number"></i>
                }
              </div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.data.sns_link1) || !string.IsNullOrWhiteSpace(Model.data.sns_link2) || !string.IsNullOrWhiteSpace(Model.data.sns_link3))
            {
              <div class="py-1 text-truncate">
                @if (!string.IsNullOrWhiteSpace(Model.data.sns_link1))
                {

                  var url = Model.data.sns_link1;

                  if (string.IsNullOrWhiteSpace(url))
                  {
                    url = "javascript:void(0);";
                  }
                  else
                  {
                    if (!url.Contains("http://") && !url.Contains("https://"))
                    {
                      url = "http://" + url;
                    }
                  }

                  <i class="fab @(Utils.ReturnFALinkClass(Model.data.sns_link1)) fa-fw" aria-hidden="true" title="URL"></i>
                  <a href="@url" target="_blank">@Model.data.sns_link1</a>
                }
                @if (!string.IsNullOrWhiteSpace(Model.data.sns_link2))
                {
                  var url = Model.data.sns_link2;

                  if (string.IsNullOrWhiteSpace(url))
                  {
                    url = "javascript:void(0);";
                  }
                  else
                  {
                    if (!url.Contains("http://") && !url.Contains("https://"))
                    {
                      url = "http://" + url;
                    }
                  }
                  <br />
                  <i class="fab @(Utils.ReturnFALinkClass(Model.data.sns_link2)) fa-fw" aria-hidden="true" title="URL"></i>
                  <a href="@url" target="_blank">@Model.data.sns_link2</a>
                }
                @if (!string.IsNullOrWhiteSpace(Model.data.sns_link3))
                {
                  var url = Model.data.sns_link3;

                  if (string.IsNullOrWhiteSpace(url))
                  {
                    url = "javascript:void(0);";
                  }
                  else
                  {
                    if (!url.Contains("http://") && !url.Contains("https://"))
                    {
                      url = "http://" + url;
                    }
                  }
                  <br />
                  <i class="fab @(Utils.ReturnFALinkClass(Model.data.sns_link3)) fa-fw" aria-hidden="true" title="URL"></i>
                  <a href="@url" target="_blank">@Model.data.sns_link3</a>
                }
              </div>
            }
            <div class="py-1">

              <i class="fa fa-home fa-fw" aria-hidden="true" title="Address"></i>
              @Model.data.addr1
              @if (Model.data.ex_addr == 1)
              {
                <i class="fa fa-globe text-primary" aria-hidden="true" title="해외 거주"></i>
              }
            </div>
            <div class="py-1">
              @if (Model.data.hope_salary != null && Model.data.hope_salary > 0)
              {
                <i class="fa fa-won-sign fa-fw" aria-hidden="true" title="Salary(Hopeful)"></i> @(Model.data.hope_salary)
              }
              @if (Model.data.hope_salary2 != null && Model.data.hope_salary2 > 0)
              {
                <text> ~ </text> @(Model.data.hope_salary2)
              }
            </div>
            <div class="py-1 row">
              <div class="col-4">
                <button class="btn btn-info btn-sm btn-block" onclick="CreateAttentionModal('@Model.data.c_seq')" title="주의요망사항 설정">
                  <i class="fa fa-user-check" aria-hidden="true"></i>
                  Attention
                </button>
              </div>

              <div class="col-4">
                <button class="btn btn-warning btn-sm btn-block" onclick="CreateConfiModal('@Model.data.c_seq')" title="Confidential 설정">
                  <i class="fa fa-eye-slash" aria-hidden="true"></i> Confidential
                </button>
              </div>

              <div class="col-4">
                <button class="btn btn-danger btn-sm btn-block" onclick="CreateInactiveModal('@Model.data.c_seq')" title="Inactive 설정">
                  <i class="fa fa-user-lock" aria-hidden="true"></i> Inactive
                </button>
              </div>
            </div>
            <!--
                <div class="py-1 form-inline">
                  <div class="form-group">
                    <label class="form-control-label" for="data_caution_type">
                      주의요망사항
                    </label>
                    <div class="input-group input-group-sm">
                      @Html.DropDownListFor(x => x.data.caution_type, new SelectList(CandidateCautionType.CandidateCautionTypes, "Key", "Value"), new { @class = "form-control form-control-sm " })
                      <span class="input-group-btn">
                        <button type="button" class="btn btn-sm btn-primary" onclick="saveCautionType()">
                          <i class="fas fa-save"></i> 적용
                        </button>
                      </span>
                    </div>

                  </div>
                </div>
              -->
          </p>
          <hr />
          <div class="row">
            <div class="col-12 col-xxl-6">

              @if (Model.data.is_external_lock != 1)
              {
                var kor_resume = Model.resumeList.Where(x => x.file_type == "K").FirstOrDefault();
                var eng_resume = Model.resumeList.Where(x => x.file_type == "E").FirstOrDefault();

                if (kor_resume != null || eng_resume != null)
                {

                  <p>
                    <dl class="dl-horizontal row">
                      <dt class="col-1"><i class="fa fa-file-alt fa-fw" aria-hidden="true" title="Resume"></i></dt>
                      <dd class="col-11">최신 이력서 다운로드 </dd>
                      <dd class="col offset-1" style="line-height:2em;">
                        @if (kor_resume != null)
                        {
                          <a class="badge badge-outline badge-primary" href="javascript:void(0)" onclick="DownloadFile(@kor_resume.cr_seq, 'canResume')" title="국문이력서 다운로드">
