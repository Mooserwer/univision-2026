@section scripts{
  <script src="~/Libs/bootstrap-toggle/js/bootstrap-toggle.min.js"></script>

  @if (Model.data.attention_type > 0 || (Model.data.caution_type == 6 && ViewBag.hire_in_year == true) || Model.data.is_confidential == 1 || Model.data.is_inactive == 1)
  {
    <script>

      function ModalCandInfo() {
        $('#modal_candidate_warning').modal({
          backdrop: 'static',
          keyboard: false
        });


        $("#div_candidate_info").addClass("after_modal_appended");
        $('.modal-backdrop').appendTo('#div_candidate_info');
        $('#modal_candidate_warning').css("position", "absolute");
        $('#modal_candidate_warning').css("padding-left", "13px");
        $('#modal_candidate_warning').css("padding-top", "60px");
        $('#modal_candidate_warning').css("z-index", "1400");
        $('.modal-backdrop').css("position", "absolute");
        $('.modal-backdrop').css("z-index", "1300");
        $('body').removeClass("modal-open");
        $('body').css("padding-right", "");

        $('#chk_modal_candidate_warning').click(function () {
          if ($(this).prop("checked")) {
            $('#btn_modal_candidate_warning').removeClass("d-none");
          } else {
            $('#btn_modal_candidate_warning').removeClass("d-none").addClass("d-none");
          }
        })
      }
      ModalCandInfo();
    </script>
  }
  <script type="text/javascript">
    function GetOfflimitData() {
      ajxCall({
        url: "@Url.Action("OfflimitCheckList", "Partial")",
        type: "POST",
        dataType: 'json',
        loading: false,
        suc: function (json) {

          //$('#btnCreateMemo').prop("disabled", false);
          //$('#btnCreateMemo').removeClass("disabled");

          if (json.ok) {
            CheckOfflimit(json.list);
          }
          else {
            ErrorAlert("Offlimit Check Error : " + json.message);
          }
        },
        err: function (jqXHR, textStatus, errorThrown) {

          ErrorAlert("Offlimit Check Failed");
        }
      });
    }

    function CheckOfflimit(list) {
      //console.log(list);
      $('.offlimit-chk-0').each(function () {
        var company = $(this).text().toLowerCase().trim();
        if (company != "지멘스" && company != "siemens" && company != "한화" && company != "LG" && company != "엘지") {
          var fil = list.filter(item => item.name_all.toLowerCase().indexOf(company) >= 0 || (item.kor_name.length > 2 && company.toLowerCase().indexOf(item.kor_name) >= 0) || (item.eng_name.length > 2 && company.toLowerCase().indexOf(item.eng_name) >= 0))
          //console.log(company, fil);
          if (fil.length > 0) {
            //console.log(fil[0]);
            if (fil[0].offlimit == 1) {
              $(this).append('<span class="badge badge-danger" title="' + fil[0].kor_name + ' (전 임직원 컨택 금지)">OFFLIMIT</span>');
            } else if (fil[0].offlimit == 2) {
              $(this).append('<span class="badge badge-warning" title="' + fil[0].kor_name + ' (유니코에 의해 채용된 임직원 컨택 금지)">OFFLIMIT</span>');
            } else if (fil[0].offlimit == 3) {
              $(this).append('<span class="badge badge-outline badge-warning" title="' + fil[0].kor_name + ' (계약서 내 오프리밋 조항은 없지만 고객사의 요청 등)">[계약서 미표기] OFFLIMIT</span>');
            }

          }
        }
      })

    }

    GetOfflimitData();


    function openCandidateExternalLock(c_seq) {
      alertify.confirm()
      .set({
        'labels': { ok: 'OK', cancel: 'Cancel' },
        'onok': function (e) {
          if (saveElementOpenLogToServer('@AppIdentity.user_seq', c_seq, 'candidate', 'candidate', '', '')) {
            location.href = "@Html.Raw(ViewContext.HttpContext.Request.Url.AbsoluteUri)";
          }
          else {
            return;
          }
        },
        'oncancel': function () {
          return;
        }
      })
      .setHeader('후보자 연락처 확인')
      .setting({
        message: "해당 후보자의 연락처를 확인하시겠습니까?<br />확인 시 연락처 확인 기록이 서버에 저장되며, 24시간 이내 동일정보는 별도 확인 없이 조회가 가능합니다."
      })
      .show();
    }

        function openCandidateExternalLockToHref(c_seq, rtn_url) {
            alertify.confirm()
            .set({
                'labels': { ok: 'OK', cancel: 'Cancel' },
                'onok': function (e) {

                    if (saveElementOpenLogToServer('@AppIdentity.user_seq', c_seq, 'candidate', 'candidate', '', '')) {
                        if (rtn_url) {
                            location.href = rtn_url;
                        } else {
                            location.href = "@Html.Raw(ViewContext.HttpContext.Request.Url.AbsoluteUri)";
                        }
                    }
                    else {
                        return;
                    }

                },
                'oncancel': function () {
                    return;
                }
            })
            .setHeader('후보자 수정화면 이동 안내')
            .setting({
              message: "해당 후보자의 정보 수정화면으로 이동하시겠습니까?<br />확인 시 연락처 확인 기록이 서버에 저장되며, 24시간 이내 동일정보는 별도 확인 없이 조회가 가능합니다."
            })
            .show();
        }


        $('.btn-li-more').click(function () {
            $(this).closest('ul').addClass('more');
        })

        $('.btn-li-collapse').click(function () {
            $(this).closest('ul').removeClass('more');
        })

        $('#switch-resume-remove').change(function () {
