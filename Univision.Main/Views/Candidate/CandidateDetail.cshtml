      }
    },
    submitHandler: function (form) {
      var c_seq  = "@Model.data.c_seq"
      //form 전송을 위한 데이터 생성.
      //기본정보
      var Activity = {
          c_seq: c_seq,
          memo: $("#memo").val(),
          ca_date : $("#ca_date").val()
