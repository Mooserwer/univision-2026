        //후보자 주의 요망사항 업데이트
        function saveCautionType() {

            $.ajax({
               url: '@Url.Action("UpdateCandidateCautionType", "Candidate")',
               data: {
                   c_seq: '@Model.data.c_seq'
                   ,
                   caution_type: $("#data_caution_type :selected").val()
                },
                dataType: 'json',
                type: 'POST',
               beforeSend: function ()
               {
                   showLoading();
               }
            })
            .done(function (json) {
                hideLoading();
                if (json.ok) {
                    NormalAlert(json.message);
                    var caution_type = $("#data_caution_type :selected").val();
                    var caution_text = $("#data_caution_type :selected").text();

                    $('#caution_alert').empty();
                    if (caution_type > 0) {
                        var alert_bar = "<div class='alert dark " + (caution_type == 6 ? "alert-success" : "alert-warning") + " alert-dismissible' role='alert' >Warning : " + caution_text + "</div>";
                        $('#caution_alert').append(alert_bar).hide().fadeIn();
                    }
                } else {
                    ErrorAlert(json.message);
                }
            })
            .fail(function (e) {
                hideLoading();
                ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
            });
        }

