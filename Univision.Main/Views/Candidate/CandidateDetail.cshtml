        //후보자 활동내역 Partial View
        function callActivityList(c_seq, page) {

            if(page == null || page == undefined)
                page = 1;

            $.ajax({
                url: '@Url.Action("CandidateActivityList", "Candidate")',
                data: {
                    c_seq: c_seq
                    ,page : page
                },
                dataType: 'html',
                type: 'POST',
                beforeSend: function () {
                    showLoading('#activityBody');
                }
            })
            .done(function (view) {
                hideLoading('#activityBody');
                if (page == 1) {
                    $('#activityBody').html(view);
                } else {
                    $('#activityBody').append(view);
                }
            })
            .always(function () {
                hideLoading('#activityBody');
            });
        }

        function callResumeList(c_seq, show_remove) {
            if ($('#resumeBody').length == 0) {
                return;
            }
            $.ajax({
                url: '@Url.Action("CandidateResumeList", "Candidate")',
                data: {
                  c_seq: c_seq,
                  show_remove: show_remove
                },
                dataType: 'html',
                type: 'POST',
                beforeSend: function () {
                    showLoading('#resumeBody');
                }
            })
            .done(function (view) {
                 hideLoading('#resumeBody');
                $('#resumeBody').html(view);

            })
            .always(function () {
                 hideLoading('#resumeBody');
            });
        }

