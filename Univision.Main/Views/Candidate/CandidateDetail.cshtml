      var formURL = $("#CreateActivityForm").attr("action");
      ajxCall({
          url: formURL,
          type: "POST",
          dataType: 'json',
          data: {
              data : Activity
          },
        loading: true,
        loading_target: '#CreateActivityForm',

          suc: function (json) {

              //$('#btnCreateMemo').prop("disabled", false);
              //$('#btnCreateMemo').removeClass("disabled");

              if (json.ok) {
                  $("#memo").val("");
                  $("#ca_date").val();
