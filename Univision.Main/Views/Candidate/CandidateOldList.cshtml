            @*
              <div class="col-md-6 col-lg-4 col-xxl-3">
                  @Html.LabelFor(x => x.search.recent_hire, "최근 6개월 내 채용", new { @class = "form-control-label small" })
                  <div class="form-group form-inline">
                      <div class="radio-custom radio-primary pr-3">
                          @Html.RadioButtonFor(x => x.search.recent_hire, -1, new { @id = "search_recent_hire_all", @class = "form-control-label small" })
