@model Univision.Core.Models.DTO.Response.Candidate.CandidateListViewModel
@{

  ViewBag.Title = "후보자 검색";
  Layout = "~/Views/Shared/_Layout.cshtml";

  int start_item = Model.PagingInfo.TotalItems == 0 ? 0 : ((Model.PagingInfo.CurrentPage - 1) * Model.PagingInfo.ItemsPerPage) + 1;
  int end_item = Model.PagingInfo.TotalItems == 0 ? 0 : start_item + Model.list.Count() - 1;


  int cookie_can_open_win = 0, cookie_can_view_list = 0;
  if (HttpContext.Current.Request.Cookies.AllKeys.Contains("CAND_OPEN_WINDOW"))
  {
    cookie_can_open_win = Convert.ToInt32(Request.Cookies["CAND_OPEN_WINDOW"].Value);
  }

  if (HttpContext.Current.Request.Cookies.AllKeys.Contains("CAND_VIEW_LIST"))
  {
    cookie_can_view_list = Convert.ToInt32(Request.Cookies["CAND_VIEW_LIST"].Value);
  }
}

<style>
  .extend-box {
    position: absolute !important;
    top: 1.9em;
    right: 1em;
  }

  .panel-body .input-search .form-control {
    border-radius: 2px;
  }

  .panel-body .form-control-label {
    margin-bottom: 0px;
    padding-bottom: 0px;
  }

  .panel-body .form-group {
    margin-bottom: 3px;
  }

  .panel {
    margin-bottom: 1rem;
  }

  .table thead th {
    font-weight: bold;
  }

  .bg-warning {
    background-color: #ab8000 !important;
  }
</style>
<link href="~/Libs/bootstrap-select/css/bootstrap-select.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/Libs/remark/base/assets/examples/css/pages/user.min599c.css?v4.0.4">
<div class="page-user">
  <div class="page-content">
    <!--검색 Form -->
    @{
      string boolean_desc = "<h5>Boolean search 지원</h5><b>- <span class='text-danger'>&amp;&amp;</span> : AND 검색 </b><br/>&nbsp;&nbsp;&nbsp;<small>(A&amp;&amp;B →A와B를 모두 포함하는 결과)</small><br><b>- <span class='text-danger'>||</span> : OR 검색(Shift + ￦)<b/><br/>&nbsp;&nbsp;&nbsp;<small>(A||B →A,B 중 하나 이상을 포함하는 결과)</small><br>- <span class='text-danger'>!!</span> : AND NOT 검색<br/>&nbsp;&nbsp;&nbsp;<small>(A!!B →A는 포함하지만 B는 포함하지 않는 결과)</small>";
    }
    @using (Html.BeginForm("CandidateOldList", "Candidate", FormMethod.Get, new { @id = "SearchForm", @autocomplete = "off" }))
    {
      @Html.HiddenFor(x => x.search.orderTxt)
      @Html.HiddenFor(x => x.search.orderOption)
      <!-- 검색 패널 시작 -->
      <div class="panel panel-primary panel-line animation-scale-up" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms;">
        <div class="panel-heading">
          <div class="panel-title">
            <i class="fas fa-search"></i>
            Candidate Search <small>(후보자 통합검색)</small>
          </div>
          <div class="panel-actions w-md-p50">

            <div class="panel-action input-search w-full">

              <button type="submit" class="input-search-btn pr-20">
                <i class="icon wb-search" aria-hidden="true" title="Search"></i>
                &nbsp;&nbsp;
                <i class="fas fa-info-circle text-info" data-html="true" data-toggle="popover" data-trigger="hover" data-content="@Html.Raw(boolean_desc)"></i>
              </button>
              @Html.TextBoxFor(x => x.search.total, new { @class = "form-control", @placeholder = "통합검색 - 검색어 입력 (이력서 상세 내용, 후보자 정보 등)" })

            </div>
          </div>

          <a class="panel-action icon wb-minus extend-box cur_hand" aria-expanded="true" data-toggle="panel-collapse" aria-hidden="true" title="Advanced Search">
          </a>

        </div>
        <div class="panel-body bg-grey-200">
          <hr class="d-md-none d-block" />
          <!-- 검색조건 첫째줄 시작 -->
          <div class="row">
            <div class="col-6 col-md-4 col-xxl-3">
              @Html.LabelFor(x => x.search.name, "이름(Name)", new { @class = "form-control-label small" })
              <div class="form-group">
                <div class="input-group input-group-sm">
                  @Html.TextBoxFor(x => x.search.name, new { @class = "form-control" })
                  <div class="input-group-append checkbox-custom checkbox-custom-sm checkbox-primary ml-1">
                    @Html.CheckBoxFor(x => x.search.foreign, new { @id = "search_foreign_frgn", @class = "form-control-label small" })
                    <label for="search_foreign_frgn" title="외국인">Foreigner</label>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-6 col-md-4 col-xxl-3">
              @Html.LabelFor(x => x.search.startBirth, "생년(Year of Birth)", new { @class = "form-control-label small" })
              <div class="form-group">
                <div class="input-group input-group-sm">
                  @Html.TextBoxFor(x => x.search.startBirth, new { @class = "form-control", @type = "number", @placeholder = "YYYY" })
                  <div class="input-group-text pl-5 pr-5">
                    ~
                  </div>
                  @Html.TextBoxFor(x => x.search.endBirth, new { @class = "form-control", @type = "number", @placeholder = "YYYY" })
                </div>
              </div>
            </div>
            <div class="col-6 col-md-4 col-xxl-3">
              @Html.LabelFor(x => x.search.gender, "성별(Gender)", new { @class = "form-control-label small" })
              <div class="form-group form-inline">
                <div class="radio-custom radio-custom-sm radio-primary pr-3">
                  @Html.RadioButtonFor(x => x.search.gender, 0, new { @id = "search_gender_all", @class = "form-control-label small" })
                  <label for="search_gender_all">All</label>
                </div>
                <div class="radio-custom radio-custom-sm radio-primary pr-3">
                  @Html.RadioButtonFor(x => x.search.gender, 1, new { @id = "search_gender_male", @class = "form-control-label small" })
                  <label for="search_gender_male">Male</label>
                </div>
                <div class="radio-custom radio-custom-sm radio-primary">
                  @Html.RadioButtonFor(x => x.search.gender, 2, new { @id = "search_gender_female", @class = "form-control-label small" })
                  <label for="search_gender_female">Female</label>
                </div>
              </div>
            </div>

            <div class="col-6 col-md-4 col-xxl-3">
              @Html.LabelFor(x => x.search.phone, "연락처(Tel No.)", new { @class = "form-control-label small" })
              @Html.TextBoxFor(x => x.search.phone, new { @class = "form-control form-control-sm", @size = "13", @placeholder = "Tel No." })
            </div>
            <div class="col-6 col-md-4 col-xxl-6">
              @Html.LabelFor(x => x.search.email, "E-mail", new { @class = "form-control-label small" })
              @Html.TextBoxFor(x => x.search.email, new { @class = "form-control form-control-sm", @placeholder = "exam@exam.com" })
            </div>
            <div class="col-6 col-md-4 col-xxl-6">
              @Html.LabelFor(x => x.search.sns, "SNS url", new { @class = "form-control-label small" })
              @Html.TextBoxFor(x => x.search.sns, new { @class = "form-control form-control-sm", @placeholder = "exam.com/exam" })
            </div>
          </div>
          <!-- 검색조건 첫째줄 끝 -->
          <!-- 검색조건 둘째줄 시작 -->
          <div class="row">
            <div class="col-md-6 col-xl-4">
              @Html.LabelFor(x => x.search.school, "출신학교(School)", new { @class = "form-control-label small" })
              <i class="fas fa-info-circle text-info" data-html="true" data-toggle="popover" data-trigger="hover" data-content="@Html.Raw(boolean_desc)"></i>
              <div class="form-group">
                @Html.TextBoxFor(x => x.search.school, new { @class = "form-control form-control-sm", placeholder = "학교명" })
              </div>
            </div>
            <div class="col-md-6 col-xl-4">
              @Html.LabelFor(x => x.search.final_edu, "최종학력", new { @class = "form-control-label small" })
              <div class="input-group input-group-sm">
                <select id='search_final_edu' name="search.final_edu" class="form-control  form-control-sm selectpicker" data-actions-box="true" multiple title="최종학력">

                  <option value='1' @(Model.search.final_edu.Count == 0 || Model.search.final_edu.Contains(1) ? "selected" : "")>고등학교</option>
                  <option value='2' @(Model.search.final_edu.Count == 0 || Model.search.final_edu.Contains(2) ? "selected" : "")>전문대</option>
                  <option value='3' @(Model.search.final_edu.Count == 0 || Model.search.final_edu.Contains(3) ? "selected" : "")>학사</option>
                  <option value='4' @(Model.search.final_edu.Count == 0 || Model.search.final_edu.Contains(4) ? "selected" : "")>석사</option>
                  <option value='5' @(Model.search.final_edu.Count == 0 || Model.search.final_edu.Contains(5) ? "selected" : "")>박사</option>
                  <option value='6' @(Model.search.final_edu.Count == 0 || Model.search.final_edu.Contains(6) ? "selected" : "")>Post Doc</option>

                </select>
                <div class="input-group-append checkbox-custom checkbox-custom-sm checkbox-primary ml-1" title="해외학교">
                  @Html.CheckBoxFor(x => x.search.foreign_school, new { @class = "form-control-label small" })
                  <label for="search_foreign_school">Overseas</label>
                </div>
              </div>
            </div>
            @*
              <div class="col-6 col-md-6 col-xl-3">
                @Html.LabelFor(x => x.search.category1_name, "전공계열(Major)", new { @class = "form-control-label small" })
                <select id="search_category1_name" name="search.category1_name" class="form-control  form-control-sm">
                  <option value="">[All]</option>
                  <option value="인문계열" @(Model.search.category1_name == "인문계열" ? "selected" : "")>인문계열</option>
                  <option value="사회계열" @(Model.search.category1_name == "사회계열" ? "selected" : "")>사회계열</option>
                  <option value="공학계열" @(Model.search.category1_name == "공학계열" ? "selected" : "")>공학계열</option>
                  <option value="자연계열" @(Model.search.category1_name == "자연계열" ? "selected" : "")>자연계열</option>
                  <option value="교육계열" @(Model.search.category1_name == "교육계열" ? "selected" : "")>교육계열</option>
                  <option value="의약계열" @(Model.search.category1_name == "의약계열" ? "selected" : "")>의약계열</option>
                  <option value="예체능계열" @(Model.search.category1_name == "예체능계열" ? "selected" : "")>예체능계열</option>
                </select>
              </div>
            *@
            <div class="col-md-6 col-xl-4">
              @Html.LabelFor(x => x.search.major, "전공(Major)", new { @class = "form-control-label small" })
              <i class="fas fa-info-circle text-info" data-html="true" data-toggle="popover" data-trigger="hover" data-content="@Html.Raw(boolean_desc)"></i>
              @Html.TextBoxFor(x => x.search.major, new { @class = "form-control  form-control-sm", placeholder = "전공" })
            </div>

          </div>
          <!-- 검색조건 둘째줄 끝 -->
          <!-- 검색조건 셋째줄 시작 -->
          <div class="row">
            <div class="col-md-6 col-xl-6">
              @Html.LabelFor(x => x.search.company, "출신회사(Company)", new { @class = "form-control-label small" })
              <i class="fas fa-info-circle text-info" data-html="true" data-toggle="popover" data-trigger="hover" data-content="@Html.Raw(boolean_desc)"></i>
              <div class="form-group">
                <div class="input-group input-group-sm">
                  @Html.TextBoxFor(x => x.search.company, new { @class = "form-control", placeholder = "회사명" })
                  <div class="input-group-append checkbox-custom checkbox-custom-sm checkbox-primary ml-1">
                    @Html.CheckBoxFor(x => x.search.final_company, new { @class = "form-control-label small" })
                    <label for="search_final_company" title="Lastest only" class="small">최종회사</label>
                  </div>
                </div>
              </div>

            </div>
            <div class="col-md-6">
              @Html.LabelFor(x => x.search.career_start, "경력기간 (Experience)", new { @class = "form-control-label small" })
              <small class="text-danger">*검색 시 경력기간이 입력되지 않은 후보자는 검색되지 않습니다.</small>
              <div class="form-group">
                <div class="input-group input-group-sm">
                  <select id="search_career_start" name="search.career_start" class="form-control">
                    <option value="">[ALL]</option>
                    <option value="11" @(Model.search.career_start == 11 ? "selected" : "")>1년 이상</option>
                    <option value="23" @(Model.search.career_start == 23 ? "selected" : "")>2년 이상</option>
                    <option value="35" @(Model.search.career_start == 35 ? "selected" : "")>3년 이상</option>
                    <option value="59" @(Model.search.career_start == 59 ? "selected" : "")>5년 이상</option>
                    <option value="83" @(Model.search.career_start == 83 ? "selected" : "")>7년 이상</option>
                    <option value="119" @(Model.search.career_start == 119 ? "selected" : "")>10년 이상</option>
                    <option value="179" @(Model.search.career_start == 179 ? "selected" : "")>15년 이상</option>
                    <option value="239" @(Model.search.career_start == 239 ? "selected" : "")>20년 이상</option>
                  </select>
                  <div class="input-group-text pl-5 pr-5">
                    ~
                  </div>
                  <select id="search_career_end" name="search.career_end" class="form-control">
                    <option value="">[ALL]</option>
                    <option value="13" @(Model.search.career_end == 13 ? "selected" : "")>1년 이하</option>
                    <option value="25" @(Model.search.career_end == 25 ? "selected" : "")>2년 이하</option>
                    <option value="37" @(Model.search.career_end == 37 ? "selected" : "")>3년 이하</option>
                    <option value="61" @(Model.search.career_end == 61 ? "selected" : "")>5년 이하</option>
                    <option value="85" @(Model.search.career_end == 85 ? "selected" : "")>7년 이하</option>
                    <option value="121" @(Model.search.career_end == 121 ? "selected" : "")>10년 이하</option>
                    <option value="181" @(Model.search.career_end == 181 ? "selected" : "")>15년 이하</option>
                    <option value="241" @(Model.search.career_end == 241 ? "selected" : "")>20년 이하</option>
                    <option value="361" @(Model.search.career_end == 361 ? "selected" : "")>30년 이하</option>
                  </select>
                </div>
              </div>
            </div>
            @*
              <div class="col-md-6 col-xl-3  pt-2">
                  @Html.LabelFor(x => x.search.position_name, "직위()", new { @class = "form-control-label small" })
                  @Html.TextBoxFor(x => x.search.position_name, new { @class = "form-control", placeholder = "직위(SELECT)", onkeydown = "FindSchool(this)", @readonly = "readonly" })
              </div>
              <div class="col-md-6 col-xl-3  pt-2">
                  @Html.LabelFor(x => x.search.position, "직급()", new { @class = "form-control-label small" })
                  @Html.TextBoxFor(x => x.search.position, new { @class = "form-control", placeholder = "직급", onkeydown = "FindSchool(this)", @readonly = "readonly" })
              </div>
            *@
            <div class="col-md-6 col-xl-6">
              @*
                @Html.LabelFor(x => x.search.isWork, "재직여부(In Office)", new { @class = "form-control-label small" })
                <div class="form-group form-inline">
                  <div class="radio-custom radio-custom-sm radio-primary pr-3">
                    @Html.RadioButtonFor(x => x.search.isWork, "", new { @id = "search_iswork_all", @class = "form-control-label small" })
                    <label for="search_iswork_all">All</label>
                  </div>
                  <div class="radio-custom radio-custom-sm radio-primary pr-3">
                    @Html.RadioButtonFor(x => x.search.isWork, 1, new { @id = "search_iswork_working", @class = "form-control-label small" })
                    <label for="search_iswork_working">In office</label>
                  </div>
                  <div class="radio-custom radio-custom-sm radio-primary">
                    @Html.RadioButtonFor(x => x.search.isWork, 2, new { @id = "search_iswork_retire", @class = "form-control-label small" })
                    <label for="search_iswork_retire">Retire</label>
                  </div>
                </div>
              *@
            </div>
          </div>
          <!-- 검색조건 셋째줄 끝 -->
          <!-- 검색조건 넷째줄 시작 -->
          <div class="row">
            <div class="col-lg-6">
              <label class="form-control-label small">
                산업(Industry)
              </label>
              <div class="input-group input-group-sm redo-site" id="businessDiv">
                <div class="bg-white pl-5 pr-5 w-p100 form-inline codeBindDiv" id="busiCodeList">
                  @if (Model.search.business.Count() > 0)
                  {
                    var idx = 0;
                    foreach (var business in Model.search.business)
                    {
                      <div id='busi@(business.code2)' code2='@business.code2' class='busiRow catRow no-side-space'>
                        <span class='category'>
                          <span class='badge badge-outline badge-default bg-white cur_hand badge-lg busiCode2badge' code1='@business.code1' code2='@business.code2' code2name='@business.code_name2' onclick='DelCategoryBadge(this)'>@business.code_name2 <i class='far fa-times-circle'></i></span>
                          <input type="hidden" name="search.business[@idx].code1" value="@business.code1" />
                          <input type="hidden" name="search.business[@idx].code2" value="@business.code2" />
                          <input type="hidden" name="search.business[@idx].code_name2" value="@business.code_name2" />
                        </span>
                      </div>
                      idx++;
                    }

                  }
                </div>
                <select id="search_business_search_type" name="search.business_search_type" class="form-control w-100">
                  <option value="AND" @(Model.search.business_search_type == "AND" ? "selected" : "")>AND</option>
                  <option value="OR" @(Model.search.business_search_type == "OR" ? "selected" : "")>OR</option>
                </select>
                <div class="input-group-btn">
                  <button type="button" class="btn btn-outline-primary" onclick="FindBusiness()">
                    <i class="fas fa-search"></i>
                  </button>
                </div>
                <div class="input-group-btn">
                  <button type="button" class="btn btn-outline-primary btn-redo-code">
                    <i class="fas fa-redo" placeholder="초기화"></i>
                  </button>
                </div>
              </div>

            </div>
            <div class="col-lg-6">
              <label class="form-control-label small">
                직무(Job Functions)
              </label>
              <div class="input-group input-group-sm redo-site" id="JobDiv">
                <div class="bg-white pl-5 pr-5 w-p100 form-inline codeBindDiv" id="jobCodeList">
                  @if (Model.search.job.Count() > 0)
                  {
                    var idx = 0;
                    foreach (var job in Model.search.job)
                    {
                      <div id='job@(job.code2)' code2='@job.code2' class='jobRow catRow no-side-space'>
                        <span class='category'>
                          <span class='badge badge-outline badge-default bg-white cur_hand badge-lg jobCode2badge' code1='@job.code1' code2='@job.code2' code2name='@job.code_name2' onclick='DelCategoryBadge(this)'>@job.code_name2<i class='far fa-times-circle'></i></span>
                          <input type="hidden" name="search.job[@idx].code1" value="@job.code1" />
                          <input type="hidden" name="search.job[@idx].code2" value="@job.code2" />
                          <input type="hidden" name="search.job[@idx].code_name2" value="@job.code_name2" />
                        </span>
                      </div>
                      idx++;
                    }
                  }
                </div>
                <select id="search_job_search_type" name="search.job_search_type" class="form-control w-100">
                  <option value="AND" @(Model.search.job_search_type == "AND" ? "selected" : "")>AND</option>
                  <option value="OR" @(Model.search.job_search_type == "OR" ? "selected" : "")>OR</option>
                </select>
                <div class="input-group-btn">
                  <button type="button" class="btn btn-outline-primary" onclick="javascript:FindJob()">
                    <i class="fas fa-search"></i>
                  </button>
                </div>
                <div class="input-group-btn">
                  <button type="button" class="btn btn-outline-primary btn-redo-code">
                    <i class="fas fa-redo" placeholder="초기화"></i>
                  </button>
                </div>
              </div>
            </div>
          </div>
          <!-- 검색조건 넷째줄 끝 -->
          <!-- 검색조건 다섯째줄 시작 -->
          <div class="row">
            <div class="col-md-6 col-xl-3">
              @Html.LabelFor(x => x.search.keyword, "키워드(Keywords)", new { @class = "form-control-label small" })
              <i class="fas fa-info-circle text-info" data-html="true" data-toggle="popover" data-trigger="hover" data-content="@Html.Raw(boolean_desc)"></i>
              <!--<small class="text-primary">&nbsp;* 띄어쓰기로 구분</small>-->
              @Html.TextBoxFor(x => x.search.keyword, new { @class = "form-control form-control-sm", placeholder = "키워드" })
            </div>
            <div class="col-md-6 col-xl-3">
              @Html.LabelFor(x => x.search.language, "어학능력(Language)", new { @class = "form-control-label small" })
              <div class="input-group input-group-sm">
                <select id="search_language" name="search.language" class="form-control">
                  <option value="">[ALL]</option>
                  <option value="01" @(Model.search.language == "01" ? "selected" : "")>중국어(Chinese)</option>
                  <option value="02" @(Model.search.language == "02" ? "selected" : "")>영어(English)</option>
                  <option value="03" @(Model.search.language == "03" ? "selected" : "")>불어(French)</option>
                  <option value="04" @(Model.search.language == "04" ? "selected" : "")>독일어(German)</option>
                  <option value="05" @(Model.search.language == "05" ? "selected" : "")>일본어(Japanese)</option>
                  <option value="06" @(Model.search.language == "06" ? "selected" : "")>러시아어(Russian)</option>
                  <option value="07" @(Model.search.language == "07" ? "selected" : "")>스페인어(Spanish)</option>
                  <option value="99" @(Model.search.language == "99" ? "selected" : "")>기타(Other)</option>
                </select>
