    function GetOfflimitData() {
      ajxCall({
        url: window.url_offlimit_check_list,
        type: "POST",
        dataType: 'json',
        loading: false,
        suc: function (json) {

          //$('#btnCreateMemo').prop("disabled", false);
          //$('#btnCreateMemo').removeClass("disabled");

          if (json.ok) {
            CheckOfflimit(json.list);
          }
          else {
            ErrorAlert("Offlimit Check Error : " + json.message);
          }
        },
        err: function (jqXHR, textStatus, errorThrown) {

          ErrorAlert("Offlimit Check Failed");
        }
      });
    }

    function CheckOfflimit(list) {
      //console.log(list);
      $('.offlimit-chk-0').each(function () {
        var company = $(this).attr("data").toLowerCase().replace(/\n/gi, "");        
        if (company != "지멘스" && company != "siemens") {
          var fil = list.filter(item => item.name_all.toLowerCase().indexOf(company) >= 0 || (item.kor_name.length > 2 && company.toLowerCase().indexOf(item.kor_name) >= 0) || (item.eng_name.length > 2 && company.toLowerCase().indexOf(item.eng_name) >= 0))
          //console.log(company, fil);
          if (fil.length > 0) {
            console.log(fil[0]);
            if (fil[0].offlimit == 1) {
              $(this).append('<span class="badge badge-danger" title="' + fil[0].kor_name + ' (전 임직원 컨택 금지)">OFFLIMIT</span>');
            } else if (fil[0].offlimit == 2) {
              $(this).append('<span class="badge badge-warning" title="' + fil[0].kor_name + ' (유니코에 의해 채용된 임직원 컨택 금지)">OFFLIMIT</span>');
            } else if (fil[0].offlimit == 3) {
              $(this).append('<span class="badge badge-outline badge-warning" title="' + fil[0].kor_name + ' (계약서 내 오프리밋 조항은 없지만 고객사의 요청 등)">[계약서 미표기] OFFLIMIT</span>');
            }

          }
        }
      })

    }

    GetOfflimitData();


    function PopMemoList(c_seq, name, gender, age) {
      //Modal 템플릿이 있고, 모달창이 열려있으면 넘어감
      if ($('#CandidateMemoModal').length > 0) {
        $('#CandidateMemoModal').parent().remove();
      }

      $('body').append($('<div>').load('/Modal/CandidateMemoModal.html?v0.0.0', function () {
        $.ajax({
          url: window.url_candidate_activity_list,
          data: {
            c_seq: c_seq,
            page: 1
          },
          dataType: 'html',
          type: 'post',
          beforeSend: function () {
            showLoading();
          }
        })
          .done(function (view) {
            hideLoading();
            $("#candidate_memo_modal_title").html(name + ' ' + age + ' (' + gender + ')');
            $("#CandidateMemoModal .modal-body").html(view)
            $('#CandidateMemoModal').modal('show');

          })
          .fail(function (e) {
            hideLoading();
            ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
            $('#CandidateMemoModal').modal('hide');
          });
      }));

    }

    function openCandidateExternalLock(c_seq) {
      alertify.confirm()
        .set({
          'labels': { ok: 'OK', cancel: 'Cancel' },
          'onok': function (e) {

            if (saveElementOpenLogToServer(window.id_user_seq, c_seq, 'candidate', 'candidate', '', '')) {
              $.ajax({
                url: window.url_candidate_single_list,
                data: {
                  c_seq: c_seq
                },
                dataType: 'html',
                type: 'POST',
                beforeSend: function () {
                  showLoading('#cand_list_' + c_seq);
                },
                success: function (response) {
                  $('#cand_list_' + c_seq).html(response);
                },
                complete: function () {
                  hideLoading('#cand_list_' + c_seq);
                }
              })
            }
            else {
              return;
            }

          },
          'oncancel': function () {
            return;
          }
        })
        .setHeader('후보자 연락처 확인')
        .setting({
          message: "해당 후보자의 연락처를 확인하시겠습니까?<br />확인 시 연락처 확인 기록이 서버에 저장되며, 7일간 별도 확인 없이 조회가 가능합니다."
        })
        .show();
    }

