    <div class="panel panel-primary panel-line">
      <div class="panel-heading">
        <h3 class="panel-title">
          <div class="row">
            <div class="col-md-6 col-sm-12">
              Search Results (@start_item.ToString("N0")  ~ @end_item.ToString("N0") of @Model.PagingInfo.TotalItems.ToString("N0"))
              <span class="panel-desc">
                Page : @Model.PagingInfo.CurrentPage.ToString("N0") of @(((Model.PagingInfo.TotalItems / Model.PagingInfo.ItemsPerPage) + 1).ToString("N0"))
              </span>
            </div>
            <div class="col-md-6 col-sm-12 text-right">
              <span class="panel-desc">
                Sort by : [
                <small>
                  <a href="#" class="sort_link">
                    Reg.Date
                    <i class="fas @Utils.ReturnOrderOptionCalss(Model.search.orderTxt, "create_dt_idx", Model.search.orderOption) colSort" orderTxt="create_dt_idx"></i>
                  </a>
                  |
                  <a href="#" class="sort_link">
                    Update
                    <i class="fas @Utils.ReturnOrderOptionCalss(Model.search.orderTxt, "modify_dt_idx", Model.search.orderOption) colSort" orderTxt="modify_dt_idx"></i>
                  </a>
                  |

                  <a href="#" class="sort_link">
                    Name
                    <i class="fas @Utils.ReturnOrderOptionCalss(Model.search.orderTxt, "name_sort_idx", Model.search.orderOption) colSort" orderTxt="name_sort_idx"></i>
                  </a>
                  |

                  <a href="#" class="sort_link">
                    Yob
                    <i class="fas @Utils.ReturnOrderOptionCalss(Model.search.orderTxt, "birth_yyyy", Model.search.orderOption) colSort" orderTxt="birth_yyyy"></i>
                  </a>
                </small>]
              </span>
              <span class="panel-desc">
                <div class="input-group-append checkbox-custom checkbox-custom-sm checkbox-primary ml-1" title="테이블 형식으로 결과 보기">
                  <input type="checkbox" name="candidate_view_list" id="candidate_view_list" class="form-control-label" onclick="javascript:fSetViewList(this);" @(cookie_can_view_list == 1 ? "checked" : "") />
                  <label for="candidate_view_list">Show Table list</label>
                </div>
                <div class="input-group-append checkbox-custom checkbox-custom-sm checkbox-primary ml-1" title="항상 후보자를 새창에서 열기">
                  <input type="checkbox" name="candidate_new_win" id="candidate_new_win" class="form-control-label" onclick="javascript:fSetCandCookie('CAND_OPEN_WINDOW', this);" @(cookie_can_open_win == 1 ? "checked" : "") />
                  <label for="candidate_new_win">Always open new window</label>
                </div>
              </span>
            </div>
          </div>
        </h3>
      </div>
      <div class="panel-body">
        @if (cookie_can_view_list == 0)
        {
          <ul class="list-group">
            @if (Model.list.Count > 0)
            {
              int num = 1;
              foreach (var data in Model.list)
              {
                <li class="list-group-item py-10" id="cand_list_@data.c_seq">
                  <div class="media">
                    <div class="media-body w-full text-left">
                      <h4 class="mt-0 mb-5">
                        <a href="javascript:openCandidate('@data.c_seq')">
                          @Html.Raw(data.kor_name)
                        </a>
                        <a href="@Url.Action("CandidateDetail", "Candidate", new { c_seq = data.c_seq })" target="candidate_@data.c_seq" title="새창에서 열기">
                          <i class="fa fa-external-link-alt"></i>
                        </a>
                        <small>
                          @Utils.YearSeparate(data.birth_date)
                          @if (data.is_confidential == 1)
                          {
                            <label class="badge badge-sm badge-danger">Confidential</label>
                          }
                          @if (data.is_inactive == 1)
                          {
                            <label class="badge badge-sm badge-warning">Inactive</label>
                          }
                          @if (data.caution_type == 6)
                          {
                            <label class="badge badge-sm badge-success">유니코에 의한 채용</label>
                          }
                          <span class="text-danger">
                            @Utils.Get1ToString(data.ex_birthdate, "[추정]")
                          </span>
                          (@Utils.ReturnGenderTxt(data.gender))
                          @if (data.cur_career_month > 0)
                          {
                            <span class="text-primary">
                              [경력 :
                              @if ((data.cur_career_month / 12) > 0)
                              {
                                <text>@(data.cur_career_month / 12)Y </text>
                              }
                              @if ((data.cur_career_month % 12) > 0)
                              {
                                <text>@(data.cur_career_month % 12)M </text>
                              }]
                            </span>
                          }
                        </small>
                        @if (data.is_external_lock == 1)
                        {
                          <a class="btn btn-sm badge badge-primary" href="javascript:openCandidateExternalLock('@data.c_seq');" title="Unlock private information">
                            <i class="fas fa-unlock-alt"></i> 연락처 확인
                          </a><br />
                        }
                        <small>
                          [Reg. : @Utils.ConvertDateTimeToString(data.create_dt) / <span class="text-secondary">Update : @Utils.ConvertDateTimeToString(data.modify_dt)</span>]
                          <a class="btn btn-sm" href="javascript:PopMemoList('@data.c_seq', '@data.kor_name.Replace("'", "\\'"))', '@Utils.ReturnGenderTxt(data.gender)', ' @Utils.YearSeparate(data.birth_date) @Utils.Get1ToString(data.ex_birthdate, "[추정]")');" title="Memo List">
                            <i class="fas fa-list"></i>
                          </a><br />
                        </small>

                        @if (!string.IsNullOrWhiteSpace(data.kor_file_ext) || !string.IsNullOrWhiteSpace(data.eng_file_ext))
                        {
                          <span class="d-block d-md-none"></span>
                          if (!string.IsNullOrWhiteSpace(data.kor_file_ext))
                          {

                            if (data.is_external_lock == 1)
                            {


                              <a class="badge badge-sm badge-outline badge-dark" href="javascript:ErrorAlert('파일을 다운로드 받으려면 해당 후보자의 연락처 확인 버튼을 눌러 해제 후 진행하여 주십시오.');" title="국문이력서 - 파일을 다운로드 받으려면 해당 후보자의 연락처 확인 버튼을 눌러 해제 후 진행하여 주십시오." download>
                                <i class="fas @Utils.ReturnFileExtensionClass(data.kor_file_ext)"></i> Resume(Kor)
                              </a>

                            }
                            else
                            {

                              <a class="badge badge-sm badge-outline badge-primary" href="javascript:void(0)" onclick="DownloadFile(@data.kor_cr_seq, 'canResume')" title="국문이력서">
                                <i class="fas @Utils.ReturnFileExtensionClass(data.kor_file_ext)"></i> Resume(Kor)
                              </a>

                            }

                          }
                          if (!string.IsNullOrWhiteSpace(data.eng_file_ext))
                          {

                            if (data.is_external_lock == 1)
                            {

                              <a class="badge badge-sm badge-outline badge-dark" href="javascript:ErrorAlert('파일을 다운로드 받으려면 해당 후보자의 연락처 확인 버튼을 눌러 해제 후 진행하여 주십시오.');" title="영문이력서 - 파일을 다운로드 받으려면 해당 후보자의 연락처 확인 버튼을 눌러 해제 후 진행하여 주십시오." download>
                                <i class="fas @Utils.ReturnFileExtensionClass(data.eng_file_ext)"></i> Resume(Eng)
                              </a>

                            }
                            else
                            {
                              <a class="badge badge-sm badge-outline badge-info" href="javascript:void(0)" onclick="DownloadFile(@data.eng_cr_seq, 'canResume')" title="영문이력서">
                                <i class="fas @Utils.ReturnFileExtensionClass(data.eng_file_ext)"></i> Resume(Eng)
                              </a>

                            }
                          }
                        }
                      </h4>
                      <p>
                        <div class="row">
                          <div class="col-md-6">
                            <div class="row">
                              <div class="col-12">
                                <span class="text-secondary small" title="E-mail">- </span>
                                <!--<i class="fa fa-at fa-fw" aria-hidden="true" title="E-mail"></i>-->
                                @if (data.is_external_lock == 1)
                                {
                                  <span class="text-secondary" title="이메일주소를 확인 하시려면 해당 후보자의 연락처 확인 버튼을 눌러 해제 후 진행하여 주십시오.">
                                    @data.email1
                                  </span>
                                }
                                else
                                {
                                  @data.email1
                                }
                              </div>
                              <div class="col-12">
                                <span class="text-secondary small" title="Phone">- </span>
                                <!--<i class="fa fa-mobile-alt fa-fw" aria-hidden="true" title="Phone"></i>-->
                                @if (data.is_external_lock == 1)
                                {
                                  <span class="text-secondary" title="전화번호를 확인 하시려면 해당 후보자의 연락처 확인 버튼을 눌러 해제 후 진행하여 주십시오.">
                                    @data.cell_phone
                                    @(!String.IsNullOrEmpty(data.phone) ? " / " + @data.phone : @data.phone)
                                  </span>
                                }
                                else
                                {
                                  @data.cell_phone
                                  @(!String.IsNullOrEmpty(data.phone) ? " / " + @data.phone : @data.phone)
                                }
                              </div>
                              @{
                                string all_school = String.Empty;
                                if (!String.IsNullOrEmpty(data.all_school))
                                {
                                  all_school = data.all_school.Replace("<span class='bg-warning'>", "").Replace("</span>", "").Replace("\n", "←");
                                }
                              }
                              <div class="col-12 text-truncate" title="@all_school">
                                <span class="text-secondary small" title="School(학교)">- </span>

                                @if (!string.IsNullOrWhiteSpace(data.all_school))
                                {
                                  string[] all_school_arr = data.all_school.Split('\n');
                                  if (all_school_arr.Length > 0)
                                  {
                                    int school_cnt = 0;

                                    foreach (var school in all_school_arr)
                                    {

                                      if (!string.IsNullOrWhiteSpace(school))
                                      {
                                        if (school_cnt > 0)
                                        {
                                          <text>←</text>
                                        }
                                        <blockbox>@Html.Raw(school.Replace("\r", ""))</blockbox>



                                        school_cnt++;
                                        if (school_cnt >= 2) { break; }
                                      }

                                    }


                                  }
                                }
                                @*
                                  <!--<i class="fa fa-graduation-cap fa-fw" aria-hidden="true" title="School(학교)"></i>--> @Html.Raw(data.school_name) /
                                  @Html.Raw(!String.IsNullOrEmpty(data.major_name) ? data.major_name : "")
                                *@
                              </div>
                            </div>
                          </div>
                          <div class="col-md-6">
                            <div class="row">
                              @{
                                string all_company = String.Empty;
                                if (!String.IsNullOrEmpty(data.all_company))
                                {
                                  all_company = data.all_company.Replace("\n", " ← ");
                                }
                              }
                              <div class="col-12 text-truncate" title="@Html.Raw(all_company.Replace("<span class='bg-warning'>", "").Replace("</span>", ""))">
                                <span class="text-secondary small" title="Company(회사/경력)">- </span>
                                @if (!string.IsNullOrWhiteSpace(data.all_company))
                                {
                                  string[] all_company_arr = data.all_company.Replace("[", "").Replace("]", "").Split('\n');
                                  if (all_company_arr.Length > 0)
                                  {
                                    int company_cnt = 0;
                                    foreach (var company in all_company_arr)
                                    {
                                      if (!string.IsNullOrWhiteSpace(company))
                                      {
                                        if (company_cnt > 0)
                                        {
                                          <text>←</text>
                                        }
                                        <blockbox class="offlimit-chk-@(company_cnt)" data="@company.Replace("<span class='bg-warning'>", "").Replace("</span>", "")">@Html.Raw(company.Replace("\r", ""))</blockbox>
                                        company_cnt++;
                                        //if (company_cnt >= 3) { break; }
                                      }
                                    }
                                  }
                                }
                              </div>
                              <div class="col-12 text-truncate" title="@Html.Raw(data.busiName)">
                                <span class="text-secondary small" title="Business(산업)">- </span>
                                <!--<i class="fa fa-industry fa-fw" aria-hidden="true" title="Business(산업)"></i>-->
                                @if (!string.IsNullOrWhiteSpace(data.busiName))
                                {
                                  string[] businessList = data.busiName.Split('\n');
                                  if (businessList.Length > 0)
                                  {
                                    int busi_cnt = 0;
                                    foreach (var business in businessList)
                                    {
                                      busi_cnt++;


                                      if (business.IndexOf(":") > 1)
                                      {
                                        <jobbusibox>@Html.Raw(business.Substring(business.IndexOf(":") + 1).Replace("\r", ""))</jobbusibox>
                                        @*<label class="badge badge-outline badge-dark" style="font-size:95%;">
                                            @business.Substring(job.IndexOf(":")+1)
                                          </label>*@
                                      }

                                    }

                                  }
                                }
                              </div>
                              <div class="col-12 text-truncate" title="@Html.Raw(data.jobName)">
                                <span class="text-secondary small" title="Job(직무)">- </span>
                                <!--<i class="fa fa-share-alt fa-fw" aria-hidden="true" title="Job(직무)"></i>-->
                                @if (!string.IsNullOrWhiteSpace(data.jobName))
                                {
                                  string[] jobList = data.jobName.Split('\n');
                                  if (jobList.Length > 0)
                                  {
                                    int job_cnt = 0;
                                    foreach (var job in jobList)
                                    {
                                      job_cnt++;
                                      if (job.IndexOf(":") > 1)
                                      {
                                        <jobbusibox>@Html.Raw(job.Substring(job.IndexOf(":") + 1).Replace("\r", ""))</jobbusibox>
                                        @*<label class="badge badge-outline badge-dark" style="font-size:95%;">
                                            @job.Substring(job.IndexOf(":")+1)
                                          </label>*@
                                      }



                                    }

                                  }
                                }
                              </div>
                            </div>
                          </div>
                          @if (data.is_external_lock != 1 && (!string.IsNullOrWhiteSpace(data.sns_link1) || !string.IsNullOrWhiteSpace(data.sns_link2) || !string.IsNullOrWhiteSpace(data.sns_link3)))
                          {

                            <div class="col-12">
                              @if (!string.IsNullOrWhiteSpace(data.sns_link1))
                              {
                                var url = data.sns_link1;

                                if (string.IsNullOrWhiteSpace(url))
                                {
                                  url = "javascript:void(0);";
                                }
                                else
                                {
                                  if (!url.Contains("http://") && !url.Contains("https://"))
                                  {
                                    url = "http://" + url;
                                  }
                                }
                                <i class="fab @(Utils.ReturnFALinkClass(data.sns_link1)) fa-fw" aria-hidden="true" title="URL"></i>
                                <a href="@url" target="_blank">@data.sns_link1</a>
                              }
                              @if (!string.IsNullOrWhiteSpace(data.sns_link2))
                              {
                                var url = data.sns_link2;

                                if (string.IsNullOrWhiteSpace(url))
                                {
                                  url = "javascript:void(0);";
                                }
                                else
                                {
                                  if (!url.Contains("http://") && !url.Contains("https://"))
                                  {
                                    url = "http://" + url;
                                  }
                                }
                                <br />
                                <i class="fab @(Utils.ReturnFALinkClass(data.sns_link2)) fa-fw" aria-hidden="true" title="URL"></i>
                                <a href="@url" target="_blank">@data.sns_link2</a>
                              }
                              @if (!string.IsNullOrWhiteSpace(data.sns_link3))
                              {
                                var url = data.sns_link3;

                                if (string.IsNullOrWhiteSpace(url))
                                {
                                  url = "javascript:void(0);";
                                }
                                else
                                {
                                  if (!url.Contains("http://") && !url.Contains("https://"))
                                  {
                                    url = "http://" + url;
                                  }
                                }
                                <br />
                                <i class="fab @(Utils.ReturnFALinkClass(data.sns_link3)) fa-fw" aria-hidden="true" title="URL"></i>
                                <a href="@url" target="_blank">@data.sns_link3</a>
                              }
                            </div>

                          }
                        </div>
                      </p>
                      @{
                        if (!string.IsNullOrWhiteSpace(data.keyword))
                        {
                          string[] keywordList = data.keyword.Split(',');
                          if (keywordList.Length > 0)
                          {
                            int key_cnt = 0;
                            <p class="text-truncate">
                              <i class="fa fa-key fa-fw" aria-hidden="true" title="Keyword"></i>

                              @foreach (var keyword in keywordList)
                              {
                                key_cnt++;
                                if (!string.IsNullOrWhiteSpace(keyword))
                                {

