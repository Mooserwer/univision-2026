@model Univision.Core.Models.DTO.Response.Candidate.CandidateResumeList

<link rel="stylesheet" href="~/Libs/dropzone/css/dropzone_cus.css?v=1533562669">
<style>
  .dropify-wrapper {
    padding: 0px 15px 0px 15px;
    box-sizing: border-box;
  }
</style>
<div class="row py-0">
  <div class="col-xxl-6 py-0 user-background card mb-1">
    <div class="card-block p-5">

      <div id="mkor_file" class="dropzone h-full text-left border-primary">
        <div class="card-title">
          <i class="fa fa-folder-open fa-fw"></i>
          <span>Makeup Resume(Kor) - <small>국문메이크업 이력서만 올려주세요.</small></span>
        </div>
        <div class="row py-2">
          <div class="col">
            <div class="dz-message"><small>[Drop files here or click to upload]</small></div>
          </div>
        </div>
        <div class="file_rst row px-15 py-2" id="mkor_file_rst">
          @{
            var mkorList = Model.resumeList.Where(x => x.file_type == "M").ToList();
          }

          @if (mkorList.Count > 0)
          {
            foreach (var data in mkorList)
            {
              string is_pdf = "";
              if (data.file_extension.ToLower() == ".pdf")
              {
                is_pdf = "type-pdf";
              }
              <div class="py-0 file_div col-12" file_name="@data.file_path">
                <input type="hidden" name="cr_seq" value="@data.cr_seq">
                <input type="hidden" name="file_origin_path" value="@data.file_origin_path">
                <a href="@Url.Action("Download", "DownloadFile", new { @element_seq = data.cr_seq, @type = "canResume" })" class="file_info text-left text-truncate cur_hand badge @(data.remove_dt == null ? "badge-secondary" : "badge-danger") link-resume @is_pdf" title="@data.file_path // @Utils.ConvertDateTimeToString(data.create_dt)">
                  @if (data.remove_dt.HasValue)
                  {
                    <small>[삭제됨][@Utils.ConvertDateTimeToString(data.remove_dt)] [@data.remove_name)] : </small>
                  }
                  else
                  {
                    <i class="far fa-fw @Utils.ReturnFileExtensionClass(data.file_extension)"></i>
                  }
                  @data.file_path
                  <small>[@Utils.ConvertDateTimeToString(data.create_dt)] [@data.create_name)]</small>

                </a>
                @if (!String.IsNullOrEmpty(is_pdf))
                {
                  <a href="@Url.Action("DownloadFileToWord", "DownloadFile", new { @element_seq = data.cr_seq, @type = "canResume" })" class="ml-3 text-truncate badge badge-info cur_hand btn-file-pdf" style="width:13%;" title="Word로 변환 후 다운로드">
                    <i class="fa fa-file-pdf" aria-hidden="true"></i>
                  </a>
                }
                @if (data.remove_dt == null)
                {
                  <a href="javascript:void(0);" class="ml-3 text-truncate badge badge-danger cur_hand btn-resume-remove" style="width:13%;" onclick="RemoveCandidate(this);">
                    <i class="fa fa-trash" aria-hidden="true"></i>
                  </a>
                }
              </div>
            }
          }
          <div class="py-0 btn-more col-12 text-center"> <i class="fas fa-chevron-down" area-hidden="true"></i> More <span class="more_cnt">(@(mkorList.Count - 2))</span></div>
          <div class="py-0 btn-collapse col-12 text-center"> <i class="fas fa-chevron-up" area-hidden="true"></i> Collapse </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-xxl-6 py-0 user-background card mb-1">
    <div class="card-block p-5">

      <div id="meng_file" class="dropzone h-full text-left border-primary">
        <div class="card-title">
          <i class="fa fa-folder-open fa-fw"></i>
          <span>Makeup Resume(Eng) - <small>영문메이크업 이력서만 올려주세요.</small></span>
        </div>
        <div class="row py-2">
          <div class="col">
            <div class="dz-message"><small>[Drop files here or click to upload]</small></div>
          </div>
        </div>
        <div class="file_rst row px-15 py-2" id="meng_file_rst">
          @{
            var mengList = Model.resumeList.Where(x => x.file_type == "N").ToList();
          }

          @if (mengList.Count > 0)
          {
            foreach (var data in mengList)
            {
              string is_pdf = "";
              if (data.file_extension.ToLower() == ".pdf")
              {
                is_pdf = "type-pdf";
              }
              <div class="py-0 file_div col-12" file_name="@data.file_path">
                <input type="hidden" name="cr_seq" value="@data.cr_seq">
                <input type="hidden" name="file_origin_path" value="@data.file_origin_path">
                <a href="@Url.Action("Download", "DownloadFile", new { @element_seq = data.cr_seq, @type = "canResume" })" class="file_info text-left text-truncate cur_hand badge @(data.remove_dt == null ? "badge-secondary" : "badge-danger") link-resume @is_pdf" title="@data.file_path // @Utils.ConvertDateTimeToString(data.create_dt)">
                  @if (data.remove_dt.HasValue)
                  {
                    <small>[삭제됨][@Utils.ConvertDateTimeToString(data.remove_dt)] [@data.remove_name)] : </small>
                  }
                  else
                  {
                    <i class="far fa-fw @Utils.ReturnFileExtensionClass(data.file_extension)"></i>
                  }
                  @data.file_path
                  <small>[@Utils.ConvertDateTimeToString(data.create_dt)] [@data.create_name)]</small>

                </a>
                @if (!String.IsNullOrEmpty(is_pdf))
                {
                  <a href="@Url.Action("DownloadFileToWord", "DownloadFile", new { @element_seq = data.cr_seq, @type = "canResume" })" class="ml-3 text-truncate badge badge-info cur_hand btn-file-pdf" style="width:13%;" title="Word로 변환 후 다운로드">
                    <i class="fa fa-file-pdf" aria-hidden="true"></i>
                  </a>
                }
                @if (data.remove_dt == null)
                {
                  <a href="javascript:void(0);" class="ml-3 text-truncate badge badge-danger cur_hand btn-resume-remove" style="width:10%;" onclick="RemoveCandidate(this);">
                    <i class="fa fa-trash" aria-hidden="true"></i>
                  </a>
                }
              </div>
            }
          }
          <div class="py-0 btn-more col-12 text-center"> <i class="fas fa-chevron-down" area-hidden="true"></i> More <span class="more_cnt">(@(mengList.Count - 2))</span></div>
          <div class="py-0 btn-collapse col-12 text-center"> <i class="fas fa-chevron-up" area-hidden="true"></i> Collapse </div>
        </div>
      </div>
    </div>
  </div>
</div>
