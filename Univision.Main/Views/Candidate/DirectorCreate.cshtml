    //학교구분 변경 시,
    function ChangeSchoolGubun(obj) {
      var school_row = $(obj).closest(".schoolRow");
      var school_gubun = $(obj).val();
      var className;
      switch (school_gubun) {
        case "1":
          className = "high_list";
          break;
        case "2":
        case "3":
        case "4":
        case "5":
        case "6":
        case "9":
          className = "univ_list";
          break;
        default:
          className = "no-school-selected";
          break;
      }
      if (school_row) {
        school_row.removeClass('no-school-selected').removeClass('high_list').removeClass('univ_list').addClass(className);
        school_row.find(".univ_resize").each(function () {
          $(this).removeClass("col-md-4").removeClass("col-md-2");
          if (className == "high_list") {
            $(this).addClass("col-md-2");
          } else {
            $(this).addClass("col-md-4");
          }
        });
      }
      //console.log($(obj).closest(".schoolRow").find("input[name='schoolName']").attr("id"));
      validator.element('#' + $(obj).closest(".schoolRow").find("input[name='schoolName']").attr("id"));
    }


