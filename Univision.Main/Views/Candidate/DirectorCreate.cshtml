@section scripts{


  <script src="~/Scripts/moment.js"></script>
  <script src="~/Libs/remark/global/vendor/bootstrap-tokenfield/bootstrap-tokenfield.min.js"></script>

  <script src="~/Libs/dropzone/js/dropzone.min.js?v=1533562669"></script>
  <script type="text/javascript">
    window.find_keyword_partial = "@Url.Action("FindKeyword", "Partial")";
    window.job_sugg_partial = "@Url.Action("JobBusiSugg", "Partial")";
    window.create_temp_picture = "@Url.Action("CreateDirectorPictureFile", "Candidate")";
    window.uploadFolder_temp = "@ViewBag.uploadFolder";
    window.national_code_search = "@Url.Action("NationalcodeSearch", "Client")";
    window.find_school_api = "@Url.Action("FindSchoolApi", "Partial")";
    window.find_major_api = "@Url.Action("FindMajorApi", "Partial")";
    window.find_company_api = "@Url.Action("FindCompanyApi", "Partial")";
    window.business_multi_api = "@Url.Action("BusinessMultiApi", "Partial")";
    window.job_multi_api = "@Url.Action("JobMultiApi", "Partial")";
    window.phone_dup_check = "@Url.Action("PhoneDuplicateCheck", "Candidate")";
    window.email_dup_check = "@Url.Action("EmailDuplicateCheck", "Candidate")";
    window.is_pop = "@ViewBag.is_pop";
  </script>
  <script type="text/javascript">
    function getJobBusiSugg(new_val) {
      var keywords = $('#keyword').val()
      if (new_val) {
        keywords += (keywords != "" ? ", " : "") + new_val;
      }
      var data_job_busi = {
        curr_job: getJobData(),
        curr_busi: getBusiData(),
        keywords: keywords.split(", ")
      }
      var url = window.job_sugg_partial;
      $.ajax({
        type: 'POST',
        url: url,
        data: data_job_busi,
        success: function (data) {
          $('.job_busi_sugg').html('');
          $('.job_busi_sugg').html(data);
        }
      });
    }

    $('#keyword').tokenfield({
      autocomplete: {
        source: function (request, response) {
          var data_source = {
            q: request.term,
            old: $('#keyword').val(),
            job: getJobData(),
            busi: getBusiData()
          }
          var url = window.find_keyword_partial;
          $.ajax({
            type: 'POST',
            url: url,
            data: data_source,
            success: function (data) {
              var old = $('#keyword').val().split(', ');
              response(
                $.map(data.list, function (item) {
                  if (!old.includes(item.name)) {
                    var value = "";
                    value = item.name;
                    return {
                      value: value,
                    }
                  }
                })
              );
              $(".ui-autocomplete").highlight(request.term);
            }
          })
        },
        delay: 500,
        minLength: 1,  //조회를 위한 최소글자수
        search: function (event, ui) {
          var is_select = $(this).attr('is_select');
          is_select = (typeof is_select === "undefined") ? 0 : is_select;
          if (is_select == 1) {
            return false;
          }
        },
        select: function (event, ui) {
          return false;
        },
        focus: function (event, ui) {
          $(this).attr('is_select', 1);
          setTimeout(function (obj) {
            $(obj).attr('is_select', 0);
          }, 1000, this);
        },
      },
      showAutocompleteOnFocus: true
    });

    $('#keyword').on('tokenfield:createtoken', function (event) {
      var existingTokens = $(this).tokenfield('getTokens');
      $.each(existingTokens, function (index, token) {
        if (token.value === event.attrs.value)
          event.preventDefault();
      });
    });

    $('#keyword').on('tokenfield:createdtoken', function (event) {
      getJobBusiSugg(event.attrs.value);
    }).on('tokenfield:editedtoken', function (event) {
      getJobBusiSugg();
    }).on('tokenfield:removedtoken', function (event) {
      getJobBusiSugg();
    })

    $("#keyword-tokenfield").blur(function () {
      $(this).val("");
    })

    function getJobData() {
      var data = [];
      $(".jobRow").each(function () {
        $(this).find(".badge").each(function () {
          //카테고리 직무에 하위 직무가 더 있다면
          if ($(this).closest(".jobRow").find(".badge").length > 1) {
            if ($(this).hasClass("jobCode1badge")) {
              return;
            }
          }
          data.push($(this).attr("code2"));
        });
      });
      return data;
    }

    function getBusiData() {
      var data = [];
      //산업
      $(".busiRow").each(function () {
        $(this).find(".badge").each(function () {
          //카테고리 산업에 하위 산업이 더 있다면
          if ($(this).closest(".busiRow").find(".badge").length > 1) {
            if ($(this).hasClass("busiCode1badge")) {
              return;
            }
          }
          data.push($(this).attr("code2"));
        });
      });

      return data;
    }

    StopEnterSubmit();

    var school_row_cnt = $(".schoolRow").length; //학력 row 갯수 초기화
    var company_row_cnt = $(".companyRow").length; //경력 row 갯수 초기화
    //console.log(company_row_cnt)
    //학력 드래그앤 드롭
    $("#schoolBody").sortable({
      group: 'candidate_edu',
      handle: '.drag_handle',
      onDragStart: function ($item, container, _super) {
        // Duplicate items of the no drop area
        if (!container.options.drop)
          $item.clone().insertAfter($item);
        _super($item, container);
      }
    });

    //경력 드래그앤 드롭
    $("#companyBody").sortable({
      group: 'candidate_exp',
      handle: '.drag_handle',
      onDragStart: function ($item, container, _super) {
        // Duplicate items of the no drop area
        if (!container.options.drop)
          $item.clone().insertAfter($item);
        _super($item, container);
      }
    });

    //파일 업로드 부분 ===============================================================================================
    //파일업로드 컴포넌트 초기화

    var mAvatarDropzone = new Dropzone("div#pic_path", {
      url: window.create_temp_picture,
      method: "post",
      params: {
        "uploadFolder": window.uploadFolder_temp

      },
      maxFilesize: 1,
      acceptedFiles: ".jpeg,.jpg,.png,.gif"
    });


    //국문 이력서 업로드 시 중복확인 및 추출 내용 반영
    mAvatarDropzone.on("success", function (file, response) {
      if (response.ok) {
        this.removeFile(file);
        $('#director_image').attr("src", "/"+response.img_path);
        $('#picture_path').val("/" +response.img_path);
        $('#btn_reset_img').css("display", "");
        this.removeFile(file);
      } else {
        ErrorAlert("[ERROR]" + response.message);
      }
    });

    $('#btn_reset_img').click(function (event) {
      event.preventDefault();
      alertify
        .confirm()
        .set({
          'labels': { ok: 'OK', cancel: 'Cancel' },
          'onok': function () {
            $('#director_image').attr("src", "");
            $('#picture_path').val("");
            $('#btn_reset_img').css("display", "none");
          },
          'oncancel': function () {
