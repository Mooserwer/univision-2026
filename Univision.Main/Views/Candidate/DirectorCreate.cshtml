    //경력 년/월 수 계산
    function CalculationExperience(event, obj) {
      var rtn_val;
      if (obj) {
        rtn_val = MonthFormat(event, obj);
      }
      var rst_years = 0
      var rst_month = 0
      $(".companyRow").each(function () {
        var from_date_str = $(this).find("[id^=join_dt_]").val();
        var to_date_str = $(this).find("[id^=leave_dt_]").val();
        if (from_date_str && from_date_str != "") {
          var from_date = moment(from_date_str + "-01")
          if (to_date_str && to_date_str != "") {
            var to_date = moment(to_date_str + "-01").add(1, 'M').add(-1, 'days');
          }
          else if ($(this).find("[id^=is_work_]:checked").length > 0) {
            var to_date = moment();
          }

          if (from_date && to_date) {
            var diff_exp = moment.duration(to_date.diff(from_date));
            rst_years += diff_exp.years();
            rst_month += diff_exp.months() + 1;
          }

        }
      });

      var rtn_str = "Total : ";
      if (rst_years == 1) {
        rtn_str += rst_years + " Year "
      } else if (rst_years > 1) {
        rtn_str += rst_years + " Years "
      }
      if (rst_month <= 1) {
        rtn_str += rst_month + " Month "
      } else if (rst_month > 1) {
        rtn_str += rst_month + " Months "
      }

      $("#total_experience").text("[" + rtn_str + "]");
      return rtn_val;
    }

