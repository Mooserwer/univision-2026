    //학교검색 input에 Autocomplete 바인딩
    function BindSchoolAutocomplete($obj) {
      $obj.autocomplete({
        source: function (request, response) {
          $.ajax({
            type: 'post',
            url: window.find_school_api,
            dataType: "json",
            //request.term = $("#autocomplete").val()
            data: findSchoolSetDate($obj, request),
            success: function (data) {
              //서버에서 json 데이터 response 후 목록에 뿌려주기 위함
              response(
                $.map(data.list, function (item) {
                  //console.log(item);
                  var label = "";
                  var value = "";

                  if (item.campusName != null && item.campusName != "null") {
                    label = item.schoolName + '(' + item.campusName + ')';
                    value = item.schoolName + '(' + item.campusName + ')';
                  }
                  else {
                    label = item.schoolName;
                    value = item.schoolName;
                  }

                  return {
                    label: label,
                    value: value,
                    campusName: item.campusName
                  }
                })
              );
              $(".ui-autocomplete").highlight(request.term);
            }
          });
        },
        delay: 300,
        autoFocus: false, //첫번째 값을 자동 focus한다
        minLength: 2,  //조회를 위한 최소글자수
        search: function (event, ui) {
          var is_select = $(this).attr('is_select');
          is_select = (typeof is_select === "undefined") ? 0 : is_select;
          //console.log(is_select);
          if (is_select == 1) {
            return false;
          }
        },
        select: function (event, ui) {

          //console.log($(event.target).closest(".schoolRow").find("[id^=campusName_]"));
          $(event.target).closest(".schoolRow").find("[id^=campusName_]").val(ui.item.campusName);
          // 만약 검색리스트에서 선택하였을때 선택한 데이터에 의한 이벤트발생
          $(event.target).closest("div").next().find("input").focus();
        },
        focus: function (event, ui) {
          //console.log("xx", $(this).attr('is_select'))
          $(this).attr('is_select', 1);
          setTimeout(function (obj) {
            $(obj).attr('is_select', 0);
            //console.log("reset");
          }, 500, this);

          event.preventDefault();
        }
      });
    }

