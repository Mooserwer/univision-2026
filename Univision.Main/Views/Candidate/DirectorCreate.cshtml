@model Univision.Main.Models.Candidate.DirectorCreateModel

@{
  //ViewBag.Title = "후보자 등록 및 수정";
  ViewBag.use_validation = true;
  Layout = "~/Views/Shared/_Layout.cshtml";
  //    if (ViewBag.is_pop == true)
  //    {
  //        Layout = "~/Views/Shared/_Layout_for_validation_NoMenu.cshtml";
  //    }
}

<link rel="stylesheet" href="~/Libs/remark/global/vendor/bootstrap-tokenfield/bootstrap-tokenfield.min599c.css?v4.0.4">
<link rel="stylesheet" href="~/Libs/dropzone/css/dropzone_cus.css?v=1533562669">

<style>
  .dz-clickable {
    cursor: pointer;
  }

  .popover {
    max-width: 500px !important;
  }

  .job_list {
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    width: 250px;
    display: inline-block;
  }

  .placeDiv span {
    font-size: 15px;
  }

  .category::after {
    content: " > "
  }

  .catRow {
    margin-top: 3px;
  }

  #normalInfo .form-group {
    margin-bottom: 3px !important;
  }

  #normalInfo .form-control-label {
    margin-bottom: 0px !important;
    padding-bottom: 0px !important;
  }

  .card {
    margin-right: 10px;
  }

  .no-top-line {
    border-top: 0px !important;
  }

  .schoolRow .form-group {
    margin-bottom: 10px !important;
  }

  /*#companyBody .panel {
        border: 1px solid black;
        border-radius: 5px;
        padding: 10px;
    }*/
  .dropify-wrapper {
    padding: 0px 15px 0px 15px;
    box-sizing: border-box;
  }

  .extend-box {
    position: absolute !important;
    top: 1.9em;
    right: 1em;
  }



  .no-company-selected .shared-field, .no-company-selected .c-level-field, .no-company-selected .od-field,
  .c-level-list .od-field, .career-list .c-level-field, .career-list .od-field {
    display: none !important;
  }

  .no-school-selected .shared-field, .no-school-selected .highschool-field, .no-school-selected .univ-field,
  .high_list .univ-field, .univ_list .highschool-field {
    display: none !important;
  }

  .tokenfield {
    min-height: 2.288rem !important;
  }
  /*
    .high_list .shared-field, .high_list .highschool-field {
        display:"" !important;
    }
    .univ_list .shared-field, univ_list .univ-field {
        display:"" !important;
    }
    */

  .more_educomp_info, .btn_educomp_collapse, .educomp_more .btn_educomp_more {
    display: none;
  }

  .educomp_more .btn_educomp_collapse {
    display: inline;
  }

  .educomp_more .more_educomp_info {
    display: flex;
  }

  .mainPanel {
    padding-left: 5px !important;
    padding-right: 5px !important;
  }
</style>

<div class="page-content">

  <div class="panel" id="candidatePanel">
    <div class="panel-body mainPanel pb-10">
      @using (Html.BeginForm("DirectorCreate", "Candidate", FormMethod.Post, new { @id = "CreateForm", @autocomplete = "off" }))
      {
        @Html.HiddenFor(x => x.d_seq)
        @Html.HiddenFor(x => x.c_seq)
        @Html.Hidden("uploadFolder")
        <div class="panel panel-primary panel-line animation-scale-up" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms;">
          <div class="panel-heading">
            <h3 class="panel-title py-10">
              <i class="fas fa-address-card"></i>
              Personal Information
            </h3>
            <div class="panel-actions">
              <a class="panel-action icon wb-minus" aria-expanded="true" data-toggle="panel-collapse" aria-hidden="true"></a>
            </div>
          </div>
          <div id="normalInfo" class="panel-body pb-10">
            <div class="row">

              <div class="col-md-2 text-center">
                <div id="pic_path" class="dropzone h-full text-center">
                  <div class="dz-message"><small>[사진 등록]</small></div>
                  <a href="#" id="btn_reset_img" class="btn btn-sm btn-danger" @(String.IsNullOrWhiteSpace(Model.picture_path) ? "style=display:none;" : "")>사진 삭제</a>
                  <img id="director_image" src="@Model.picture_path" style="max-width:80%;" />
                  @Html.HiddenFor(x => x.picture_path)
                </div>
              </div>
              <div class="col-md-10">
                <div class="row">
                  <div class="col-12 col-md-6 col-lg-3 form-group">
                    @Html.LabelFor(x => x.kor_name, " Name(Kor)", new { @class = "form-control-label" })
                    <span class="label-reqired">*</span>
                    <div class="input-group input-group-sm">
                      @Html.TextBoxFor(x => x.kor_name, new { @class = "form-control", @autocomplete = "off", @required = "true" })
                      <div class="input-group-append pl-3">
                        <div class="checkbox-custom checkbox-custom-sm checkbox-primary mb-0" title="외국인 여부">
                          <input type="checkbox" id="is_foreign" name="is_foreign" value="1" @(Model.is_foreign == 1 ? "checked" : "") />
                          <label for="is_foreign">Foreign</label>
                        </div>
                      </div>
                    </div>
                  </div>
                  @*
                    <div class="col-12 col-md-6 col-lg-2 form-group">
                      @Html.LabelFor(x => x.eng_name, " Name(Eng)", new { @class = "form-control-label" })

                      @Html.TextBoxFor(x => x.eng_name, new { @class = "form-control form-control-sm" })

                    </div>
                  *@
                  <div class="col-12 col-md-6 col-lg-3 form-group">
                    @Html.LabelFor(x => x.birth_date, " Dob", new { @class = "form-control-label" })
                    <span class="label-reqired">*</span>
                    <div class="input-group input-group-sm">
                      @Html.TextBoxFor(x => x.birth_date, Utils.ConvertDateTimeToString(Model.birth_date), new { @class = "form-control", @onkeyup = "return DateFormat(event, this)", @onkeypress = "return DateFormat(event, this)", @placeholder = "YYYY-MM-DD", @required = "true" })
                      <div class="input-group-append pl-3">
                        @{
                          string boolean_desc = "<h5>생년 불확실 여부</h5><b>후보자의 생년이 불확실할 경우 체크합니다.<br/></b><b class='red-600'>※월일이 불확실한 경우 체크 하지 않습니다.<br>(ex 1985년생후보자 생년을 모르는 경우 : <b>1985-01-01</b> 입력) .<br/><b>";
                        }
                        <div class="checkbox-custom checkbox-custom-sm checkbox-primary mb-0" data-html="true" data-toggle="popover" data-trigger="hover" data-content="@Html.Raw(boolean_desc)">
                          <input type="checkbox" id="ex_birthdate" name="ex_birthdate" value="1" @(Model.ex_birthdate == 1 ? "checked" : "") />
                          <label for="ex_birthdate">Uncertain</label>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="col-12 col-md-6 col-lg-4 form-group">
                    @Html.LabelFor(x => x.gender, " Gender", new { @class = "form-control-label" })
                    <span class="label-reqired">*</span>
                    <div class="form-inline">
                      <div class="radio-custom radio-custom-sm radio-primary pr-3" style="margin-left:5px;" title="남">
                        @Html.RadioButtonFor(x => x.gender, 1, new { @id = "gender_male", @class = "form-control-label", @required = "true" })
                        <label for="gender_male" class="font-small">Male</label>
                      </div>
                      <div class="radio-custom radio-custom-sm radio-primary pr-3" title="여">
                        @Html.RadioButtonFor(x => x.gender, 2, new { @id = "gender_female", @class = "form-control-label", @required = "true" })
                        <label for="gender_female" class="font-small">Female</label>
                      </div>
                      <div class="radio-custom radio-custom-sm radio-primary" title="성별 모름">
                        @Html.RadioButtonFor(x => x.gender, 0, new { @id = "gender_unknown", @class = "form-control-label", @required = "true" })
                        <label for="gender_unknown" class="font-small">Unknown</label>
                      </div>
                    </div>
                  </div>
                  <div class="col-12 col-md-2 form-group">
                    @Html.LabelFor(x => x.country_name, " Nationality", new { @class = "form-control-label" })
                    <div class="input-group input-group-sm">
                      @Html.HiddenFor(x => x.country_code, new { @class = "form-control" })
                      @Html.TextBoxFor(x => x.country_name, new { @class = "form-control form-control-sm", @readonly = "readonly", @placeholder = "후보자 국적" })
                      <span class="input-group-btn">
                        <button type="button" class="btn btn-primary" id="btnNationalitySearch"><i class="icon wb-search" aria-hidden="true"></i></button>
                      </span>
                    </div>

                  </div>
                </div>
                @*
                  <div class="row">

                    <div class="col-md-10 col-12 form-group">
                      @Html.LabelFor(x => x.addr1, " Address", new { @class = "form-control-label" })
                      <div class="input-group input-group-sm">
                        @Html.TextBoxFor(x => x.addr1, new { @class = "form-control" })
                        <div class="input-group-append pl-3">
                          <div class="checkbox-custom checkbox-custom-sm checkbox-primary mb-0" title="해외 거주 여부">
                            <input type="checkbox" id="ex_addr" name="ex_addr" value="1" @(Model.ex_addr == 1 ? "checked" : "") />
                            <label for="ex_addr">Overseas residence</label>
                          </div>
                        </div>
                      </div>

                    </div>
                  </div>
                *@

                <div class="row">
                  <div class="col-12 form-group">
                    @Html.LabelFor(x => x.reg_type, "Source (후보자 출처)", new { @class = "form-control-label" })<span class="label-reqired">*</span>
                    <div class="form-inline">
                      <div class="radio-custom radio-custom-sm radio-primary pt-2">
                        @Html.RadioButtonFor(x => x.reg_type, 1, new { @id = "reg_type_1", @class = "form-control-label", @required = "true" })
                        <label for="reg_type_1" class="pr-10">Applicant<span>(직접지원)</span></label>
                      </div>
                      <div class="radio-custom radio-custom-sm radio-primary pt-2">
                        @Html.RadioButtonFor(x => x.reg_type, 2, new { @id = "reg_type_2", @class = "form-control-label", @required = "true" })
                        <label for="reg_type_8" class="pr-10">IR data<small>(기업 공시자료)</small></label>
                      </div>
                      <div class="radio-custom radio-custom-sm radio-primary pt-2">
                        @Html.RadioButtonFor(x => x.reg_type, 3, new { @id = "reg_type_3", @class = "form-control-label", @required = "true" })
                        <label for="reg_type_2" class="pr-10">Market research <span>(임원동향조사)</span></label>
                      </div>
                      <div class="radio-custom radio-custom-sm radio-primary pt-2">
                        @Html.RadioButtonFor(x => x.reg_type, 4, new { @id = "reg_type_4", @class = "form-control-label", @required = "true" })
                        <label for="reg_type_3" class="pr-10">Referral <span>(소개)</span></label>
                      </div>
                      <div class="radio-custom radio-custom-sm radio-primary pt-2">
                        @Html.RadioButtonFor(x => x.reg_type, 9, new { @id = "reg_type_9", @class = "form-control-label", @required = "true" })
                        <label for="reg_type_4" class="pr-10">ETC</label>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="row">
                  <div class="col-12 col-md-6 form-group">
                    @Html.LabelFor(x => x.cell_phone, "Phone", new { @class = "form-control-label" })
                    <div class="input-group input-group-sm">
                      @Html.TextBoxFor(x => x.cell_phone, new { @class = "form-control phone-group", @placeholder = "010-0000-0000" })
                      @Html.TextBoxFor(x => x.phone, new { @class = "form-control phone-group", @valid_error_target = "#cell_phone", @placeholder = "010-0000-0000" })
                    </div>
                  </div>
                  <div class="col-12 col-md-6 form-group">
                    @Html.LabelFor(x => x.email1, " E-mail", new { @class = "form-control-label" })
                    <div class="input-group input-group-sm">
                      @Html.TextBoxFor(x => x.email1, new { @class = "form-control form-control-sm w-md-p50 w-sm-full", @placeholder = "email@email.com" })

                      @Html.TextBoxFor(x => x.email2, new { @class = "form-control form-control-sm w-md-p50 w-sm-full", @placeholder = "email2@email2.com" })
                    </div>
                  </div>

                </div>
              </div>
            </div>
            <div class="row">
              <div class="col-12 form-group">
                <label class="form-control-label pb-10">
                  Industry<span class="label-reqired">*</span>
                  <a href="javascript:void(0)" class="btn btn-xs btn-outline-primary" onclick="FindBusiness()">
                    <i class="fa fa-search"></i> Find Industry
                  </a>
                </label>
                <input type="text" id="busiCodeList_hid" name="busiCodeList_hid" valid-highlight="#busiCodeList" style="width:1px;height:1px;border:0;" />
                <div id="busiCodeList" class="form-control" style="min-height:2.288rem;height:auto;">
                  @if (Model.busiList.Count > 0)
                  {
                    double beforeBusi = 0;

                    foreach (var busi in Model.busiList)
                    {
                      //첫행이 아니면서 code2가 이전 값과 다르다면 이전 div행 닫아줌.
                      if (beforeBusi != 0 && beforeBusi != busi.code1)
                      {
                        @Html.Raw("</div>")
                      }

                      if (busi.code1 != beforeBusi)
                      {
                        @Html.Raw("<div id='busi" + busi.code1 + "' code1='" + busi.code1 + "' class='busiRow catRow'>")
                      }

                      //code3이 0이라는 것은 2만 있는 category를 의미.
                      if (busi.code1 != beforeBusi)
                      {
                        <span class="category">
                          <span class="badge badge-outline badge-default bg-white cur_hand badge-lg busiCode1badge" code1="@busi.code1" name1="@busi.code_name1" onclick="DelCategoryBadge('busi', this)">
                            @busi.code_name1
                            <i class="far fa-times-circle"></i>
                          </span>
                        </span>
                      }

                      <span class="badge badge-outline badge-default bg-white badge-lg cur_hand busiCode2badge" code1="@busi.code1" name1="@busi.code_name1" code2="@busi.code2" id="@busi.code2" busicode2name="@busi.code_name2" onclick="DelBadge('busi', this)">
                        @busi.code_name2
                        <i class="far fa-times-circle"></i>
                      </span>


                      if (busi.code1 != beforeBusi)
                      {
                        beforeBusi = busi.code1;
                      }
                    }
                    if (beforeBusi != 0)
                    {
                      @Html.Raw("</div>")
                    }
                  }
                </div>

              </div>
            </div>
            <div class="row">
              <div class="col-12 form-group">
                <label class="form-control-label pb-10">
                  Job functions<span class="label-reqired">*</span>
                  <a href="javascript:void(0)" class="btn btn-xs btn-outline-primary" onclick="FindJobCode()">
                    <i class="fa fa-search"></i> Find Job functions
                  </a>
                </label>
                <input type="hidden" id="jobCodeList_hid" name="jobCodeList_hid" valid-highlight="#jobCodeList" style="width:1px;height:1px;border:0;" />
                <div id="jobCodeList" class="form-control" style="min-height:2.288rem;height:auto;">
                  @if (Model.jobList.Count > 0)
                  {
                    double beforeJob = 0;

                    foreach (var job in Model.jobList)
                    {
                      //첫행이 아니면서 code2가 이전 값과 다르다면 이전 div행 닫아줌.
                      if (beforeJob != 0 && beforeJob != job.code1)
                      {
                        @Html.Raw("</div>")
                      }
                      if (job.code1 != beforeJob)
                      {
                        @Html.Raw("<div id='job" + job.code1 + "' code1='" + job.code1 + "' class='jobRow catRow'>")
                      }

                      //code3이 0이라는 것은 2만 있는 category를 의미.
                      if (job.code1 != beforeJob)
                      {
                        <span class="category">
                          <span class="badge badge-outline badge-default bg-white cur_hand badge-lg jobCode1badge" code1="@job.code1" name1="@job.code_name1" onclick="DelCategoryBadge('job', this)">
                            @job.code_name1
                            <i class="far fa-times-circle"></i>
                          </span>
                        </span>
                      }


                      <span class="badge badge-outline badge-default bg-white badge-lg cur_hand jobCode2badge" code1="@job.code1" name1="@job.code_name1" code2="@job.code2" id="@job.code2" jobcode2name="@job.code_name2" onclick="DelBadge('job', this)">
                        @job.code_name2
                        <i class="far fa-times-circle"></i>
                      </span>


                      if (job.code2 != beforeJob)
                      {
                        beforeJob = job.code1;
                      }
                    }
                    if (beforeJob != 0)
                    {
                      @Html.Raw("</div>")
                    }
                  }
                </div>


              </div>
            </div>
            <div class="row">
              <div class="col-12 form-group">
                @Html.LabelFor(x => x.keyword, "Keyword", new { @class = "form-control-label" })<small class="text-primary">&nbsp;* 쉼표(,) 로 구분</small><span class="label-reqired">*</span>
                @{
                  var keywordVal = "";
                  //if (Model.keywordList.Count > 0)
                  //{
                  //    keywordVal = String.Join(",", Model.keywordList.Select(x => x.pk_name).ToArray());
                  //}
                }
                @Html.TextBoxFor(x => x.keyword, new { @class = "form-control form-control-sm", @data_plugin = "tokenfieldX", @placeholder = "Keyword" })

                <div class="job_busi_sugg"></div>
              </div>


            </div>
          </div>
        </div>
        <!-- 경력 Row 시작-->
        <div class="panel panel-primary panel-line animation-scale-up" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms;">
          <div class="panel-heading">
            <h3 class="panel-title">
              <i class="fas fa-building"></i>
              Experiences <small id="total_experience" class="text-dark">(Total : 0 Years 0 Months)</small> <span class="red-600 font-size-12">드레그 하여 순서 이동<small>(최종경력이 제일 위로..)</small></span>
            </h3>
            <div class="panel-actions">
              <a class="panel-action icon wb-minus" aria-expanded="true" data-toggle="panel-collapse" aria-hidden="true"></a>
            </div>
          </div>
          <div class="panel-body px-5 pb-5">
            @if (Model.d_seq > 0)
            {
              <div class="row">
                <div class="col-12 h4">
                  <button type="button" class="btn bg-transparent text-primary w-full" onclick="AddCompanyRow(this)">
                    <i class="fas fa-plus-circle"></i> Add company
                  </button>
                </div>
              </div>
            }
            <div id="companyBody">
              @if (Model.companyList.Count > 0)
              {
                var i = 0;
                string className = String.Empty;
                foreach (var comp in Model.companyList)
                {
                  if (comp.pos_type == 0 && comp.dc_seq == 0)
                  {
                    className = "no-company-selected";
                  }
                  else if (comp.pos_type == 1)
                  {
                    className = "c-level-list";                    
                  }
                  else if (comp.pos_type == 2)
                  {
                    className = "od-list";
                  }
                  else
                  {
                    className = "career-list";
                  }

                  <div id="company_row_@(i)" class="panel border border-primary companyRow mb-5 pb-5 @(className)">
                    <div class="panel-body pt-10 pb-5 input-company-gubun">
                      <div class="drag_handle position-absolute" style="top:5px;left:10px;cursor:cell;"><i class="fa fa-arrows-alt-v" aria-hidden="true"></i></div>
                      <a class="panel-action fas fa-times position-absolute" style="top:5px;right:10px;" aria-hidden="true" href="javascript:void(0);" onclick="DeleteRow(this)"></a>
                      <div class="row">
                        <div class="form-group col-2 col-md-3 col-lg-2">
                          <select id="pos_type_@(i)" name="pos_type" class="form-control form-control-sm" onchange="ChangeCompanyGubun(this);">
                            <option value="">[SELECT]</option>
                            <option value="1" @(comp.pos_type == 1 ? "selected" : "")>사내임원</option>
                            <option value="2" @(comp.pos_type == 2 ? "selected" : "")>사외이사</option>
                            <option value="3" @(comp.pos_type == 3 ? "selected" : "")>일반임원</option>
                            <option value="3" @(comp.pos_type == 3 ? "selected" : "")>일반경력</option>
                          </select>
                        </div>
                        <div class="form-group col-3 col-md-2 col-lg-2 od-field">
                          <select id="outdirector_type_@(i)" name="outdirector_type" class="form-control form-control-sm">
                            <option value="0">[SELECT]</option>
                            <option value="1" @(comp.outdirector_type == 1 ? "selected" : "")>기업</option>
                            <option value="2" @(comp.outdirector_type == 2 ? "selected" : "")>행정</option>
                            <option value="3" @(comp.outdirector_type == 3 ? "selected" : "")>정치</option>
                            <option value="4" @(comp.outdirector_type == 4 ? "selected" : "")>학계</option>
                            <option value="5" @(comp.outdirector_type == 5 ? "selected" : "")>법조</option>
                            <option value="6" @(comp.outdirector_type == 6 ? "selected" : "")>언론</option>
                            <option value="7" @(comp.outdirector_type == 7 ? "selected" : "")>전문직</option>
                            <option value="8" @(comp.outdirector_type == 8 ? "selected" : "")>군인</option>
                            <option value="9" @(comp.outdirector_type == 9 ? "selected" : "")>기타</option>
                          </select>
                        </div>
                        <div class="form-group col-4 col-md-3 col-lg-3 c-level-field">
                          <input type="text" id="group_name_@(i)" name="group_name" value="@comp.group_name" class="form-control form-control-sm" placeholder="그룹명">
                        </div>
                        <div class="form-group col-2 col-md-2 col-lg-2 shared-field">
                          <div class="form-group form-inline">
                            <div class="radio-custom radio-custom-sm radio-primary pr-3">
                              <input type="radio" name="is_top" id="is_top_@(i)" class="form-control-label small" value="1" @(comp.is_top == 1 ? "checked" : "") />
                              <label for="is_top_@(i)">대표 경력으로 설정</label>
                            </div>
                          </div>
                        </div>
                        <div class="form-group col-2 col-md-2 col-lg-1 shared-field">
                          <div class="form-group form-inline">
                            <div class="checkbox-custom checkbox-custom-sm checkbox-primary pr-3">
                              <input type="checkbox" name="is_display" id="is_display_@(i)" class="form-control-label small" value="1" @(comp.is_display == 1 ? "checked" : "")/>
                              <label for="is_display_@(i)">주요경력</label>
                            </div>
                          </div>
                        </div>
                      </div>
                      <div class="row shared-field">
                        <div class="form-group col-md-4">
                          <input type="hidden" id="g_seq_@(i)" name="g_seq" value="@comp.g_seq">
