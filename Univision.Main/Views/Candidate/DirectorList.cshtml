    //회사 찾기
    function BindCompanyAutocomplete($obj) {
      $obj.autocomplete({
        source: function (request, response) {
          $.ajax({
            type: 'post',
            url: '@Url.Action("FindCompanyApi", "Partial")',
            dataType: "json",
            //request.term = $("#autocomplete").val()
            data: {
              companyName: request.term
            },
            success: function (data) {
              //console.log(data)
              //서버에서 json 데이터 response 후 목록에 뿌려주기 위함
              response(
                $.map(data.list, function (item) {
                  //console.log(item);
                  return {
                    label: item.WKPL_NM,
                    value: item.WKPL_NM,
                    g_seq: item.G_SEQ,
                    rgstNo: item.BZOWR_RGST_NO,
                    busi: item.VLDT_VL_KRN_NM
                  }
                })
              );

              $(".ui-autocomplete").highlight(request.term);
            }
          });
        },
        autoFocus: false, //첫번째 값을 자동 focus한다
        minLength: 2,  //조회를 위한 최소글자수
        select: function (event, ui) {
          $(event.target).closest("div").find("input[name='g_seq']").val(ui.item.g_seq);
          // 만약 검색리스트에서 선택하였을때 선택한 데이터에 의한 이벤트발생
          $(event.target).closest("div").next().find("input").focus();
        },
        focus: function (event, ui) {
          //event.target.value = ui.item.label;
          event.preventDefault();
        }
      }).data("ui-autocomplete")._renderItem = function (ul, item) {

        return $("<li>")
          .data("ui-menu-item", item)
          .append("<div class='ui-menu-item-wrapper'><span class='font-size-12'>" + item.label + "</span></div>")
          .appendTo(ul);
      };
    }
