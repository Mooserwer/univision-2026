  <script type="text/javascript">
    window.multi_api_hidden_pretext = "search."
    BindDatePicker('.date-time');

    window.onpopstate = function (event) {
      //console.log(event, event.state , event.state.form_name , event.state.form_data , $(event.state.form_name) , event.state.title , document.title);
      if (event.state && event.state.form_name && event.state.form_data && $(event.state.form_name) && event.state.title == document.title) {
        event.preventDefault();
        $(event.state.form_name).deserialize(event.state.form_data)
        SetJobBusiAjx(event.state.form_data);

        Search();

      }
    };

    function SetJobBusiAjx(ddata) {
      ajxCall({
          url: '@Url.Action("PartialDirectorSearchBusiList")',
          data: ddata,
          dataType: 'html',
          suc: function (response) {
            $('#busiCodeList').empty();
            $('#busiCodeList').html(response);
          }
        })

        ajxCall({
          url: '@Url.Action("PartialDirectorSearchJobList")',
          data: ddata,
          dataType: 'html',
          suc: function (response) {
            $('#jobCodeList').empty();
            $('#jobCodeList').html(response);
          }
        })
    }

    jQuery.fn.deserialize = function (data) {
      var f = this,
        map = {},
        find = function (selector) { return f.is("form") ? f.find(selector) : f.filter(selector); };
      //Get map of values
      jQuery.each(data.split("&"), function () {
        var nv = this.split("="),
          n = decodeURIComponent(nv[0]),
          v = nv.length > 1 ? decodeURIComponent(nv[1]) : null;
        if (!(n in map)) {
          map[n] = [];
        }
        map[n].push(v);
      })
      //Set values for all form elements in the data
      jQuery.each(map, function (n, v) {
        find("[name='" + n + "']").val(v);
      })
      //Clear all form elements not in form data
      find("input:text,select,textarea").each(function () {
        if (!(jQuery(this).attr("name") in map)) {
          jQuery(this).val("");
        }
      })
      find("input:checkbox:checked,input:radio:checked").each(function () {
        if (!(jQuery(this).attr("name") in map)) {
          this.checked = false;
        }
      })
      return this;
    };

    jQuery.fn.serializeObject = function () {
      var obj = null;
      try {
        if (this[0].tagName && this[0].tagName.toUpperCase() == "FORM") {
          var arr = this.serializeArray();
          if (arr) {
            obj = {};
            jQuery.each(arr, function () {
              obj[this.name] = this.value;
            });
          }//if ( arr ) {
        }
      } catch (e) {
        alert(e.message);
      } finally {
      }

      return obj;
    };



    $('#SearchForm').submit(function () { //submit이 발생하면
      $('#SearchForm_CurrentPage').val(1);
      Search(true); //옵션값대로 ajax비동기 동작을 시키고
      return false; //기본 동작인 submit의 동작을 막아 페이지 reload를 막는다.
    });

    function SearchPaging(page) {
      $('#SearchForm_CurrentPage').val(page);
      Search(true);
    }

    function Search(pushstate) {
      var search_data = $('#SearchForm').serializeObject();
      var serial_data = $('#SearchForm').serialize().replace(/[^=&]+=(&|$)/g, "").replace(/&$/, "");

      ajxCall({
        url: '@Url.Action("DirectorAjxList", "Candidate")',
        data: search_data,
        dataType: 'html',
        type: 'POST',
        loading: true,
        loading_target: '.page-content',
        suc: function (response) {
          $('#panel_cd_list').empty();
          $('#panel_cd_list').html(response);
        },
        comp: function () {
          if(pushstate === true) {
            window.history.pushState({ title: document.title, form_name: '#SearchForm', form_data: serial_data }, document.title, "?replace=1&" + serial_data); //주소표시줄 업데이트
          } else {//  console.log("replace");
            window.history.replaceState({ title: document.title, form_name: '#SearchForm', form_data: serial_data }, document.title, "?replace=1&" + serial_data); //주소표시줄 업데이트
          }

        }
      })


    }

    function cd_order_set(field) {
      if ($('#search_orderTxt').val() == field) {
        if ($('#search_orderOption').val() == "DESC") {
          $('#search_orderOption').val("ASC");
        } else {
          $('#search_orderOption').val("DESC");
        }
      } else {
        $('#search_orderTxt').val(field);
        $('#search_orderOption').val("ASC");
      }
      Search(true);
    }

    function openCandidateDirector(val1) {
      var win_yn = true;
      if (document.getElementById("candidate_new_win"))
        var win_yn = document.getElementById("candidate_new_win").checked;
      var url = "/Candidate/DirectorDetail?d_seq=" + val1;

      if (win_yn) {
        var win = window.open(url + "&is_pop=1", "WIN_DIR_" + val1, "scrollbars=yes,resizable=yes,width=1200,height=750");
        win.focus();
      } else {
        document.location.href = url;
      }
    }

