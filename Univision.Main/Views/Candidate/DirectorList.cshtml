                  c_seq: c_seq
                },
                dataType: 'html',
                type: 'POST',
                beforeSend: function () {
                  showLoading('#cand_list_' + c_seq);
                },
                success: function (response) {
                  $('#cand_list_' + c_seq).html(response);
                },
                complete: function () {
                  hideLoading('#cand_list_' + c_seq);
                }
              })
            }
