@using Univision.Core.Models;
@using Univision.Core.Models.DTO;
@model Univision.Core.Models.DTO.Response.Candidate.MyCandidateListViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    string pageTag = ViewBag.pageTag;
    ViewBag.Title = "나의 관심 후보 목록";
}
@*<link rel="stylesheet" href="~/Libs/remark/global/vendor/tablesaw/tablesaw.min599c.css?v4.0.4">*@
<link rel="stylesheet" href="~/Libs/tablesaw/tablesaw.css?v4.0.4">
<div class="page-content">
    <!--검색 Form -->
    <div class="panel panel-primary panel-line animation-scale-up" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms;">
        <!-- 검색 패널 시작 -->
        @using (Html.BeginForm("MyCandidateList", "Candidate", FormMethod.Get, new { @id = "searchForm" }))
        {
            @Html.HiddenFor(x => x.search.orderTxt)
            @Html.HiddenFor(x => x.search.orderOption)
            <div class="panel-heading">
                <div class="panel-title">
                    <i class="fas fa-info-circle"></i>
                    Favorite (후보자 즐겨찾기)
                </div>
                <div class="panel-actions" style="display:flex">
                    <div class="panel-action input-search">
                        <select id="search_searchOption" name="search.searchOption" class="form-control">
                            <option value="C.kor_name">이름</option>
                            <option value="CI.memo">메모</option>
                            <option value="CI.company">추천회사</option>
                            <option value="CI.position">포지션</option>
                        </select>
                    </div>
                    <div class="panel-action input-search">
                        <button type="submit" class="input-search-btn">
                            <i class="icon wb-search" aria-hidden="true"></i>
                            &nbsp;&nbsp;
                        </button>
                        @Html.TextBoxFor(x => x.search.searchTxt, new { @class = "form-control" })
                    </div>
                </div>
            </div>
            <!-- 검색 패널 끝 -->
        }

        <div class="panel-body pt-5">
            <div class="">
                <table class="block_table table table-striped tablesaw-columntoggle" data-tablesaw-mode="columntoggle" data-tablesaw-minimap>
                    <colgroup>
                        <col style="width:10%" />
                        <col style="width:10%" />
                        <col style="width:35%" />
                        <col style="width:10%" />
                        <col style="width:10%" />
                        <col style="width:10%" />
                        <col style="width:15%" />
                    </colgroup>
                    <thead>
                        <tr>
                            <th class="text-center tbw20">
                                이름
                                <i class="fas @Utils.ReturnOrderOptionCalss(Model.search.orderTxt, "kor_name", Model.search.orderOption) colSort" orderTxt="kor_name"></i>
                            </th>
                            <th class="text-center hidden-sm-down">
                                생년
                                <i class="fas @Utils.ReturnOrderOptionCalss(Model.search.orderTxt, "birth_date", Model.search.orderOption) colSort" orderTxt="birth_date"></i>
                            </th>
                            <th class="text-center tbw60">메모</th>
                            <th class="text-center hidden-sm-down">추천회사</th>
                            <th class="text-center hidden-sm-down">포지션</th>
                            <th class="text-center hidden-sm-down">
                                추가일자
                                <i class="fas @Utils.ReturnOrderOptionCalss(Model.search.orderTxt, "create_dt", Model.search.orderOption) colSort" orderTxt="create_dt"></i>
                            </th>
                            <th class="text-center tbw20">기타</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.list.Count > 0)
                        {
                            foreach (var data in Model.list)
                            {
                                <tr>
                                    <td class="text-center">
                                        <a href="javascript:void(0)" onclick="callModifyFavoriteInfo('@data.cf_seq')">
                                            @data.kor_name
                                        </a>
                                    </td>
                                    <td class="text-center hidden-sm-down">
                                        @Utils.ConvertDateTimeToString(data.birth_date)
                                    </td>

                                    <td class="text-left " title="@data.memo">
                                        @Utils.Truncate(data.memo, 40)
                                    </td>

                                    <td class="text-center hidden-sm-down ">
                                        @data.company
                                    </td>
                                    <td class="text-center hidden-sm-down ">
                                        @data.position
                                    </td>
                                    <td class="text-center hidden-sm-down ">
                                        @Utils.ConvertDateTimeToString(data.create_dt)
                                    </td>
                                    <td class="text-center">
                                        <a class="btn btn-sm btn-primary sm_link_mo_type01" href="@Url.Action("CandidateDetail", "Candidate", new { @c_seq = data.c_seq })">
                                            상세정보
                                        </a>
                                        <button class="btn btn-sm btn-danger sm_link_mo_type01" onclick="DeleteMyListConfirm('@data.cf_seq')">삭제</button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td class="text-center" colspan="7">
                                    No Data.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (Model != null && Model.list.Count > 0)
                {
                    @Html.PageAjaxLinks(Model.PagingInfo,
                     ViewContext.HttpContext.Request.Url.AbsoluteUri,
                     x => Url.Action("MyCandidateList", new
                     {
                         page = x
                     }))

                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="MyCandidateModifyModal" aria-hidden="false" aria-labelledby="MyCandidateModifyModalLabel" role="dialog" tabindex="-1">
    <div class="modal-dialog modal-simple">
        <div class="modal-content" style="width:500px;">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
                <h4 class="modal-title text-center" id="MyCandidateModifyModalLabel">
                    <i class="fas fa-user"></i>
                    My Candidate Information
                </h4>
            </div>
            <div class="modal-body" style="max-height:800px; overflow-y:auto">

            </div>
        </div>
    </div>
</div>

@section scripts{

    <script type="text/javascript">

        $(document).ready(function () {

        });

        $(".colSort").click(function () {

            $(".colSort").not(this).each(function () {

                $(this).removeClass("fa-sort-up");
                $(this).removeClass("fa-sort-down");
                $(this).addClass("fa-sort");
            })

            $(this).removeClass("fa-sort");

            if ($(this).hasClass("fa-sort-up")) {
                $(this).addClass("fa-sort-down");
                $(this).removeClass("fa-sort-up");
                $("#search_orderTxt").val($(this).attr("orderTxt"));
                $("#search_orderOption").val("DESC");
            }
            else {
                $(this).addClass("fa-sort-up");
                $(this).removeClass("fa-sort-down");
                $("#search_orderTxt").val($(this).attr("orderTxt"));
                $("#search_orderOption").val("ASC");
            }

            $("#searchForm").submit();

        });

        //관심후보자 메모, 추천회사, 포지션 수정
        function callModifyFavoriteInfo(cf_seq) {
            $.ajax({
                url: '@Url.Action("MyCandidateModify", "Candidate")',
                data: {
                    cf_seq: cf_seq
                },
                dataType: 'html',
                type: 'GET',
                beforeSend: function ()
                {
                    showLoading();
                }
            })
            .done(function (view) {
                hideLoading();

                $("#MyCandidateModifyModal .modal-body").html(view)
                $('#MyCandidateModifyModal').modal('toggle');

            })
            .fail(function (e) {
                hideLoading();
                ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
            });
        }

        //마이리스트 삭제 (confirm)
        function DeleteMyListConfirm(cf_seq) {

            alertify.confirm()
                    .set({
                        'labels': { ok: '확인', cancel: '취소' },
                        'onok': function () {
                            DeleteMyList(cf_seq)
                        },
                        'oncancel': function () {
                            return;
                        },
                    })
                    .setHeader('<i class="fas fa-exclamation-triangle" style="color:#FFDC2E"></i>Remove from My List')
                    .setting({
                        message: "Are you sure want to remove this candidate from My List?",
                    })
                    .show();

        }

        //마이리스트 삭제
        function DeleteMyList(cf_seq) {

            $.ajax({
               url: '@Url.Action("DeleteMyList", "Candidate")',
               data: {
                   cf_seq: cf_seq
                },
                dataType: 'json',
                type: 'POST',
               beforeSend: function ()
               {
                   showLoading();
               }
            })
            .done(function (json) {
                hideLoading();
                if (json.ok) {
                    NormalAlert(json.message);
                    location.reload();

                } else {
                    ErrorAlert(json.message);
                }
            })
            .fail(function (e) {
                hideLoading();
                ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
            });
        }

    </script>

}