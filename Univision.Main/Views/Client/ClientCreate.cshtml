    function BindClientDupAutocomplete($obj, type) {
      if (!type) {
        type = "kor";
      }
      $obj.autocomplete({
        source: function (request, response) {
          $.ajax({
            type: 'post',
            url: '@Url.Action("FindClientApi", "Partial")',
            dataType: "json",
            //request.term = $("#autocomplete").val()
            data: { client_name: request.term, c_seq: $('#c_seq').val(), type : type },
            success: function (data) {
              //서버에서 json 데이터 response 후 목록에 뿌려주기 위함
              response(
                $.map(data.list, function (item) {

                  var client = "";
                  if (item.eng_name != undefined) {
                    client = item.kor_name + '(' + item.eng_name + ')';
                  }
                  else {
                    client = item.school_name;
                  }

                  return {
                    label: item.kor_name,
                    eng: item.eng_name,
                    value: item.kor_name
                  }
                })
              );
              $(".ui-autocomplete").highlight(request.term);
            }
          });
        },
        select: function (event, ui) {
          //console.log(event);
          $(event.target).val(ui.item.label);
          //console.log($(event.target).val());
          $('#CreateForm').formValidation('revalidateField', 'kor_name');
          //console.log($(event.target).val());
        },
        html: true,
        delay: 300,
        autoFocus: false, //첫번째 값을 자동 focus한다
        minLength: 2,  //조회를 위한 최소글자수
        focus: function (event, ui) {
          //event.target.value = ui.item.label;
          event.preventDefault();
        },
        create: function () {
          $(this).data('ui-autocomplete')._renderItem = function (ul, item) {
            var path = 'basepath' + item.value;

            return $('<li>')
                   .data("ui-menu-item", item)
                   .append('<li><div class="btn btn-sm btn-outline-secondary"> <span class="badge badge-waring">[이미 등록된 고객사]</span> ' + item.label + (item.eng ? '  <small>(' + item.eng + ')</small>' : '') + '</div></li>')
                    .appendTo(ul); // customize your HTML
                };
              }
            })
        }
    BindClientDupAutocomplete($('#kor_name'), "kor");
    BindClientDupAutocomplete($('#eng_name'), "eng");

