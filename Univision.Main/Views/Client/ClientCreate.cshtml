@model Univision.Main.Models.Client.ClientCreateModel
@{
  ViewBag.Title = "고객사 등록 및 수정";
  Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
  #btnSpan_Dup {
    display: none;
  }

  .has-success > .input-group > #btnSpan_Dup {
    display: inline !important;
  }
</style>

<div class="page-content">
  @using (Html.BeginForm("ClientCreate", "Client", FormMethod.Post, new { @id = "CreateForm" }))
  {
    @Html.HiddenFor(x => x.c_seq)
    @Html.HiddenFor(x => x.i_seq)
    @*@Html.HiddenFor(x => x.checkValue)*@
    <input type="hidden" name="checkValue" id="checkValue" value="0" />
    <input type="hidden" name="old_kor" id="old_kor" value="@Model.kor_name" />
    <div class="panel panel-primary panel-line animation-scale-up" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms;">
      <div class="panel-heading">
        <h3 class="panel-title">
          <i class="fas fa-newspaper"></i>
          Client Info
        </h3>
        <div class="panel-actions">
          <a class="panel-action icon wb-minus" aria-expanded="true" data-toggle="panel-collapse" aria-hidden="true"></a>
        </div>
      </div>
      <div id="projectInfo" class="panel-body">
        <div class="row">
          <div class="form-group col-6 col-md-3">
            <label class="form-control-label small" for="kor_name" title="고객사명(국문)">Client Name(Kr) <span class="label-reqired">*</span></label>
            <div class="input-group input-group-sm">
              <input type="hidden" id="g_seq" name="g_seq">
              <input type="hidden" id="cc_seq" name="cc_seq">
              @*@Html.TextBoxFor(x => x.kor_name, new { @class = "form-control col-md-10", @autocomplete = "off", onkeydown = "FindCompany(this)" })
                <span class="input-group-btn">
                    <button type="button" class="btn btn-primary" id="btnClientSearch"><i class="icon wb-search" aria-hidden="true"></i></button>
                </span>*@
              @*@Html.TextBoxFor(x => x.kor_name, new { @class = "form-control col-md-10", @readonly = "readonly" })*@

              @*@Html.TextBoxFor(x => x.checkValue, new { @class = "form-control col-md-10"})*@
              @*<span class="input-group-btn">
                    <button type="button" class="btn btn-primary" id="btnClientSearch"><i class="icon wb-search" aria-hidden="true"></i></button>
                </span>*@
              @Html.TextBoxFor(x => x.kor_name, new { @class = "form-control", @autocomplete = "off", @placeholder = "회사명(국문)" })
              <span class="input-group-btn" id="btnSpan_Dup">
                <button type="button" @*id="doubleCheck"*@ onclick="javascript:NewClientSearch();" class="btn btn-primary" title="연금보험 납입 사업자 조회">불러오기</button>
              </span>
            </div>
          </div>
          <div class="form-group col-6 col-md-3">
            <label class="form-control-label small" for="eng_name" title="고객사명(영문)">Client Name(En) <span class="label-reqired">*</span></label>
            @Html.TextBoxFor(x => x.eng_name, new { @class = "form-control form-control-sm", @autocomplete = "off", @placeholder = "회사명(영문)" })
          </div>
          <div class="form-group col-6 col-md-3">
            <label class="form-control-label small" for="ceo" title="대표자명">C.E.O</label><span class="label-reqired">&nbsp;</span>
            @Html.TextBoxFor(x => x.ceo, new { @class = "form-control form-control-sm", @autocomplete = "off", @placeholder = "대표자명" })
          </div>
          <div class="form-group col-6 col-md-3">
            <label class="form-control-label small" for="biz_code" title="사업자등록번호(ex:123-12-12345)">Business No.</label><span class="label-reqired">&nbsp;</span>
            @Html.TextBoxFor(x => x.biz_code, new { @class = "form-control form-control-sm", @autocomplete = "off", @placeholder = "000-00-00000", @maxlength = "12" })
          </div>
          <div class="form-group col-12">
            <label class="form-control-label small" for="offlimit_keyword">회사명 동의어 <small class="text-primary">&nbsp;* 쉼표(,) 로 구분</small> <i class="fa fa-info-circle text-info" title="회사이름 영문표기 국문표기 줄임말 등 입력 시 검색, offlimit 및 중복체크에 활용 됩니다."></i></label>
            @Html.TextBoxFor(x => x.offlimit_keyword, new { @class = "form-control form-control-sm", @data_plugin = "tokenfieldX", @placeholder = "회사명 동의어 (검색 및 Offlimit 확인용)" })
          </div>
        </div>

        <div class="row">
          <div class="form-group col-md-9">
            <label class="form-control-label small" for="addr1" title="고객사 소재지(주소)">Invoice Address</label>
            <div class="input-group input-group-sm">
              @Html.TextBoxFor(x => x.addr1, new { @class = "form-control form-control-sm w-p100", @autocomplete = "off", @placeholder = "고객사 소재지" })
              <div class="input-group-append">
                <div class="checkbox-custom checkbox-custom-sm checkbox-primary checkbox-inline">
                  <input type="checkbox" id="foreignYes" name="is_foreign" value="1" @(Model.is_foreign == 1 ? "checked" : "")>
                  <label for="foreignYes" title="고객사 주소가 해외일 경우 체크해주세요">Foreign Address</label>
                </div>
              </div>
            </div>

          </div>
          <div class="form-group col-md-3">
            <label class="form-control-label small" for="country_name" title="본사 주소가 해외에 있을 경우 본사가 위치한 국가(선택)">HQ Country</label>
            <div class="input-group input-group-sm">
              @*@Html.TextBoxFor(x => x.country_name, new { @class = "form-control col-md-9", @autocomplete = "off", onkeydown = "FindNationality(this)" })*@
              @Html.TextBoxFor(x => x.country_name, new { @class = "form-control", @readonly = "readonly", @placeholder = "고객사 국적" })
              <span class="input-group-btn">
                <button type="button" class="btn btn-primary" id="btnNationalitySearch"><i class="icon wb-search" aria-hidden="true"></i></button>
              </span>
            </div>
            @Html.HiddenFor(x => x.foreign_code)
          </div>
        </div>

        <div class="row">
          <div class="form-group col-7 col-md-3">
            <label class="form-control-label small" for="title">Foreign / Domestic <span class="label-reqired">*</span></label>
            <div class="">
              <div class="radio-custom radio-custom-sm radio-primary radio-inline">
                <input type="radio" id="investYes" name="is_foreign_invest" value="1" @(Model.is_foreign_invest == 1 ? "checked" : "")>
                <label for="investYes">Foreign</label>
              </div>
              <div class="radio-custom radio-custom-sm radio-primary radio-inline">
                <input type="radio" id="investNo" name="is_foreign_invest" value="0" @(Model.is_foreign_invest == 0 ? "checked" : "")>
                <label for="investNo">Domestic</label>
              </div>
            </div>
          </div>
          <div class="form-group col-5 col-md-3">
            <label class="form-control-label small" for="title">Contract <span class="label-reqired">*</span></label>
            <div class="">
              <div class="radio-custom radio-custom-sm radio-primary radio-inline">
                <input type="radio" id="contractYes" name="is_contract" value="1" @(Model.is_contract == 1 ? "checked" : "")>
                <label for="contractYes">Yes</label>
              </div>
              <div class="radio-custom radio-custom-sm radio-primary radio-inline">
                <input type="radio" id="contractNo" name="is_contract" value="0" @(Model.is_contract == 0 ? "checked" : "")>
                <label for="contractNo">No</label>
              </div>
            </div>
          </div>
          <div class="form-group col-6 col-md-3">
            <label class="form-control-label small" for="title">Inorder / BD <span class="label-reqired">*</span></label>
            <div class="">
              <div class="radio-custom radio-custom-sm radio-primary radio-inline">
                <input type="radio" id="is_inorder_y" name="is_inorder" value="1" @(Model.is_inorder == 1 ? "checked" : "")>
                <label for="is_inorder_y">Inorder<small>(회사오더)</small></label>
              </div>
              <div class="radio-custom radio-custom-sm radio-primary radio-inline">
                <input type="radio" id="is_inorder_n" name="is_inorder" value="0" @(Model.is_inorder == 0 ? "checked" : "")>
                <label for="is_inorder_n">BD</label>
              </div>
              <div class="radio-custom radio-custom-sm radio-primary radio-inline">
                <input type="radio" id="is_inorder_bdm" name="is_inorder" value="3" @(Model.is_inorder == 3 ? "checked" : "")>
                <label for="is_inorder_bdm">BD Manager</label>
              </div>
              <div class="radio-custom radio-custom-sm radio-primary radio-inline">
                <input type="radio" id="is_inorder_a" name="is_inorder" value="2" @(Model.is_inorder == 2 ? "checked" : "")>
                <label for="is_inorder_a">All-in-One<small>(리멤버)</small></label>
              </div>
            </div>
          </div>
          <div class="form-group col-6 col-md-3">
            <label class="form-control-label small" for="title" title="고객사 임직원 컨택 금지 조항">Offlimit<span class="label-reqired">*</span></label>
            <div class="" id="client-offlimit-label">
              <div class="radio-custom radio-custom-sm radio-danger radio-inline mr-20">
                <input type="radio" id="offlimit_y" name="offlimit" value="1" @(Model.offlimit == 1 ? "checked" : "")>
                <label for="offlimit_y" title="계약서 상 전 임직원 컨택금지 조항">[계약서 표기] 전 임직원</label>
              </div>
              <div class="radio-custom radio-custom-sm radio-warning radio-inline ml-0 mr-20">
                <input type="radio" id="offlimit_2" name="offlimit" value="2" @(Model.offlimit == 2 ? "checked" : "")>
                <label for="offlimit_2" title="계약서 상 유니코에 의한 채용자 컨택금지 조항">[계약서 표기] 유니코채용직원</label>
              </div>
              <div class="radio-custom radio-custom-sm radio-info radio-inline ml-0 mr-20">
                <input type="radio" id="offlimit_3" name="offlimit" value="3" @(Model.offlimit == 3 ? "checked" : "")>
                <label for="offlimit_3" title="계약서 내 오프리밋 조항은 없지만 고객사의 요청 등">[계약서 미표기] OFFLIMIT</label>
              </div>
              <div class="radio-custom radio-custom-sm radio-primary radio-inline ml-0 mr-20">
                <input type="radio" id="offlimit_n" name="offlimit" value="0" @(Model.offlimit == 0 ? "checked" : "")>
                <label for="offlimit_n">No</label>
              </div>
            </div>
          </div>

          <div class="form-group col-6 col-md-9">
            <label class="form-control-label small" for="title">AM <i class="fa fa-info-circle text-info" title="프로젝트 수주 시 AM으로 등록합니다. 기존 AM(AM1)이 휴면 상태(Dormant)인 경우, 삭제할 수 있습니다"></i> <span class="label-reqired">*</span></label>
            <div class="input-group input-group-sm">
              <div class="form-control" id="AMDiv" name="AMDiv">
                @if (Model.amList.Count > 0)
                {
                  foreach (var am in Model.amList)
                  {
                    <span class="category small mr-5">
                      <span class="badge badge-outline badge-default bg-white cur_hand badge-lg font-size-14" am_seq="@am.uv_seq">
                        @am.am_name
                        <i class="far fa-times-circle" onclick="removeBadge(this)"></i>
                      </span>
                    </span>
                  }
                }
              </div>
              <div class="input-group-btn">
                <button type="button" id="btnAm" class="btn btn-sm btn-success"><i class="fas fa-plus" aria-hidden="true"></i></button>
              </div>

            </div>
          </div>

          <div class="form-group col-6 col-md-3">
            <label class="form-control-label small" for="title">PE Portfolio사 <span class="label-reqired">*</span></label>
            <div class="">
              <div class="radio-custom radio-custom-sm radio-primary radio-inline">
                <input type="radio" id="is_portfolio_y" name="is_portfolio" value="1" @(Model.is_portfolio == 1 ? "checked" : "")>
                <label for="is_portfolio_y">Yes</label>
              </div>
              <div class="radio-custom radio-custom-sm radio-primary radio-inline">
                <input type="radio" id="is_portfolio_n" name="is_portfolio" value="0" @(Model.is_portfolio == 0 ? "checked" : "")>
                <label for="is_portfolio_n">No</label>
              </div>
            </div>
          </div>

        </div>

        <div class="row">
          <div class="form-group col-6 col-md-3">
            <label class="form-control-label small" for="biz_type">Business Type</label>
            @Html.TextBoxFor(x => x.biz_type, new { @class = "form-control form-control-sm", @autocomplete = "off", @placeholder = "업태" })
          </div>
          <div class="form-group col-6 col-md-3">
            <label class="form-control-label small" for="biz_category">Business Item</label>
            @Html.TextBoxFor(x => x.biz_category, new { @class = "form-control form-control-sm", @autocomplete = "off", @placeholder = "종목" })
          </div>
          <div class="form-group col-md-6">
            <label class="form-control-label small" for="company_name">Industry <span class="label-reqired">*</span> <i class="fa fa-info-circle text-info" title="해당 고객사에 등록된 산업이 프로젝트 작성 시 산업 항목에 자동으로 입력 됩니다."></i></label>
            @*<div class="input-group">
                  <div id="businessCodeDiv" name="businessCodeDiv" class="form-control col-md-10" style="background-color:white"></div>
                  <span class="input-group-btn">
                      <button type="button" class="btn btn-primary" id="btnBusiness"><i class="icon wb-search" aria-hidden="true"></i></button>
                  </span>
              </div>*@
            <div class="input-group input-group-sm redo-site" id="businessDiv">
              @Html.HiddenFor(x => x.busiCode1, new { @class = "busiCode1" })
              @Html.HiddenFor(x => x.busiCode2, new { @class = "busiCode2" })
              @{
                string business_str = String.Empty;
                if (!String.IsNullOrEmpty(Model.business_name2))
                {
                  business_str = "[" + Model.business_name1 + " > " + Model.business_name2 + "]";
                }
              }
              @Html.TextBox("business_name2", business_str, new { @class = "form-control bg-white busiTargetText form-control-sm", @readonly = "readonly", @placeholder = "산업" })
              <div class="input-group-btn">
                <button type="button" class="btn btn-primary" onclick="FindBusinessSingle('businessDiv')">
                  <i class="fas fa-search"></i>
                </button>
              </div>
            </div>
          </div>
          @*<div class="form-group col-md-3">
                <label class="form-control-label small" for="title">고정타이틀(Biz_Title)</label>
                @Html.TextBoxFor(x => x.fix_title, new { @class = "form-control col-md-11", @autocomplete = "off" })
            </div>*@
        </div>

        <div class="row">
          <div class="form-group col-md-3">
            <label class="form-control-label small" for="fix_title" title="프로젝트 고정 타이틀 : ex:[외국계 IT회사]">
              Project Title Heading
              <i class="fa fa-info-circle text-info" title="해당 고객사에 등록된 고정 타이틀이 프로젝트 작성 시 산업항목에 구인제목에 자동으로 입력 됩니다."></i>
            </label>
            @Html.TextBoxFor(x => x.fix_title, new { @class = "form-control form-control-sm", @autocomplete = "off", @placeholder = "예시 - [국내 대기업]" })
          </div>
          <div class="form-group col-md-3">
            <label class="form-control-label small" for="homepage" title="홈페이지 주소">Homepage</label>
            @Html.TextBoxFor(x => x.homepage, new { @class = "form-control form-control-sm", @autocomplete = "off", @placeholder = "http://exam.net" })
          </div>
          <div class="form-group col-6 col-md-3">
            <label class="form-control-label small" for="employee_number">Number of Employees</label>
            @Html.TextBoxFor(x => x.employee_number, new { @type = "number", @class = "form-control form-control-sm", @placeholder = "사원 수", @autocomplete = "off", style = "text-align:right;" })
          </div>
          <div class="form-group col-6 col-md-3">
            <label class="form-control-label small" for="sales_amount">Sales Amount <span class="d-md-inline-block d-none">(100 million won)</span></label>
            @Html.TextBoxFor(x => x.sales_amount, new { @type = "number", @class = "form-control form-control-sm", @placeholder = "연간 매출액(억원)", @autocomplete = "off", style = "text-align:right;" })
          </div>
        </div>

        <div class="row">

        </div>

      </div>
    </div>
    if (Model.c_seq == null || Model.c_seq == 0)
    {
      <!-- Contact 시작 -->
      <div class="panel panel-primary panel-line animation-scale-up" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms;">
        <div class="panel-heading">
          <h3 class="panel-title">
            <i class="fas fa-user-tie"></i>
            Contact Info (인보이스 담당자)
          </h3>
          <div class="panel-actions">
            <a class="panel-action icon wb-minus" aria-expanded="true" data-toggle="panel-collapse" aria-hidden="true"></a>
          </div>
        </div>
        <div id="projectTax" class="panel-body">
          <div class="row">
            <div class="form-group col-6 col-md-3">
              <label class="form-control-label small" for="name">Contact Name <span class="label-reqired">*</span></label>
              @Html.HiddenFor(x => x.contact_seq)
              @Html.TextBoxFor(x => x.name, new { @class = "form-control form-control-sm", @autocomplete = "off", @placeholder = "고객사 담당자 명" })

            </div>
            <div class="form-group col-6 col-md-3">
              <label class="form-control-label small" for="name">Gender <span class="label-reqired">*</span></label>
              <div class="">
                <div class="radio-custom radio-custom-sm radio-primary radio-inline">
                  <input type="radio" id="male" name="gender" value="1" @(Model.gender == 1 ? "checked" : "")>
                  <label for="male">Male</label>
                </div>
                <div class="radio-custom radio-custom-sm radio-primary radio-inline">
                  <input type="radio" id="female" name="gender" value="2" @(Model.gender == 2 ? "checked" : "")>
                  <label for="female">Female</label>
                </div>
                <div class="radio-custom radio-custom-sm radio-primary radio-inline">
                  <input type="radio" id="gender_unknown" name="gender" value="3" @(Model.gender == 3 ? "checked" : "")>
                  <label for="gender_unknown">모름</label>
                </div>
              </div>
            </div>
            <div class="form-group col-6 col-md-3">
              <label class="form-control-label small" for="contact_position">Position <span class="label-reqired">*</span></label>
              @Html.TextBoxFor(x => x.position, new { @class = "form-control form-control-sm", @autocomplete = "off", @placeholder = "직급" })
            </div>
            <div class="form-group col-6 col-md-3">
              <label class="form-control-label small" for="contact_division">Department <span class="label-reqired">*</span></label>
              @Html.TextBoxFor(x => x.division, new { @class = "form-control form-control-sm", @autocomplete = "off", @placeholder = "부서" })
            </div>
          </div>
          <div class="row">
            <div class="form-group col-md-3">
              <label class="form-control-label small" for="email">E-mail</label> <span class="label-reqired">*</span>
              @Html.TextBoxFor(x => x.email, new { @class = "form-control form-control-sm", @autocomplete = "off", @placeholder = "exam@exam.net" })
            </div>
            <div class="form-group col-6 col-md-3">
              <label class="form-control-label small" for="phone">Phone</label><span class="label-reqired">*</span>
              @Html.TextBoxFor(x => x.phone, new { @class = "form-control form-control-sm", @autocomplete = "off", @placeholder = "00-0000-0000" })
            </div>
            <div class="form-group col-6 col-md-3">
              <label class="form-control-label small" for="cell_phone">Mobile</label><span class="label-reqired">&nbsp;</span>
              @Html.TextBoxFor(x => x.cell_phone, new { @class = "form-control form-control-sm", @autocomplete = "off", @placeholder = "000-0000-0000" })
            </div>
          </div>
        </div>
      </div>
      <!-- Contact 끝 -->

      <!-- 전자세금계산서 담당자 시작 -->
      <div class="panel panel-primary panel-line animation-scale-up" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms;">
        <div class="panel-heading">
          <h3 class="panel-title">
            <i class="fas fa-wallet"></i>
            E-Tax Manager (세금계산서 담당자)
          </h3>
          <div class="panel-actions">
            <a class="panel-action icon wb-minus" aria-expanded="true" data-toggle="panel-collapse" aria-hidden="true"></a>
          </div>
        </div>
        <div id="projectTax" class="panel-body">
          <div class="row">
            <div class="form-group col-6 col-md-3">
              <label class="form-control-label small" for="tax_name">Name</label>
              @Html.HiddenFor(x => x.tax_seq)
              @Html.TextBoxFor(x => x.tax_name, new { @class = "form-control form-control-sm", @autocomplete = "off", @placeholder = "담당자명 + 직급" })
            </div>
            <div class="form-group col-6 col-md-3">
              <label class="form-control-label small" for="tax_division">Department</label>
              @Html.TextBoxFor(x => x.tax_division, new { @class = "form-control form-control-sm", @autocomplete = "off", @placeholder = "담당부서" })
            </div>
            <div class="form-group col-6 col-md-3">
              <label class="form-control-label small" for="tax_division">E-mail</label>
              @Html.TextBoxFor(x => x.tax_email, new { @class = "form-control form-control-sm email", @autocomplete = "off", @placeholder = "exam@exam.net" })
            </div>
            <div class="form-group col-6 col-md-3">
              <label class="form-control-label small" for="tax_division">Mobile</label>
              @Html.TextBoxFor(x => x.tax_cell_phone, new { @class = "form-control form-control-sm", @autocomplete = "off", @placeholder = "000-0000-0000" })
            </div>
          </div>
          <div class="row">
            <div class="form-group col-6 col-md-3">
