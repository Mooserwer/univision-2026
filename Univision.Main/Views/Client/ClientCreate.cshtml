        function FindCompany(obj) {

            $(obj).autocomplete({
                source: function (request, response) {
                    $.ajax({
                        type: 'post',
                        url: '@Url.Action("FindCompanyApi", "Partial")',
                        dataType: "json",
                        //request.term = $("#autocomplete").val()
                        data: {
                            companyName: request.term
                        },
                        success: function(data) {
                            //서버에서 json 데이터 response 후 목록에 뿌려주기 위함
                            response(
                                $.map(data.list, function (item) {
                                    return {
                                        //label: item.wkplNm,
                                        //value: item.wkplNm,
                                        //ac_seq: item.ac_seq,
                                        //rgstNo: item.bzowrRgstNo,
                                        //busi: item.vldtVlKrnNm,
                                        //jnngpCnt: item.jnngpCnt
                                        label: item.WKPL_NM,
                                        value: item.WKPL_NM,
                                        g_seq: item.G_SEQ,
                                        rgstNo: item.BZOWR_RGST_NO,
                                        busi: item.VLDT_VL_KRN_NM
                                    }
                                })
                            );

                            $(".ui-autocomplete").highlight(request.term);
                        }
                    });
                },
                autoFocus:true, //첫번째 값을 자동 focus한다
                minLength: 2,  //조회를 위한 최소글자수
