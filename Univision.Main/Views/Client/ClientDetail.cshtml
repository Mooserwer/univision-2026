        function callProjectList(c_seq, page) {

            if(page == null || page == undefined)
              page = 1;

          var pageSize = $('#project_pageSize').val();
          var state = $('#project_state').val();

          if (pageSize == null || pageSize == undefined)
            pageSize = 5;

          if (state == "" || state == null || state == undefined)
            state = 0;


            $.ajax({
                url: '@Url.Action("ClientProjectList", "Client")',
                data: {
                  c_seq: c_seq
                  , pjt_page_size: pageSize
                  , pjt_state : state
