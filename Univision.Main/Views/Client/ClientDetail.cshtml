@section scripts{

  <script src="~/Libs/remark/global/vendor/bootstrap-tokenfield/bootstrap-tokenfield.min599c.js?v4.0.4"></script>
  <script src="~/Libs/remark/global/js/Plugin/bootstrap-tokenfield.min599c.js?v4.0.4"></script>
  <script src="~/Libs/dropzone/js/dropzone.min.js?v=1533562669"></script>

  <script type="text/javascript">

        var callJobObj;
        var callBusiObj;
        var callRankObj;
        //var callContractfileList;
        var code2Arr = []; //placePopup 에서 사용하는 전역변수.
        var AM_Arr = [];

        var jobCodeArr = []; //jobbusinessApi 에서 사용
        var busiCodeArr = []; //jobbusinessApi 에서 사용
        var feeTypeA = [];
        var feeTypeB = [];

        $(document).ready(function () {

            BindDatePicker($(".jDatePicker"));

            $("input[name='fee_type']").change(function () {
                if ($(this).val() == "@Model.fee_type") {
                    $("#feeValue").val("@Model.feeValue");
                } else {
                    $("#feeValue").val("");
                }

                if ($(this).val() == "C") {
                    $("#feeSettingBtn").css("display", "none");
                    $("#fix_fee_rate").removeAttr("readonly");
                }
                else {
                    $("#feeSettingBtn").css("display", "inline");
                    $("#fix_fee_rate").val("0");
                    $("#fix_fee_rate").attr("readonly", "readonly");
                }
            });

            $("#fix_fee_rate").change(function () {

                $("#feeValue").val("고정 수수료 : " + $(this).val() + "%");

            });

            //폼 유효성 검사
            $("#contractForm").formValidation({
                framework: "bootstrap4",
                button: {
                    selector: "#ContractSaveBtn",
                    disabled: "disabled"
                },
                submitHandler: function () {
                },
                icon: null,
                fields: {
                    contract_date: {
                        validators: {
                            notEmpty: {
                                message: "계약일을 입력하세요."
                            }
                        }
                    },
                    deposit_limit: {
                        validators: {
                            notEmpty: {
                                message: "입금일을 입력하세요."
                            }
                        }
                    },
                    feeValue: {
                        validators: {
                            notEmpty: {
                                message: "수수료율을 설정하세요."
                            }
                        }
                    }
                },
                err: {
                    clazz: "invalid-feedback"
                },
                control: {
                    valid: "is-valid",
                    invalid: "is-invalid"
                },
                row: {
                    invalid: "has-danger"
                }
            })
            //validation 성공시, ajax submit.
            //ajax submit 사용하지 않을 경우, on 부분은 삭제해도 됨.
            .on('success.form.fv', function (e) {
                //기본 submit 이벤트 취소.
                e.preventDefault();

                var contract = {
                    c_seq: $("#c_seq").val(),
                    cc_seq: $("#cc_seq").val(),
                    contract_date: $("#contract_date").val(),
                    deposit_limit: $("#deposit_limit").val(),
                    fee_type: $("input:radio[name=fee_type]:checked").val(),
                    guarntee_type: $("input:radio[name=guarntee_type]:checked").val(),
                    is_construct_debut: $("input:radio[name=is_construct_debut]:checked").val(),
                    contract_comment: $("#contract_comment").val(),
                    fix_fee_rate: $("#fix_fee_rate").val()
                };

                var annualIncomeList = [];
                var positionRateList = [];
                //연봉별
                if (contract.fee_type == "A") {

                    feeTypeA.forEach(function (row) {
                        var annual = {
                            Currency_Name: row.currency_name,
                            start_income:row.incomSamt,
                            end_income:row.incomEamt,
                            percentage:row.incomPer
                        }
                        annualIncomeList.push(annual);
                    });
                }
                //직급별
                else if (contract.fee_type == "B") {

                    feeTypeB.forEach(function (row) {
                        var position = {
                            start_code_seq: row.positionS,
                            end_code_seq: row.positionE,
                            rate: row.positionPer
                        }
                        positionRateList.push(position);
                    });
                }
                debugger;
                $.ajax({
                   url: '@Url.Action("ClientContractCreate", "Client")',
                   data: {
                       model: {
                           contract: contract,
                           annualIncomeList: annualIncomeList,
                           positionRateList: positionRateList
                       }
                   },
                   dataType: 'json',
                   type: 'POST',
                   beforeSend: function ()
                   {
                       showLoading('#contractInfo');
                   }
                })
                .done(function (json) {
                    hideLoading('#contractInfo');

                    if (json.ok) {
                        NormalAlert("계약 정보를 저장했습니다.", function () { location.reload(); });
                    } else {
                        ErrorAlert(json.message);
                    }
                })
                .fail(function (e) {
                    hideLoading('#contractInfo');
                    ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
                });
            });

        });

        function openClientExternalLock(c_seq) {
            alertify.confirm()
            .set({
                'labels': { ok: 'OK', cancel: 'Cancel' },
                'onok': function (e) {

                    if (saveElementOpenLogToServer('@Univision.Security.AppIdentity.user_seq', c_seq, 'client', 'client', '', '')) {
                        location.href = "@Html.Raw(ViewContext.HttpContext.Request.Url.AbsoluteUri)";
                    }
                    else {
                        return;
                    }

                },
                'oncancel': function () {
                    return;
                }
            })
            .setHeader('고객사 개인정보 확인')
            .setting({
              message: "해당 고객사의 개인정보를 확인하시겠습니까?<br />확인 시 개인정보 확인 기록이 서버에 저장되며, 24시간 이내 동일정보는 별도 확인 없이 조회가 가능합니다."
            })
            .show();
        }

        function openClientExternalLockToHref(c_seq, rtn_url) {
            alertify.confirm()
            .set({
                'labels': { ok: 'OK', cancel: 'Cancel' },
                'onok': function (e) {

                    if (saveElementOpenLogToServer('@Univision.Security.AppIdentity.user_seq', c_seq, 'client', 'client', '', '')) {
                        if (rtn_url) {
                            location.href = rtn_url;
                        } else {
                            location.href = "@Html.Raw(ViewContext.HttpContext.Request.Url.AbsoluteUri)";
                        }
                    }
                    else {
                        return;
                    }

                },
                'oncancel': function () {
                    return;
                }
            })
            .setHeader('고객사 수정화면 이동 안내')
            .setting({
              message: "해당 고객사의 정보 수정화면으로 이동하시겠습니까?<br />확인 시 개인정보 확인 기록이 서버에 저장되며, 24시간 이내 동일정보는 별도 확인 없이 조회가 가능합니다."
            })
            .show();
        }

        function feeSetting(c_seq, cc_seq) {

            var fee_type = $("input:radio[name=fee_type]:checked").val();

            if (fee_type == "A") {
                ContractFeeA(c_seq, cc_seq);
            }
            else if (fee_type == "B") {
                ContractFeeB(c_seq, cc_seq);
            }
        }

        //update history 버튼
        function openClientLogDetail(c_seq) {
            try {
                 $.ajax({
