        function callMyProjectList(searchTxt, state, orderTxt, orderOption, excelDown, page) {

            $.ajax({
                url: '@Url.Action("ClientProjectList", "Client")',
                data: {
                    'search.searchTxt': searchTxt
                    , 'search.state': state
