@model Univision.Core.Models.DTO.Response.Client.ClientOfferletterList
@using Univision.Security

@if (Model.offerletterList.Count > 0)
{
  <div class="mt-15">
    <table class="block_table table table-striped table-hover">
      <thead class="text-center">
        <tr>
          <th class="tbw55">Project</th>
          <th class="tbw55">후보자(입사일)</th>
          <th class="tbw55">File(Download)</th>
        </tr>
      </thead>
      <tbody class="text-center">
        @{
          int num = (Model.PagingInfo.CurrentPage - 1) * Model.PagingInfo.ItemsPerPage + 1;
          foreach (var data in Model.offerletterList)
          {
            <tr>
              <td class="text-left text-truncate">
                <a href="@Url.Action("ProjectDetail", "Project", new { p_seq = data.p_seq })" target="_blank">@data.title</a>
              </td>
              <td class="hidden-sm-down">
                @data.kor_name (@Utils.ConvertDateTimeToString(data.schedule_date))
              </td>
              <td class="text-left text-truncate">
                @if (!string.IsNullOrWhiteSpace(data.file_path))
                {
                  <a href="@data.file_directory">
                    <span class="text-truncate s2" title="@data.file_path">
                      @data.file_path
                    </span>
                  </a>

                }

              </td>


            </tr>
          }
        }

      </tbody>
    </table>
  </div>
  @Html.PageAjaxLinksWithFunction(Model.PagingInfo,
                                  ViewContext.HttpContext.Request.Url.AbsoluteUri,
                                  x => String.Format("javascript:callOfferletterList({0}, {1})", Model.c_seq, x))
}
else
{

  <div class="card">
    <div class="card-block text-center">
      <h4 class="card-title">등록된 오퍼레터가 없습니다.<small>[No Offer letter data]</small></h4>
      <p class="card-text">
        프로젝트 입사 확정 시 오퍼레터를 업로드 하실 수 있습니다.
      </p>
    </div>
  </div>

}
<script type="text/javascript" src="~/Scripts/FileDownload.js?v0.0.1"></script>
<script type="text/javascript">
$(document).ready(function () {
$("#fileBtn").click(function() {
$.ajax({
                            url: '@Url.Action("PopFile", "Client", new { @c_seq = Model.c_seq })',
dataType: 'html',
type: 'POST',
beforeSend: function()
{
                                    showLoading('#fileBody');
                                }
                            })
.done(function(json) {
                                hideLoading('#fileBody');
$.fancybox.open({
                                    'content':json,
    'width': '500',
    'height': '300',
    'autoDimensions':false,
    'type':'iframe',
    'autoSize': false,
    'title': '파일 추가',
    helpers:
                                    {
                                    title:
                                        {
                                        type: 'inside',
            position: 'top'
                                        },
        overlay:
                                        {
                                        closeClick: false
        }
                                    }
                                });
                            })
.fail(function(e) {
                                hideLoading('#fileBody');
                                ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요1.');
                            });
                        });


$('.deleteFileBtn').click(function(e) {
                            var cf_seq = e.target.value;
                            var c_seq = $("#c_seq").val();

                            alertify.confirm()
                                .set({
                                'labels': { ok: '확인', cancel: '취소' },
        'onok': function() {
            $.ajax({
                                    url: '@Url.Action("ClientFileDelete", "Client")',
                data: { cc_seq: cc_seq },
                dataType: 'json',
                type: 'POST',
                beforeSend: function() {
                                            showLoading('#fileBody');
                                        }
                                    })
            .done(function(json) {
                                        hideLoading('#fileBody');
                                        if (json.ok)
                                        {
                                            location.href = "/Client/ClientDetail?c_seq=" + c_seq;
                                        }
                                        else
                                        {
                                            ErrorAlert('오류입니다.');
                                        }
                                    });
                                },
        'oncancel': function() {
                                    return;
                                },
    })
    .setHeader('<i class="fas fa-exclamation-triangle" style="color:#FFDC2E"></i>파일 삭제')
    .setting({
                            message: "파일을 삭제 하시겠습니까?",
    })
.show();

                        });
                    });

function DeleteClientFile(c_seq, cf_seq)
                    {
                        alertify.confirm()
                        .set({
                            'labels': { ok: '확인', cancel: '취소' },
    'onok': function() {
        $.ajax({
                                url: '@Url.Action("DeleteClientFile", "Client")',
            type: "POST",
            dataType: 'json',
            data:
                                    {
                                    c_seq: c_seq,
                cf_seq: cf_seq
            },
            beforeSend: function() {
                                        showLoading('#fileBody');
                                    },
            success: function(json) {
                                        hideLoading('#fileBody');
                                        if (json.ok)
                                        {
                                            NormalAlert(json.message);
                                            callOfferletterList(c_seq, @Model.PagingInfo.CurrentPage);
                                        }
                                        else
                                        {
                                            ErrorAlert(json.message);
                                        }
                                    },
            error: function(jqXHR, textStatus, errorThrown) {
                                        hideLoading('#fileBody');
                                        ErrorAlert("알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.");
                                    }
                                });
                            },
    'oncancel': function() {

                                return;
                            },
})
.setHeader('<i class="fas fa-exclamation-triangle" style="color:#FFDC2E"></i>' + "관련 파일 삭제")
.setting({
                        message: "관련 파일을 삭제 하시겠습니까?",
})
.show();
                    }



</script>
