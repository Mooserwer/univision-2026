         //학교 검색
        function FindSchool(obj) {

            $(obj).autocomplete({
                source: function (request, response) {

                    $.ajax({
                        type: 'post',
                        url: '@Url.Action("FindCodeSchool", "Project")',
                        dataType: "json",
                        //request.term = $("#autocomplete").val()
                        data: {
                            school_name: request.term
                        },
                        success: function (data) {

                            //서버에서 json 데이터 response 후 목록에 뿌려주기 위함
                            response(
                                $.map(data.list, function (item) {

                                    var label = "";
                                    var value = "";

                                    if (item.campus_name != null) {
                                        label = item.school_name + '(' + item.campus_name + ')';
                                        value = item.school_name + '(' + item.campus_name + ')';
                                    }
                                    else {
                                        label = item.school_name;
                                        value = item.school_name;
                                    }

                                    return {
                                        label: label,
                                        value: value,
                                        sc_seq: item.sc_seq
                                    }
                                })
                            );

                            $(".ui-autocomplete").highlight(request.term);
                        }
                    });
                },
                autoFocus: true, //첫번째 값을 자동 focus한다
                minLength: 2,  //조회를 위한 최소글자수
