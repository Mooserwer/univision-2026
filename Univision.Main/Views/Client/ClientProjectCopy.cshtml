@model Univision.Main.Models.Project.ProjectCreateModel

@{
  ViewBag.Title = "프로젝트 생성 - 채용";
  Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/Libs/remark/global/vendor/bootstrap-tokenfield/bootstrap-tokenfield.min599c.css?v4.0.4">

<style>
  .placeDiv span {
    font-size: 15px;
  }

  .job_list {
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    width: 250px;
    display: inline-block;
  }
</style>

<div class="page-content">
  @using (Html.BeginForm("ProjectCreate", "Project", FormMethod.Post, new { @id = "CreateForm" }))
  {
    @Html.HiddenFor(x => x.p_seq)
    <div class="panel panel-primary panel-line animation-scale-up" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms;">
      <div class="panel-heading">
        <h3 class="panel-title">
          <i class="fas fa-newspaper"></i>
          Project 기본정보
        </h3>
        <div class="panel-actions">
          <a class="panel-action icon wb-minus" aria-expanded="true" data-toggle="panel-collapse" aria-hidden="true"></a>
        </div>
      </div>
      <div id="projectInfo" class="panel-body">
        <div class="form-group">
          <label class="form-control-label">프로젝트 구분</label>
          <div>
            <div class="radio-custom radio-default radio-inline">
              <input type="radio" id="hire" name="pjt_type" value="1" checked @(Model.pjt_type == 1 ? "checked" : "")>
              <label for="hire">채용</label>
            </div>
          </div>
        </div>

        <div class="row">
          <div class="form-group col-md-3">
            <label class="form-control-label" for="company_name">회사명</label>
            @Html.HiddenFor(x => x.c_seq)
            <div class="input-group">
              @Html.TextBoxFor(x => x.company_name, new { @class = "form-control col-md-10", @autocomplete = "off", @readonly = "readonly" })
              <span class="input-group-btn">
                <button type="button" class="btn btn-primary" id="btnClientSearch"><i class="icon wb-search" aria-hidden="true"></i></button>
              </span>
            </div>
          </div>
          <div class="form-group col-md-3">
            <label class="form-control-label" for="recruit_number">모집인원</label>
            @Html.TextBoxFor(x => x.recruit_number, new { @class = "form-control col-md-6", @type = "number", @autocomplete = "off" })
          </div>
          <div class="form-group col-md-6">
            <label class="form-control-label" for="AMDiv">AM</label>
            <div class="input-group">
              <div class="form-control col-md-10" id="AMDiv" name="AMDiv">
                @if (Model.amList.Count > 0)
                {
                  foreach (var am in Model.amList)
                  {
                    <span class="category mr-5">
                      <span class="badge badge-outline badge-default bg-white cur_hand badge-lg" am_seq="@am.uv_seq">
                        [@am.ud_name] @am.name
                        <i class="far fa-times-circle" onclick="removeBadge(this)"></i>
                      </span>
                    </span>
                  }
                }
              </div>
              <button type="button" id="btnAm" class="btn btn-success"><i class="fas fa-plus" aria-hidden="true"></i></button>
            </div>
          </div>
        </div>

        <div class="row">
          <div class="form-group col-md-12">
            <label class="form-control-label" for="Searcher">Searcher</label>
            <div class="input-group">
              <div class="form-control col-md-11" id="Searcher" name="Searcher">
                @if (Model.searcherList.Count > 0)
                {
                  foreach (var searcher in Model.searcherList)
                  {
                    <span class="category mr-5">
                      <span class="badge badge-outline badge-default bg-white cur_hand badge-lg" searcher_seq="@searcher.uv_seq">
                        [@searcher.ud_name] @searcher.name
                        <i class="far fa-times-circle" onclick="removeBadge(this)"></i>
                      </span>
                    </span>
                  }
                }
              </div>
              <button type="button" id="btnSearcher" class="btn btn-success"><i class="fas fa-plus" aria-hidden="true"></i></button>
            </div>
          </div>
        </div>

        <div class="row">
          <div class="form-group col-md-3">
            <label class="form-control-label" for="is_posting">포스팅 여부</label>
            <div>
              <div class="radio-custom radio-default radio-inline">
                <input type="radio" id="hire" name="is_posting" value="1" checked @(Model.is_posting == 1 ? "checked" : "")>
                <label for="hire">Yes</label>
              </div>
              <div class="radio-custom radio-default radio-inline">
                <input type="radio" id="reputation" name="is_posting" value="0" @(Model.is_posting == 0 ? "checked" : "")>
                <label for="radio">No</label>
              </div>
            </div>
          </div>
          <div class="form-group col-md-9">
            <label class="form-control-label" for="title">제목</label>
            @Html.TextBoxFor(x => x.title, new { @class = "form-control col-md-11", @autocomplete = "off" })
          </div>
        </div>

        <div class="row">
          <div class="form-group col-md-3">
            <label class="form-control-label" for="position_seq">포지션명</label>
            <select id="position_seq" name="position_seq" class="form-control">
              <option value="">선택</option>
              <option value="1" @(Model.position_seq == 1 ? "selected" : "")>팀원</option>
              <option value="2" @(Model.position_seq == 2 ? "selected" : "")>팀장</option>
              <option value="3" @(Model.position_seq == 3 ? "selected" : "")>매니저</option>
              <option value="4" @(Model.position_seq == 4 ? "selected" : "")>파트장</option>
              <option value="5" @(Model.position_seq == 5 ? "selected" : "")>실장</option>
              <option value="6" @(Model.position_seq == 6 ? "selected" : "")>지점장</option>
              <option value="7" @(Model.position_seq == 7 ? "selected" : "")>지사장</option>
              <option value="8" @(Model.position_seq == 8 ? "selected" : "")>원장</option>
              <option value="9" @(Model.position_seq == 9 ? "selected" : "")>국장</option>
              <option value="10" @(Model.position_seq == 10 ? "selected" : "")>본부장</option>
              <option value="11" @(Model.position_seq == 11 ? "selected" : "")>센터장</option>
              <option value="12" @(Model.position_seq == 12 ? "selected" : "")>공장장</option>
              <option value="13" @(Model.position_seq == 13 ? "selected" : "")>그룹장</option>
            </select>
          </div>
          <div class="form-group col-md-3">
            <label class="form-control-label" for="expreience_number">경력(년)</label>
            <div class="form-inline">
              @Html.TextBoxFor(x => x.expreience_number, new { @class = "form-control col-md-6", @type = "number", @autocomplete = "off" })
              <select class="form-control" id="experience_type" name="experience_type">
                <option value="1" @(Model.experience_type == 1 ? "selected" : "")>이상</option>
                <option value="2" @(Model.experience_type == 2 ? "selected" : "")>이하</option>
              </select>
            </div>
          </div>
          <div class="form-group col-md-3">
            <label class="form-control-label" for="edu_code">학력</label>
            <select class="form-control col-md-6" id="edu_code" name="edu_code">
              <option value="0" @(Model.edu_code == 0 ? "selected" : "")>학력무관</option>
              <option value="1" @(Model.edu_code == 1 ? "selected" : "")>고등학교졸업</option>
              <option value="2" @(Model.edu_code == 2 ? "selected" : "")>대학졸업(2,3년)</option>
              <option value="3" @(Model.edu_code == 3 ? "selected" : "")>대학교졸업(4년)</option>
              <option value="4" @(Model.edu_code == 4 ? "selected" : "")>석사졸업</option>
              <option value="5" @(Model.edu_code == 5 ? "selected" : "")>박사졸업</option>
              <option value="6" @(Model.edu_code == 6 ? "selected" : "")>고등학교졸업이상</option>
              <option value="7" @(Model.edu_code == 7 ? "selected" : "")>대학졸업(2,3년)이상</option>
              <option value="8" @(Model.edu_code == 8 ? "selected" : "")>대학교졸업(4년)이상</option>
              <option value="9" @(Model.edu_code == 9 ? "selected" : "")>석사졸업이상</option>
            </select>
          </div>
          <div class="form-group col-md-3">
            <label class="form-control-label" for="foreign_lang">외국어</label>
            <div class="form-inline">
              <select id="foreign_lang" name="foreign_lang" class="form-control">
                <option value="00" @(Model.foreign_lang == "00" ? "selected" : "")>외국어</option>
                <option value="01" @(Model.foreign_lang == "01" ? "selected" : "")>중국어</option>
                <option value="02" @(Model.foreign_lang == "02" ? "selected" : "")>영어</option>
                <option value="03" @(Model.foreign_lang == "03" ? "selected" : "")>불어</option>
                <option value="04" @(Model.foreign_lang == "04" ? "selected" : "")>독일어</option>
                <option value="05" @(Model.foreign_lang == "05" ? "selected" : "")>일본어</option>
                <option value="06" @(Model.foreign_lang == "06" ? "selected" : "")>러시아어</option>
                <option value="99" @(Model.foreign_lang == "99" ? "selected" : "")>기타</option>
                <option value="07" @(Model.foreign_lang == "07" ? "selected" : "")>스페인어</option>
              </select>
              <select id="foreign_level" name="foreign_level" class="form-control">
                <option value="0" @(Model.foreign_level == 0 ? "selected" : "")>능력</option>
                <option value="1" @(Model.foreign_level == 1 ? "selected" : "")>상</option>
                <option value="2" @(Model.foreign_level == 2 ? "selected" : "")>중</option>
                <option value="3" @(Model.foreign_level == 3 ? "selected" : "")>하</option>
              </select>
            </div>
          </div>
        </div>

        <div class="row">
          <div class="form-group col-md-3">
            <label class="form-control-label" for="businessCodeDiv">산업</label>

            <div class="input-group" id="businessCodeDiv">
              @Html.HiddenFor(x => x.business_code1, new { @class = "busiCode1" })
              @Html.HiddenFor(x => x.business_code2, new { @class = "busiCode2" })
              @Html.TextBoxFor(x => x.business_name2, new { @class = "form-control bg-white col-md-10 busiTargetText", @readonly = "readonly", @placeholder = "산업" })
              <span class="input-group-btn">
                <button type="button" class="btn btn-primary" onclick="javascript:FindBusinessSingle('businessCodeDiv')"><i class="icon wb-search"></i></button>
              </span>
              @*<div id="businessCodeDiv" class="form-control col-md-10 job_group">
                    @Html.HiddenFor(x => x.business_code1, new { @class = "busiCode1" })
                    @Html.HiddenFor(x => x.business_code2, new { @class = "busiCode2" })
                    @Html.TextBoxFor(x => x.business_name2, new { @class = "form-control bg-white col-md-10", @readonly = "readonly", @placeholder = "산업" })
                    <div class="input-group-btn">
                        <button type="button" class="btn btn-primary" onclick="javascript:FindBusinessSingle(this)">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </div>*@
            </div>
          </div>
          <div class="form-group col-md-3">
            <label class="form-control-label" for="p_seq">직무</label>
            <div class="input-group">
              <div id="jobCodeDiv" class="form-control col-md-10 job_group">
                <span class="job_list" name="jobBody">
                  @if (Model.jobList.Count > 0)
                  {
                    var jobVal = "";
                    <span>
                      @foreach (var job in Model.jobList)
                      {
                        if (!string.IsNullOrWhiteSpace(jobVal))
                        {
                          jobVal += "/";
                        }
                        jobVal += job.code_name3;
                        <input class="jobCode" type="hidden" id="jobCode" name="jobCode" code1="@job.code1" code2="@job.code2" code3="@job.code3">
                      }
                      @jobVal
                    </span>
                  }
                </span>
              </div>
              <span class="input-group-btn">
                <button type="button" class="btn btn-primary" onclick="javascript:FindJob(this)"><i class="icon wb-search" aria-hidden="true"></i></button>
              </span>
            </div>
          </div>
          <div class="form-group col-md-6">
            <label class="form-control-label" for="place">근무지</label>
            <div class="input-group">
              <div class="form-control col-md-10 placeDiv" id="placeDiv" name="placeDiv">
                @if (Model.placeList.Count > 0)
                {
                  foreach (var place in Model.placeList)
                  {
                    <span class="badge badge-outline badge-primary placeRow" style="margin-right:3px;">
                      <input type="hidden" id="pp_seq" name="pp_seq" value="@place.pp_seq">
                      <input type="hidden" id="place_code1" name="place_code1" value="@place.code1">
                      <input type="hidden" id="place_area1" name="place_area1" value="@place.area1">
                      <input type="hidden" id="place_code2" name="place_code2" value="@place.code2">
                      <input type="hidden" id="place_area2" name="place_area2" value="@place.area2">
                      @if (place.code1 == place.code2)
                      {
                        @place.area2
                      }
                      else
                      {
                        @(place.area1 + " " + place.area2)
                      }
                      <i class="fas fa-times cur_hand" onclick="DeletePlace(this)"></i>
                    </span>
                  }
                }
              </div>
              <span class="input-group-btn">
                <button type="button" class="btn btn-success" onclick="FindPlace(this)"><i class="fas fa-plus" aria-hidden="true"></i></button>
              </span>
            </div>
          </div>
        </div>
        <div class="row">
          <div class="form-group col-md-6">
            <label class="form-control-label" for="assign_task">담당업무</label>
            @Html.TextAreaFor(x => x.assign_task, new { @class = "form-control", @rows = "3" })
          </div>
          <div class="form-group col-md-6">
            <label class="form-control-label" for="requirement">자격요건</label>
            @Html.TextAreaFor(x => x.requirement, new { @class = "form-control", @rows = "3" })

          </div>
        </div>

        <div class="form-group">
          <label class="form-control-label">제출서류</label>
          <div id="paperDiv" name="paperDiv" class="form-inline">
            <div class="checkbox-custom checkbox-primary">
              <input type="checkbox" id="is_kor_resume" value="1" @(Model.is_kor_resume == 1 ? "checked" : "")>
              <label for="is_kor_resume">국문이력서</label>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
            </div>
            <div class="checkbox-custom checkbox-primary">
              <input type="checkbox" id="is_eng_resume" value="1" @(Model.is_eng_resume == 1 ? "checked" : "")>
              <label for="is_eng_resume">영문이력서</label>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
            </div>
            <div class="checkbox-custom checkbox-primary">
              <input type="checkbox" id="is_portfolio" value="1" @(Model.is_portfolio == 1 ? "checked" : "")>
              <label for="is_portfolio">포트폴리오</label>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
            </div>
            <div class="checkbox-custom checkbox-primary">
              <input type="checkbox" id="is_self_introduction" value="1" @(Model.is_self_introduction == 1 ? "checked" : "")>
              <label for="is_self_introduction">자기소개서</label>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
            </div>
            <div class="checkbox-custom checkbox-primary">
              <input type="checkbox" id="is_etc" value="1" @(Model.is_etc == 1 ? "checked" : "")>
              <label for="is_etc">기타</label>&nbsp;&nbsp;
            </div>
            @Html.TextBoxFor(x => x.etc_comment, new { @class = "form-control", @autocomplete = "off" })
          </div>
        </div>
      </div>
    </div>

    <div class="panel panel-primary panel-line animation-scale-up" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms;">
      <div class="panel-heading">
        <h3 class="panel-title">
          <i class="fas fa-project-diagram"></i>
          Project 부가정보
        </h3>
        <div class="panel-actions">
          <a class="panel-action icon wb-minus" aria-expanded="true" data-toggle="panel-collapse" aria-hidden="true"></a>
        </div>
      </div>
      <div id="projectAdd" class="panel-body">
        <div class="row">
          <div class="form-group col-md-6">
            <label class="form-control-label">구인절차</label>
            <div class="form-inline">
              <div class="checkbox-custom checkbox-primary">
                <input type="checkbox" id="is_pre_interview" value="1" @(Model.is_pre_interview == 1 ? "checked" : "")>
                <label for="is_pre_interview">사전면접</label>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
              </div>

              <div class="checkbox-custom checkbox-primary">
                <input type="checkbox" id="is_number" value="1" @(Model.is_number == 1 ? "checked" : "")>
                <label></label>
              </div>
              <select class="form-control" id="interview_number" name="interview_number">
                <option value="1" @(Model.interview_number == 1 ? "selected" : "")>1</option>
                <option value="2" @(Model.interview_number == 2 ? "selected" : "")>2</option>
                <option value="3" @(Model.interview_number == 3 ? "selected" : "")>3</option>
                <option value="4" @(Model.interview_number == 4 ? "selected" : "")>4</option>
                <option value="5" @(Model.interview_number == 5 ? "selected" : "")>5</option>
              </select>
              <label for="interview_number">차 면접</label>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;

              <div class="checkbox-custom checkbox-primary">
                <input type="checkbox" id="is_personality_test" value="1" @(Model.is_personality_test == 1 ? "checked" : "")>
                <label for="is_personality_test">인적성검사</label>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
              </div>
            </div>
          </div>
          <div class="form-group col-md-3">
            <label class="form-control-label" for="genderMan">성별</label>
            <div>
              <div class="radio-custom radio-default radio-inline">
                <input type="radio" id="genderMan" name="gender_type" value="1" @(Model.gender_type == 1 ? "checked" : "")>
                <label for="hire">남</label>
              </div>
              <div class="radio-custom radio-default radio-inline">
                <input type="radio" id="genderWoman" name="gender_type" value="2" @(Model.gender_type == 2 ? "checked" : "")>
                <label for="genderWoman">여</label>
              </div>
              <div class="radio-custom radio-default radio-inline">
                <input type="radio" id="genderNone" name="gender_type" value="3" checked @(Model.gender_type == 3 ? "checked" : "")>
                <label for="genderNone">무관</label>
              </div>
            </div>
          </div>
          <div class="form-group col-md-3">
            <label class="form-control-label" for="start_age">연령대</label>
            <div class="form-inline">
              @Html.TextBoxFor(x => x.start_age, new { @class = "form-control col-md-5", @type = "number", @autocomplete = "off", @placeholder = "시작연령" })&nbsp;&nbsp;
              ~&nbsp;&nbsp;&nbsp;
              @Html.TextBoxFor(x => x.end_age, new { @class = "form-control col-md-5", @type = "number", @autocomplete = "off", @placeholder = "종료연령" })
            </div>
          </div>
        </div>
        <div class="row">
          <div class="form-group col-md-3">
            <label class="form-control-label" for="target_school">타겟학교</label>
            @Html.HiddenFor(x => x.target_school)
            @{
              var school_name = string.IsNullOrWhiteSpace(Model.target_school_campus) ? Model.target_school_name : Model.target_school_name + "(" + Model.target_school_campus + ")";
            }
            @Html.TextBox("school_name", school_name, new { @class = "form-control col-md-10", @placeholder = "학교명", @onkeydown = "FindSchool(this)" })
          </div>
          <div class="form-group col-md-3">
            <label class="form-control-label" for="target_major">타겟전공</label>
            @Html.HiddenFor(x => x.target_major)
            @Html.TextBox("major_name", Model.target_major_name, new { @class = "form-control col-md-10", @placeholder = "전공명", @onkeydown = "FindMajor(this)" })
          </div>
          <div class="form-group col-md-3">
            <label class="form-control-label" for="target_company">타겟회사</label>
            @Html.HiddenFor(x => x.target_company)
            @Html.TextBox("target_company_name", Model.target_company_name, new { @class = "form-control col-md-10", @placeholder = "회사명", @onkeydown = "FindCompany(this)" })
          </div>
          <div class="form-group col-md-3">
            <label class="form-control-label" for="keywordField">키워드<span style="color:red"> * 콤마 또는 엔터키로 구분</span></label>
            @{
              var keywordVal = "";
              if (Model.keywordList.Count > 0)
              {
                keywordVal = String.Join(",", Model.keywordList.Select(x => x.pk_name).ToArray());
              }
            }
            <input type="text" id="keywordField" name="keywordField" class="form-control" data-plugin="tokenfield" value="@keywordVal" />
          </div>
        </div>
        <div class="row">
          <div class="form-group col-md-3">
            <label class="form-control-label" for="confidentiallity">Confidentiallity</label>
            <div class="checkbox-custom checkbox-primary">
              <input type="checkbox" id="confidentiallity" name="confidentiallity" value="1" @(Model.confidentiallity == 1 ? "checked" : "")>
              <label for="inputUnchecked"></label>
            </div>
          </div>
          <div class="form-group col-md-3">
            <label class="form-control-label" for="expected_salary">예상연봉</label>
            @Html.TextBoxFor(x => x.expected_salary, new { @class = "form-control col-md-10", @type = "number", @autocomplete = "off" })
          </div>
          <div class="form-group col-md-3">
            <label class="form-control-label" for="fee_rate">수수료율</label>
            @Html.TextBoxFor(x => x.fee_rate, new { @class = "form-control col-md-10", @autocomplete = "off" })
          </div>
        </div>
      </div>
    </div>

    <div class="text-right">
      <button type="submit" id="btnSave" class="btn btn-primary">등록</button>
    </div>
  }

</div>

@section scripts {
  <script src="~/Libs/remark/global/vendor/bootstrap-tokenfield/bootstrap-tokenfield.min599c.js?v4.0.4"></script>
  <script src="~/Libs/remark/global/js/Plugin/bootstrap-tokenfield.min599c.js?v4.0.4"></script>

  <script type="text/javascript">
        var callJobObj;
