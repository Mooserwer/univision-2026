        //학과 검색
        function FindMajor(obj) {

            $(obj).autocomplete({
                source: function (request, response) {

                    $.ajax({
                        type: 'post',
                        url: '@Url.Action("FindCodeMajor", "Project")',
                        dataType: "json",
                        //request.term = $("#autocomplete").val()
                        data: {
                            major_name: request.term
                        },
                        success: function(data) {
                            //서버에서 json 데이터 response 후 목록에 뿌려주기 위함
                            response(
                                $.map(data.list, function (item) {
                                    return {
                                        label: item.major_name,
                                        value: item.major_name,
                                        major_code : item.major_code
                                    }
                                })
                            );

                            $(".ui-autocomplete").highlight(request.term);
                        }
                    });
                },
                autoFocus:true, //첫번째 값을 자동 focus한다
                minLength: 2,  //조회를 위한 최소글자수
                select: function (event, ui) {
                    $("#target_major").val(ui.item.major_code)
                }
            });
        }

        //업체 검색
        function FindCompany(obj) {

            $(obj).autocomplete({
                source: function (request, response) {

                    $.ajax({
                        type: 'post',
                        url: '@Url.Action("FindApiCompany", "Project")',
                        dataType: "json",
                        //request.term = $("#autocomplete").val()
                        data: {
                            companyName: request.term
                        },
                        success: function(data) {
                            //서버에서 json 데이터 response 후 목록에 뿌려주기 위함
                            response(
                                $.map(data.list, function (item) {
                                    return {
                                        label: item.WKPL_NM,
                                        value: item.WKPL_NM,
                                        g_seq : item.G_SEQ
                                    }
                                })
                            );

                            $(".ui-autocomplete").highlight(request.term);
                        }
                    });
                },
                autoFocus:true, //첫번째 값을 자동 focus한다
                minLength: 2,  //조회를 위한 최소글자수
                select: function (event, ui) {
                    $("#target_company").val(ui.item.g_seq)
                }
            });
        }

