@model Univision.Main.Models.Client.SeachClientModel
@using Univision.Security
@{
    Layout = null;
}

<style>
    h3 {
        margin-top: 0px !important;
    }

    .fancybox-title {
        text-align: left !important;
    }
</style>

<script>
    $('#searchTxt').keypress(function (event) {

        if (event.which == 13) {
            $('#btnSearch').click();
            return false;
        }
    });
</script>

<div class="form-inline mb-10">
    <div class="input-group col-md-12 no-side-space">
        @Html.TextBoxFor(x => x.searchTxt, new { @class = "form-control", @placeholder = "업체명" })
        <button type="button" class="btn btn-primary" id="btnSearch" onclick="FancyBoxSearchAndPageMove(1);"><i class="fas fa-search" aria-hidden="true"></i></button>
    </div>
</div>


<div class="panel" style="margin-bottom:0px !important;">
    <div class="panel-body" style="padding: 5px 10px 5px 10px;">
        <div class="">
            <table class="block_table table table-borderless table-hover">
                <colgroup>
                    <col style="width:30%" />
                    <col style="width:10%" />
                    <col style="width:20%" />
                    <col style="width:40%" />
                </colgroup>
                <thead class="text-center">
                    <tr>
                        <th class="tbw50">업체명</th>
                        <th class="tbw50">사업자번호</th>
                        <th class="hidden-sm-down">업종</th>
                        <th class="hidden-sm-down">주소</th>
                    </tr>
                </thead>
                <tbody id="clientSearchBody" class="text-center" style="vertical-align:middle;">
                    @if (Model.list.Count > 0)
                    {
                        foreach (var data in Model.list)
                        {
                            <tr>
                                <td class="text-truncate" style="text-align:left;" title="@data.WKPL_NM">
                                    <label class="form-control-plaintext" style="cursor:pointer" onclick="selectCompany('@data.G_SEQ', '@data.WKPL_NM', '@data.BZOWR_RGST_NO', '@data.VLDT_VL_KRN_NM', '@data.WKPL_ROAD_NM_DTL_ADDR');">
                                        @data.WKPL_NM
                                    </label>
                                </td>
                                <td>
                                    @data.BZOWR_RGST_NO
                                </td>
                                <td class="text-truncate hidden-sm-down" title="@data.VLDT_VL_KRN_NM">
                                    @Utils.Truncate(data.VLDT_VL_KRN_NM, 10)
                                </td>
                                <td class="text-truncate hidden-sm-down" style="text-align:left;">
                                    @data.WKPL_ROAD_NM_DTL_ADDR
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5">데이터가 없습니다.</td>
                        </tr>
                    }

                    <tr>
                        <td colspan="5" style="text-align:right"> <font color="red"><b><a href="javascript:selfClientInput();"> -> 검색하신 업체가 없으시면 눌러주세요.</a></b></font></td>
                    </tr>

                </tbody>
            </table>
            @Html.PageAjaxLinksWithFunction(Model.PagingInfo,
                    ViewContext.HttpContext.Request.Url.AbsoluteUri,
                    x => String.Format("javascript:FancyBoxSearchAndPageMove({0})", x))
        </div>


    </div>
</div>

<script type="text/javascript">

    function selectCompany(g_seq, wkpl_nm, bzowr_rgst_no, vldt_vl_krn_nm, wkpl_road_nm_dtl_addr) {
        $("#g_seq").val(g_seq);
        $("#addr1").val(wkpl_road_nm_dtl_addr);
        //$("#biz_code").val(bzowr_rgst_no);
        $("#kor_name").val(wkpl_nm);
        $("#CreateForm").formValidation('revalidateField', 'kor_name');
        //$("#checkValue").val(2);
        //$("#checkClient").html("이용가능한 업체입니다.");
        //$("#btnSave").removeAttr("disabled");
        //$("#btnSave").removeClass("disabled");

        $.fancybox.close();
    }

    function selfClientInput() {
        $("#checkValue").val(2);
        //$("#checkClient").html("이용가능한 업체입니다.");
        //$("#btnSave").removeAttr("disabled");
        //$("#btnSave").removeClass("disabled");
        $.fancybox.close();
    }


    function FancyBoxSearchAndPageMove(page) {
        if (page == null || page == undefined)
            page = 1;

        $.ajax({
            url: '@Url.Action("ClientSearch", "Client")',
            data: {
                searchTxt: $("#searchTxt").val(),
                page: page
            },
            dataType: 'html',
            type: 'POST',
            beforeSend: function () {

            }
        })
        .done(function (view) {

            $.fancybox({
                'content': view,
                'width': $(".fancybox-outer").width(),
                'height': $(".fancybox-outer").height(),
                'autoDimensions': false,
                'type': 'iframe',
                'autoSize': false,
                'title': $(".fancybox-title").text(),
                helpers: {
                    title: {
                        type: 'inside',
                        position: 'top'
                    },
                    overlay: {
                        closeClick: false
                    }
                }
            });

        })
        .always(function () {

        });
    }

</script>