@model Univision.Main.Models.Client.ClientPopupModel
@{
    Layout = null;
}

<style>
    .fancybox-inner .form-group{
        margin-bottom:5px;
    }

    .custom_tooltip{
        background: #3e8ef7 !important;
        opacity: 100 !important;
        border: 0px!important;
        -webkit-box-shadow: 0 0 0px #aaa !important;
        box-shadow: 0 0 0px #aaa !important;
    }

</style>

<div class="container">
  @using (Html.BeginForm("ClientActivityCreate", "Client", FormMethod.Post, new { @id = "ActivityCreateForm" }))
  {
    <div class="row">
      <div class="col-12 col-md-8">
        <input type="hidden" id="calSeq" name="calSeq" value="@Model.log_data.cal_seq" />
        <input type="hidden" id="cSeq" name="cSeq" value="@ViewBag.cSeq" />
        <div class="form-group">
          <label class="form-control-label small" for="biz_type" title="메모 제목">Title</label>
          @Html.TextBox("title", Model.log_data.title, new { @class = "form-control form-control-sm", @placeholder = "메모 제목" })
        </div>
      </div>
      <div class="col-12 col-md-4 form-group">
        <label class="form-control-label small" for="log_date" title="일정">Date</label>
        <div class="input-group input-group-sm">
          @Html.TextBox("log_date", Utils.ConvertDateTimeHourToString2(Model.log_data.log_date), new { @class = "form-control jDateTimePicker", @autocomplete = "off" })
          <span class="input-group-addon cur_hand">
            <i class="fas fa-calendar-alt" aria-hidden="true"></i>
          </span>
        </div>
      </div>
    </div>
    <div class="row">
      <div class="col-md-12 form-group">
        <div class="checkbox-custom checkbox-custom-sm checkbox-primary" title="체크 후 등록 시 스케쥴에도 함께 등록 됩니다.">
          <input type="checkbox" id="is_schedule" name="is_schedule" value="1" @(Model.is_schedule == 1 ? "checked" : "")>
          <label for="is_schedule" style="">
            Add with the schedule <span class="d-md-inline-block d-none">(스케줄에 함께 등록)</span><i class="fas fa-question-circle"></i>
          </label>
        </div>
      </div>
    </div>
    <div class="row">
      <div class="col-md-12 form-group">
        <select id="act_type" name="act_type" class="form-control w-150">
          <option value="1" @(Model.log_data.act_type == 1 ? "selected" : "")>BD / Progress</option>
          <option value="2" @(Model.log_data.act_type == 2 ? "selected" : "")>회사정보</option>
          <option value="9" @(Model.log_data.act_type == 9 ? "selected" : "")>기타</option>
        </select>
        <span id="span_act_type" class="d-none font-size-12">- 작성 사항: BD 배경, 컨택 경로, 커뮤니케이션 현황, 지속적인 진행 상황 업데이트 등</span>
      </div>
    </div>
    <div class="row">
      <div class="col-12 form-group">
        <label class="form-control-label form-control-label-sm" for="log_comment" title="내용">Memo</label>
        @Html.TextArea("log_comment", Model.log_data.log_comment, new { @class = "form-control", @placeholder = "메모 내용", @rows = "6" })
      </div>
    </div>


    <div class="row">
      <div class="col-12 pt-10 text-right">
        <button type="submit" id="ActivitySaveBtn" class="btn btn-sm btn-primary w-100" title="저장하기">
          <i class="icon wb-check"></i>
          Submit
        </button>
      </div>
    </div>
  }

</div>




<script type="text/javascript">
  if ($("#log_comment").val() != "") {
    $("#log_comment").val($("#log_comment").val().replace(/&lt;/g, "<").replace(/&gt;/g, ">"));
  }
  $(document).ready(function () {
        StopEnterSubmit()

        $('#act_type').change(function () {
          var type = $(this).val();
          console.log(type)
          if (type == "1") {
            $('#span_act_type').removeClass("d-none");
          } else {
            $('#span_act_type').removeClass("d-none").addClass("d-none");
          }
        })
    $('#act_type').change();
        BindDateTimePicker(".jDateTimePicker");

        $(".fa-question-circle").tooltip({
            tooltipClass: "custom_tooltip"
        });

        $("#log_date").change(function () {
            $('#ActivityCreateForm').formValidation('revalidateField', 'log_date');
        });

        //유효성 검사 및 폼 전송
        $("#ActivityCreateForm").formValidation({
            framework: "bootstrap4",
            button: {
                selector: "#ActivitySaveBtn",
                disabled: "disabled"
            },
            submitHandler: function () {

            },
            icon: null,
            fields: {
                title: {
                    validators: {
                        notEmpty: {
                            message: "제목은 필수 입력 항목 입니다."
                        }
                    }
                },
                log_date: {
                    validators: {
                        notEmpty: {
                            message: "일자는 필수 입력 항목 입니다."
                        },
                        date: {
                            format: 'YYYY-MM-DD h:m',
                            message: '올바른 날짜 형식이 아닙니다.',
                        }
                    }
                },
                log_comment : {
                    validators: {
                        notEmpty: {
                            message: "내용은 필수 입력 항목 입니다."
                        }
                    }
                }
            },
            err: {
                clazz: "invalid-feedback"
            },
            control: {
                valid: "is-valid",
                invalid: "is-invalid"
            },
            row: {
                invalid: "has-danger"
            }
        })
        //validation 성공시, ajax submit.
        //ajax submit 사용하지 않을 경우, on 부분은 삭제해도 됨.
        .on('success.form.fv', function (e) {
            //기본 submit 이벤트 취소.
            e.preventDefault();
            
            alertify.confirm()
                    .set({
                        'labels': { ok: '확인', cancel: '취소' },
                        'onok': function () {
                            
                            var c_seq;
          
                            if ($("#cSeq").val() != 0) {
                                c_seq = $("#cSeq").val();
                            }
                            else {
                                c_seq = $("#c_seq").val();
                            }
                            var formURL = $("#ActivityCreateForm").attr("action");

                            
                            $.ajax({
                                url: formURL,
                                type: "POST",
                                dataType: 'json',
                                data: {
                                    cal_Seq: $("#calSeq").val(),
                                    c_seq: c_seq,
                                    title: $("#title").val(),
                                  log_comment: $("#log_comment").val().replace(/</g, "&lt;").replace(/>/g, "&gt;"),
                                    log_date: $("#log_date").val(),
                                  is_schedule: $("#is_schedule").is(":checked") ? 1 : 0,
                                    act_type : $("#act_type").val(),
                                },
                                beforeSend: function () {
                                    showLoading("#ActivityCreateForm");
                                },
                                success: function (json) {
                                    hideLoading("#ActivityCreateForm");

                                    if (json.ok) {
                                        NormalAlert("활동내역을 등록 했습니다.");
                                        location.reload();
                                        //등록 후 이벤트 작성하시면 되요.
                                    }
                                    else {
                                        ErrorAlert(json.message);
                                    }
                                },
                                error: function (jqXHR, textStatus, errorThrown) {
                                    hideLoading("#ActivityCreateForm");

                                    ErrorAlert("알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.");
                                }
                            });
                        },
                        'oncancel': function () {
                    
                            return;
                        },
                    })
                    .setHeader('<i class="fas fa-exclamation-triangle" style="color:#FFDC2E"></i>활동내역 등록')
                    .setting({
                        message: "활동내역을 등록하시겠습니까?",
                    })
                    .show();
        });

    });

</script>