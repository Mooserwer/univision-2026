            <label for="data_fee_type_A">연봉 기준</label>
          </div>
          <div class="radio-custom radio-custom-sm radio-primary radio-inline ml-10">
            <input type="radio" id="data_fee_type_B" name="data.fee_type" class="radio_contract_fee_type" value="B" @(Model.data.fee_type == "B" ? "checked" : "")>
            <label for="data_fee_type_B">직급 기준</label>
          </div>
          <div class="radio-custom radio-custom-sm radio-primary radio-inline ml-10">
            <input type="radio" id="data_fee_type_C" name="data.fee_type" class="radio_contract_fee_type" value="C" @(Model.data.fee_type == "C" ? "checked" : "")>
