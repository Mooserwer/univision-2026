                      <option value="30">임원급</option>
                      <option value="20">최고재무경영자</option>
                      <option value="10">최고 경영자</option>
                    </select>
                    <span class="input-group-text small">이상&nbsp;&nbsp;</span>
                    <select name="fee_step_e" class="form-control">
                      <option value="">없음</option>
                      <option value="100">신입사원급</option>
                      <option value="90">경력사원급</option>
                      <option value="80" selected>대리급</option>
