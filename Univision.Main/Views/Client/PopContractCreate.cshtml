                      </select>
                      <span class="input-group-text small">미만</span>
                    </div>
                  </td>
                  <td class="text-center">
                    <input type="text" name="fee_rate_per" value="@fee.percentage" class="form-control text-right form-control-sm" placeholder="%" />
                  </td>
                  <td class="text-center">
                    <button type="button" onclick="RemoveRowFee(this);" class="btn btn-xs btn-danger"><i class="fa fa-minus"></i></button>
                  </td>
                </tr>
              }
            }
            else
            {
              <tr>
                <td class="text-center">
                  <div class="input-group input-group-sm w-p100">
                    <select name="fee_step_s" class="form-control">
                      <option value="" selected>없음</option>
