  function RemoveRowFee(obj) {
    $(obj).closest('tr').remove();
  }
  function setGrtField() {
    var type = $('#data_grt_type').val()
    //console.log(type)
    if (type == "") {
      $('.grt_field').removeClass("d-none").addClass("d-none")
    } else {
      $('.grt_field').removeClass("d-none")
    }
  }

  function setDebutField() {
    var type = $('#data_is_construct_debut').val()
    //console.log(type)
    if (type == "N") {
      $('.debut_field').removeClass("d-none").addClass("d-none")
      $('#data_construct_debut_per').val(0)
    } else {
      $('.debut_field').removeClass("d-none")
      if ($('#data_construct_debut_per').val() >= 100 || $('#data_construct_debut_per').val() == 0) {
        $('#data_construct_debut_per').val(30)
      }
    }
  }

  function setDepositField() {
    var type = $('#data_deposit_gubun1').val()
    //console.log(type)
    if (type == "") {
      $('.deposit_field').removeClass("d-none").addClass("d-none")
    } else {
      $('.deposit_field').removeClass("d-none")
    }
  }
  function setFeeType() {
    $("#contract_fee_type_a").removeClass("d-none").addClass("d-none");
    $("#contract_fee_type_b").removeClass("d-none").addClass("d-none");
    $("#contract_fee_type_c").removeClass("d-none").addClass("d-none");

    var st = $(".radio_contract_fee_type:checked").val();
    if (st && st != "") {
      $("#contract_fee_type_" + st.toLowerCase()).removeClass("d-none");
    }

  }
  $(".radio_contract_fee_type").click(setFeeType);
  $('#data_deposit_gubun1').change(setDepositField);
  $('#data_grt_type').change(setGrtField);
  $('#data_is_construct_debut').change(setDebutField);
  setFeeType()
  setDepositField();
  setGrtField();
  setDebutField();

