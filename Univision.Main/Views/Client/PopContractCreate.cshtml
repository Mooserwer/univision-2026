@model Univision.Core.Models.DTO.Response.Client.ClientContractDetailModel
@using Univision.Security
@{
  Layout = null;
}
<script>
    function SaveContract() {
        var mode = $('input[name=contract_edit_mode]:checked').val() ? $('input[name=contract_edit_mode]:checked').val() : "";

        var model = {
            edit_mode: mode,
            data: {},
            fee_step : []
        }

        var contract = {
            cc_seq: mode == "A" ? $('#data_cc_seq').val() : 0, //수정일때 필수
            c_seq: $('#c_seq').val(), //필수
            contract_date: $('#data_contract_date').val(), //필수
            fee_type: $('input[name=data\\.fee_type]:checked').val() ? $('input[name=data\\.fee_type]:checked').val() : "",
            is_construct_debut: $('#data_is_construct_debut]').val(),
            construct_debut_per: ($('#data_is_construct_debut]').val() == "Y" ? $('#construct_debut_per').val() : ""),
            vat_type: $('#vat_type').val(),
            deposit_gubun1: $('#data_deposit_gubun1').val(),
            deposit_gubun2: $('#data_deposit_gubun1').val() != "" ? $('#data_deposit_gubun2').val() : "",
            deposit_period: $('#data_deposit_gubun1').val() != "" ? $('#data_deposit_period').val() : "",
            grt_type: $('#data_grt_type').val(),
            grt_period: $('#data_grt_type').val() != "" ? $('#data_grt_period').val() : "",
            grt_gubun: $('#data_grt_type').val() != "" ? $('#data_grt_gubun').val() : "",
            fix_fee_rate: $('input[name=data\\.fee_type]:checked').val() == "C" ? $('#data_fix_fee_rate').val() : "",
            contract_comment: $('#contract_comment').val(),
            currency_cd: $('#contract_currency_name').val(),
        }

        model.data = contract;
        if (model.data.fee_type == "A") {
            $('#contract_fee_type_a tbody tr').each(function () {
                model.fee_step.push({
                    start_income : $(this).find('input[name=fee_step_s]').val(),
                    end_income : $(this).find('input[name=fee_step_e]').val(),
                    percentage : $(this).find('input[name=fee_rate_per]').val()
                })

            })
        } else if (model.data.fee_type == "B") {
            $('#contract_fee_type_b tbody tr').each(function () {
                model.fee_step.push({
                    start_income : $(this).find('select[name=fee_step_s]').val(),
                    end_income : $(this).find('select[name=fee_step_e]').val(),
                    percentage : $(this).find('input[name=fee_rate_per]').val()
                })

            })
        }

        $.ajax({
            url: '@Url.Action("PopContractCreate", "Client")',
            type: "POST",
            dataType: 'json',
            data: model,
            beforeSend: function () {
                showLoading("#client_contract_pop");
            },
            success: function (json) {
                hideLoading("#client_contract_pop");
                if (json.ok) {

                    callContractDetail($('#c_seq').val());

                    $.fancybox.close()

                }
                else {
                    ErrorAlert(json.message);
                }
            },
            error: function (jqXHR, textStatus, errorThrown) {
                hideLoading("#client_contract_pop");
                ErrorAlert("알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요1.");
            }
        });

        //console.log(model);

    }
</script>
<div class="pt-5" id="client_contract_pop">
  @if (Model.data.cc_seq > 0)
  {
    <div class="row">
      <div class="input-group input-group-sm">
        <div class="">
          <div class="radio-custom radio-primary radio-inline ml-10">
            <input type="radio" id="contract_edit_mode_a" name="contract_edit_mode" value="A">
            <label for="contract_edit_mode_a">기존 계약 정보수정</label>
          </div>
          <div class="radio-custom radio-primary radio-inline ml-10">
            <input type="radio" id="contract_edit_mode_b" name="contract_edit_mode" checked value="B">
            <label for="contract_edit_mode_b">갱신(새로운 계약으로 생성됩니다.)</label>
          </div>
        </div>
      </div>
    </div>
  }
  <div class="row">
    @Html.HiddenFor(x => x.data.cc_seq)
    <div class="form-group col-md-6">
      <div class="row">
        <div class="col-6 col-md-12">
          <label class="form-control-label form-control-label-sm text-secondary">계약일</label>
          @Html.TextBoxFor(x => x.data.contract_date, new { @class = "form-control form-control-sm jDatePicker", @size = "10", @placeholder = "YYYY-MM-DD", @autocomplete = "off" })
        </div>
        <div class="col-4 col-md-8">
          <label class="form-control-label form-control-label-sm text-secondary">기초조사비 공제 여부</label>
          
            <select name="data.is_construct_debut" id="data_is_construct_debut" class="form-control">
              <option @(Model.data.is_construct_debut == "Y" ? "selected" : "") value="Y">Yes</option>
              <option @(Model.data.is_construct_debut != "Y" ? "selected" : "") value="N">No</option>
            </select>
          
        </div>
        <div class="col-2 col-md-4 debut_field">
          <label class="form-control-label form-control-label-sm text-secondary">공제 비율(%)</label>
          
            @Html.TextBoxFor(x => x.data.construct_debut_per, new { @type = "number", @class = "form-control text-right", @placeholder = "0", @autocomplete = "off" })

        </div>
        <div class="col-6 col-md-12">
          <label class="form-control-label form-control-label-sm text-secondary">VAT 구분 <!--(인보이스 발행 시 기본설정)--></label>
          <div class="input-group input-group-sm">
            <select name="vat_type" id="vat_type" class="form-control form-control-sm fee_change">
              <option value="3" @(Model.data.vat_type == 3 ? "selected" : "")>면세</option>
              <option value="1" @(Model.data.vat_type == 1 ? "selected" : "")>VAT별도</option>
              <option value="0" @(Model.data.vat_type == 0 ? "selected" : "")>VAT포함</option>
              <option value="2" @(Model.data.vat_type == 2 ? "selected" : "")>영세율(0%)</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <div class="form-group col-md-6">
      <div class="row">
        <div class="col-6 col-md-12">
          <label class="form-control-label form-control-label-sm text-secondary">입금일 지정</label>
          <div class="input-group input-group-sm">
            <select name="data.deposit_gubun1" id="data_deposit_gubun1" class="w-p50 form-control">
              <option value="">[입금일 지정정보 없음]</option>
              <option @(Model.data.deposit_gubun1 == "계산서를 수령한 날로부터" ? "selected" : "") value="계산서를 수령한 날로부터">계산서를 수령한 날로부터</option>
              <option @(Model.data.deposit_gubun1 == "세금계산서를 수령한 날로부터" ? "selected" : "") value="세금계산서를 수령한 날로부터">세금계산서를 수령한 날로부터</option>
              <option @(Model.data.deposit_gubun1 == "입사일로 부터" ? "selected" : "") value="입사일로 부터">입사일로 부터</option>
            </select>
            @Html.TextBoxFor(x => x.data.deposit_period, new { @type = "number", @class = "w-p25 form-control deposit_field", @placeholder = "0", @autocomplete = "off" })
            <select name="data.deposit_gubun2" id="data_deposit_gubun2" class="w-p25 form-control deposit_field">
              <option @(Model.data.deposit_gubun2 == "주" ? "selected" : "") value="주">주 이내</option>
              <option @(Model.data.deposit_gubun2 == "개월" ? "selected" : "") value="개월">개월 이내</option>
              <option @(Model.data.deposit_gubun2 == "일" ? "selected" : "") value="일">일 이내</option>
            </select>
          </div>

        </div>
        <div class="col-6 col-md-12">
          <label class="form-control-label form-control-label-sm text-secondary">후보자 보증기간</label>


          <div class="input-group input-group-sm">
            <select name="data.grt_type" id="data_grt_type" class="w-p50 form-control">
              <option @(String.IsNullOrEmpty(Model.data.grt_type) ? "selected" : "") value="">[보증기간 없음]</option>
              <option @(!String.IsNullOrEmpty(Model.data.grt_type) ? "selected" : "") value="입사일로 부터">입사일로 부터</option>
            </select>
            @Html.TextBoxFor(x => x.data.grt_period, new { @type = "number", @class = "w-p25 form-control grt_field", @placeholder = "0", @autocomplete = "off" })
            <select name="data.grt_gubun" id="data_grt_gubun" class="w-p25 form-control grt_field">
              <option @(Model.data.grt_gubun == "일" ? "selected" : "") value="일">일</option>
              <option @(Model.data.grt_gubun == "개월" ? "selected" : "") value="개월">개월</option>
            </select>
          </div>

        </div>

      </div>
    </div>


  </div>
  <div class="row">
    <div class="form-group col-6">
      <label class="form-control-label form-control-label-sm text-secondary">수수료율 반영 구분</label>
      <div class="input-group input-group-sm">
        <div class="">
          <div class="radio-custom radio-custom-sm radio-primary radio-inline">
