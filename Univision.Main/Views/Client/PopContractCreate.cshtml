                  <input type="text" name="fee_rate_per" value="30" class="form-control text-right form-control-sm" placeholder="%" />
                </td>
                <td class="text-center">
                  <button type="button" onclick="RemoveRowFee(this);" class="btn btn-xs btn-danger"><i class="fa fa-minus"></i></button>
                </td>
              </tr>
            }
          </tbody>
        </table>
