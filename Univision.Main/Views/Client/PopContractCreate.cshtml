                  <option value="KRW" @((Model.data.currency_cd == "KRW" || String.IsNullOrEmpty(Model.data.currency_cd)) ? "selected" : "")>KRW(원)</option>
                  <option value="USD" @(Model.data.currency_cd == "USD" ? "selected" : "")>USD(미국달러)</option>
                  <option value="HKD" @(Model.data.currency_cd == "HKD" ? "selected" : "")>HKD(홍콩달러)</option>
                  <option value="YEN" @(Model.data.currency_cd == "YEN" ? "selected" : "")>YEN(엔화)</option>
                  <option value="GBP" @(Model.data.currency_cd == "GBP" ? "selected" : "")>GBP(파운드)</option>
                  <option value="DEM" @(Model.data.currency_cd == "DEM" ? "selected" : "")>DEM(마르크)</option>
                  <option value="FRF" @(Model.data.currency_cd == "FRF" ? "selected" : "")>FRF(프랑스 프랑)</option>
                  <option value="CHF" @(Model.data.currency_cd == "CHF" ? "selected" : "")>CHF(스위스 프랑)</option>
                  <option value="EUR" @(Model.data.currency_cd == "EUR" ? "selected" : "")>EUR(유로)</option>
                  <option value="CNY" @(Model.data.currency_cd == "CNY" ? "selected" : "")>CNY(위안)</option>
                  <option value="AUD" @(Model.data.currency_cd == "AUD" ? "selected" : "")>AUD(호주달러)</option>
                  <option value="NZD" @(Model.data.currency_cd == "NZD" ? "selected" : "")>NZD(뉴질랜드달러)</option>
                  <option value="CAD" @(Model.data.currency_cd == "CAD" ? "selected" : "")>CAD(캐나다달러)</option>
                </select>

              </th>
              <th class="w-p25 text-center">수수료율</th>
              <th class="w-p15 text-center">
                <button type="button" class="btn btn-xs btn-success" onclick="AddRowFee('a');"><i class="fa fa-plus"></i></button>
              </th>
            </tr>
          </thead>
          <tbody>
            @if (Model.feeList.Count() > 0 && Model.data.fee_type == "A")
            {
              foreach (var fee in Model.feeList)
              {
                <tr>
                  <td class="text-center">
                    <div class="input-group input-group-sm w-p100">
                      <input type="text" name="fee_step_s" value="@fee.start_income" class="form-control text-right" />
                      <span class="input-group-text small">이상&nbsp;&nbsp;</span>
                      <input type="text" name="fee_step_e" value="@fee.end_income" class="form-control text-right" />
                      <span class="input-group-text small">미만</span>
                    </div>
                  </td>
                  <td class="text-center">
                    <input type="text" name="fee_rate_per" value="@fee.percentage" class="form-control text-right form-control-sm" placeholder="%" />
                  </td>
                  <td class="text-center">
                    <button type="button" onclick="RemoveRowFee(this);" class="btn btn-xs btn-danger"><i class="fa fa-minus"></i></button>
                  </td>
                </tr>
              }
            }
            else
            {
              <tr>
                <td class="text-center">
                  <div class="input-group input-group-sm w-p100">
                    <input type="text" name="fee_step_s" value="" class="form-control text-right" />
                    <span class="input-group-text small">이상&nbsp;&nbsp;</span>
                    <input type="text" name="fee_step_e" value="50000000" class="form-control text-right" />
                    <span class="input-group-text small">미만</span>
                  </div>
                </td>
                <td class="text-center">
                  <input type="text" name="fee_rate_per" value="20" class="form-control text-right form-control-sm" placeholder="%" />
                </td>
                <td class="text-center">
                  <button type="button" onclick="RemoveRowFee(this);" class="btn btn-xs btn-danger"><i class="fa fa-minus"></i></button>
                </td>
              </tr>
              <tr>
                <td class="text-center">
                  <div class="input-group input-group-sm w-p100">
                    <input type="text" name="fee_step_s" value="50000000" class="form-control text-right" />
                    <span class="input-group-text small">이상&nbsp;&nbsp;</span>
                    <input type="text" name="fee_step_e" value="100000000" class="form-control text-right" />
                    <span class="input-group-text small">미만</span>
                  </div>
                </td>
                <td class="text-center">
                  <input type="text" name="fee_rate_per" value="25" class="form-control text-right form-control-sm" placeholder="%" />
                </td>
                <td class="text-center">
                  <button type="button" onclick="RemoveRowFee(this);" class="btn btn-xs btn-danger"><i class="fa fa-minus"></i></button>
                </td>
              </tr>
              <tr>
                <td class="text-center">
                  <div class="input-group input-group-sm w-p100">
                    <input type="text" name="fee_step_s" value="100000000" class="form-control text-right" />
                    <span class="input-group-text small">이상&nbsp;&nbsp;</span>
                    <input type="text" name="fee_step_e" value="" class="form-control text-right" />
                    <span class="input-group-text small">미만</span>
                  </div>
