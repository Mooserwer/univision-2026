@model Univision.Main.Models.Client.ClientPopupModel
@{
    Layout = null;
}

@using (Html.BeginForm("ClientTaxCreate", "Client", FormMethod.Post, new { @id = "TaxCreateForm" }))
{
    <div class="row mr-0 pr-0">
        <input type="hidden" id="ctcSeq" name="ctcSeq" value="@Model.tax_data.ctc_seq" />
        <div class="col-lg-3 col-md-6 form-group">
            <label class="form-control-label " for="biz_type">
                <b>Name</b>
            </label>
            @Html.TextBox("name", Model.tax_data.name, new { @class = "form-control form-control-sm" })
        </div>
        <div class="col-lg-3 col-md-6 form-group">
            <label class="form-control-label" for="biz_type">
                <b>Department</b>
            </label>
            @Html.TextBox("division", Model.tax_data.division, new { @class = "form-control form-control-sm" })
        </div>


        <div class="col-lg-3 col-md-6 form-group">
            <label class="form-control-label" for="biz_type">
                <b>E-mail</b>
            </label>
            @Html.TextBox("email", Model.tax_data.email, new { @class = "form-control form-control-sm" })
        </div>
        <div class="col-lg-3 col-md-6 form-group">
            <label class="form-control-label" for="biz_type">
                <b>Mobile</b>
            </label>
            @Html.TextBox("cell_phone", Model.tax_data.cell_phone, new { @class = "form-control form-control-sm" })
        </div>
        <div class="col-lg-3 col-md-6 form-group">
            <label class="form-control-label" for="biz_type">
                <b>Name for Tax</b>
            </label>
            @Html.TextBox("deposit_manager", Model.tax_data.deposit_manager, new { @class = "form-control form-control-2" })
        </div>
        <div class="col-lg-3 col-md-6 form-group">
            <label class="form-control-label" for="biz_type">
                <b>Email For Tax</b>
            </label>
            @Html.TextBox("deposit_email", Model.tax_data.deposit_email, new { @class = "form-control form-control-2" })
        </div>
        <div class="col-lg-3 col-md-6 form-group">
            <label class="form-control-label" for="biz_type">
                <b>Phone</b>
            </label>
            @Html.TextBox("phone", Model.tax_data.phone, new { @class = "form-control form-control-2" })
        </div>
        <div class="col-lg-3 col-md-6 form-group" style="text-align:center;">
            <div class="p-5">
                <label class="form-control-label" for="">&nbsp;</label>
                <div class="p-5">
                    <div class="checkbox-custom checkbox-default checkbox-inline">
                        <input type="checkbox" name="sameBtn" id="sameBtn" />
                        <label for="sameBtn" title="계산서 담당자명, 이메일이 발행용 항목과 동일 할 경우 체크해 주세요.">Same Name / E-mail</label>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="row mr-0 pr-0">
        <div class="col-md-12" style="text-align:right;">
            <button type="submit" id="TaxSaveBtn" class="btn btn-primary">등록</button>
        </div>
    </div>
}


<script type="text/javascript">

    var phoneValidator = {
        validators: {
            selector: "phone",
            callback: {
                message: "전화번호 혹은 휴대폰 번호 중 한 개의 번호는 입력 하셔야 합니다.",
                callback: function (input) {

                    var fv = $("#TaxCreateForm").data("formValidation");

                    let isEmpty = true;

                    if ($("#phone").val() != "" || $("#cell_phone").val() != "") {
                        isEmpty = false;
                    }

                    if (!isEmpty) {
                        // Update the status of callback validator for all fields
                        fv.updateStatus('phone', 'Valid', 'callback');
                        fv.updateStatus('cell_phone', 'Valid', 'callback');
                        return true;
                    }

                    return false;
                }
            }
        }
    };

    $(document).ready(function () {

        StopEnterSubmit();

        $("#cell_phone").change(function () {
            $('#TaxCreateForm').formValidation('revalidateField', 'cell_phone');
        });

        $("#TaxCreateForm").formValidation({
            framework: "bootstrap4",
            button: {
                selector: "#TaxSaveBtn",
                disabled: "disabled"
            },
            submitHandler: function () {
            },
            icon: null,
            fields: {
                name: {
                    validators: {
                        notEmpty: true
                    }
                },
                division: {
                    validators: {
                        notEmpty: true
                    }
                },
                deposit_manager: {
                    validators: {
                        notEmpty: true
                    }
                },
                deposit_email: {
                    validators: {
                        notEmpty: true
                    }
                },
                email: {
                    validators: {
                        notEmpty: true
                    }
                },
                phone: phoneValidator,
                cell_phone: phoneValidator,
            },
            err: {
                clazz: "invalid-feedback"
            },
            control: {
                valid: "is-valid",
                invalid: "is-invalid"
            },
            row: {
                invalid: "has-danger"
            }
        })
            .on('success.form.fv', function (e) {
                e.preventDefault();

                var formURL = $("#TaxCreateForm").attr("action");

                $.ajax({
                    url: formURL,
                    type: "POST",
                    dataType: 'json',
                    data: {
                        name: $("#name").val(),
                        division: $("#division").val(),
                        email: $("#email").val(),
                        phone: $("#phone").val(),
                        cell_phone: $("#cell_phone").val(),
                        deposit_manager: $("#deposit_manager").val(),
                        deposit_email: $("#deposit_email").val(),
                        c_seq: $("#c_seq").val(),
                        ctcSeq: $("#ctcSeq").val()
                    },
                    beforeSend: function () {
                        showLoading("#TaxCreateForm");
                    },
                    success: function (json) {
                        hideLoading("#TaxCreateForm");

                        if (json.ok) {
                            location.reload();
                        }
                        else {
                            ErrorAlert(json.message);
                        }
                    },
                    error: function (jqXHR, textStatus, errorThrown) {
                        hideLoading("#TaxCreateForm");

                        ErrorAlert("알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요1.");
                    }
                });
            });

        $('#sameBtn').click(function () {
            var same = this.checked;
            if (same == true) {
                $("#deposit_manager").val($("#name").val());
                $("#deposit_email").val($("#email").val());
                //$("input[name='deposit_manager']").val($("input[name='name']").val());
                //$("input[name='deposit_email']").val($("input[name='email']").val());
                $("#deposit_manager").filter('input:text')
                    //$("input[name='deposit_manager']").filter('input:text')
                    .attr('readonly', true)
                    .css('opacity', 0.5);
                $("#deposit_email").filter('input:text')
                    //$("input[name='deposit_email']").filter('input:text')
                    .attr('readonly', true)
                    .css('opacity', 0.5);
            } else {
                $("#deposit_manager").val("");
                $("#deposit_email").val("");
                //$("input[name='deposit_manager']").val("");
                //$("input[name='deposit_email']").val("");
                $("#deposit_manager").filter('input:text')
                    //$("input[name='deposit_manager']").filter('input:text')
                    .attr('readonly', false)
                    .css('opacity', 1);
                $("#deposit_email").filter('input:text')
                    //$("input[name='tax_deposit_email']").filter('input:text')
                    .attr('readonly', false)
                    .css('opacity', 1);
            }
        });
    });

</script>
