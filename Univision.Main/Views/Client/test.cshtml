
@{
    ViewBag.Title = "View";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/Libs/remark/global/vendor/bootstrap-table/bootstrap-table.min.js?v4.0.4"></script>
<script src="~/Libs/remark/global/vendor/bootstrap-table/extensions/mobile/bootstrap-table-mobile.min.js?v4.0.4"></script>
<div class="example">
    <div class="bootstrap-table">
        <div class="fixed-table-toolbar"></div>
        <div class="fixed-table-container" style="height: 250px; padding-bottom: 36px;">
            <div class="fixed-table-header" style="margin-right: 0px;">
                <table class="table table-hover" style="width: 717px;">
                    <thead>
                        <tr>
                            <th style="text-align: center; " data-field="Tid">
                                <div class="th-inner sortable both asc">LID</div>
                                <div class="fht-cell" style="width: 174px;"></div>
                            </th>
                            <th style="text-align: left; " data-field="First">
                                <div class="th-inner sortable both">First Name</div>
                                <div class="fht-cell" style="width: 319px;"></div>
                            </th>
                            <th style="" data-field="Score">
                                <div class="th-inner sortable both">Score</div>
                                <div class="fht-cell" style="width: 222px;"></div>
                            </th>
                        </tr>
                    </thead>
                </table>
            </div>
            <div class="fixed-table-body">
                <div class="fixed-table-loading" style="top: 37px; display: none;">Loading, please wait...</div>
                <table data-toggle="table" data-url="../assets/data/table_base.json" data-height="250" data-sort-name="Score" data-sort-order="desc" data-mobile-responsive="true" class="table table-hover" style="margin-top: -36px;">
                    <thead>
                    <tr>
                        <th style="text-align: center; " data-field="Tid">
                            <div class="th-inner sortable both asc">LID</div>
                            <div class="fht-cell"></div>
                        </th>
                        <th style="text-align: left; " data-field="First">
                            <div class="th-inner sortable both">First Name</div>
                            <div class="fht-cell"></div>
                        </th>
                        <th style="" data-field="Score">
                            <div class="th-inner sortable both">Score</div>
                            <div class="fht-cell"></div>
                        </th>
                    </tr>
                    </thead>
                    <tbody>
                    <tr data-index="0"> 
                        <td style="text-align: center; ">1</td> 
                        <td style="text-align: left; ">Jill</td> 
                        <td style="">50</td> 
                    </tr>
                    <tr data-index="1"> 
                        <td style="text-align: center; ">2</td> 
                        <td style="text-align: left; ">Eve</td> 
                        <td style="">94</td> 
                    </tr>
                </table>
            </div><div class="fixed-table-footer" style="display: none;">
            <table><tbody><tr></tr></tbody></table></div><div class="fixed-table-pagination" style="display: none;"></div>
        </div>
    </div><div class="clearfix"></div>
</div>

