@model Univision.Main.Models.DashBoard.DashBoardTopSummaryModel

@{
  ViewBag.Title = "Home(Dash Board)";
  Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
  .receipt-blinking {
    -webkit-animation: blink 1.0s ease-in-out infinite alternate;
    -moz-animation: blink 1.0s ease-in-out infinite alternate;
    animation: blink 1.0s ease-in-out infinite alternate;
  }

  @@-webkit-keyframes blink {
    0% {
      opacity: 0;
    }

    100% {
      opacity: 1;
    }
  }

  @@-moz-keyframes blink {
    0% {
      opacity: 0;
    }

    100% {
      opacity: 1;
    }
  }

  @@keyframes blink {
    0% {
      opacity: 0;
    }

    100% {
      opacity: 1;
    }
  }

</style>
<div class="page-content container-fluid">
  <div class="row d-none" id="ReceiptReady">
    <div class="col-md-12">
      <div class="page-header h-200 mb-30 border-danger border bg-red-100 shadow">
        <div class="text-center m-0 mt-30">
          <div class="font-size-20 mb-30 text-danger receipt-blinking">
            ※ 제출이 필요한 제경비<span class="text-dark" id="receiptReadyList"></span>가 있습니다.

          </div>

          <ul class="list-inline font-size-14">
            <li class="list-inline-item">
              <a href="@Url.Action("ReceiptList", "MyList")" title="제경비 제출하러 가기"><i class="fas fa-arrow-right" aria-hidden="true"> 제경비 제출하러 가기</i></a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
  <div class="row">

    <div class="col-4 col-lg-2">
      <!-- Card -->
      <div class="card card-block p-15 shadow">
        <div class="counter counter-md text-left">
          <div class="counter-label small text-uppercase mb-3" title="현재 진행 중인 프로젝트 수">PROJECT <small><br />in progress</small><br /><span class="blue-900 d-none d-md-inline-block">&lt;진행 프로젝트&gt;</span></div>
          <div class="counter-number-group mb-5 text-right">
            <span class="counter-number font-size-20" title="현재"><a href="@Url.Action("MyProjectList", "Project")" class="text-dark">@Model.pjtCnt</a></span>
            <span class="counter-number font-size-14 text-secondary" title="목표">/ 8</span>
          </div>
          <div class="counter-label">
            @{
              double pjt_per = Model.pjtCnt / 8.0 * 100;
            }
            <div class="progress progress-xs mb-5" title="@(pjt_per)%">
              <div class="progress-bar progress-bar-info bg-blue-600" aria-valuenow="@pjt_per" aria-valuemin="0"
                   aria-valuemax="100" style="width: @(pjt_per)%" role="progressbar">
                <span class="sr-only">@(pjt_per)%</span>
              </div>
            </div>

          </div>
        </div>
      </div>
      <!-- End Card -->
    </div>
    <div class="col-4 col-lg-2">
      <!-- Card -->
      <div class="card card-block p-15 shadow">
        <div class="counter counter-md text-left">
          <div class="counter-label small text-uppercase mb-3" title="이번달 후보자 추천 수">Recommend <small><br />candidates</small><br /><span class="indigo-900 d-none d-md-inline-block">&lt;추천후보자 수&gt;</span></div>
          <div class="counter-number-group mb-5 text-right">
            <span class="counter-number font-size-20" title="현재"><a href="@Url.Action("UnivisionActivity", "Statistics")" class="text-dark">@Model.rCandidateCnt</a></span>
            <span class="counter-number font-size-14 text-secondary" title="월 목표">/ 20</span>
          </div>
          <div class="counter-label">
            @{
              double rec_per = Model.rCandidateCnt / 20.0 * 100;
            }
            <div class="progress progress-xs mb-5" title="@(rec_per)%">
              <div class="progress-bar progress-bar-info bg-indigo-600" aria-valuenow="@rec_per" aria-valuemin="0"
                   aria-valuemax="100" style="width: @(rec_per)%" role="progressbar">
                <span class="sr-only">@(rec_per)%</span>
              </div>
            </div>

          </div>
        </div>
      </div>
      <!-- End Card -->
    </div>
    <div class="col-4 col-lg-2">
      <!-- Card -->
      <div class="card card-block p-15 shadow">
        <div class="counter counter-md text-left">
          <div class="counter-label small text-uppercase mb-3" title="이번달 후보자 면접">
            Interview <small><br />candidates</small>
            <br /><span class="orange-900 d-none d-md-inline-block">&lt;면접후보자 수&gt;</span>
          </div>
          <div class="counter-number-group mb-5 text-right">
            <span class="counter-number font-size-20" title="현재"><a href="@Url.Action("UnivisionActivity", "Statistics")" class="text-dark">@Model.intvCandidateCnt</a></span>
            <span class="counter-number font-size-14 text-secondary" title="월 목표">/ 10</span>
          </div>
          <div class="counter-label">
            @{
              double itv_per = Model.intvCandidateCnt / 10.0 * 100;
            }
            <div class="progress progress-xs mb-5" title="@(itv_per)%">
              <div class="progress-bar progress-bar-info bg-orange-600" aria-valuenow="@itv_per" aria-valuemin="0"
                   aria-valuemax="100" style="width: @(itv_per)%" role="progressbar">
                <span class="sr-only">@(itv_per)%</span>
              </div>
            </div>

          </div>
        </div>
      </div>
      <!-- End Card -->
    </div>
    <div class="col-4 col-lg-2">
      <!-- Card -->
      <div class="card card-block p-15 shadow">
        <div class="counter counter-md text-left">
          <div class="counter-label small text-uppercase mb-3" title="이번달 후보자 등록 및 업데이트">Candidate <small class="text-truncate"><br />reg. &amp; update</small><br /><span class="green-900 d-none d-md-inline-block">&lt;후보자 등록/업데이트&gt;</span></div>
          <div class="counter-number-group mb-5 text-right">
            <span class="counter-number font-size-20" title="현재"><a href="@Url.Action("UnivisionActivity", "Statistics")" class="text-dark">@(Model.candidateCnt+ Model.candidateUdCnt)</a></span>
            <span class="counter-number font-size-14 text-secondary" title="월 목표">/ 20</span>
          </div>
          <div class="counter-label">
            @{
              double reg_per = (Model.candidateCnt + +Model.candidateUdCnt) / 20.0 * 100;
            }
            <div class="progress progress-xs mb-5" title="@(reg_per)%">
              <div class="progress-bar progress-bar-info bg-green-600" aria-valuenow="@reg_per" aria-valuemin="0"
                   aria-valuemax="100" style="width: @(reg_per)%" role="progressbar">
                <span class="sr-only">@(reg_per)%</span>
              </div>
            </div>

          </div>
        </div>
      </div>
      <!-- End Card -->
    </div>
    <div class="col-4 col-lg-2">
      <!-- Card -->
      <div class="card card-block p-15 shadow">
        <div class="counter counter-md text-left">
          <div class="counter-label small text-uppercase mb-3" title="이번달 후보자 메모 등록">Memo <small><br />registration</small><br /><span class="cyan-900 d-none d-md-inline-block">&lt;후보자메모 등록&gt;</span></div>
          <div class="counter-number-group mb-5 text-right">
            <span class="counter-number font-size-20" title="현재"><a href="@Url.Action("UnivisionActivity", "Statistics")" class="text-dark">@Model.MemoCnt</a></span>
            <span class="counter-number font-size-14 text-secondary" title="월 목표">/ 20</span>
          </div>
          <div class="counter-label">
            @{
