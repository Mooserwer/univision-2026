    window.client_url = '@Url.Action("ClientList", "Dashboard")';
    window.kpi_url = '@Url.Action("KPIList", "Dashboard")';
    window.unbilled_url = '@Url.Action("UnBilledInvoiceList", "Dashboard")';
    window.invoice_url = '@Url.Action("BilledInvoiceList", "Dashboard")';
    window.cowork_url = '@Url.Action("CoworkProjectList", "Dashboard")';
