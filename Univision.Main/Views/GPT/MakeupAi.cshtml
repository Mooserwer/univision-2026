    </div>
    <div class="mu-header-right">
      <select id="gpt_model" name="gpt_model" class="mu-model-select"
              onchange="setCookieOrg('MAKEUP_GPT_MODEL', this.value, 30);">
        <option value="gpt-4.1-mini" @(lastest_model == "gpt-4.1-mini" ? "selected" : "")>GPT-4.1 Mini</option>
        <option value="gpt-4.1" @(lastest_model == "gpt-4.1" ? "selected" : "")>GPT-4.1</option>
      </select>
      <label class="mu-toggle-label" for="chk_is_editable">
        <input type="checkbox" id="chk_is_editable" value="Y"
               @(is_editabel == "Y" ? "checked" : "")
               onchange="setCookieOrg('MAKEUP_EDITABLE', (this.checked ? 'Y' : ''), 30);" />
        검토 후 생성
      </label>
      <a href="javascript:ResetUploadPage();" class="mu-btn-reset">
        <i class="fa fa-redo" style="font-size:0.75rem;"></i> 초기화
      </a>
    </div>
  </div>

  <!-- ▶ 메인 2컬럼 -->
  <div class="mu-body">

    <!-- 좌측: 업로드 영역 -->
    <div class="mu-upload-section">
      <div class="mu-upload-grid">

        <!-- 국문 -->
        <div class="mu-upload-card">
          <div class="mu-upload-card-header">
            <span class="mu-lang-badge kr">🇰🇷 국문</span>
            <span class="mu-upload-card-title">한국어 이력서</span>
          </div>
          <form id="form_makeup_kr" class="dropzone mu-dropzone">
            <div class="dz-message">
              <span class="mu-dz-icon">📄</span>
              <div class="mu-dz-text">파일을 드래그하거나<br>클릭하여 업로드</div>
              <span class="mu-dz-hint">PDF, DOCX 지원</span>
            </div>
          </form>
        </div>

        <!-- 영문 -->
        <div class="mu-upload-card">
          <div class="mu-upload-card-header">
            <span class="mu-lang-badge en">🌐 영문</span>
            <span class="mu-upload-card-title">English Resume</span>
          </div>
          <form id="form_makeup_en" class="dropzone mu-dropzone">
            <div class="dz-message">
              <span class="mu-dz-icon">📄</span>
              <div class="mu-dz-text">Drop file or<br>click to upload</div>
              <span class="mu-dz-hint">PDF, DOCX supported</span>
            </div>
          </form>
        </div>

      </div><!-- /upload-grid -->
      <!-- 안내사항 -->
      <div class="mu-notice-card">
        <div class="mu-notice-title">
          <i class="fas fa-exclamation-triangle" style="color:#f59e0b;"></i>
          GPT 분석 시 주의사항
        </div>
        <ul class="mu-notice-list">
          <li class="warn">GPT가 분석한 내용은 정확하지 않을 수 있습니다. 누락되거나 잘못된 정보가 포함될 수 있으므로 반드시 검수 후 사용하세요.</li>
          <li class="warn">학력/경력 기간, 경력 상세정보 들여쓰기, 자격증, 기타 사항 등을 꼭 확인해주세요.</li>
          <li>자기소개 내용은 생성하지 않습니다. (직접 붙여넣기 해주세요.)</li>
          <li>글자 인식이 가능한 이력서만 작업이 가능합니다. (이미지 형식 인식 불가)</li>
          <li>내용이 너무 길거나 용량이 큰 파일은 인식이 어려울 수 있습니다.</li>
        </ul>
      </div>
    </div><!-- /upload-section -->
    <!-- 우측: 사이드패널 -->
    <div class="mu-sidebar">
      <div class="mu-panel">
        <div class="mu-panel-header">
          <div class="mu-panel-title">
            <i class="fas fa-tasks"></i> 처리 현황
          </div>
          <div class="mu-panel-counts">
            <span class="mu-count-chip" id="chip_total" style="display:none;"></span>
            <span class="mu-count-chip done" id="chip_done" style="display:none;"></span>
          </div>
        </div>
        <!-- 빈 상태 -->
        <div id="mu_empty_state" class="mu-panel-empty">
          <span class="mu-panel-empty-icon">📭</span>
          <div class="mu-panel-empty-text">
            아직 업로드된 파일이 없습니다.<br>
            좌측에서 이력서를 업로드해주세요.
          </div>
        </div>
        <!-- 작업 목록 -->
        <div class="mu-jobs-list" id="mu_jobs_list" style="display:none;"></div>
      </div>
    </div><!-- /sidebar -->

  </div><!-- /mu-body -->
  <!-- 히든: 기존 서버 폼 -->
  <div class="d-none">
    <form id="ai_makeup_form" method="post" action="@Url.Action("CandidateAiCreate", "")" target="_blank">
      <input type="hidden" name="uploadFolder" id="uploadFolder" value="" />
      <textarea id="makeup_model" name="makeup_model"></textarea>
    </form>
  </div>
</div><!-- /mu-page -->

@section scripts{
  <script src="~/Scripts/makeup/resume_makeup_manager.js"></script>
  <script src="~/Scripts/makeup/makeup_prompt.js"></script>
  <script type="text/javascript">
    const API_KEY = "@api_key";
    window.url_make_makeup  = "@Url.Action("MakeMakeup", "GPT")";
    window.url_make_makeup2 = "@Url.Action("MakeMakeup2026", "GPT")";
    window.url_resume_upload_get_contents = "@Url.Action("ResumeUploadGetContents", "Candidate")";
  </script>

  <script type="text/javascript">
    Dropzone.autoDiscover = false;

    let working_cnt = 0;
    let total_cnt = 0;
    let done_cnt = 0;

    function updateSidebarCounts() {
      const chipTotal = document.getElementById('chip_total');
      const chipDone = document.getElementById('chip_done');
      if (total_cnt > 0) {
        chipTotal.style.display = '';
        chipTotal.textContent = '전체 ' + total_cnt + '건';
      }
      if (done_cnt > 0) {
        chipDone.style.display = '';
        chipDone.textContent = '✅ ' + done_cnt + '건 완료';
      }
    }

    function showJobsList() {
      document.getElementById('mu_empty_state').style.display = 'none';
      document.getElementById('mu_jobs_list').style.display = '';
    }

    async function handleUploadSuccess(lang, response) {
      const currentModel = document.getElementById('gpt_model').value;
      const worker = new ResumeMakeupManager(lang, working_cnt, currentModel, function () {
        done_cnt++;
        updateSidebarCounts();
      });

      window.debug_worker = worker;

      if (!worker.setFileInfo(response)) return;

      // 언어(lang)에 따라 프롬프트 분기
      // KR: 이력서 언어와 무관하게 한국어 출력 강제
      // EN: 이력서 언어와 무관하게 영어 출력 강제
      const isKR = (lang === "KR");
      const ncPrompt = isKR ? gpt4_kr_no_career_prompt_base : gpt4_en_no_career_prompt_base;
      if (!await worker.fetchAIStream(ncPrompt, "NC")) return;

      worker.updateProgress(50, "경력사항 분석 중");

      const ocPrompt = isKR ? gpt4_kr_career_only_prompt_base : gpt4_en_career_only_prompt_base;
      if (!await worker.fetchAIStream(ocPrompt, "OC")) return;

      const finalData = await worker.finalizeData();
      if (finalData) await worker.createResumeFile(finalData);
    }

    // ── Dropzone 공통 설정 ──────────────────────────────────
    // uploadMultiple: false → 파일마다 개별 요청 (success 이벤트가 파일별로 발생)
    // parallelUploads: 2    → 동시 업로드 최대 2개 (서버 부하 조절)
    // maxFiles 제거         → 여러 파일 드래그 허용
    const dzCommonOptions = {
      uploadMultiple: false,
      parallelUploads: 2,
      url: window.url_resume_upload_get_contents,
      method: "post",
    };

    function makeDzSuccessHandler(lang) {
      return async function (file, response) {
        // 업로드 완료 즉시 Dropzone에서 파일 제거 (미리보기 누적 방지)
        this.removeFile(file);
        working_cnt++; total_cnt++;
        showJobsList(); updateSidebarCounts();

        if (!response.ok) {
          const ew = new ResumeMakeupManager(lang, working_cnt, document.getElementById('gpt_model').value, null);
          ew.addLog("danger", "업로드 실패: " + response.message);
          return;
        }
        // 각 파일은 독립적으로 비동기 처리 (await 없이 호출 → 동시 병렬 실행)
        handleUploadSuccess(lang, response);
      };
    }

    // 국문 Dropzone
    var myDropzoneKR = new Dropzone("#form_makeup_kr", dzCommonOptions);
    myDropzoneKR.on("success", makeDzSuccessHandler("KR"));

    // 영문 Dropzone
    var myDropzoneEn = new Dropzone("#form_makeup_en", dzCommonOptions);
    myDropzoneEn.on("success", makeDzSuccessHandler("EN"));

    function ResetUploadPage() {
      alertify.confirm()
        .set({
          labels: { ok: 'OK', cancel: 'Cancel' },
          onok: function () { location.reload(); },
          oncancel: function () { }
        })
        .setting({ message: "업로드 화면을 초기화 하시겠습니까?" })
        .show();
    }
  </script>
}