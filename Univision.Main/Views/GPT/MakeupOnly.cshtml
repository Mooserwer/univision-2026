  const GenerateJsonFromResumeStreamNoCareer = async (pic_seq, lang = "K", prg_result) => {
    let result = true;
    let usageFeedback = {};
    let prompt_nc = document.querySelector(`#prompt_without_career_${lang}`);

    const startTime = new Date();
    controller = new AbortController();
    const signal = controller.signal;
    const token_cnt = countTokens(document.querySelector('#file_content').value + prompt_nc.value);

    AddLog("info", `경력사항 제외 내용 분석 준비(1/2).. 요청토큰(${token_cnt})`);
    prg_result.html(`<span class="text-info">경력사항 제외 내용 분석 준비</span>`);
    AddLog("info", `GPT를 통해 경력사항을 제외한 내용 분석 중(1/2)..<span id='${lang}-generate_sec-nc-${pic_seq}'></span>
    <textarea class='form-control border-info' id='${lang}-openai-stream-nc-${pic_seq}' rows='20' readonly='true'></textarea>`);
    prg_result.html(`<span class="text-info">GPT를 통해 경력사항을 제외한 내용 분석 중</span>`);
    const openaiStream = document.getElementById(`${lang}-openai-stream-nc-${pic_seq}`);
    const generateSec = document.getElementById(`${lang}-generate_sec-nc-${pic_seq}`);

    btn_cancel_result.disabled = false;
    openaiStream.value = "내용 분석 중...";

    try {
      const response = await fetch(API_URL, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Authorization: `Bearer ${API_KEY}`,
        },
        body: JSON.stringify({
          model: $('#gpt_model').val(),
          temperature: 0,
          top_p: 0,
          messages: [
            { role: "system", content: prompt_nc.value },
            { role: "user", content: file_content.value }
          ],
          stream: true,
        }),
        signal,
      });

      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }

      const reader = response.body.getReader();
      const decoder = new TextDecoder("utf-8");
      ai_summary_stream_nc.value = '';
      openaiStream.value = '';
      let buffer = "";

      const processStream = async () => {
        let done = false;
        while (!done) {
          const now = parseInt((new Date() - startTime) / 1000);
          generateSec.innerText = `(${now} 초 경과)`;

          const { value, done: streamDone } = await reader.read();
          done = streamDone;

          if (done) {
            break;
          }

          // 헤더 값 가져오기
          usageFeedback = {
            limit: response.headers.get('x-ratelimit-limit'),
            remaining: response.headers.get('x-ratelimit-remaining'),
            reset: response.headers.get('x-ratelimit-reset'),
            used: response.headers.get('x-ratelimit-used'),
          };

          buffer += decoder.decode(value, { stream: true });

          const lines = buffer.split("\n\n");
          buffer = lines.pop(); // 마지막 라인은 버퍼에 남겨둠

          const parsedLines = lines
            .map(line => line.replace(/^data: /, "").trim()) // "data: " 접두사 제거
            .filter(line => line && line !== "[DONE]"); // 빈 줄과 "[DONE]" 제거

          parsedLines.forEach(line => {
            try {
              const parsedLine = JSON.parse(line); // JSON 문자열 파싱
              const { content } = parsedLine.choices[0].delta;
              if (content) {
                ai_summary_stream_nc.value += content;
                openaiStream.value += content;
                openaiStream.scrollTop = openaiStream.scrollHeight;
              }
            } catch (error) {
              console.error('JSON 파싱 오류:', error);
            }
          });
        }
      };

      await processStream();

      AddLog("info", "파일 내용 분석 완료 (경력사항제외)", prg_result);
    } catch (error) {
      if (signal.aborted) {
        AddLog("danger", "요청이 중지 되었습니다.", prg_result);
      } else {
        console.error("Error:", error);
        ai_summary_stream_nc.value += `\n분석 중 오류가 발생하였습니다.\n내용: ${error}`;
        AddLog("danger", `분석 중 오류가 발생하였습니다.\n내용: ${error}`, prg_result);
      }
      result = false;
    } finally {
      if (usageFeedback.limit) {
        AddLog("info", `토큰 사용량<br/>Limit: ${usageFeedback.limit}<br/>Remaining: ${usageFeedback.remaining}<br/>Reset: ${usageFeedback.reset}`);
      }
      btn_cancel_result.disabled = true;
      controller = null; // Reset the AbortController instance
    }

    return result;
  };

