        ai_summary_stream_oc.value += `\n분석 중 오류가 발생하였습니다.\n내용: ${error}`;
        AddLog("danger", `분석 중 오류가 발생하였습니다.\n내용: ${error}`, prg_result);
      }
      result = false;
    } finally {
      if (usageFeedback.limit) {
        AddLog("info", `토큰 사용량<br/>Limit: ${usageFeedback.limit}<br/>Remaining: ${usageFeedback.remaining}<br/>Reset: ${usageFeedback.reset}`);
      }
      btn_cancel_result.disabled = true;
      controller = null;
    }

    return result;
  };


  const GenerateJsonFromResumeStreamOnlyCareer = async (pic_seq, lang = "K", prg_result) => {
    let result = true;
    let usageFeedback = {};
    let prompt_oc = document.querySelector(`#prompt_career_only_${lang}`);

    const startTime = new Date();
    controller = new AbortController();
    const signal = controller.signal;
    const token_cnt = countTokens(document.querySelector('#file_content').value + prompt_oc.value);

    AddLog("info", `경력사항 분석 준비(2/2).. 요청토큰(${token_cnt})`);
    prg_result.html(`<span class="text-info">경력사항 분석 준비</span>`);
    AddLog("info", `GPT를 통해 경력사항 분석 중(2/2)..<span id='${lang}-generate_sec-oc-${pic_seq}'></span>
    <textarea class='form-control border-info' id='${lang}-openai-stream-oc-${pic_seq}' rows='20' readonly='true'></textarea>`);
    prg_result.html(`<span class="text-info">GPT를 통해 경력사항 분석 중</span>`);





    const openaiStream = document.getElementById(`${lang}-openai-stream-oc-${pic_seq}`);
    const generateSec = document.getElementById(`${lang}-generate_sec-oc-${pic_seq}`);

    btn_cancel_result.disabled = false;
    openaiStream.value = "내용 분석 중...";

    try {
      const response = await fetch(API_URL, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Authorization: `Bearer ${API_KEY}`,
        },
        body: JSON.stringify({
          model: $('#gpt_model').val(),
          temperature: 0,
          top_p: 1,
          messages: [
            { role: "system", content: prompt_oc.value },
            { role: "user", content: file_content.value }
          ],
          stream: true,
        }),
        signal,
      });

      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }

      const reader = response.body.getReader();
      const decoder = new TextDecoder("utf-8");
      ai_summary_stream_oc.value = '';
      openaiStream.value = '';
      let buffer = "";

      const processStream = async () => {
        let done = false;
        while (!done) {
          const now = parseInt((new Date() - startTime) / 1000);
          generateSec.innerText = `(${now} 초 경과)`;

          const { value, done: streamDone } = await reader.read();
          done = streamDone;

          if (done) {
            break;
          }

          usageFeedback = {
            limit: response.headers.get('x-ratelimit-limit'),
            remaining: response.headers.get('x-ratelimit-remaining'),
            reset: response.headers.get('x-ratelimit-reset'),
            used: response.headers.get('x-ratelimit-used'),
          };

          buffer += decoder.decode(value, { stream: true });

          const lines = buffer.split("\n\n");
          buffer = lines.pop();

          const parsedLines = lines
            .map(line => line.replace(/^data: /, "").trim())
            .filter(line => line && line !== "[DONE]");

          parsedLines.forEach(line => {
            try {
              const parsedLine = JSON.parse(line);
              const { content } = parsedLine.choices[0].delta;
              if (content) {
                ai_summary_stream_oc.value += content;
                openaiStream.value += content;
                openaiStream.scrollTop = openaiStream.scrollHeight;
              }
            } catch (error) {
              console.error('JSON 파싱 오류:', error);
            }
          });
        }
      };

      await processStream();

      AddLog("info", "파일 내용 분석 완료 (경력사항)", prg_result);
    } catch (error) {
      if (signal.aborted) {
        AddLog("danger", "요청이 중지 되었습니다.", prg_result);
      } else {
        console.error("Error:", error);
        ai_summary_stream_oc.value += `\n분석 중 오류가 발생하였습니다.\n내용: ${error}`;
        AddLog("danger", `분석 중 오류가 발생하였습니다.\n내용: ${error}`, prg_result);
      }
      result = false;
    } finally {
      if (usageFeedback.limit) {
        AddLog("info", `토큰 사용량<br/>Limit: ${usageFeedback.limit}<br/>Remaining: ${usageFeedback.remaining}<br/>Reset: ${usageFeedback.reset}`);
      }
      btn_cancel_result.disabled = true;
      controller = null;
    }

    return result;
  };

  function ResetMakeupPage() {
    alertify.confirm()
      .set({
        'labels': { ok: 'OK', cancel: 'Cancel' },
        'onok': function () {
          location.reload();
        },
        'oncancel': function () {
          return;
        },
      })
      .setting({
        title: "새로고침",
        message: "후보자 정보를 다시 불러오시겠습니까?",
      })
      .show();
  }

  function AddLog(type, contents, second_target) {
    if (!type) {
      type = "info";
    }
    var event_time = "[" + new Date().toISOString() + "]";
    var reset_btn = '';
    /*if (type == "danger") {
      reset_btn = '<button class="btn btn-primary" onclick="ResetUploadPage();">다시 업로드 하기</button> ';
    }*/
    var card = `<div class='card border border-${type} shadow'>
                <div class="card-block text-${type} py-2 ">
                  <span class='text-dark'>${event_time}</span><br/>
                  ${contents}
                </div>
                ${reset_btn}
              </div>`;
    let temp = document.createElement("div");
    temp.innerHTML = card;
    temp.style.opacity = '0';
    temp.style.transition = 'opacity 500ms';
    document.getElementById('ai_upload_log').prepend(temp);

    setInterval(() => temp.style.opacity = '1', 100);

    if (second_target) {
      second_target.html(`<span class="text-${type}">${contents}</span>`);
    }
  }

  document.querySelectorAll('input[name="chk_request_makeup"]').forEach(masterCheckbox => {
    masterCheckbox.addEventListener('change', function () {
      const isChecked = this.checked;
      const targetClass = this.dataset.target;
      const Checkboxes = document.querySelectorAll(`.${targetClass}`);

      Checkboxes.forEach(checkbox => {
        checkbox.checked = isChecked;
      });
    });
  });

</script>