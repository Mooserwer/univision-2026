@model List<Univision.Core.Models.DTO.pjt_recandidate_history>
@{
  ViewBag.Title = "이력서 Makeup (by GPT)";
  ViewBag.NoMenu = true;
  Layout = "~/Views/Shared/_Layout.cshtml";
  string actionName = ViewContext.RouteData.Values["action"].ToString().ToLower();

  string lastest_model = "gpt-4o-mini";
  string api_key = System.Configuration.ConfigurationManager.AppSettings["OpenAIApiKey"]; //메이크업 사용자용
}

<div class="p-3">
  <div class="panel panel-success animation-scale-up" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms;">
    <div class="panel-heading">
      <h3 class="panel-title">
        <i class="fas fa-newspaper"></i>
        이력서 Makeup (by GPT) <span class="badge badge-primary">Beta</span>
      </h3>
      <div class="panel-actions">
        <a class="panel-action" aria-hidden="true" title="업로드 초기화" href="javascript:ResetMakeupPage();"><i class="fa fa-redo"></i></a>
      </div>
    </div>
    <div id="makeup_list_panel" class="panel-body">
      <div class="modal fade" id="modal_makeup_progress" tabindex="-1" role="dialog" aria-labelledby="modal_makeup_progress_label" aria-hidden="true">
        <div class="modal-dialog">
          <div class="modal-content">
            <div class="modal-title">
              <h3 class="pl-20"><span id="ai_modal_title">GPT가 파일을 분석 중 입니다..</span></h3>
            </div>
            <div class="modal-body text-center" id="ai_modal_contents">
              <span id="summary_loader" class="loader"></span>
            </div>
            <div class="modal-footer">
              <span style="" class="text-center">
                <button type="button" class="btn btn-danger" style="min-width:200px;" id="btn_cancel_result" disabled="true">요청취소</button>
                <button type="button" class="btn btn-secondary d-none" style="min-width:200px;" id="btn_close_modal" data-dismiss="modal">닫기</button>
              </span>
            </div>
          </div>

        </div>

      </div>
      <div class="table-responsive">
        <input type="hidden" class="req_user" value="@ViewBag.request_user" name="req_user" id="req_user" />
        <table class="table table- bg-progress-table" style="table-layout:fixed;font-size:1em;">
          <thead>
            <tr>
              <th class="text-center" style="width:100px;">후보자 정보<br />&nbsp;</th>
              <th class="text-center" style="width:120px;">
                국문이력서<br />
                <input type="checkbox" class="chk_request_makeup" name="chk_request_makeup" id="select_all_kor" data-target="chk_kor_makeup" />
              </th>
              <th class="text-center" style="width:120px;">
                영문이력서<br />
                <input type="checkbox" class="chk_request_makeup" name="chk_request_makeup" id="select_all_eng" data-target="chk_eng_makeup" />
              </th>
              <th class="text-center" style=""></th>
            </tr>
          </thead>
          <tbody class="progress-table-body">
            @if (Model.Count > 0)
            {
              foreach (var data in Model)
              {
                <tr>
                  <td class="text-center">
                    <input type="hidden" class="pic_seq" value="@data.pic_seq" name="pic_seq" id="pic_seq_@(data.pic_seq)" data-name="@data.kor_name" data-seq="@data.c_seq" />

                    <a href="javascript:openCandidatePop('@data.c_seq')" data-html="true" data-toggle="popover" data-trigger="hover">
                      @data.kor_name<br />
                      @if (data.birth_date.HasValue)
                      {
                        @("(" + Utils.ConvertDateTimeToString(data.birth_date).Substring(2, 2) + "년생")
                      }

                      @(" / " + Utils.ReturnGenderTxt(data.gender) + ")")
                    </a>
                  </td>
                  <td class="text-center">

                    @if (!string.IsNullOrWhiteSpace(data.final_kor_resume_dir))
                    {
                      <a class="badge badge-outline badge-primary" href="@Url.Action("Download", "DownloadFile", new { @element_seq = data.final_kor_cr_seq, @type = "canResume" })" title="국문원본이력서 : @data.final_kor_resume_name">
                        <i class="fas fa-file"></i> K (@Utils.ConvertDateTimeToString(data.final_kor_resume_date))
                      </a><br />
                      <input type="checkbox" class="chk_kor_makeup" name="chk_kor_makeup" id="kor_makeup_@data.pic_seq" value="@data.final_kor_cr_seq" data-c_seq="@data.c_seq" />
                    }
                  </td>
                  <td class="text-center">
                    @if (!string.IsNullOrWhiteSpace(data.final_eng_resume_dir))
                    {
                      <a class="badge badge-outline badge-info" href="@Url.Action("Download", "DownloadFile", new { @element_seq = data.final_eng_cr_seq, @type = "canResume" })" title="영문원본이력서 : @data.final_eng_resume_name" download>
                        <i class="fas fa-file"></i> E (@Utils.ConvertDateTimeToString(data.final_eng_resume_date))
                      </a><br />
                      <input type="checkbox" class="chk_eng_makeup" name="chk_eng_makeup" id="eng_makeup_@data.pic_seq" value="@data.final_eng_cr_seq" data-c_seq="@data.c_seq" />
                    }
                  </td>
                  <td class="small">
                    <div class="border p-1">
                      [K] : <span class="progress-kor-@data.pic_seq">
                        @if (data.final_kor_resume_date < data.final_mkor_resume_date)
                        {
                          <span class="text-danger">* 최근Makeup 파일보다 오래됨. 최신 이력서인지 확인해주세요.</span>
                        }
                        else
                        {

                        }
                      </span>
                    </div>
                    <div class="border p-1">
                      [E] : <span class="progress-eng-@data.pic_seq">
                        @if (data.final_eng_resume_date < data.final_meng_resume_date)
                        {
                          <span class="text-danger">* 최근Makeup 파일보다 오래됨. 최신 이력서인지 확인해주세요.</span>
                        }
                      </span>
                    </div>
                  </td>
                </tr>

              }
            }
          </tbody>
        </table>
      </div>
    </div>
    <div class="row">
      <div class="col-12 text-center">
        @if (actionName == "makeupgpt_mr")
        {
          <select id="gpt_model" name="gpt_model" onchange="javascript: setCookieOrg('MAKEUP_GPT_MODEL', this.value, 30); console.log(this.value);" class="d-none">
            <option value="gpt-4o-mini" @(lastest_model == "gpt-4o-mini" ? "selected" : "")>GPT-4o-mini(조금 덜똑똑하지만 가볍고 빠름)</option>
            <option value="gpt-3.5-turbo-16k" @(lastest_model == "gpt-3.5-turbo-16k" ? "selected" : "")>GPT-3.5t(옛날GPT)</option>
            <option value="gpt-4o" @(lastest_model == "gpt-4o" ? "selected" : "")>GPT-4o (현재 제일똑똑하지만 무겁고 느림 + 비쌈)</option>
          </select>
        }
        else
        {
          <input type="hidden" id="gpt_model" name="gpt_model" value="@lastest_model" />
        }

      </div>
      <div class="col-12 text-center pb-10">
        <button class="btn btn-lg btn-success" onclick="javascript:StartMakeup()">작업 시작</button>
      </div>
    </div>
    @if (actionName != "makeupgpt_mr")
    {
      <div class="row">
        <div class="col-sm-12 col-lg-6 offset-lg-3 border border-info shadow p-5">
          <span class="text-danger font-weight-800">
            * GPT가 분석한 내용은 정확하지 않을 수 있습니다. <br />
            &nbsp;&nbsp;누락되거나 잘못된 정보가 포함될 확률이 매우 높습니다. 검수를 꼭 해주세요.<br />
            &nbsp;&nbsp;(* 학력/경력 기간, 경력상세정보 내용 및 들여쓰기, 자격증, 기타 사항 등 꼭 검수 필요)
          </span><br /><br />

          <span class="font-weight-800">
            - 자기소개 내용은 생성하지 않습니다. (직접 붙여넣기 해주세요.)<br />
          </span>
          - 원본이력서가 최신 이력서가 아닐 경우 후보자 화면에서 최신이력서를 업로드 하신 다음 새로고침 해주세요.<br />

          - 글자 인식이 가능한 이력서만 작업이 가능합니다.(이미지 형식은 인식 불가)<br />
          - 내용이 너무 길거나 용량이 큰 파일은 인식이 어려울 수 있습니다.<br />

          <span class="font-weight-800">
            - 최종 검증이 끝난 유효한 메이크업 이력서 파일은 직접 후보자 정보에 업로드 부탁드립니다.<br />
          </span>
        </div>
      </div>
    }
  </div>

  <div class="">
