  async function StartMakeup() {
    if ($('.chk_kor_makeup:checked').length <= 0 && $('.chk_eng_makeup:checked').length <= 0) {
      ErrorAlert("메이크업할 이력서를 체크 후 진행하여 주십시오.");
      return;
    }
    document.getElementById('log_panel').classList.remove('d-none');

    const picSeqElements = $('.pic_seq');

    for (const item of picSeqElements) {
      if ($('#kor_makeup_' + item.value + ':checked').length > 0) {
        $('.progress-kor-' + item.value).html(`<span class="text-info">작업대기중</span>`);
      }
      if ($('#eng_makeup_' + item.value + ':checked').length > 0) {
        $('.progress-eng-' + item.value).html(`<span class="text-info">작업대기중</span>`);
      }
    }

    for await (const item of picSeqElements) {
      //for (let i = 0; i < picSeqElements.length; i++) {
      //const item = picSeqElements[i];
      //console.log(i);
      file_content.value = '';
      ai_summary_stream.value = '';
      ai_summary_stream_nc.value = '';
      ai_summary_stream_oc.value = '';

      if ($('#kor_makeup_' + item.value + ':checked').length > 0) {
        await processMakeup(item, 'K');
      }

      if ($('#eng_makeup_' + item.value + ':checked').length > 0) {
        await processMakeup(item, 'E');
      }
    }
  }

  async function processMakeup(item, lang) {
    //console.log(item, lang);
    let prg_result;

    if (lang === "K") {
      prg_result = $('.progress-kor-' + item.value);
    } else if (lang === "E") {
      prg_result = $('.progress-eng-' + item.value);
    }

    const langName = lang === 'K' ? '국문' : '영문';
    AddLog("success", `${item.dataset.name} ${langName} 이력서 메이크업 시작`, prg_result);
    const cr_seq = $(`#${lang === 'K' ? 'kor' : 'eng'}_makeup_${item.value}`).val();



    // 최신이력서 내용 추출
    isprogress = await SetFileInfo(cr_seq, prg_result);
    if (!isprogress) return;

    // GPT 분석
    isprogress = await GenerateJsonFromResumeStreamNoCareer(item.value, lang, prg_result);
    //isprogress = await GenerateJsonFromResumeStreamNoCareerProxy(item.value, lang, prg_result);
    if (!isprogress) return;
    isprogress = await GenerateJsonFromResumeStreamOnlyCareer(item.value, lang, prg_result);
    //isprogress = await GenerateJsonFromResumeStreamOnlyCareerProxy(item.value, lang, prg_result);
    if (!isprogress) return;

    // Makeup 생성 모델 변환
    const makeup_result = await ConvertMakeupCreateModel2(ai_summary_stream_nc.value, ai_summary_stream_oc.value, prg_result);
    if (!makeup_result.result) {
      isprogress = false;
      AddLog("danger", "정상적인 데이터가 생성되지 못했습니다.", prg_result);
      return;
    }

    console.log(`make2(${item.dataset.seq}, '${lang}', ${req_user}, ${item.value});`);
    await make2(item.dataset.seq, lang, req_user, item.value);
  }

