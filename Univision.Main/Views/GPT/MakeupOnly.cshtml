  async function SetFileInfo(cr_seq, prg_result) {
    try {
      AddLog("info", "파일 내용 확인 중..", prg_result);

      const response = await fetch(window.url_makeup_get_contents, {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ cr_seq })
      });

      if (!response.ok) {
        throw new Error(`Network response was not ok: ${response.statusText}`);
      }

      const data = await response.json();

      if (!data.file_content) {
        //console.log(prg_result, "error-pre")
        throw new Error("내용을 확인할 수 없는 파일입니다.");

      }

      file_content.value = data.file_content;
      AddLog("info", `파일 내용 확인 완료<textarea class='form-control border-info' rows='5' readonly='true'>${data.file_content}</textarea>`);
      if (prg_result) {
        prg_result.html(`<span class="text-info">파일 내용 확인 완료</span>`);
      }
      return true;
    } catch (error) {
      console.error(error);
      //console.log(prg_result, "error")
      AddLog("danger", `파일 내용 확인 중 오류 발생: ${error.message}`, prg_result);
      return false;
    }
  }

  const ConvertMakeupCreateModel2 = async (data_nc, data_oc, prg_result) => {
    AddLog("info", "분석된 이력서 내용을 Makeup 데이터로 변환 시도 중...", prg_result);

    let data, career_data;
    try {
      // Clean up input strings if they are in string format
      if (typeof data_nc === "string") {
        data_nc = data_nc.replace(/json/, "").replace(/```/gi, "");
      }
      if (typeof data_oc === "string") {
        data_oc = data_oc.replace(/json/, "").replace(/```/gi, "");
      }

      // Parse the non-career data
      const inputData = data_nc || $('#ai_summary_stream_without_career').val();
      data = JSON.parse(inputData);

      // Parse the career data
      const inputData2 = data_oc || $('#ai_summary_stream_career_only').val();
      career_data = JSON.parse(inputData2);
    } catch (error) {
      console.error(error);
      AddLog("danger", `데이터 변환 중 오류가 발생했습니다. <br/>분석된 데이터가 올바르지 않거나 서버 오류가 발생했을 가능성이 있습니다.<br/>${error}`, prg_result);
      return { result: false };
    }

    // Construct the final data model
    try {
      var data_core = [''];
      if (data?.core || data.core != "") {
        if (typeof (data.core) == "string") {
          data_core = [data.core];
        } else {
          data_core = data.core;
        }
      }
      const currentData = {
        candidate: data?.candidate ?? '',
        yob: data?.yob ?? '',
        gender: data?.gender ?? '',
        addr: data?.addr ?? '',
        core: data_core,//((data?.core || data.core != "")) ? data.core : [''],
        education: ((data?.education || data.education != "")) ? data.education : [], 
        career: career_data?.career ?? [],
        learns: ((data?.learns || data.learns != "")) ? data.learns : [],
        awards: ((data?.awards || data.awards != "")) ? data.awards : [],
        activities: ((data?.activities || data.activities != "")) ? data.activities : [],
        overseas: ((data?.overseas || data.overseas != "")) ? data.overseas : [],
        skills: ((data?.skills || data.skills != "")) ? data.skills : [],
        certifications: ((data?.certifications || data.certifications != "")) ? data.certifications : [],
        languages: ((data?.languages || data.languages != "")) ? data.languages : [],
        etcs: ((data?.etcs || data.etcs != "")) ? data.etcs : []
      };

      $('#makeup_model').val(JSON.stringify(currentData));
      AddLog("info", "메이크업 데이터 변환 완료");

      return { result: true };
    } catch (error) {
      console.error(error);
      AddLog("danger", `데이터 변환 중 오류가 발생했습니다.<br/>올바르지 않은 데이터가 포함되어 있을 가능성이 있습니다.<br/>${error}`, prg_result);
      return { result: false };
    }
  };

  async function make2(c_seq, file_type, req_seq, pic_seq) {
    let progress_result;
    let kor_name = document.getElementById('pic_seq_' + pic_seq).dataset.name;

    if (file_type === "K") {
      progress_result = $('.progress-kor-' + pic_seq);
    } else if (file_type === "E") {
      progress_result = $('.progress-eng-' + pic_seq);
    }

    try {
      const response = await fetch(window.url_make_makeup2, {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          makeup_model: $('#makeup_model').val(),
          c_seq: c_seq,
          kor_name: kor_name,
          file_type: file_type,
          request_user: req_user
        })
      });

      if (!response.ok) {
        throw new Error(`Network response was not ok: ${response.statusText}`);
      }

      const data = await response.json();
      if (data.ok && data.file_url) {
        progress_result.html('<span class="text-success">파일이 생성되었습니다.</span> : ');
        progress_result.append(`<a href="${data.file_url}" target="_blank">${data.file_name}</a>`);
      } else {
        throw new Error(data.message);
      }
    } catch (error) {
      console.error(error);
      progress_result.html(`<span class="text-danger">파일 생성중 오류 발생 : ${error} </span>`);
      progress_result.append(`<a href="javascript:make2(${c_seq}, '${file_type}', ${req_seq}, ${pic_seq});" class="d-none">[다시시도]</a>`);
    }
  }

