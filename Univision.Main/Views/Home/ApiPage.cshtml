@model Univision.Main.Models.tempModel

@{
                /**/

                Layout = "~/Views/Shared/_Layout.cshtml";
}


    <div class="page-content">
        <div class="row">
            <div class="col-lg-6">
                <h5>회사 검색(API 가 많이 느려요..)</h5>
                <br />
                <div class="row">
                    <div class="col-md-4 form-group">
                        @Html.TextBox("company", "", new { @class = "form-control" })
                    </div>
                    <div class="col-md-8 form-group">
                        <button type="button" id="btnSearch" class="btn btn-sm btn-primary float-left">검색</button>
                    </div>

                </div>
                <br />
                <br />
                <h5>학교검색</h5>
                <br />
                <div class="row">
                    <div class="col-lg-2 form-group">
                        <select id="gubun" class="form-control">
                            <option value="high_list">고등학교</option>
                            <option value="univ_list">대학교</option>
                        </select>

                    </div>
                    <div class="col-lg-4 form-group">
                        @Html.TextBox("schoolName", "", new { @class = "form-control" })
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <h5>산업 검색</h5>
                <br />
                <div class="row">

                    <div id="businessCodeDiv" class="col-md-8 form-group business_group" style="background-color:white">
                    </div>
                    <button type="button" id="btnBusiness" class="btn btn-sm btn-primary">선택</button>
                    <div class="col-md-4 form-group">

                    </div>
                </div>

                <h5>직무 검색</h5>
                <br />
                <div class="row">

                    <div id="jobCodeDiv" class="col-md-8 form-group business_group form-group" style="background-color:white">
                    </div>
                    <button type="button" id="btnJob" class="btn btn-sm btn-primary">선택</button>
                    <div class="col-md-4 ">

                    </div>
                </div>
            </div>

        </div>
        <br />
        <br />
        <div class="row">
            <div class="col-md-6">
                <h5>파일추가</h5>
                <button type="button" id="btnFile" class="btn btn-sm btn-primary">
                    <i class="fas fa-plus"></i>
                    파일 추가
                </button>
            </div>
            <div class="col-md-6">
                <h5>알림</h5>
                <button type="button" class="btn btn-sm btn-primary" onclick="NormalAlert('기본 알림')">기본 알림</button>
                <button type="button" class="btn btn-sm btn-info" onclick="ConfirmAlert('삭제', '컨펌 메세지는 ConfirmOkFunction() 을 꼭 같이 만들어야 합니다')">컨펌</button>
                <button type="button" class="btn btn-sm btn-danger" onclick="ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.')">오류 알림</button>
            </div>
        </div>

        <br />
        <br />
        <div class="row">
            <div class="col-md-6">
                <h5>직급/직책</h5>
                <br />
                <div class="row">

                    <div class="col-md-8 form-group rpCodeDiv">
                        <input type="hidden" name="r_code" value="0" />
                        <input type="hidden" name="p_code" value="0" />
                        <input type="text" name="rankposition" class="form-control bg-white" placeholder="직책/직급" readonly="readonly" onclick="FindRankPosition(this)"  />
                    </div>
                </div>

            </div>
            <div class="col-md-6">
                
            </div>
        </div>

        @Html.PageAjaxLinks(Model.PagingInfo,
                     ViewContext.HttpContext.Request.Url.AbsoluteUri,
                     x => Url.Action("ApiPage", new
                     {
                         page = x
                     }))
    </div>


@section scripts{

    <!-- 학교검색 -->

    <script type="text/javascript">
    var callJobObj;
        var callBusiObj;
    var callRankObj;

        $(document).ready(function () {

            $("#btnSearch").click(function () {

                $.ajax({
                    url: '@Url.Action("FindCompanyApi", "Partial")',
                    data: {
                        companyName: $("#company").val()
                    },
                    dataType: 'html',
                    type: 'POST',
                    beforeSend: function ()
                    {
                        $(".page").isLoading({
                            text: "Loading",
                            position: "overlay"
                        });
                    }
                })
                .done(function (json) {
                    $(".page").isLoading( "hide" );
                    $.fancybox.open(json, {
                        helpers: {
                            overlay: {
                                closeClick: false
                            }
                        }
                    });
                })
                .fail(function (e) {
                    $(".page").isLoading( "hide" );
                    ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
                });

            });

            //학교 검색
            $( "#schoolName" ).autocomplete({
                source : function( request, response ) {
                    $.ajax({
                        type: 'post',
                        url: '@Url.Action("FindSchoolApi", "Partial")',
                        dataType: "json",
                        //request.term = $("#autocomplete").val()
                        data: {
                            gubun : $("#gubun").val()
                            ,schoolName: request.term
                        },
                        success: function(data) {
                            //서버에서 json 데이터 response 후 목록에 뿌려주기 위함
                            response(
                                $.map(data.list, function (item) {
                                    return {
                                        label: item.schoolName,
                                        value: item.schoolName
                                    }
                                })
                            );
                        }
                    });
                },
                autoFocus:true, //첫번째 값을 자동 focus한다
                minLength: 2,  //조회를 위한 최소글자수
                select: function( event, ui ) {
                    // 만약 검색리스트에서 선택하였을때 선택한 데이터에 의한 이벤트발생
                }
            });

            //파일추가
            $("#btnFile").click(function () {
                $.ajax({
                    url: '@Url.Action("FileUploadApi", "Partial")',
                    data: {

                    },
                    dataType: 'html',
                    type: 'POST',
                    beforeSend: function ()
                    {
                        $(".page").isLoading({
                            text: "Loading",
                            position: "overlay"
                        });
                    }
                })
                .done(function (json) {
                    $(".page").isLoading( "hide" );
                    $.fancybox.open({
                        'content':json,
                        'width': '700',
                        'height': '300',
                        'autoDimensions':false,
                        'type':'iframe',
                        'autoSize': false,
                        'title': '파일 추가',
                        'titleShow'      : 'true',
                        'titlePosition'  : 'inside',
                        helpers: {
                            title : {
                                type: 'inside',
                                position : 'top'
                            },
                            overlay: {
                                closeClick: false
                            }
                        }
                    });
                })
                .fail(function (e) {
                    $(".page").isLoading( "hide" );
                    ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
                });
            })

            //산업
            $("#btnBusiness").click(function () {
                callBusiObj = $("#businessCodeDiv");
                var businessCodeList = [];

                var i = 0;
                $("#businessCodeDiv").find(".busiCode").each(function () {

                    var data = {
                        code1: $(this).attr("code1"),
                        code2: $(this).attr("code2"),
                        code3: $(this).attr("code3")
                    };

                    businessCodeList.push(data);

                    i++;
                });

                $.ajax({
                    url: '@Url.Action("BusinessApi", "Partial")',
                    data: {
                        data: businessCodeList
                    },
                    dataType: 'html',
                    type: 'POST',
                    beforeSend: function ()
                    {
                        $(".page").isLoading({
                            text: "Loading",
                            position: "overlay"
                        });
                    }
                })
                .done(function (json) {
                    $(".page").isLoading( "hide" );
                    $.fancybox.open({
                        'content':json,
                        'width': '640',
                        'height': '500',
                        'autoDimensions':false,
                        'type':'iframe',
                        'autoSize': false,
                        'title': '산업 키워드',
                        helpers: {
                            title : {
                                type: 'inside',
                                position : 'top'
                            },
                            overlay: {
                                closeClick: false
                            }
                        }
                    });
                })
                .fail(function (e) {
                    $(".page").isLoading( "hide" );
                    ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
                });

            });

            //직무
            $("#btnJob").click(function () {
                callJobObj = $(this);
                var jobCodeList = [];

                var i = 0;
                $("#jobCodeDiv").find(".jobCode").each(function () {

                    var data = {
                        code1: $(this).attr("code1"),
                        code2: $(this).attr("code2"),
                        code3: $(this).attr("code3")
                    };

                    jobCodeList.push(data);

                    i++;
                });

                $.ajax({
                    url: '@Url.Action("JobApi", "Partial")',
                    data: {
                        data: jobCodeList
                    },
                    dataType: 'html',
                    type: 'POST',
                    beforeSend: function ()
                    {
                        $(".page").isLoading({
                            text: "Loading",
                            position: "overlay"
                        });
                    }
                })
                .done(function (json) {
                    $(".page").isLoading( "hide" );
                    $.fancybox.open({
                        'content':json,
                        'width': '640',
                        'height': '500',
                        'autoDimensions':false,
                        'type':'iframe',
                        'autoSize': false,
                        'title': '직무 키워드',
                        helpers: {
                            title : {
                                type: 'inside',
                                position : 'top'
                            },
                            overlay: {
                                closeClick: false
                            }
                        }
                    });
                })
                .fail(function (e) {
                    $(".page").isLoading( "hide" );
                    ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
                });

            });

            //직급/직책
            $("#btnRP").click(function () {
                debugger;
                FindRankPosition(this);
                
            });
        });

    function FindRankPosition(obj) {
        callRankObj = obj;
        
        var r_code = $(obj).closest(".rpCodeDiv").find("input[name='r_code']").val();
        var p_code = $(obj).closest(".rpCodeDiv").find("input[name='p_code']").val();

        $.ajax({
            url: '@Url.Action("RankPositionApi", "Partial")',
            data: {
                r_code: r_code,
                p_code: p_code
            },
            dataType: 'html',
            type: 'POST',
            beforeSend: function ()
            {
                $(".page").isLoading({
                    text: "Loading",
                    position: "overlay"
                });
            }
        })
        .done(function (json) {
            $(".page").isLoading( "hide" );
            $.fancybox.open({
                'content':json,
                'width': '350',
                'height': '245',
                'autoDimensions':false,
                'type':'iframe',
                'autoSize': false,
                helpers: {
                    overlay: {
                        closeClick: false
                    }
                }
            });
        })
        .fail(function (e) {
            $(".page").isLoading( "hide" );
            ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
        });
    }
        

    //Confirm OkFunction 세트
    function ConfirmOkFunction() {
        alert("confirm Alert Ok");
    }


    </script>

}