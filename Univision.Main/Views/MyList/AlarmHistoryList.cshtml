@model Univision.Main.Models.MyList.AlarmHistoryListViewModel

@{
    ViewBag.Title = "AlarmHistoryList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .custom1 a:active, .custom1 a:link, .custom1 a:any-link {
        text-decoration: none;
        color: white;
    }
</style>

<div class="page-content container-fluid">
    <div class="row">
        <div class="col-xl-12">
            @using (Html.BeginForm("AlarmHistoryList", "MyList", FormMethod.Get, new { @id = "searchForm" }))
            {
                <div class="form-group custom5">

                    <div class="input-group w-300 mr-20 st">
                        @Html.TextBoxFor(x => x.search.searchTxt, new { @class = "form-control", @placeholder = "Search..." })
                        <span class="input-group-btn">
                            <button type="submit" class="btn btn-primary" id="btnSearch"><i class="icon wb-search" aria-hidden="true"></i></button>
                        </span>
                    </div>

                </div>
            }
        </div>
    </div>

    <div class="row">
        <div class="col-xl-12">
            <div class="panel custom1">
                <header class="panel-heading">
                    <h3 class="panel-title">
                        알림 내역
                    </h3>
                    <div class="panel-actions">
                        <button type="button" class="btn btn-sm btn-primary" id="btnAllRead">읽음 표시</button>
                    </div>
                </header>
                <div class="panel-body">
                    <div class="table-responsive">
                        <table id="default-table" class="table table-hover ">
                            <colgroup>
                                <col style="width:5%" />
                                <col style="width:60%">
                                <col style="width:10%">
                                <col style="width:10%">
                                <col style="width:10%">
                                <col style="width:5%">
                            </colgroup>
                            <thead>
                                <tr>
                                    <th>
                                        <div class="checkbox-custom checkbox-primary">
                                            <input type="checkbox" id="checkAll" name="checkAll">
                                            <label for="checkAll"></label>
                                        </div>
                                    </th>
                                    <th>내용</th>
                                    <th>생성일</th>
                                    <th>읽음 여부</th>
                                    <th>읽은 날짜</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.list.Count > 0)
                                {
                                    foreach (var data in Model.list)
                                    {
                                        <tr>
                                            <td>
                                                <div class="checkbox-custom checkbox-primary">
                                                    <input type="checkbox" id="@data.am_seq" name="data.am_seq" value="@data.am_seq">
                                                    <label for="@data.am_seq"></label>
                                                </div>
                                            </td>
                                            <td class="text-left">
                                                @data.message
                                            </td>
                                            <td>
                                                @Utils.ConvertDateTimeToString(data.create_dt)
                                            </td>
                                            <td>
                                                @(data.is_read == 0 ? "N" : "Y")
                                            </td>
                                            <td>
                                                @Utils.ConvertDateTimeToString(data.read_date)
                                            </td>
                                            <td>
                                                <a href="@data.href_url" class="btn btn-sm btn-success" onclick="AlarmConfirm('@data.am_seq')">
                                                    <i class="fas fa-external-link-alt"></i> 이동
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6">
                                            알람 내역이 없습니다.
                                        </td>
                                    </tr>
                                }

                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="panel-footer">
                    @Html.PageAjaxLinks(Model.PagingInfo,
                     ViewContext.HttpContext.Request.Url.AbsoluteUri,
                     x => Url.Action("AlarmHistoryList", new
                     {
                         page = x
                     }))
                </div>

            </div>
        </div>
    </div>

    <!-- 문자내역 보기 모달 -->
    <div class="modal fade show sms" role="dialog" id="smsDetailModal">
        <div class="modal-dialog modal-simple smspop">
            <div class="modal-content">
                <div class="modal-header">
                    <div class="icondemo-wrap vertical-align" data-name="message">
                        <div class="icondemo vertical-align-middle">
                            <i class="icon ml-message" aria-hidden="true"></i>
                        </div>
                    </div>
                    <h4 class="modal-title" id="smsDetailModalLabel">문자 내역</h4>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">×</span>
                    </button>
                </div>
                <div class="modal-body" id="smsDetailModalBody">
                    <div class="row">
                        <div class="col-xl-12 form-group">
                            <div class="col-xl-12 row tit">
                                <div class="icondemo-wrap vertical-align " data-name="message">
                                    <div class="icondemo vertical-align-middle">
                                        <i class="icon fa-envelope-o" aria-hidden="true"></i>
                                    </div>
                                </div>
                                <h5>발신번호 (보내는사람)</h5>
                            </div>

                            <div class="cont">
                                <p class="form-control-plaintext send_num">

                                </p>
                            </div>
                        </div>
                        <div class="col-xl-12 form-group">
                            <div class="col-xl-12 row tit">
                                <div class="icondemo-wrap vertical-align" data-name="message">
                                    <div class="icondemo vertical-align-middle">
                                        <i class="icon fa-envelope-open-o" aria-hidden="true"></i>
                                    </div>
                                </div>
                                <h5>수신번호 (받는사람)</h5>
                            </div>
                            <div class="cont2 row">
                                <p class="form-control-plaintext receive_num">

                                </p>
                            </div>
                        </div>

                        <div class="col-xl-12 form-group">
                            <div class="col-xl-12 row tit">
                                <div class="icondemo-wrap vertical-align" data-name="message">
                                    <div class="icondemo vertical-align-middle">
                                        <i class="icon wb-order" aria-hidden="true"></i>
                                    </div>
                                </div>
                                <h5>내용입력</h5>
                            </div>
                            <div class="cont2">
                                <p class="form-control-plaintext sms_contents">

                                </p>

                            </div>
                            <div class="cont3">
                                <div class="col-md-12 float-right custom5">
                                    <button class="btn btn-primary btn-outline ed" data-dismiss="modal" type="button">확인</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
    <!-- 문자내역 보기 모달 -->

</div>

@section scripts {

    <script type="text/javascript">
        $(document).ready(function () {

            $("#checkAll").click(function () {
                if ($(this).is(":checked")) {
                    $("input:checkbox[name='data.am_seq']").prop("checked", true);
                }
                else {
                    $("input:checkbox[name='data.am_seq']").prop("checked", false);
                }
            });//checkAll 끝.

            //체크 항목 모두 읽기
            $("#btnAllRead").click(function () {

                var am_seqs = [];
                $("input:checkbox[name='data.am_seq']:checked").each(function () {
                    am_seqs.push($(this).val());
                });

                if (am_seqs.length == 0)
                    ErrorAlert("읽음표시 하려는 메세지를 선택 하세요.");


                $.ajax({
                    url: '@Url.Action("CheckAlarmConfirm", "Partial")',
                    data: {
                        am_seqs: am_seqs
                    },
                     dataType: 'json',
                     type: 'POST',
                    beforeSend: function ()
                    {
                        showLoading();
                    }
                })
                .done(function (json) {
                    hideLoading();
                    if (json.ok) {
                        NormalAlert(json.message);
                        
                    } else {
                        ErrorAlert(json.message);
                    }

                    return true;
                })
                .fail(function (e) {
                    hideLoading();
                    ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
                });



            });//체크항목 모두 읽기 끝

        });
        //document ready 끝.
        


    </script>

}