
@{
    ViewBag.Title = "AttendUpload";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-content">

    <div class="panel">
        <div class="panel-heading">
            <h3 class="panel-title">
                <i class="fas fa-upload"></i>
                출근 파일 업로드
            </h3>
        </div>
        <div class="panel-body">
            @using (Html.BeginForm("AttendUpload", "MyList", FormMethod.Post, new { @id = "CreateForm", @enctype = "multipart/form-data" }))
            {
                <div class="row">
                    <div class="form-group col-md-6">
                        <div class="input-group input-group-file" data-plugin="inputGroupFile">
                            <input type="text" class="form-control" readonly="">
                            <span class="input-group-btn">
                                <span class="btn btn-success btn-file">
                                    <i class="icon wb-upload" aria-hidden="true"></i>
                                    <input type="file" id="files" name="files" multiple="">
                                </span>
                            </span>
                        </div>
                    </div>
                    <div class="form-group col-md-6">
                        <button type="submit" class="btn btn-primary">등록</button>
                    </div>
                </div>
            }

        </div>
    </div>

</div>

@section scripts {
    <script src="~/Libs/remark/global/js/Plugin/input-group-file.min599c.js?v4.0.4"></script>
    <script type="text/javascript">

        $(document).ready(function () {
            StopEnterSubmit();

            $("#CreateForm").ajaxForm({
                dataType: 'json',
                beforeSubmit: function () {
                    showLoading();
                    if (!document.getElementById("files").files.length > 0) {
                        ErrorAlert("업로드 할 파일을 등록 하세요.");
                        return false;
                    }
                },
                success: function (json) {
                    hideLoading();
                    if (json.ok) {
                        NormalAlert(json.message);
                    }
                    else {
                        NormalAlert(json.message);
                    }
                },
                error: function () {
                    hideLoading();
                }
        });
        });

    </script>

}