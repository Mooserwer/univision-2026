
@{
    ViewBag.Title = "UserAttend";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/Libs/remark/global/vendor/fullcalendar/fullcalendar.min599c.css?v4.0.4">
<link rel="stylesheet" href="~/Libs/remark/base/assets/examples/css/apps/calendar.min599c.css?v4.0.4">

<div class="page-content">
    <div class="calendar-container">
        <div id="calendar"></div>
    </div>
</div>

@section scripts {
    <script src="~/Scripts/moment.js"></script>
    <script src="~/Libs/remark/global/vendor/fullcalendar/fullcalendar.min599c.js?v4.0.4"></script>

    <script type="text/javascript">
        
        $(document).ready(function () {

            updateCalendar();

        });

        function updateCalendar() {
            
            var date = moment($("#calendar").fullCalendar("getDate")).format("YYYY-MM-DD");

            $.ajax({
                url: '@Url.Action("UserAttendUpdate", "MyList")',
                type: "POST",
                dataType: 'json',
                data: {
                    calDate: moment($("#calendar").fullCalendar("getDate")).format("YYYY-MM-DD")
                },
                beforeSend: function () {
                    showLoading();
                },
                success: function (json) {
                    hideLoading();
                    if (json.ok) {
                        $("#calendar").fullCalendar("destroy")

                        $("#calendar").fullCalendar({
                            header: {
                                left: null,
                                center: "prev,title,next",
                                right: false
                            },
                            defaultDate: date,
                            contentHeight: 'auto',
                            events: json.events
                        });

                        //Prev 버튼
                        $(".fc-prev-button").click(function () {
                            updateCalendar();                
                        });

                        //Next 버튼
                        $(".fc-next-button").click(function() {
                            updateCalendar();
                        });
                    }
                    else {
                        
                    }
                },
                error: function (jqXHR, textStatus, errorThrown) {
                    hideLoading();
                    ErrorAlert("알 수 없는 오류가 발생 했습니다.<br />관리자에게 문의 하세요.");
                },
                complete: function () {
               
                }
            });

        }


    </script>
}
