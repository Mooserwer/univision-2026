@model Univision.Main.Models.Api.BusinessModel

<style>
    h3 {
        margin-top: 0px !important;
    }

    .pop-padding {
        padding: 2px !important;
    }

    .no-right-margin {
        margin-right: 0px;
    }

    .no-right-padding {
        padding-right: 0px;
    }

    .list-group {
        max-height: 300px;
        overflow: auto
    }

    .item-empty {
        height: 300px;
    }

    .no-margin {
        margin: 0px;
    }

    .no-padding {
        padding: 0px;
    }

    .code3badge {
        margin: 0px 2px 0px 2px;
    }

    .highlight {
        background-color: #feffad;
    }

    .fancybox-title
    {
        text-align:left !important;
    }

    #codeBind .badge{
        font-weight: 100;
    }

    #codeBind .badge-lg{
        font-size: 15px;
    }
</style>


<div>
    @Html.TextBox("business_search", "", new { @class = "form-control", @placeholder = "찾고자 하는 산업 및 키워드 입력" })
</div>
@*<div class="row col-md-12">
    <div class="col-md-4 pop-padding">
        <h5>산업 선택 <span id="code1Cnt" class="blue-500">0</span>/1</h5>
    </div>
    <div class="col-md-4 pop-padding">

    </div>
    <div class="col-md-auto">
        <h5>키워드 선택 <span id="code3Cnt" class="blue-500">0</span>/5</h5>
    </div>
</div>*@
<div class="row col-md-12 no-side-space">

    <!-- 산업 1단계-->
    <div class="col-md-4 pop-padding">
        <div>
            <h5>산업 선택 <span id="code1Cnt" class="blue-500">0</span>/1</h5>
        </div>
        <div class="list-group list-group-bordered code1Group">
            @if (Model.list1.Count > 0)
            {
                foreach (var data in Model.list1)
                {
                    <a href="javascript:void(0)" class="list-group-item flex-column align-items-start code1" id="@data.code1" onclick="code1Click(this, 'Y')">
                        <p class="mb-0">@data.code_name1</p>
                    </a>
                }
            }
        </div>
    </div>

    <!-- 산업 2단계-->
    <div class="col-md-4 pop-padding">
        <div>
            <h5>키워드 선택 <span id="code3Cnt" class="blue-500">0</span>/5</h5>
        </div>
        <div class="list-group list-group-bordered code2Group">
            @if (Model.list2.Count > 0)
            {
                foreach (var data in Model.list2)
                {
                    <a href="javascript:void(0)" class="list-group-item flex-column align-items-start code2" id="@data.code2" onclick="code2Click(this, 'Y')">
                        <p class="mb-0">@data.code_name2</p>
                    </a>
                }
            }
            else
            {
                <a href="javascript:void(0)" class="list-group-item bg-inherit bg-grey-100 code2 item-empty">
                    <p class="mb-0">← 산업을 선택하세요.</p>
                </a>
            }
        </div>
    </div>

    <!-- 산업 3단계-->
    <div class="col-md-4 pop-padding float-right">
        <div class="list-group list-group-bordered code3Group">
            @if (Model.list3.Count > 0)
            {
                foreach (var data in Model.list3)
                {
                    <ul class="list-group-item flex-column align-items-start">
                        <div class="checkbox-custom checkbox-primary no-margin">
                            <input type="checkbox" class="code3" id="@data.code3" name="@data.code_name3" onclick="code3Click(this)">
                            <label for="@data.code3">@data.code_name3</label>
                        </div>
                    </ul>
                }
            }
            else
            {
                <a href="javascript:void(0)" class="list-group-item bg-inherit bg-grey-100 code3 item-empty">
                    <p class="mb-0">← 산업을 선택하세요.</p>
                </a>
            }




        </div>
    </div>
</div>

<div class="row col-md-12 no-right-margin no-right-padding">
    <div id="codeBind" class="col-md-11">

        <button id="btnReset" type="button" class="btn btn-sm bg-grey-100">
            <i class="wb-reload">초기화</i>
        </button>
    </div>

    <div class="col-md-1 text-right no-margin no-padding">
        <button id="btnPopSave" type="button" class="btn btn-sm btn-primary">확인</button>
    </div>
</div>

<script type="text/javascript">
    var timer;
    //산업 단계별로 선택 안했을 때, 사용함.
    var emptyItem = "<a href='#' class='list-group-item bg-inherit bg-grey-100 item-empty'><p class='mb-0'>← 산업를 선택하세요.</p></a>";
    var errorItem = "<a href='#' class='list-group-item bg-inherit bg-grey-100 item-empty'><p class='mb-0'>산업 정보를 가져올 수 없습니다.</p></a>";

    $(document).ready(function () {

        //초기 시작.
        Initialize();

        //산업 키워드 검색.
        $("#business_search").autocomplete({
            source : function( request, response ) {
                $.ajax({
                    type: 'post',
                    url: '@Url.Action("SearchBusinessKeywordApi", "Partial")',
                    dataType: "json",
                    //request.term = $("#autocomplete").val()
                    data: {
                        searchValue : request.term
                    },
                    success: function(data) {
                        //서버에서 json 데이터 response 후 목록에 뿌려주기 위함
                        response(
                            $.map(data.list, function (item) {
                                return {
                                    label: item.code_name1 + " > " + item.code_name2 + " > " + item.code_name3,
                                    code1: item.code1,
                                    code2: item.code2,
                                    code3: item.code3
                                }
                            })
                        );

                        $(".ui-autocomplete").highlight(request.term);
                    }
                });
            },
            autoFocus:true, //첫번째 값을 자동 focus한다
          minLength: 1,  //조회를 위한 최소글자수
          search: function (event, ui) {
            var is_select = $(this).attr('is_select');
            is_select = (typeof is_select === "undefined") ? 0 : is_select;
            //console.log(is_select);
            if (is_select == 1) {
              return false;
            }
          },
            select: function(event, ui) {
                // 검색리스트에서 선택 했을 때 이벤트 발생
                reset();

                $("#code1Cnt").html("1");

                
                selectCode2List(ui.item.code1, ui.item.code2)
                
                //selectCode3List(ui.item.code1, ui.item.code2, ui.item.code3)
                
                $(".code1").each(function () {
                    if ($(this).attr("id") == ui.item.code1)
                        $(this).addClass("active");
                });

                timer = setInterval("chkBusiness3(" + ui.item.code3 + ")", "100");

                $(".code3").each(function () {
                    
                    if ($(this).attr("id") == ui.item.code3)
                        $(this).click()
                });

          },
          focus: function (event, ui) {
            //console.log("xx", $(this).attr('is_select'))
            $(this).attr('is_select', 1);
            setTimeout(function (obj) {
              $(obj).attr('is_select', 0);
              //console.log("reset");
            }, 500, this);
            
            event.preventDefault();
          },
            change:function(event){
                $("#business_search").val("");
                return false;
            }
        });

        //초기화 버튼
        $("#btnReset").click(function () {
            reset();
        });

        //확인 버튼
        $("#btnPopSave").click(function () {

            var title = "";
            var hidden = "";

            var appendHtml = "<span>";
            //codeBind Div에 Span(선택된 산업) 갯수만큼 each
            $("#codeBind").find("span").each(function () {
                if (title != "") {
                    title += "/";
                }
                title += $(this).attr("code3Name");
                hidden += "<input class='busiCode' type='hidden' id='busiCode' name='busiCode' code1='" + $(this).attr("code1") + "' code2='" + $(this).attr("code2") + "' code3='" + $(this).attr("code3") + "' /> ";
            });

            appendHtml += title + hidden + "</span>";

            //$("#businessCodeDiv").html(appendHtml);
            //호출 페이지에 정의. 호출한 element
            $(callBusiObj).html(appendHtml);

            //호출 페이지 Validator 호출. - CreateProject 페이지 사용.
            $('#CreateForm').formValidation('revalidateField', 'businessCodeDiv');

            $.fancybox.close();
        })

    });

    function chkBusiness3(code3) {
        
        $(".code3").each(function () {   
            if ($(this).attr("id") == code3)
                $(this).click()
        });

        var checkCnt = $(".code3:checked").length;

        if (checkCnt > 0) {
            //인터벌 종료.
        clearInterval(timer);
        }
        
    }

    //페이지 시작.
    function Initialize() {

        var code1 = @Model.code1;
        var code2 = @Model.code2;
        var code3 = @Html.Raw(Json.Encode(Model.code3));

        if (code1 > 0) {
            $(".code1").each(function () {
                if ($(this).attr("id") == code1)
                    code1Click($(this), 'N');
            });

            $(".code2").each(function () {
                if ($(this).attr("id") == code2)
                    code2Click($(this), 'N');
            });

            $(".code3").each(function () {

                for (var i = 0; i < code3.length; i++) {
                    if ($(this).attr("id") == code3[i]) {
                        $(this).click();
                    }
                }
                
            })
        }


    }

    function reset() {
        //badge 삭제.
        $("#codeBind").find(".code3badge").remove();

        //1단계 초기화.
        $("#code1Cnt").html(0);
        $(".code1").removeClass("active");

        //2단계 초기화.
        $(".code2Group").empty();
        $(".code2Group").html(emptyItem);

        //3단계 초기화
        $(".code3Group").empty();
        $(".code3Group").html(emptyItem);
        $("#code3Cnt").html(0);
    }

    //산업 1단계 클릭 이벤트
    function code1Click(obj, flag) {
        var now;

        //이전에 선택한 산업 1단계를 찾음.
        $(".code1").each(function () {
            if ($(this).hasClass("active"))
                now = $(this);
        });
        
        //현재 선택한 산업 단계에 a 태그 active 클래스 부여.
        $(obj).addClass("active");

        //현재 선택한 산업 단계 이외의 a 태그 active 클래스 제거
        $(".code1").not(obj).removeClass("active");

        $("#code1Cnt").html("1");

        if (flag != "N") {

            //현재 선택한 산업 단계와 이전에 선택한 산업 단계가 다르다면 초기화.
            if ($(obj).attr("id") != $(now).attr("id")) {
                $(".code2Group").empty();
                $(".code2Group").html(emptyItem);

                $(".code3Group").empty();
                $(".code3Group").html(emptyItem);
            }

            //산업 2단계 리스트 불러옴.
            selectCode2List($(obj).attr("id"));
        }
    }

    //산업 2단계 클릭 이벤트.
    function code2Click(obj, flag) {

        var now;

        //이전에 선택한 산업 2단계를 찾음.
        $(".code2").each(function () {
            if ($(this).hasClass("active"))
                now = $(this);
        });

        //현재 선택한 산업 단계에 a 태그 active 클래스 부여.
        $(obj).addClass("active");

        //현재 선택한 산업 단계 이외의 a 태그 active 클래스 제거
        $(".code2").not(obj).removeClass("active");

        if (flag != "N") {
            //현재 선택한 산업 단계와 이전에 선택한 산업 단계가 다르다면 초기화.
            if ($(obj).attr("id") != $(now).attr("id")) {
                $(".code3Group").empty();
                $(".code3Group").html(emptyItem);
            }

            //산업 3단계 목록 불러오기.
            selectCode3List($(".code1.active").attr("id"), $(obj).attr("id"))
        }

    }

    //산업 3단계 클릭 이벤트.
    function code3Click(obj) {
        
        //checkbox 카운트
        var checkCnt = $(".code3:checked").length;
        $("#code3Cnt").html(checkCnt);

        //체크 해제시.
        if (!$(obj).is(":checked")) {
            //전체 Badge에서 현재 선택한 code3를 찾아 삭제.
            $(".code3badge").each(function () {
                if ($(this).attr("code3") == $(obj).attr("id")) {
                    $(this).remove();

                }
            });

            return;
        }

        if (checkCnt > 5) {
            alert("키워드는 최대 5개까지 선택 가능합니다.");
            $(obj).prop("checked", false);
            return;
        }

        var sb = new StringBuilder();

        var code1 = $(".code1.active").attr("id");
        var code2 = $(".code2.active").attr("id");
        var code3 = $(obj).attr("id");
        var code3Name = $(obj).attr("name");

        var appendHtml = "";
        appendHtml += "<span class='badge badge-outline badge-default bg-white badge-lg cur_hand code3badge' code1='" + code1 + "' code2='" + code2 + "' code3='" + code3 + "' code3Name='" + code3Name + "' onclick='delCode3(this)'>";
        appendHtml += code3Name;
        appendHtml += "<i class='far fa-times-circle'></i>";
        appendHtml += "</span>";

        $("#codeBind").prepend(appendHtml.toString());
    }

    //Badge 클릭하여 삭제.
    function delCode3(obj) {
        //3단계 목록에서 현재 삭제하려는 요소의 체크박스 해제.
        $(".code3").each(function () {
            if ($(this).attr("id") == $(obj).attr("code3")) {
                $(this).prop("checked", false);
            }
        });

        $("#code3Cnt").html($(".code3:checked").length);

        $(obj).remove();
    }

    //산업 2단계 목록 조회.
    function selectCode2List(code1, selectCode2) {

        $.ajax({
               url: '@Url.Action("BusinessApi2", "Partial")',
               data: {
                   code1: code1
                },
                dataType: 'json',
                type: 'POST',
               beforeSend: function ()
               {

               }
        })
        .done(function (json) {

            if (json.ok) {

                if (json.list.length > 0) {

                    var sb = new StringBuilder();

                    for (var i = 0; i < json.list.length; i++) {

                        var data = json.list[i];

                        sb.append("<a href='#' class='list-group-item flex-column align-items-start code2' id='" + data.code2 + "' onclick='code2Click(this, &quot;Y&quot;)'>");
                        sb.append("<p class='mb-0'>" + data.code_name2 + "</p>");
                        sb.append("</a>");
                    }

                    $(".code2Group").empty();
                    $(".code2Group").append(sb.toString());

                    if (selectCode2 != undefined) {

                        $(".code2").each(function () {
                            if ($(this).attr("id") == selectCode2)
                                code2Click($(this), 'Y');
                        });
                    }
                }
            } else {
                $(".code2Group").empty();
                $(".code2Group").append(errorItem);
            }
        })
        .fail(function (e) {
            ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
        });
    }

    //산업 3단계 목록 조회.
    function selectCode3List(code1, code2, selectCode3) {

        $.ajax({
               url: '@Url.Action("BusinessApi3", "Partial")',
               data: {
                   code1: code1
                   ,
                   code2: code2
                },
                dataType: 'json',
                type: 'POST',
               beforeSend: function ()
               {

               }
        })
        .done(function (json) {

            if (json.ok) {

                if (json.list.length > 0) {

                    var sb = new StringBuilder();

                    for (var i = 0; i < json.list.length; i++) {

                        var data = json.list[i];

                        sb.append("<ul class='list-group-item flex-column align-items-start'>");
                        sb.append("<div class='checkbox-custom checkbox-primary no-margin'>");
                        sb.append("<input type='checkbox' class='code3' id='" + data.code3 + "' name='" + data.code_name3 + "' onclick='code3Click(this)'>");
                        sb.append("<label for='" + data.code3 + "'>" + data.code_name3 + "</label>");
                        sb.append("</div>");
                        sb.append("</ul>");
                    }

                    $(".code3Group").empty();
                    $(".code3Group").append(sb.toString());

                    $(".code3").each(function () {
                        if ($(this).attr("id") == selectCode3) {
                            //$(this).prop("checked", true);
                            //code3Click($(this));
                            $(this).click();
                        }
                    });
                    
                }
            } else {
                $(".code3Group").empty();
                $(".code3Group").append(errorItem);
            }
        })
        .fail(function (e) {
            ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
        });
    }

</script>
