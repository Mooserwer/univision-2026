@model Univision.Main.Models.Api.JobBusinessModel

<style>
    h3 {
        margin-top: 0px !important;
    }

    .pop-padding {
        padding: 2px !important;
    }

    .no-right-margin {
        margin-right: 0px;
    }

    .no-right-padding {
        padding-right: 0px;
    }

    .list-group {
        max-height: 300px;
        overflow: auto
    }

    .item-empty {
        height: 300px;
    }

    .no-margin {
        margin: 0px;
    }

    .no-padding {
        padding: 0px;
    }

    .code3badge {
        margin: 0px 2px 0px 2px;
    }

    .fancybox-title {
        text-align: left !important;
    }

    .ajs-modal {
        z-index: 999999999999;
    }

    #popBottom .badge {
        font-weight: 100;
    }

    #popBottom .badge-lg {
        font-size: 15px;
    }

    .category::after {
        content: " > "
    }

    .catRow {
        margin-top: 3px;
    }

</style>


<div>
    <div>
        @Html.TextBox("search", "", new { @class = "form-control col-md-12", @placeholder = "찾고자 하는 직무 및 키워드 입력" })
    </div>
    
    <!-- 산업 탭 시작 -->
    <div class="tab-pane" id="jobTab" role="tabpanel">
        @*<div class="row col-md-12">
            <div class="col-md-4 pop-padding">
                <h5>대분류 선택</h5>
            </div>
            <div class="col-md-4 pop-padding">
                <h5>중분류 선택(최대 5개) <span id="jobCode2Cnt" class="blue-500">0</span>/5</h5>
            </div>
            <div class="col-md-auto">
                <h5>소분류 선택(최대 5개)
            </div>
        </div>*@
        <div class="row col-md-12 no-side-space">

            <!-- 직무 1단계-->
            <div class="col-md-4 pop-padding">
                <div>
                    <h5>대분류 선택</h5>
                </div>
                <div class="list-group list-group-bordered jobCode1Group">
                    @if (Model.jobList1.Count > 0)
                    {
                        foreach (var data in Model.jobList1)
                        {
                            <a href="javascript:void(0)" class="list-group-item flex-column align-items-start jobCode1" id="@data.code1" onclick="code1Click(this)">
                                <p class="mb-0">@data.code_name1 <span class='jobCode2Cnt'></span></p>
                            </a>
                        }
                    }
                </div>
            </div>

            <!-- 직무 2단계-->
            <div class="col-md-8 pop-padding jobCode2Group">
                <div>
                    <h5>소분류 선택(최대 10개) <span id="jobCode2Cnt" class="blue-500">0</span>/10</h5>
                </div>
                <div class="list-group list-group-bordered">
                    <a href="javascript:void(0)" class="list-group-item bg-inherit bg-grey-100 jobCode2 item-empty">
                        <p class="mb-0">← 직무를 선택하세요.</p>
                    </a>
                </div>
            </div>
            @*
            <!-- 직무 3단계-->
            <div class="col-md-4 pop-padding float-right jobCode3Group">
                <div>
                    <h5>소분류 선택(최대 5개)</h5>
                </div>
                <div class="list-group list-group-bordered">
                    <a href="javascript:void(0)" class="list-group-item bg-inherit bg-grey-100 jobCode3 item-empty">
                        <p class="mb-0">← 직무를 선택하세요.</p>
                    </a>
                </div>
            </div>
                *@
        </div>
    </div>
    <!-- 직무 탭 끝 -->
</div>
<!-- 탭 끝-->
<!-- 하단 영역 시작 -->
<div id="popBottom" class="row col-md-12 no-side-space" style="padding-bottom:5px;">
    <div class="col-md-9 no-side-space form-inline">
        <!-- 직무 badge 시작 -->
        <div class="col-md-12 no-side-space form-inline" style="margin-top:10px;">
            <div class="col-md-2 no-side-space">
                <label class="blue-500 font-weight-bold"> 선택된 직무 ｜ </label>
            </div>
            <div id="jobCodeBind" class="col-md-10 no-side-space form-inline">
            </div>
        </div>
        <!-- 직무 badge 시작 -->
    </div>

    <div class="col-md-3 no-margin no-padding" style="border-left:1px solid #e4eaec">
        <button id="btnReset" type="button" class="btn btn-sm bg-grey-100">
            <i class="wb-reload">초기화</i>
        </button>
        <button id="btnPopSave" type="button" class="btn btn-sm btn-primary float-right">확인</button>
    </div>

</div>
<!-- 하단 영역 끝 -->


<script type="text/javascript">
    
    //직무 단계별로 선택 안했을 때, 사용함.
     var errorItem = "<a href='javascript:void(0)' class='list-group-item bg-inherit bg-grey-100 item-empty'><p class='mb-0'>직무 정보를 가져올 수 없습니다.</p></a>"
    //2단계 몇개까지 선택 가능한지
    var code2Len = 10
        
    //3단계 몇개까지 선택 가능한지
    var code3Len = 5

    $(document).ready(function () {
        
        //초기 시작.
        Initialize();

        //초기화 버튼
        $("#btnReset").click(function () {
            reset();
        });

        //직무 및 산업 키워드 검색
        $("#search").autocomplete({
            source : function( request, response ) {
                $.ajax({
                    type: 'post',
                    url: '@Url.Action("SearchJobKeywordApi", "Partial")',
                    dataType: "json",
                    //request.term = $("#autocomplete").val()
                    data: {
                        searchValue : request.term
                    },
                    success: function(data) {
                        //서버에서 json 데이터 response 후 목록에 뿌려주기 위함
                        response(
                            $.map(data.list, function (item) {
                                return {
                                    label: item.code_name1 + " > " + item.code_name2, // + " > " + item.code_name3,
                                    //type: item.type,
                                    code1: item.code1,
                                    code2: item.code2,
                                    //code3: item.code3
                                }
                            })
                        );

                        $(".ui-autocomplete").highlight(request.term);
                    }
                });
            },
            autoFocus:true, //첫번째 값을 자동 focus한다
          minLength: 2,  //조회를 위한 최소글자수
          search: function (event, ui) {
            var is_select = $(this).attr('is_select');
            is_select = (typeof is_select === "undefined") ? 0 : is_select;
            //console.log(is_select);
            if (is_select == 1) {
              return false;
            }
          },
            select: function(event, ui) {
                // 검색리스트에서 선택 했을 때 이벤트 발생


                var data = ui.item;

                $("#job").click();

                //1단계 active class 부여.
                code1Click($(".jobCode1Group").find("#" + data.code1));

                //2단계 checkbox 선택
                var code2Obj = $(".jobCode2Group").find("#" + data.code2);
                $(code2Obj).prop("checked", true);
                code2Click($(code2Obj));

              event.preventDefault();
              $("#search").val("");
                
                //3단계 checkbox 선택 및 badge 생성.
                //var code3Obj = $(".jobCode3Group").find("#" + data.code3);
                //$(code3Obj).prop("checked", true);
                //code3Click($(code3Obj));

          },
          focus: function (event, ui) {
            //console.log("xx", $(this).attr('is_select'))
            $(this).attr('is_select', 1);
            setTimeout(function (obj) {
              $(obj).attr('is_select', 0);
              //console.log("reset");
            }, 500, this);

            event.preventDefault();
          },
            change:function(event){
                //$("#search").val("");
                return false;
            }
        });

        $("#btnPopSave").click(function () {
            $("#jobCodeList").html($("#popBottom").find("#jobCodeBind").html())

            //부모 페이지 validator가 있으면 재검사
            if ($('#CreateForm').formValidation) {
                $('#CreateForm').formValidation('revalidateField', 'jobCodeList');
            } else if(validator) {
                validator.element('#jobCodeList_hid');
            }

          if (getJobBusiSugg) {
            getJobBusiSugg();
          }

            $.fancybox.close();
        });
    });

    //페이지 시작.
    function Initialize() {
        //호출 페이지에 전역변수로 선언된 jobCodeArr에 담긴 항목이 있다면
        if (jobCodeArr.length > 0) {

            for (var i = 0; i < jobCodeArr.length; i++) {

                code1Click($(".jobCode1Group").find("#" + jobCodeArr[i].code1));

                //2단계 checkbox 선택
                var code2Obj = $(".jobCode2Group").find("#" + jobCodeArr[i].code2);
                $(code2Obj).prop("checked", true);
                code2Click($(code2Obj));

                //3단계 checkbox 선택 및 badge 생성.
                //var code3Obj = $(".jobCode3Group").find("#" + jobCodeArr[i].code3);
                //$(code3Obj).prop("checked", true);
                //code3Click($(code3Obj));
            }
        }
    }

    //초기화
    function reset() {

        //상단 카운팅 초기화
        $("#jobCode2Cnt").html(0);
        $("#jobCode3Cnt").html(0);
        

        //1단계 active 삭제
        $(".jobCode1").removeClass("active");

        //2단계 체크 해제
        $(".jobCode2Group").find(".item-empty").closest(".list-group").css("display", "block");
        $(".jobCode2Group").find(".list-group").not($(".jobCode2Group").find(".item-empty").closest(".list-group")).remove();

        //3단계 체크 해제
        //$(".jobCode3Group").find(".item-empty").closest(".list-group").css("display", "block");
        //$(".jobCode3Group").find(".list-group").not($(".jobCode3Group").find(".item-empty").closest(".list-group")).remove();

        //하단 뱃지 삭제.
        $("#jobCodeBind").empty();
    }

    function code1Reloaad() {
        $('.jobCode1').each(function () {
            var group1_id = $(this).attr("id");
            
            $(this).removeClass("active");
            var $group2 = $(".jobCode2Group").find(".list-group#" + group1_id)
            var chkLen = $group2.find(".jobCode2:checked").length;
            //console.log(chkLen, $group2.css("display"), group1_id);
            if (chkLen > 0 || ($group2.css("display") && $group2.css("display") != "none")) {
                $(this).addClass("active");
            }
        });
        code2Check();
    }

    //직무,산업 1단계 클릭 이벤트
    function code1Click(obj) {
        var isOk = true;

        //현재 선택한 직무 단계에 a 태그 active 클래스 부여.
        $(obj).addClass("active");

        //코드2 그룹에서 체크가 하나도 되지 않은 단계가 있는지 찾음.
        $(".jobCode2Group").find(".list-group").each(function () {

            var chkLen = $(this).find(".jobCode2:checked").length;
            if (chkLen == 0) {
                $(".jobCode1Group").find("#" + $(this).attr("id")).not(obj).removeClass("active");
            }
        })
        /*
        var code3Depth = $(".jobCode3Group").find(".list-group");
        if ($(code3Depth).length > 1) {
            $(code3Depth).first().css("display", "block")
            $(code3Depth).not($(code3Depth).first()).css("display", "none");
        }
        */
        //현재 선택한 1단계 항목에 대한 list가 2단계에 그려져 있는지 찾음.
        var nowSelect = $(".jobCode2Group").find("div#" + $(obj).attr("id"));

        //현재 선택한 1단계 항목에 대한 list가 2단계에 그려져 있다면.
        if (nowSelect.length > 0) {
            //2단계 row 디스플레이 변경.
            $(nowSelect).css("display", "block");
            $(".jobCode2Group").find(".list-group").not(nowSelect).css("display", "none");
            return false;
        }
                
        //직무 2단계 리스트 불러옴.
        selectCode2List($(obj).attr("id"));
    }

    //직무,산업 2단계 클릭 이벤트.
    function code2Click(obj) {
        
        var now;
        var isOk = false;
         //2단계 몇개 체크 됐는지 확인.
        isOk = code2Check(obj);

        //체크하면 하단 바인딩 부분에 카테고리 생성.
        if ($(obj).is(":checked")) {
            //CreateCategoryBadge($(obj).attr("code1"), $(obj).attr("id"), $(obj).attr("name"));
            CreateBadge($(obj).attr("code1"), $(obj).attr("name1"), $(obj).attr("id"), $(obj).attr("name"));
        } else {
            DelBadge_job(obj);
            //DelCategoryBadge_job($("#jobCodeBind").find("#job" + $(obj).attr("id")));
        }

        //현재 선택한 2단계 항목에 대한 리스트가 3단계에 그려져 있는지 찾음.
        isOk = chk3DepthList($(obj).attr("id"));

        if (!isOk) {
            return false;
        }

        //직무 3단계 목록 불러오기.
        //selectCode3List($(obj).attr("code1"), $(obj).attr("id"))
    }

    //직무,산업 3단계 클릭 이벤트.
    function code3Click(obj) {

        var isOk = false;

         //3단계 몇개 체크 됐는지 확인.
        isOk = code3Check(obj);

        if (isOk) {
            //체크하면 하단 바인딩 부분에 카테고리 생성.
            if ($(obj).is(":checked")) {

                var code2Obj = $(".jobCode2Group").find("#" + $(obj).attr("code2"));
                //2단계에서 체크가 안되어 있다면
                if (!$(code2Obj).is(":checked")) {

                    //2단계 체크
                    $(code2Obj).prop("checked", true);

                    //2단계 이벤트로.
                    code2Click(code2Obj)
                }

                //CreateBadge($(obj).attr("code1"), $(obj).attr("code2"), $(obj).attr("id"), $(obj).attr("name"));

            } else {
                DelBadge_job(obj);
            }
        }

    }

    //하단 바인딩 부분에 카테고리 생성.
    function CreateCategoryBadge(code1, code1Name) {
        
        if ($("#jobCodeBind").find("#job" + code1).length > 0) {
            return false;
        }

        var appendHtml = "";
        appendHtml += "<div id='job" + code1 + "' code1='" + code1 + "' class='jobRow catRow col-md-12 no-side-space'>";
        appendHtml += "<span class='category'>";
        appendHtml += "<span class='badge badge-outline badge-default bg-white cur_hand badge-lg jobCode1badge' code1='" + code1 + "' name1='" + code1Name + "' onclick='DelCategoryBadge_job(this)'>" + code1Name + "<i class='far fa-times-circle'></i></span>";
        appendHtml += "</span>";
        appendHtml += "</div>";

        $("#jobCodeBind").append(appendHtml.toString());
    }

    //카테고리 하위 배지
    function CreateBadge(code1, code1Name, code2, code2Name) {
        //debugger;
        CreateCategoryBadge(code1, code1Name);

        var category = $("#jobCodeBind").find("#job" + code1);

        if ($("#jobCodeBind").find("#job" + code1).find("#" + code2).length > 0) {
            return false;
        } 


        var appendHtml = "";
        appendHtml += "<span class='badge badge-outline badge-default bg-white badge-lg cur_hand jobCode2badge' code1='" + code1 + "' code2='" + code2 + "' id='" + code2 + "' jobCode2Name='" + code2Name + "' onclick='DelBadge_job(this)'>";
        appendHtml += code2Name;
        appendHtml += "<i class='far fa-times-circle'></i>";
        appendHtml += "</span>";

        $(category).append(appendHtml.toString());

    }

    //Badge 카테고리 삭제.
    function DelCategoryBadge_job(obj, is_silence) {
        
        //obj가 jobRow를 갖지 않은, 즉 Badge에서 삭제 버튼을 통해 해당 함수에 접근 했다면, 상위 div를 찾아서 다시 매핑.
        if (!$(obj).hasClass("jobRow")) {
            obj = $(obj).closest(".jobRow");
        }

        //하위 아이템이 있다면.
        if ($(obj).find("span").length > 2) {
            if (is_silence == true) {
                return;
            }
            alertify.confirm()
                    .set({
                        'labels': { ok: '확인', cancel: '취소' },
                        'onok': function () {

                            //카테고리 삭제 전, 3단계 목록에 있는 체크박스 해제
                            $(obj).closest(".jobRow").find(".jobCode2badge").each(function () {
                                $(".jobCode2Group").find("#" + $(this).attr("id")).prop("checked", false);
                            })

                            //카테고리 row 삭제.
                            $(obj).closest(".jobRow").remove();

                            code1Reloaad();
                        },
                        'oncancel': function () {
                            return;
                        },
                    })
                    .setHeader('<i class="fas fa-exclamation-triangle" style="color:#FFDC2E"></i>산업 삭제')
                    .setting({
                        message: "선택하신 산업을 삭제하면 하위 키워드도 함께 삭제됩니다. 삭제하시겠습니까?",
                    })
                    .show();
        }
        else {
            $(obj).remove();
            $(".jobCode2Group").find("#" + $(obj).attr("code2")).prop("checked", false);
        
            code1Reloaad();
        }
        
        //상단 리스트에서 체크박스 해제.
        
    }
    /*
    //Badge 카테고리 삭제.
    function DelCategoryBadge(obj) {

        //obj가 jobRow를 갖지 않은, 즉 Badge에서 삭제 버튼을 통해 해당 함수에 접근 했다면, 상위 div를 찾아서 다시 매핑.
        if (!$(obj).hasClass("jobRow")) {
            obj = $(obj).closest(".jobRow");
        }

        //하위 아이템이 있다면.
        if ($(obj).find("span").length > 2) {

            alertify.confirm()
                    .set({
                        'labels': { ok: '확인', cancel: '취소' },
                        'onok': function () {

                            //카테고리 삭제 전, 3단계 목록에 있는 체크박스 해제
                            $(obj).closest(".jobRow").find(".jobCode3badge").each(function () {
                                $(".jobCode3Group").find("#" + $(this).attr("id")).prop("checked", false);
                            })

                            //카테고리 row 삭제.
                            $(obj).closest(".jobRow").remove();
                        },
                        'oncancel': function () {
                            return;
                        },
                    })
                    .setHeader('<i class="fas fa-exclamation-triangle" style="color:#FFDC2E"></i>직무 삭제')
                    .setting({
                        message: "선택하신 직무를 삭제하면 하위 키워드도 함께 삭제됩니다. 삭제하시겠습니까?",
                    })
                    .show();
        }
        else {
            $(obj).remove();
        }

        //상단 리스트에서 체크박스 해제.
        $(".jobCode2Group").find("#" + $(obj).attr("code2")).prop("checked", false);

    }
    */

    //Badge 삭제
    function DelBadge_job(obj) {
        //console.log(obj)
        if (!$(obj).hasClass("badge")) {
            obj = $("#jobCodeBind").find("#" + $(obj).attr("id"))
        }
        var category = $(obj).closest(".jobRow").find('span.category')[0];
        
        $(obj).remove();

        $(".jobCode2Group").find("#" + $(obj).attr("id")).prop("checked", false);

        DelCategoryBadge_job(category, true);
    }
    /*
    //Badge 삭제
    function DelBadge(obj) {

        if (!$(obj).hasClass("badge")) {
            obj = $("#jobCodeBind").find("#" + $(obj).attr("id"))
        }

        $(obj).remove();

        $(".jobCode3Group").find("#" + $(obj).attr("id")).prop("checked", false);
    }
    */
    //2단계 몇개 체크 됐는지 확인.
    //type = job, job
    function code2Check(obj) {

        if ($(".jobCode2:checked").length > code2Len) {
            $(obj).prop("checked", false);
            NormalAlert("소분류는 " + code2Len + "개이상 등록할 수 없습니다..");

            //혹시 3단계에 선택된 항목이 있다면..
            //$(".jobCode3Group").find("#" + $(obj).attr("id")).find(".jobCode3").prop("checked", false);
            return false;
        }

        $("#jobCode2Cnt").html($(".jobCode2:checked").length);

        return true;
    }

    //3단계 몇개 체크 됐는지 확인
    //type = job, job
    function code3Check(obj) {
        len = $(".jobCode3Group").find("#" + $(obj).attr("code2")).find(".jobCode3:checked").length;
        if (len > code3Len) {
            $(obj).prop("checked", false);
            NormalAlert("소분류 키워드는 한 중분류당 최대 " + code3Len + "개까지만 선택 가능합니다.");

            return;
        }
        
        var $cntObj = $(".jobCode2Group").find("#jobCode2_div_" + $(obj).attr("code2")).find(".jobCode3Cnt");
        if (len > 0) {
            $cntObj.text(len);
            $cntObj.removeClass("badge badge-primary").addClass("badge badge-primary");
        } else {
            $cntObj.text("");
            $cntObj.removeClass("badge badge-primary")
        }

        return true;
    }

    //선택한 2단계 항목에 대한 3단계 리스트 그려져 있는지 체크
    function chk3DepthList(code2) {
        //현재 선택한 2단계 항목에 대한 list가 3단계에 그려져 있는지 찾음.
        var nowSelect = $(".jobCode3Group").find("div#" + code2);

        //현재 선택한 2단계 항목에 대한 list가 3단계에 그려져 있다면.
        if (nowSelect.length > 0) {
            //3단계 row 디스플레이 변경.
            $(nowSelect).css("display", "block");
            $(".jobCode3Group").find(".list-group").not(nowSelect).css("display", "none");
            return false;
        }

        return true;
    }

