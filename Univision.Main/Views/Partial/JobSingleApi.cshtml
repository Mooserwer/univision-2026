@model Univision.Main.Models.Api.JobModel

<style>
    h3 {
        margin-top: 0px !important;
    }

    .pop-padding {
        padding: 2px !important;
    }

    .no-right-margin {
        margin-right: 0px;
    }

    .no-right-padding {
        padding-right: 0px;
    }

    .list-group {
        max-height: 300px;
        overflow: auto
    }

    .item-empty {
        height: 300px;
    }

    .no-margin {
        margin: 0px;
    }

    .no-padding {
        padding: 0px;
    }

    .code3badge {
        margin: 0px 2px 0px 2px;
    }

    .highlight {
        background-color: #feffad;
    }

    .fancybox-title
    {
        text-align:left !important;
    }

    #codeBind .badge{
        font-weight: 100;
    }

    #codeBind .badge-lg{
        font-size: 15px;
    }
</style>


<div>
    
    @Html.TextBox("job_search", "", new { @class = "form-control", @placeholder = "찾고자 하는 직무 및 키워드 입력" })
</div>
