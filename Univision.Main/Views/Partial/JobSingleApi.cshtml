<div class="row col-md-12 no-side-space">

    <!-- 직무 1단계-->
    <div class="col-md-6 pop-padding">
        <div>
            <h5>직무 선택 <span id="code1Cnt" class="blue-500">0</span>/1</h5>
        </div>
        <div class="list-group list-group-bordered code1Group">
            @if (Model.list1.Count > 0)
            {
                foreach (var data in Model.list1)
                {
                    <a href="javascript:void(0)" class="list-group-item flex-column align-items-start code1" id="@data.code1" onclick="code1Click(this, 'Y')">
                        <p class="mb-0">@data.code_name1</p>
                    </a>
                }
            }
        </div>
    </div>

    <!-- 직무 2단계-->
    <div class="col-md-6 pop-padding">
        <div>
            <h5>키워드 선택 <span id="code2Cnt" class="blue-500">0</span>/1</h5>
        </div>
        <div class="list-group list-group-bordered code2Group">
            @if (Model.list2.Count > 0)
            {
                foreach (var data in Model.list2)
                {
                    <a href="javascript:void(0)" class="list-group-item flex-column align-items-start code2" code1="@data.code1" code2="@data.code2" id="@data.code2" onclick="code2Click(this, 'Y')">
                        <p class="mb-0">@data.code_name2</p>
                    </a>
                }
            }
            else
            {
                <a href="javascript:void(0)" class="list-group-item bg-inherit bg-grey-100 code2 item-empty">
                    <p class="mb-0">← 직무를 선택하세요.</p>
                </a>
            }
        </div>
    </div>
</div>

<div id="popBottom" class="row col-md-12 no-right-margin no-right-padding">
    <div id="codeBind" class="col-md-11">
        <button id="btnPopReset" type="button" class="btn btn-sm bg-grey-100">
            <i class="wb-reload">초기화</i>
        </button>
    </div>
    <div class="col-md-1 text-right no-margin no-padding">
        <button id="btnPopSave" type="button" class="btn btn-sm btn-primary">확인</button>
    </div>
</div>

<script type="text/javascript">

    //직무 단계별로 선택 안했을 때, 사용함.
    var emptyItem = "<a href='javascript:void(0)' class='list-group-item bg-inherit bg-grey-100 item-empty'><p class='mb-0'>← 직무를 선택하세요.</p></a>";
    var errorItem = "<a href='javascript:void(0)' class='list-group-item bg-inherit bg-grey-100 item-empty'><p class='mb-0'>직무 정보를 가져올 수 없습니다.</p></a>";

    $(document).ready(function () {

        //초기 시작.
        Initialize();

        //직무 키워드 검색.
        $("#job_search").autocomplete({
            source : function( request, response ) {
                $.ajax({
                    type: 'post',
                    url: '@Url.Action("SearchJobKeywordApi2", "Partial")',
                    dataType: "json",
                    //request.term = $("#autocomplete").val()
                    data: {
                        searchValue : request.term
                    },
                    success: function(data) {
                        //서버에서 json 데이터 response 후 목록에 뿌려주기 위함
                        response(
                            $.map(data.list, function (item) {
                                return {
                                    label: item.code_name1 + " > " + item.code_name2,
                                    code1: item.code1,
                                    code2: item.code2
                                }
                            })
                        );

                        $(".ui-autocomplete").highlight(request.term);
                    }
                });
            },
            autoFocus:true, //첫번째 값을 자동 focus한다
          minLength: 1,  //조회를 위한 최소글자수
          search: function (event, ui) {
            var is_select = $(this).attr('is_select');
            is_select = (typeof is_select === "undefined") ? 0 : is_select;
            //console.log(is_select);
            if (is_select == 1) {
              return false;
            }
          },
            select: function(event, ui) {
                // 검색리스트에서 선택 했을 때 이벤트 발생
   
                reset();

                $("#code1Cnt").html("1");
                $("#code2Cnt").html("1");
                
                selectCode2List(ui.item.code1, ui.item.code2)
                
                $(".code1").each(function () {
                    if ($(this).attr("id") == ui.item.code1)
                        $(this).addClass("active");
                });
          },
          focus: function (event, ui) {
            //console.log("xx", $(this).attr('is_select'))
            $(this).attr('is_select', 1);
            setTimeout(function (obj) {
              $(obj).attr('is_select', 0);
              //console.log("reset");
            }, 500, this);

            event.preventDefault();
          },
            change:function(event){
                $("#job_search").val("");
                return false;
            }
        });

        //초기화 버튼
        $("#btnPopReset").click(function () {
            reset();
        });

        //확인 버튼
        $("#btnPopSave").click(function () {
            
            var title = "";
            var hidden = "";
            var appendHtml = "";

            if ($(".code2.active").length > 0) {
                
                $("#search_jobCode1").val($(".code2.active").attr("code1"))
                $("#search_jobCode2").val($(".code2.active").attr("code2"))

              callJobObj.find(".jobCode1").val($(".code2.active").attr("code1"))
              callJobObj.find(".jobCode2").val($(".code2.active").attr("code2"))

                //호출 페이지에 정의. 호출한 element
              callJobObj.find(".jobTargetText").val($(".code1.active")[0].innerText + " > " + $(".code2.active")[0].innerText);
            }
            else {
                ErrorAlert("소분류를 선택해주세요.");
                return false;
            }

            if ($("#CreateForm").formValidation() != null) {
                $('#CreateForm').formValidation('revalidateField', 'job_name2');
            }

            $.fancybox.close();
        })

    });
    
    //페이지 시작.
    function Initialize() {

        var code1 = @Model.code1;
        var code2 = @Model.code2;

        if (code1 > 0) {
            $(".code1").each(function () {
                if ($(this).attr("id") == code1)
                    code1Click($(this), 'N');
            });

            $(".code2").each(function () {
                if ($(this).attr("id") == code2)
                    code2Click($(this), 'N');
            });
        }
    }

    function reset() {

        //1단계 초기화.
        $("#code1Cnt").html(0);
        $(".code1").removeClass("active");
        
        //2단계 초기화.
        $("#code2Cnt").html(0);
        $(".code2Group").empty();
        $(".code2Group").html(emptyItem);
    }

    //직무 1단계 클릭 이벤트
    function code1Click(obj, flag) {
        var now;

        //이전에 선택한 직무 1단계를 찾음.
        $(".code1").each(function () {
            if ($(this).hasClass("active"))
                now = $(this);
        });
        
        //현재 선택한 직무 단계에 a 태그 active 클래스 부여.
        $(obj).addClass("active");

        //현재 선택한 직무 단계 이외의 a 태그 active 클래스 제거
        $(".code1").not(obj).removeClass("active");

        $("#code1Cnt").html("1");

        if (flag != "N") {

            //현재 선택한 직무 단계와 이전에 선택한 직무 단계가 다르다면 초기화.
            if ($(obj).attr("id") != $(now).attr("id")) {
                $(".code2Group").empty();
                $(".code2Group").html(emptyItem);
            }

            //직무 2단계 리스트 불러옴.
            selectCode2List($(obj).attr("id"));
        }
    }

    //직무 2단계 클릭 이벤트.
    function code2Click(obj, flag) {

        var now;

        $("#code2Cnt").html(1);

        //이전에 선택한 직무 2단계를 찾음.
        $(".code2").each(function () {
            if ($(this).hasClass("active"))
                now = $(this);
        });

        //현재 선택한 직무 단계에 a 태그 active 클래스 부여.
        $(obj).addClass("active");

        //현재 선택한 직무 단계 이외의 a 태그 active 클래스 제거
        $(".code2").not(obj).removeClass("active");

    }

    //직무 2단계 목록 조회.
    function selectCode2List(code1, selectCode2) {

        $.ajax({
               url: '@Url.Action("JobApi2", "Partial")',
               data: {
                   code1: code1
                },
                dataType: 'json',
                type: 'POST',
               beforeSend: function ()
               {

               }
        })
        .done(function (json) {

            if (json.ok) {

                if (json.list.length > 0) {

                    var sb = new StringBuilder();

                    for (var i = 0; i < json.list.length; i++) {

                        var data = json.list[i];

                        sb.append("<a href='javascript:void(0)' class='list-group-item flex-column align-items-start code2' code1='" + data.code1 + "' code2='" + data.code2 + "' id='" + data.code2 + "' onclick='code2Click(this, &quot;Y&quot;)'>");
                        sb.append("<p class='mb-0'>" + data.code_name2 + "</p>");
                        sb.append("</a>");
                    }

                    $(".code2Group").empty();
                    $(".code2Group").append(sb.toString());

                    if (selectCode2 != undefined) {

                        $(".code2").each(function () {
                            if ($(this).attr("id") == selectCode2)
                                code2Click($(this), 'Y');
                        });
                    }
                }
            } else {
                $(".code2Group").empty();
                $(".code2Group").append(errorItem);
            }
        })
        .fail(function (e) {
            ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
        });
    }

</script>
