
@{
    ViewBag.Title = "SMS발송";
    ViewBag.NoMenu = true;
    Layout = "~/Views/Shared/_Layout.cshtml";

    string myPhoneNumber = ViewBag.myPhoneNumber;
    string companyNumber = ViewBag.companyNumber;
    string receive_number = ViewBag.receive_number;
}

    <div class="p-3">
        @using (Html.BeginForm("SendSms", "Partial", FormMethod.Post, new { @class = "", @id = "SmsCreateForm" }))
        {
            @Html.Hidden("contents_len", "")
            @Html.Hidden("sms_type", "")

            <div class="row">
                <div class="col-12 form-group">
                    <label class="form-control-label"> <i class="fas fa-send" aria-hidden="true"></i>발신번호 (보내는사람)</label>    
                    <div class="cont">
                        <div class="col-12 form-inline radio_area">
                            <div class="radio-custom pr-20 radio-primary">
                                <input type="radio" id="myCellPhone" name="send_type" value="@SMSSendType.cellphone" checked="checked">
                                <label for="myCellPhone">휴대전화</label>
                            </div>
                            <div class="radio-custom radio-primary">
                                <input type="radio" id="myCompanyPhone" name="send_type" value="@SMSSendType.companyPhone">
                                <label for="myCompanyPhone">회사전화</label>
                            </div>
                        </div>
                        @Html.TextBox("send_number", myPhoneNumber, new { @class = "form-control rad_va", @placeholder = "- 없이 입력해주세요.", @onKeyup = "MobileAutoHypen(event, this);" })
                    </div>
                </div>

                <div class="col-12 form-group">
                    <label class="form-control-label"> <i class="fas fa-send" aria-hidden="true"></i>수신번호 (받는사람)</label>
                    <div class="cont2 row">
                        @Html.TextBox("receive_number", receive_number, new { @class = "form-control addb", placeholder = "- 없이 입력해주세요.", @onKeyup = "MobileAutoHypen(event, this);" })
                        <button type="button" class="btn btn-outline btn-default add_btn" id="btnNumAdd">
                            <i class="icon wb-plus" aria-hidden="true"></i> 추가
                        </button>
                        <div class="ad_list" style="min-height:53.6px;">

                        </div>

                    </div>
                </div>

                <div class="col-12 form-group">
                    <label class="form-control-label"> <i class="fas fa-send" aria-hidden="true"></i>내용입력</label>
                    <div class="cont2">
                        @Html.TextArea("sms_contents", "", new { @class = "form-control", @placeholder = "보낼 내용을 입력하세요.", @rows = 5 })
                        <div>
                            <span class="sms_type">SMS</span> :
                            <span class="contentsLen">0</span>/
                            <span class="contentsMaxLen">80</span> Bytes
                        </div>
                    </div>
                    <div class="cont3">
                        <div class="col-md-12 float-right custom5">
                            <button class="btn btn-default btn-outline" type="button" id="btnSmsModalClose">취소</button>
                            <button class="btn btn-primary btn-outline ed" id="btnSendSms" type="button">보내기</button>
                        </div>
                    </div>
                </div>
            </div>

        }
    </div>

<script type="text/javascript" src="~/Scripts/Utf8ByteCounter.js"></script>
<script type="text/javascript">

    $(document).ready(function () {

        StopEnterSubmit();
        
        //수신번호 엔터 입력시,
        $("#receive_number").keydown(function (e) {

            if (e.keyCode == 13)
                $("#btnNumAdd").click();
            else
                return;

        });

        
        $("#btnSmsModalClose").click(function () {
            self.close();
        });
        //수신목록 추가 버튼 클릭시,
        $("#btnNumAdd").click(function () {

            var hpno = $("#receive_number").val();

            if (!chkNumberExp(hpno)) {
                $("#receive_number").focus();
                callErrorToastr("잘못된 전화 번호입니다. 숫자, - 를 포함한 숫자만 입력하세요.", $("#smsModal"))
                return false;
            }

            if (!chkDuplicateNumber(hpno)) {
                $("#receive_number").focus();
                callErrorToastr("이미 등록된 전화번호 입니다.", $("#smsModal"))
                return false;
            }

            var appendHtml = "";
            appendHtml += "<div class='receive_div mr-3'>";
            appendHtml += "<span class='receive_num'>" + hpno + "</span>";
            appendHtml += "<button type='button' class='close ' onclick='DelReceiveNum(this)'>";
            appendHtml += "<span aria-hidden='true'>×</span>";
            appendHtml += "</button>";
            appendHtml += "</div>";

            $(".ad_list").append(appendHtml.toString());
            $("#receive_number").val("");
            $("#receive_number").focus();

        });

        //textarea 문자열 byte길이 계산
        $("#sms_contents").keyup(function () {
            var len = getByteLength($(this).val());

            if (len > 80) {
                $(".sms_type").text("LMS");
                $(".contentsMaxLen").text("2000");
                $("#sms_type").val("@SMSType.lms");
            }

            else {
                $(".sms_type").text("SMS");
                $(".contentsMaxLen").text("80");
                $("#sms_type").val("@SMSType.sms");
            }

            $("#contents_len").val(len);

            $(".contentsLen").text(len);
        });

        //휴대전화, 회사전화 체크.
        $('input[name="send_type"]').change(function() {

            if ($(this).val() == "@SMSSendType.cellphone") {
                $("#send_number").val("@myPhoneNumber")
            }
            else {
                $("#send_number").val("@companyNumber")
            }

        });

        //전송 버튼 클릭.
        $("#btnSendSms").click(function () {

            if ($("#send_number").val() == "") {
                $("#send_number").focus();
                callErrorToastr("발신번호를 입력하세요.", $("#smsModal"));
                return false;
            }

            if ($(".ad_list .receive_div").length == 0) {
                $("#receive_number").focus();
                callErrorToastr("수신번호를 입력하세요.", $("#smsModal"));
                return false;
            }

            if ($("#sms_contents").val() == "") {
                $("#sms_contents").focus();
                callErrorToastr("내용을 입력하세요.", $("#smsModal"));
                return false;
            }

            alertify.confirm()
                .set({
                    'labels': { ok: '확인', cancel: '취소' },
                    'onok': function () {

                        var currentData = {
                            sms_type: $("#sms_type").val(),
                            send_number: $("#send_number").val(),
                            send_type: $("input[name=send_type]:checked").val(),
                            receive_numbers: [],
                            contents: $("#sms_contents").val(),
                            contents_len: $("#contents_len").val()
                        };

                        //수신번호 리스트 추가.
                        $(".ad_list .receive_div").each(function () {

                            currentData.receive_numbers.push($(this).find(".receive_num").text().replace(/\-/gi, ""));

                        });

                        var formURL = $("#SmsCreateForm").attr("action");
                        $.ajax({
                            url: formURL,
                            type: "POST",
                            dataType: 'json',
                            data: {
                                data: currentData
                            },
                            beforeSend: function () {
                                showLoading();
                            },
                            success: function (json) {
                                hideLoading();
                                if (json.ok) {

                                    NormalAlert(json.message);
                                    $("#btnSmsModalClose").click();

                                }
                                else {
                                    ErrorAlert(json.message);
                                }
                            },
                            error: function (jqXHR, textStatus, errorThrown) {
                                hideLoading();
                                ErrorAlert("알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.");
                            }
                        });
                    },
                    'oncancel': function () {
                        return;
                    },
                })
                .setHeader('<i class="fas fa-exclamation-triangle" style="color:#FFDC2E"></i>메세지 발송')
                .setting({
                    message: "메세지를 발송 하시겠습니까?"
                }).show();

        });

    });

    //올바른 전화번호인지 체크
    function chkNumberExp(num) {

        var regExp = /^(01[016789]{1}|02|0[346789]{1}[0-9]{1}|0507)-?[0-9]{3,4}-?[0-9]{4}$/;

        if (!regExp.test(num)) {
            return false;
        } else {
            return true;
        }
    }

    //중복번호 체크
    function chkDuplicateNumber(num) {

        var isChk = true;

        var nowNum = num.replace(/\-/gi, "");

        $(".ad_list .receive_div").each(function () {

            var tmpNo = $(this).find(".receive_num").text().replace(/\-/gi, "");

            if (nowNum == tmpNo) {
                isChk = false;
                return false;
            }
        });

        return isChk;
    }

    //수신번호 목록에서 삭제
    function DelReceiveNum(obj) {
        $(obj).closest(".receive_div").remove();
    }

</script>

<script src="~/Libs/remark/global/vendor/bootstrap-tokenfield/bootstrap-tokenfield.min599c.js?v4.0.4"></script>