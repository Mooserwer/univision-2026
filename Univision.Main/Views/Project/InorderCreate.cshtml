                cc_phone: $("#cc_phone").val(),
                cc_cell_phone: $("#cc_cell_phone").val(),
                cc_email: $("#cc_email").val(),
                cc_reason: $("#cc_reason").val(),
                inorder_dt: $("#inorder_dt").val(),
                inorder_type: $("#inorder_type").val(),
                can_dept: $("#can_dept").val(),
                can_pos: $("#can_pos").val(),
                can_location: $("#can_location").val(),
                can_jobdesc: $("#can_jobdesc").val(),
                can_contents: $("#can_contents").val(),
                fileList: []
            };

            //파일
            $("#inorder_file").find('#inorder_file_rst').find('.file_div').each(function () {
                var fileData = {
                    file_origin_path: $(this).find('input[name="file_origin_path"]').val()
                }
                currentData.fileList.push(fileData);
            });

            var formURL = $("#CreateForm").attr("action");
            $.ajax({
                url: formURL,
                type: "POST",
                dataType: 'json',
                data: {
                    data : currentData
                },
                beforeSend: function () {
                    showLoading();
                },
                success: function (json) {
                    hideLoading();
                    if (json.ok) {
                        NormalAlert("오더를 등록 했습니다.");
                        location.href = "/Project/InorderDetail?i_seq=" + json.i_seq;
                    }
                    else {
                        ErrorAlert(json.message);
                    }
                },
                error: function (jqXHR, textStatus, errorThrown) {
                    hideLoading();
                    ErrorAlert("알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.");
                }
            });

        }


        $("#CreateForm").validate(valid_option);

        StopEnterSubmit();

        BindDatePicker('.date-time');

        if ($('.dropzone').length > 0) {
            var myDropzone = new Dropzone("div#inorder_file", {
                url: "@Url.Action("CreateTempInorderFile", "Project")",
                method: "post",
                params: {
                    "uploadFolder": "@ViewBag.uploadFolder"
                }
            });

            myDropzone.on("success", function (file, response) {
                if (response.ok) {

                    file_html = MakeHtmlFileList(response.result);
                    $('#inorder_file_rst').prepend($(file_html).hide().fadeIn(1000));
                    console.log(response.file_rst);
                    //NormalAlert(response.file_rst);
                    this.removeFile(file);

                    if ($("#can_jobdesc").val() == "") {
                        $("#can_jobdesc").val("첨부파일을 참고하세요.");
                    }
                    

                } else {
                    ErrorAlert("[ERROR]" + response.message);
                }

            });


        }

        function MakeHtmlFileList(obj_file) {
            var cols = ""
            if(obj_file.file_path && obj_file.file_path != ''){
                var icon_str = "";
                var badge_str = "badge-secondary";
                var width_str = 'style="width:85%;"';
                var btn_str = "";


                if (obj_file.file_extension == ".pdf") {
                  icon_str = "far fa-file-pdf text-primary"
                } else if ( obj_file.file_extension == ".jpg" || obj_file.file_extension == ".png" || obj_file.file_extension == ".gif" || obj_file.file_extension == ".bmp" ){
                  icon_str = "far fa-file-image text-primary";
                } else if ( obj_file.file_extension == ".doc" || obj_file.file_extension == ".docx" ){
                  icon_str = "far fa-file-word text-primary";
                } else if ( obj_file.file_extension == ".xls" || obj_file.file_extension == ".xlsx"  ){
                  icon_str = "far fa-file-excel text-primary";
                } else if ( obj_file.file_extension == ".ppt" || obj_file.file_extension == ".pptx"){
                  icon_str = "far fa-file-powerpoint text-primary";
                } else {
                  icon_str = "fa fa-file-alt text-light";
                }

                cols += '<div class="py-0 file_div col-12">' //'+obj_file.col+'
                cols += '  <input type="hidden" name="file_origin_path" value="'+obj_file.file_origin_path+'">'
                cols += '  <a href="/'+obj_file.file_dir+'" class="file_info text-left text-truncate pointer badge '+badge_str+'" title="'+obj_file.file_path+'" download ' + width_str
                cols += '  >';
                cols += '    <i class="'+icon_str+'" aria-hidden="true"></i> ' + obj_file.file_path ;
                cols += '  </a>'
                cols += '  <a href="javascript:void(0);" class="ml-3 text-truncate badge badge-danger" style="width:10%;" onclick="RemoveFile(this);">';
                cols += '   <i class="fa fa-trash pointer" aria-hidden="true"></i>';
                cols += '  </a>' + btn_str;
                cols += '</div>';

            }
            return cols;
        }

        function RemoveFile(obj) {

            alertify.confirm()
                .set({
                    'labels': { ok: 'OK', cancel: 'Cancel' },
                    'onok': function () {
                        //TODO:실제 서버에서 파일 삭제 프로세스 추가 예정

                        DeleteFile(obj)


                    },
                    'oncancel': function () {
                        return;
                    },
                })
                .setHeader('Remove file')
                .setting({
                    message: "Are you sure want to delete this file?",
                })
                .show();
        }

        //임시 이력서 파일 삭제
        function DeleteFile(obj) {
            file_origin_path = $(obj).closest('.file_div').find("input[name=file_origin_path]").val();
            $.ajax({
                    url: '@Url.Action("DeleteInorderTempFile", "Project")',
                    data: {
                        file_origin_path: file_origin_path
                    },
                    dataType: 'json',
                    type: 'POST',
                    beforeSend: function () {
                        showLoading();
                    }
                })
                .done(function (json) {
                    hideLoading();
                    if (json.ok) {
                        $(obj).closest('.file_div').remove();
                    } else {
                        ErrorAlert(json.message);
                    }
                })
                .fail(function (e) {
                    hideLoading();
                    ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
                });
        }



