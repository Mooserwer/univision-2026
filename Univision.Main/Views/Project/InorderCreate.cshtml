        function validHanlder(form) {
            //form 전송을 위한 데이터 생성.
            //기본정보
            
            var currentData = {
                i_seq: $("#i_seq").val(),
                c_seq: $("#c_seq").val(),
                clt_name: $("#clt_name").val(),
                clt_busi_type: $("#clt_busi_type").val(),
