@model Univision.Main.Models.Project.InorderCreateModel
@{
    ViewBag.Title = "Inorder 생성";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/Libs/dropzone/css/dropzone_cus.css?v=1533562669">

<div class="page-user">
    <div class="page-content">
        @using (Html.BeginForm("InorderCreate", "Project", FormMethod.Post, new { @id = "CreateForm", @autocomplete = "off" }))
        {
            @Html.HiddenFor(x => x.i_seq)
            <div class="panel panel-primary panel-line animation-scale-up" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms;">
                <div class="panel-heading">
                    <h3 class="panel-title">
                        <i class="fas fa-newspaper"></i>
                        Client Information
                    </h3>
                </div>
                <div id="clientInfo" class="panel-body">
                    <div class="row">
                        <div class="col-md-4 form-group">
                            @Html.LabelFor(x => x.clt_name, "Client Name", new { @class = "form-control-label" })
                            <span class="label-reqired">*</span>
                            <div class="input-group">
                                @Html.TextBoxFor(x => x.clt_name, new { @class = "form-control", @required = "required", @placeholder = "고객사명(직접입력 또는 검색)" })
                                @Html.HiddenFor(x => x.c_seq)
                                <span class="input-group-btn">
                                    <button type="button" class="btn btn-primary" id="btnClientSearch"><i class="icon wb-search" aria-hidden="true"></i></button>
                                </span>
                            </div>
                        </div>
                        <div class="col-md-4 form-group">
                            @Html.LabelFor(x => x.clt_busi_type, "Business Type", new { @class = "form-control-label" })
                            @Html.TextBoxFor(x => x.clt_busi_type, new { @class = "form-control", @placeholder = "업종" })
                        </div>
                        <div class="col-md-4 form-group">
                            @Html.LabelFor(x => x.clt_url, "Homepage", new { @class = "form-control-label" })
                            @Html.TextBoxFor(x => x.clt_url, new { @class = "form-control", @placeholder = "홈페이지(http://exam.net)" })
                        </div>
                    </div>
                </div>
            </div>

            <div class="panel panel-primary panel-line animation-scale-up" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms;">
                <div class="panel-heading">
                    <h3 class="panel-title">
                        <i class="fas fa-address-card"></i>
                        Contact Information
                    </h3>
                </div>
                <div id="contactInfo" class="panel-body">
                    <div class="row">
                        <div class="col-md-3  form-group">
                            @Html.LabelFor(x => x.cc_name, "Contact Name", new { @class = "form-control-label" })
                            <span class="label-reqired">*</span>
                            @Html.TextBoxFor(x => x.cc_name, new { @class = "form-control", @required = "required", @placeholder = "담당자명" })
                        </div>
                        <div class="col-md-3 form-group">
                            @Html.LabelFor(x => x.cc_gender, "Gender", new { @class = "form-control-label" })
                            <div class="form-inline">
                                <div class="radio-custom radio-primary">
                                    <input type="radio" id="gender0" name="cc_gender" value="0" @(Model.cc_gender == 0 ? "checked" : "") />
                                    <label for="gender1">Unknown</label>
                                </div>
                                <div class="radio-custom radio-primary ml-10">
                                    <input type="radio" id="gender1" name="cc_gender" value="1" @(Model.cc_gender == 1 ? "checked" : "") />
                                    <label for="gender1">Male</label>
                                </div>
                                <div class="radio-custom radio-primary ml-10">
                                    <input type="radio" id="gender2" name="cc_gender" value="2" @(Model.cc_gender == 2 ? "checked" : "") />
                                    <label for="gender2">Female</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 form-group">
                            @Html.LabelFor(x => x.cc_position, "Position", new { @class = "form-control-label" })
                            @Html.TextBoxFor(x => x.cc_position, new { @class = "form-control", @placeholder = "직급" })
                        </div>
                        <div class="col-md-3 form-group">
                            @Html.LabelFor(x => x.cc_division, "Dept.", new { @class = "form-control-label" })
                            @Html.TextBoxFor(x => x.cc_division, new { @class = "form-control", @placeholder = "부서" })
                        </div>
                       
                    </div>
                    <div class="row">
                        <div class="col-md-3 form-group">
                            @Html.LabelFor(x => x.cc_phone, " Phone", new { @class = "form-control-label" })
                            <span class="label-reqired">*</span>
                            @Html.TextBoxFor(x => x.cc_phone, new { @class = "form-control least-one-contact", @placeholder = "00-0000-0000" })
                        </div>
                        <div class="col-md-3 form-group">
                            @Html.LabelFor(x => x.cc_cell_phone, " Mobile", new { @class = "form-control-label" })
                            <span class="label-reqired">*</span>
                            @Html.TextBoxFor(x => x.cc_cell_phone, new { @class = "form-control least-one-contact", @onKeyup = "MobileAutoHypen(event, this);", @placeholder = "010-0000-0000" })
                        </div>
                        <div class="col-md-3 form-group">
                            @Html.LabelFor(x => x.cc_email, " E-mail", new { @class = "form-control-label" })
                            <span class="label-reqired">*</span>
                            @Html.TextBoxFor(x => x.cc_email, new { @class = "form-control least-one-contact", @placeholder = "email@email.com" })
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-lg-12 col-12 form-group">
                            @Html.LabelFor(x => x.cc_reason, "Known path", new { @class = "form-control-label" })
                            @Html.TextAreaFor(x => x.cc_reason, new { @class = "form-control", @placeholder = "유니코써치를 알게 된 경로", @rows=5 })
                        </div>
                    </div>

                </div>
            </div>
            <div class="panel panel-primary panel-line animation-scale-up" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms;">
                <div class="panel-heading">
                    <h3 class="panel-title">
                        <i class="fas fa-share"></i>
                        Description of the Request
                    </h3>
                </div>
                <div id="inorderInfo" class="panel-body">
                    <div class="row">
                        <div class="col-md-3 form-group">
                            @Html.LabelFor(x => x.inorder_dt, "Order date", new { @class = "form-control-label" })
                            @Html.TextBoxFor(x => x.inorder_dt, "{0:yyyy-MM-dd}", new { @class = "form-control date-time", @required = "required" })
                        </div>
                        <div class="col-md-3 form-group">
                            @Html.LabelFor(x => x.inorder_type, "Inorder type", new { @class = "form-control-label" })
                            <select id="inorder_type" name="inorder_type" class="form-control">
                                <option value="">[의뢰구분 선택]</option>
                                <option value="1" @(Model.inorder_type == 1 ? "selected" : "")>Executive Search</option>
                                <option value="2" @(Model.inorder_type == 2 ? "selected" : "")>Reference Check</option>
                                <option value="3" @(Model.inorder_type == 3 ? "selected" : "")>Assessment</option>
                                <option value="4" @(Model.inorder_type == 4 ? "selected" : "")>Recruitment Process Outsourcing(RPO)</option>
                                <option value="6" @(Model.inorder_type == 6 ? "selected" : "")>Outside directors</option>
                            </select>
                        </div>
                        <div class="col-md-3 form-group">
                            @Html.LabelFor(x => x.can_dept, "Recruting department", new { @class = "form-control-label" })
                            @Html.TextBoxFor(x => x.can_dept, new { @class = "form-control", @placeholder = "채용 부서" })
                        </div>
                        <div class="col-md-3 form-group">
                            @Html.LabelFor(x => x.can_pos, "Recruting position", new { @class = "form-control-label" })
                            @Html.TextBoxFor(x => x.can_pos, new { @class = "form-control", @placeholder = "채용 직급" })
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 form-group">
                            @Html.LabelFor(x => x.can_location, "Location", new { @class = "form-control-label" })
                            @Html.TextBoxFor(x => x.can_location, new { @class = "form-control", @placeholder = "근무지역" })
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 col-12 form-group">
                            @Html.LabelFor(x => x.can_jobdesc, "Job description", new { @class = "form-control-label" })
                            <span class="label-reqired">*</span>
                            @Html.TextAreaFor(x => x.can_jobdesc, new { @class = "form-control", @required = "required", @rows = "6", @placeholder = "담당업무 (JD파일 등록 시 생략가능)" })
                        </div>
                        <div class="col-md-6 col-12 form-group">
                            @Html.LabelFor(x => x.can_contents, "Qualifications", new { @class = "form-control-label" })
                            @Html.TextAreaFor(x => x.can_contents, new { @class = "form-control", @rows = "6", @placeholder = "자격요건 (JD파일 등록 시 생략가능)" })
                        </div>
                    </div>

                    @if (Model.i_seq == 0)
                    {
                        <div class="row" id="inorder_file">
                            <div class="col-12">
                                <div id="inorder_file" class="dropzone h-full text-left">
                                    <label for="inorder_file" class="form-control-label">Files</label>
                                    <div class="row py-2">
                                        <div class="col">
                                            <div class="dz-message"><small>[Drop files here or click to upload]</small></div>
                                        </div>
                                    </div>
                                    <div class="row py-2" id="inorder_file_rst">

                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="text-right">
                <button type="submit" class="btn btn-primary" id="btnSave">Submit </button>
                <button type="reset" class="btn btn-default btn-outline">Reset</button>
            </div>
                
        }
    </div>
</div>

