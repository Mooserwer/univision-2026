@model Univision.Core.Models.DTO.Response.Project.MakeupRequestListModel
<style>
    h3 {
        margin-top: 0px !important;
    }

    .fancybox-title {
        text-align: left !important;
    }

    .client-md, .member-title-md, .client-sm, .member-title-sm {
        display: none;
    }

    @@media (max-width:898px) {
        .client-md {
            display: block;
        }

        .member-title-md {
            display: inline;
        }

        .table.table-memo-list thead th:nth-of-type(1) {
            display: none
        }

        .table.table-memo-list tbody td:nth-of-type(1) {
            display: none
        }

        .table.table-memo-list thead th:nth-of-type(4) {
            display: none
        }

        .table.table-memo-list tbody td:nth-of-type(4) {
            display: none
        }

        .app-work .panel-body .table .work-progress {
            display: none
        }
    }

    @@media (max-width:500px) {
        .client-sm {
            display: block;
        }

        .member-title-sm {
            display: inline;
        }

        .table.table-memo-list thead th:nth-of-type(3) {
            display: none
        }

        .table.table-memo-list tbody td:nth-of-type(3) {
            display: none
        }

        .app-work .panel-body .table .work-progress {
            display: none
        }
    }
</style>
<div id="pop_search_makeup" class="p-0">
    <div class="py-10">
        @using (Html.BeginForm("MakeupRequestList", "Project", FormMethod.Get, new { @id = "SearchFormMakeup" }))
        {
            <div class="row">
                <div class="col">
                    <select name="search.search_status" id="search_search_status" class="form-control form-control-sm">
                        <option value="0" @(Model.search.search_status == 0 ? "selected" : "")>상태-전체</option>
                        <option value="1" @(Model.search.search_status == 1 ? "selected" : "")>상태-대기</option>
                        <option value="2" @(Model.search.search_status == 2 ? "selected" : "")>상태-완료</option>
                    </select>
                </div>
                <div class="col-8">
                    <div class="input-group input-group-sm">
                        @Html.HiddenFor(x => x.search.start_date)
                        @Html.HiddenFor(x => x.search.end_date)
                        <select name="search.search_field" id="search_search_field" class="form-control form-control-m">
                            <option value="B.kor_name" @(Model.search.search_field == "B.kor_name" ? "selected" : "")>후보자명</option>
                            <option value="C.name" @(Model.search.search_field == "C.name" ? "selected" : "")>신청자명</option>
                        </select>
                        @Html.TextBoxFor(x => x.search.search_value, new { @class = "form-control", @placeholder = "내용" })
                        <span class="input-group-btn">
                            <button type="button" class="btn btn-primary" id="btn_pop_search_makeup">
                                <i class="fas fa-search" aria-hidden="true"></i>
                            </button>
                        </span>
                    </div>
                </div>
            </div>
        }
    </div>
    <div class="panel" id="searchMakeup" >
      <div class="panel-body">
        <div class="border border-info pb-15 p-10">
          <h4 class='font-weight-900'>[메이크업 신청 시 유의사항]</h4>
          <span class='font-weight-800'> ◆ 메이크업 진행이 어려운 이력서 형식 </span></br>
          <div class='pl-10'>
            - <span class='font-weight-600'>메이크업 완료 후 일부 업데이트(경력 및 자기소개 추가 등) 발생 시</span><br />
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;→ 컨설턴트 직접 작업 요청<br />
            - <span class='font-weight-600'>10 page 이상 이력서</span><br />
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;→ 컨설턴트 직접 작업 or 후보자에게 유니코 양식으로 작성 요청<br />
            - <span class='font-weight-600'>Text 복사가 되지 않고, 복사 시 글머리가 없는 경우, 경력 구분이 없는 PDF 파일 이력서</span><br />
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;→  후보자에게 원본 워드 파일 요청<br />
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;(*후보자 요청 불가시, 최소 컨설턴트가 워드로 변환 및 경력 구분하여 신청 요망)<br />
          </div>
          <span class='font-weight-600'> ◆ 하루 최대 5건까지 신청 (퇴근 후/주말은 다음 작업하는 날 개수로 포함.) </span>
        </div>
        <table class="table table-borderless table-hover table-memo-list" style="table-layout:fixed;font-size:0.9rem;">
          <thead class="text-center">
            <tr>
              <th style="width:10%;">순번</th>
              <th>후보자(프로젝트)</th>
              <th style="width:10%;">구분</th>
              <th style="width:10%;">신청자</th>
              <th style="width:15%;">신청일<br />(완료일)</th>
              <th style="width:10%;">상태</th>
              <th style="width:15%;"><i class="fa fa-cog"></i></th>
            </tr>
          </thead>
          <tbody class="text-center">
            @if (Model.list.Count > 0)
            {
              int idx = 1;
              foreach (var data in Model.list)
              {
                string tr_color = "";
                if (data.status == "작업중")
                {
                  tr_color = "bg-blue-100";
                }
                else if (data.status == "작업완료")
                {
                  tr_color = "bg-green-100";
                }

                <tr class="@tr_color">
                  <td class="text-center">
                    @idx
                  </td>
                  <td class="text-left text-truncate">
                    <a href="javascript:openCandidate('@data.c_seq');">[@data.kor_name]</a><br />
                    <span class="text-secondary"> - @data.title</span>
                  </td>
                  <td class="text-center">
                    @if (data.resume_type == "K")
                    {
                      <span class="badge badge-primary" title="Korean">국문</span>
                    }
                    else if (data.resume_type == "E")
                    {
                      <span class="badge badge-info" title="English">영문</span>
                    }
                  </td>
                  <td class="text-center">
                    @data.name
                  </td>
                  <td class="text-center">
                    @Utils.ConvertDateTimeToString(data.request_date)<br />
                    @Utils.ConvertDateTimeToString(data.complete_date)
                  </td>
                  <td class="text-center">

                    @data.status
                  </td>
                  <td class="text-center">
                    @if ((data.req_user == Univision.Security.AppIdentity.user_seq || Univision.Security.AppIdentity.ua_seq < 3) && @data.status == "요청")
                    {
                      <button class="btn btn-danger btn-xs" onClick="javascript:mk_cancel('@data.mr_idx');">요청취소</button>
                    }
                  </td>
                </tr>
                idx++;
              }
            }
            else
            {
              <tr>
                <td colspan="7">No Data Found.</td>
              </tr>
            }

          </tbody>
        </table>
        <span class="red-600">※ 작업중 / 작업완료 된 메이크업 요청취소는 담당자에게 직접 요청하셔야 합니다.</span>
      </div>
    </div>
</div>

<script type="text/javascript">

  $('.popover_makeup').popover();
    StopEnterSubmit();

    $('#btn_pop_search_makeup').click(function () {
        FancyBoxSearchAndPageMove(1);
    });



        //FancyBox 팝업 내의 페이지 이동.
        function FancyBoxSearchAndPageMove(page) {
            if (page == null || page == undefined)
                page = 1;

            $.ajax({
                url: '@Url.Action("MakeupRequestList", "Project")',
                data: $('#SearchFormMakeup').serialize(),
                dataType: 'html',
                type: 'POST',
                beforeSend: function () {
                    showLoading('#searchMakeup');
                }
            })
            .done(function (view) {
                hideLoading('#searchMakeup');
                $("#makeupModalBody").html(view);
            })
            .always(function () {
                hideLoading('#searchMakeup');
            });
        }


    function mk_cancel(mr_idx) {
            alertify.confirm()
            .set({
                'labels': { ok: 'OK', cancel: 'Cancel' },
                'onok': function (e) {
                    $.ajax({
                        url: '@Url.Action("CancelMakeup", "Project")',
                        data: {mr_idx : mr_idx},
                        dataType: 'json',
                        type: 'POST',
                        beforeSend: function () {
                            showLoading('#searchMakeup');
                        }
                    })
                    .done(function (e) {
                        //console.log(e);
                        if (e.ok) {
                            NormalAlert(e.message);
                            FancyBoxSearchAndPageMove(1);
                        } else {
                            ErrorAlert('[Error]' + e.message);
                        }
                        
                    })
                    .fail(function (e) {
                        ErrorAlert('[Error]' + e.message);
                    })
                    .always(function () {
                        hideLoading('#searchMakeup');
                    });
                },
                'oncancel': function () {
                    return;
                }
            })
            .setHeader("Makeup 요청취소")
            .setting({
                message: "해당 Makeup 요청을 취소하시겠습니까?"
            })
            .show();


        }
</script>