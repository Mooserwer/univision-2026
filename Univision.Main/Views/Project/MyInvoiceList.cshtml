@model Univision.Core.Models.DTO.Response.Statistics.KeyProjectListModel
@using Univision.Security

@{
  Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet">
<script type="text/javascript" src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>

<div class="page-content container-fluid">

  <!-- row -->
  <div class="row" id="key_project_body">
    <div class="col-xl-12">
      <div class="panel custom1">
        <div class="panel-heading">
          @using (Html.BeginForm("MyInvoiceList", "Project", FormMethod.Get, new { @id = "SearchForm" }))
          {
            <div class="panel-title">
              나의 인보이스 현황
            </div>
            <div class="panel-actions w-md-100">
              <div class="panel-action text-right w-full">
                <button type="button" class="btn btn-sm btn-raised btn-primary btn-block" id="table-setdata">새로고침</button>
              </div>
            </div>
          }
        </div>

        <div class="panel-body p-10">
          <div id="invoice_table" data-role="container">

          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- // row -->


</div>

@section scripts {
  <script type="text/javascript" src="https://oss.sheetjs.com/sheetjs/xlsx.full.min.js"></script>
  <script type="text/javascript">
        $(document).ready(function () {
            BindDatePicker($(".jDatePicker"));
        });

    function fSetDate(type) {
      var today = new Date();
      var today_str = getDateStr(today)
      $('#search_endDt').val(today_str);
      if (type == "day") {
        $('#search_startDt').val(today_str)

      } else if (type == "week") {
        $('#search_startDt').val(dateAdd(today_str, -7, "d"))
      } else if (type == "month") {
        $('#search_startDt').val(dateAdd(today_str, -1, "m"))
      }
    }

    function getDateStr(date) {
      // GET YYYY, MM AND DD FROM THE DATE OBJECT
      var yyyy = date.getFullYear().toString();
      var mm = (date.getMonth() + 1).toString();
      var dd = date.getDate().toString();

      // CONVERT mm AND dd INTO chars
      var mmChars = mm.split('');
      var ddChars = dd.split('');

      // CONCAT THE STRINGS IN YYYY-MM-DD FORMAT
      return yyyy + '-' + (mmChars[1] ? mm : "0" + mmChars[0]) + '-' + (ddChars[1] ? dd : "0" + ddChars[0]);

    }

    function dateAdd(sDate, v, t) {
      var yy = parseInt(sDate.substr(0, 4), 10);
      var mm = parseInt(sDate.substr(5, 2), 10);
      var dd = parseInt(sDate.substr(8), 10);

      if (t == "d") {
        d = new Date(yy, mm - 1, dd + v);
      } else if (t == "m") {
        d = new Date(yy, mm - 1 + v, dd);
      } else if (t == "y") {
        d = new Date(yy + v, mm - 1, dd);
      } else {
        d = new Date(yy, mm - 1, dd + v);
      }

      yy = d.getFullYear();
      mm = d.getMonth() + 1; mm = (mm < 10) ? '0' + mm : mm;
      dd = d.getDate(); dd = (dd < 10) ? '0' + dd : dd;

      return '' + yy + '-' + mm + '-' + dd;
    }

    var printIconRemove = function (cell, formatterParams, onRendered) { //plain text value
      return "<button class='btn btn-xs btn-warning btn-outline'><i class='fa fa-remove'></i> Key 제거</button>";
    };

    var printIconLink = function (cell, formatterParams, onRendered) { //plain text value
      return "<button class='btn btn-xs btn-warning btn-outline'><i class='fa fa-external'></i> 상세화면</button>";
    };

    function cancelMyKeyProject(p_seq) {
      alertify.confirm()
        .set({
          'labels': { ok: '확인', cancel: '취소' },
          'onok': function () {
            $.ajax({
              url: "@Url.Action("RemoveKeyProject", "Project")",
              data: {
                p_seq: p_seq
              },
              dataType: 'json',
              type: 'POST',
              beforeSend: function () {

              }
            })
              .done(function (json) {

                if (json.ok) {
                  NormalAlert(json.message);
                  table.setData("@Url.Action("MyKeyProjectListAjx", "Project")");
                } else {
                  ErrorAlert(json.message);
                }
              })
              .fail(function (e) {
                ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
              });
          },
          'oncancel': function () {

            return;
          },
        })
        .setHeader('<i class="fas fa-exclamation-triangle" style="color:#FFDC2E"></i>Key 프로젝트 취소')
        .setting({
          message: "현재 프로젝트를 Key 프로젝트에서 제거 하시겠습니까?",
        })
        .show();
    }

    var table = new Tabulator("#invoice_table", {
      height: "600px",
      layout: "fitDataFill",
      frozenRows: 0,
      columns: [
        { formatter: "rownum", hozAlign: "center", width: 40 },


        {
          title: "", field: "", frozen: true, width: 150, hozAlign: "center", formatter: function (cell, formatterParams) {
            var invoice_status = cell.getData().invoice_status;
            var p_seq = cell.getData().p_seq;
            var pii_seq = cell.getData().pii_seq;
            
            if (invoice_status == "발행 전") {
              var pic_seq = cell.getData().pic_seq;
              return "<button type='button' class='btn btn-sm btn-primary p-1 font-size-12' onclick='goContengencyInvoice(\"" + p_seq + "\", \"" + pic_seq + "\")'>성공 발행</button>";
            }
            else if (invoice_status == "승인대기") {
              return "<button type='button' class='btn btn-sm btn-danger p-1 font-size-12' onclick='goDeleteInvoice(\"" + pii_seq + "\")'>삭제</button>";
            } else if (invoice_status == "발송완료") {
              var invoice_type = cell.getData().invoice_type;
              var refund_cnt = cell.getData().refund_cnt;
              var cancel_cnt = cell.getData().cancel_cnt;

              if ((invoice_type != 4 && invoice_type != 5) && refund_cnt == 0 && cancel_cnt == 0) {
                return "<button type='button' class='btn btn-sm btn-warning p-1 font-size-12' onclick='goRefundInvoice(\"" + p_seq + "\", \"" + pii_seq + "\")'>환불 발행</button> "
                      +" <button type='button' class='btn btn-sm btn-secondary p-1 font-size-12' onclick='goCancelInvoice(\"" + p_seq + "\", \"" + pii_seq + "\")'>취소 발행</button>";
              } else {
                return "";
              }
            }
          }},
        //{ title: "월", field: "mon", sorter: "string", hozAlign: "center", width:100},
        //{ title: "종료/재진행사유", field: "status_comment", sorter: "string", width: 100 },

        //{ title: "프로젝트코드", field: "p_seq", sorter: "number", hozAlign: "right", editor: false, frozen: true },

        //{ title: "종료/재진행사유", field: "status_comment", sorter: "string", width: 100 },
        {
          title: "종류", field: "invoice_type_name", sorter: "string", hozAlign: "center", width: 100
        },
        {
          title: "상태", field: "invoice_status", sorter: "string", hozAlign: "center", width: 100,
          formatter: function (cell, formatterParams) {
            var value = cell.getValue();

            if (value == "승인대기") {
              return "<span class='text-warning text-bold'>발행요청<br/>(승인대기)</span>";
            } else if (value == "승인") {
              return "<span class='text-success text-bold'>승인완료</span>";
            }else if (value == "발송완료") {
                return "<span class='text-success text-bold'>" + value + "</span>";
            } else {
              return value;
            }
          }
        },
        { title: "신청자", field: "request_user_name", sorter: "string", width: 100, headerFilter: "input" },
        { title: "발행요청일", field: "billing_dt_str", sorter: "string", hozAlign: "center", width: 100 },
        { title: "보증일", field: "expire_guarantee_str", sorter: "string", hozAlign: "center", width: 100 },
        { title: "고객사명", field: "client_name", sorter: "string", width: 100, headerFilter: "input", formatter: function (cell, formatterParams) {
          var client_name = cell.getValue();
          var client_seq = cell.getData().client_seq;
          return '<a href="@Url.Action("ClientDetail", "Client")?c_seq=' + client_seq + '" target="_blank">' + client_name+'</a>'
         }},
        { title: "프로젝트종류", field: "pjt_type_str", sorter: "string", headerFilter: "input" },
        { title: "구인제목", field: "title", sorter: "string", headerFilter: "input", width: 150, formatter: function (cell, formatterParams) {
            var title = cell.getValue();
            var p_seq = cell.getData().p_seq;
            var pjt_type = cell.getData().pjt_type;

            if (pjt_type == 1) {
              return '<a href="@Url.Action("ProjectDetail", "Project")?p_seq=' + p_seq + '" target="_blank">'+title+'</a>'
            } else {
              return '<a href="@Url.Action("ProjectRepDetail", "Project")?p_seq=' + p_seq + '" target="_blank">'+title+'</a>'
            }

          } },
        { title: "AM", field: "director_name", sorter: "string", headerFilter: "input" },
        { title: "SM", field: "manager_name", sorter: "string", headerFilter: "input" },
        { title: "비고", field: "share_name", sorter: "string", hozAlign: "center", width: 250, headerFilter: "input" },
        {
          title: "빌링금액", field: "billing_money", formatter: "money", sorter: "number", hozAlign: "right", width: 150,
          formatterParams: { decimal: ".", thousand: ",", negativeSign: true, precision: false, },
        },
        { title: "단위", field: "bill_currency_cd", sorter: "string", hozAlign: "center", width: 50 },
        { title: "VAT구분", field: "vat_type_str", sorter: "string", hozAlign: "center", width: 80 },
        { title: "수수료율", field: "fee_rate_str", sorter: "string", hozAlign: "center", width: 100},
        { title: "후보자", field: "candidate_name", sorter: "string", hozAlign: "center", width: 150, headerFilter: "input", formatter: function (cell, formatterParams) {
          var candidate_name = cell.getValue();
          var candidate_seq = cell.getData().candidate_seq;
          return '<a href="@Url.Action("CandidateDetail", "Candidate")?c_seq=' + candidate_seq + '" target="_blank">' + candidate_name+'</a>'
         } },
        { title: "입사일", field: "join_dt_str", sorter: "string", hozAlign: "center", width: 100 },
        {
          title: "연봉", field: "ann_income", formatter: "money", sorter: "number", hozAlign: "right", width: 150,
          formatterParams: { decimal: ".", thousand: ",", negativeSign: true, precision: false, },
          //accessorDownload: numberConvert
        },
        { title: "연봉단위", field: "income_currency_cd", sorter: "string", hozAlign: "center", width: 50 },

        //{ formatter: printIconRemove, field: "p_seq", width: 80, hozAlign: "center", cellClick: function (e, cell) { cancelMyKeyProject(cell.getRow().getData().p_seq) } },



      ],
      /*
      rowFormatter: function (row) {
        if (row.getData().pjt_status == 5) {
          row.getElement().classList.add("bg-success");
        } else if (row.getData().pjt_status == 4) {
          row.getElement().classList.add("bg-info");
        } else if (row.getData().pjt_status == 3 ) {
          row.getElement().classList.add("bg-danber");
        } else if (row.getData().pjt_status == 2) {
          row.getElement().classList.add("bg-waning");
        }
      },*/
      ajaxURL: "@Url.Action("MyInvoiceListAjx", "Project")",
      ajaxConfig: "POST",
      ajaxContentType: "json",

      ajaxResponse: function (url, params, response) {
        //url - the URL of the request
        //params - the parameters passed with the request
        //response - the JSON object returned in the body of the response.

        return response.list; //return the tableData property of a response json object
      },
      pagination: "local",
      paginationSize: 100,
      paginationSizeSelector: [10, 20, 30, 50, 100],
      paginationCounter: "rows",

    });
    document.getElementById("table-setdata").addEventListener("click", function () {
      table.setData("@Url.Action("MyInvoiceListAjx", "Project")");
    });



    function goRefundInvoice(p_seq, pii_seq) {
      var win_tag = 'INVOICE_' + p_seq;
      var param = '?p_seq=' + p_seq + '&pre_pii=' + pii_seq
      var win = window.open("@Url.Action("InvoiceRefundCreate", "Invoice")" + param, win_tag, 'width=993, height=800');
      win.focus();
    }

    function goCancelInvoice(p_seq, pii_seq) {
      var win_tag = 'INVOICE_' + p_seq;
      var param = '?p_seq=' + p_seq + '&pre_pii=' + pii_seq
      var win = window.open("@Url.Action("InvoiceCancelCreate", "Invoice")" + param, win_tag, 'width=993, height=800');
      win.focus();
    }

    function goContengencyInvoice(p_seq, pic_seq) {
      var win_tag = 'INVOICE_' + p_seq;
      var param = '?p_seq=' + p_seq + '&pic_seq=' + pic_seq
      var win = window.open("@Url.Action("InvoiceContengencyCreate", "Invoice")" + param, win_tag, 'width=993, height=800');
      win.focus();
    }


    function goDeleteInvoice(pii_seq) {
      alertify.confirm()
                    .set({
                        'labels': { ok: '확인', cancel: '취소' },
                        'onok': function () {

                            $.ajax({
                               url: '@Url.Action("ProjectInvoiceDelete", "Project")',
                               data: {
                                 pii_seq: pii_seq
                               },
                               dataType: 'json',
                               type: 'POST',
                               beforeSend: function ()
                               {
                                   showLoading();
                               }
                            })
                            .done(function (json) {
                                hideLoading();
                                if (json.ok) {
                                    NormalAlert(json.message);
                                    table.setData("@Url.Action("MyInvoiceListAjx", "Project")");
                                } else {
                                    ErrorAlert(json.message);
                                }
                            })
                            .fail(function (e) {
                                hideLoading();
                                ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
                            });
                        },
                        'oncancel': function () {

                            return;
                        },
                    })
                    .setHeader('<i class="fas fa-exclamation-triangle" style="color:#FFDC2E"></i>인보이스 삭제')
                    .setting({
                        message: "인보이스를 삭제 하시겠습니까?",
                    })
                .show();
    }


  </script>

}