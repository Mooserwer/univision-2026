@model Univision.Core.Models.DTO.Response.Statistics.KeyProjectListModel
@using Univision.Security

@{
  Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet">
<script type="text/javascript" src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>

<div class="page-content container-fluid">

  <!-- row -->
  <div class="row" id="key_project_body">
    <div class="col-xl-12">
      <div class="panel custom1">
        <div class="panel-heading">
          @using (Html.BeginForm("MyKeyProjectList", "Project", FormMethod.Get, new { @id = "SearchForm" }))
          {
            <div class="panel-title">
              나의 Key 프로젝트 현황 / 관리
            </div>
            <div class="panel-actions w-md-100">
              <div class="panel-action text-right w-full">
                <button type="button" class="btn btn-sm btn-raised btn-primary btn-block" id="table-setdata">새로고침</button>
              </div>
            </div>
          }
          </div>
        
        <div class="panel-body p-10">
          <div id="key_project_table" data-role="container">

          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- // row -->


</div>

@section scripts {
  <script type="text/javascript" src="https://oss.sheetjs.com/sheetjs/xlsx.full.min.js"></script>
  <script type="text/javascript">
        $(document).ready(function () {
            BindDatePicker($(".jDatePicker"));
        });

    function fSetDate(type) {
      var today = new Date();
      var today_str = getDateStr(today)
      $('#search_endDt').val(today_str);
      if (type == "day") {
        $('#search_startDt').val(today_str)

      } else if (type == "week") {
        $('#search_startDt').val(dateAdd(today_str, -7, "d"))
      } else if (type == "month") {
        $('#search_startDt').val(dateAdd(today_str, -1, "m"))
      }
    }

    function getDateStr(date) {
      // GET YYYY, MM AND DD FROM THE DATE OBJECT
      var yyyy = date.getFullYear().toString();
      var mm = (date.getMonth() + 1).toString();
      var dd = date.getDate().toString();

      // CONVERT mm AND dd INTO chars
      var mmChars = mm.split('');
      var ddChars = dd.split('');

      // CONCAT THE STRINGS IN YYYY-MM-DD FORMAT
      return yyyy + '-' + (mmChars[1] ? mm : "0" + mmChars[0]) + '-' + (ddChars[1] ? dd : "0" + ddChars[0]);

    }

    function dateAdd(sDate, v, t) {
      var yy = parseInt(sDate.substr(0, 4), 10);
      var mm = parseInt(sDate.substr(5, 2), 10);
      var dd = parseInt(sDate.substr(8), 10);

      if (t == "d") {
        d = new Date(yy, mm - 1, dd + v);
      } else if (t == "m") {
        d = new Date(yy, mm - 1 + v, dd);
      } else if (t == "y") {
        d = new Date(yy + v, mm - 1, dd);
      } else {
        d = new Date(yy, mm - 1, dd + v);
      }

      yy = d.getFullYear();
      mm = d.getMonth() + 1; mm = (mm < 10) ? '0' + mm : mm;
      dd = d.getDate(); dd = (dd < 10) ? '0' + dd : dd;

      return '' + yy + '-' + mm + '-' + dd;
    }

    var printIconRemove = function (cell, formatterParams, onRendered) { //plain text value
      return "<button class='btn btn-xs btn-warning btn-outline'><i class='fa fa-remove'></i> Key 제거</button>";
    };

    var printIconLink = function (cell, formatterParams, onRendered) { //plain text value
      return "<button class='btn btn-xs btn-warning btn-outline'><i class='fa fa-external'></i> 상세화면</button>";
    };

    function cancelMyKeyProject(p_seq) {
      alertify.confirm()
        .set({
          'labels': { ok: '확인', cancel: '취소' },
          'onok': function () {
            $.ajax({
              url: "@Url.Action("RemoveKeyProject", "Project")",
              data: {
                p_seq: p_seq
              },
              dataType: 'json',
              type: 'POST',
              beforeSend: function () {

              }
            })
              .done(function (json) {

                if (json.ok) {
                  NormalAlert(json.message);
                  table.setData("@Url.Action("MyKeyProjectListAjx", "Project")");
                } else {
                  ErrorAlert(json.message);
                }
              })
              .fail(function (e) {
                ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
              });
          },
          'oncancel': function () {

            return;
          },
        })
        .setHeader('<i class="fas fa-exclamation-triangle" style="color:#FFDC2E"></i>Key 프로젝트 취소')
        .setting({
          message: "현재 프로젝트를 Key 프로젝트에서 제거 하시겠습니까?",
        })
        .show();
    }

    var table = new Tabulator("#key_project_table", {
      height: "600px",
      layout: "fitDataFill",
      frozenRows: 0,
      columns: [
        { formatter: "rownum", hozAlign: "center", width: 40 },
        {
          title: "", field: "p_seq", formatter: "link", formatterParams: {
            label: "[상세정보]",
            urlPrefix: "@Url.Action("ProjectDetail", "Project")?p_seq=",
            target: "_blank",
          }
        },
        { formatter: printIconRemove, field: "p_seq", width: 80, hozAlign: "center", cellClick: function (e, cell) { cancelMyKeyProject(cell.getRow().getData().p_seq)}},
        { title: "Key등록일자", field: "key_create_dt", sorter: "string", hozAlign: "center" },

        //{ title: "부서", field: "ud_name", sorter: "string", hozAlign: "left", headerFilter: "input", frozen: true, },
        //{ title: "월", field: "mon", sorter: "string", hozAlign: "center", width:100},
        //{ title: "종료/재진행사유", field: "status_comment", sorter: "string", width: 100 },

        //{ title: "프로젝트코드", field: "p_seq", sorter: "number", hozAlign: "right", editor: false, frozen: true },

        //{ title: "종료/재진행사유", field: "status_comment", sorter: "string", width: 100 },
        { title: "고객사명", field: "client_name", sorter: "string", width: 200, headerFilter: "input" },
        { title: "구인제목", field: "title", sorter: "string", headerFilter: "input", width: 300, },
        { title: "프로젝트상태", field: "pjt_status_str", sorter: "string", hozAlign: "center", headerFilter: "list", headerFilterParams: { valuesLookup: true, clearable: true } },
        { title: "AM", field: "am_names", sorter: "string", headerFilter: "input" },
        { title: "SM", field: "searcher_names", sorter: "string", headerFilter: "input" },
        { title: "(재)진행일", field: "open_dt", sorter: "string", hozAlign: "center", width: 100 },
        { title: "종료일자", field: "close_dt", sorter: "string", hozAlign: "center", width: 100 },
        { title: "잠재후보", field: "interest_cnt", sorter: "number", hozAlign: "center", width: 80 },
        { title: "추천", field: "recommend_cnt", sorter: "number", hozAlign: "center", width: 80 },
        { title: "면접", field: "interview_cnt", sorter: "number", hozAlign: "center", width: 80 },
        { title: "협상/검증", field: "nego_cnt", sorter: "number", hozAlign: "center", width: 80 }



      ],
      /*
      rowFormatter: function (row) {
        if (row.getData().pjt_status == 5) {
          row.getElement().classList.add("bg-success");
        } else if (row.getData().pjt_status == 4) {
          row.getElement().classList.add("bg-info");
        } else if (row.getData().pjt_status == 3 ) {
          row.getElement().classList.add("bg-danber");
        } else if (row.getData().pjt_status == 2) {
          row.getElement().classList.add("bg-waning");
        }
      },*/
      ajaxURL: "@Url.Action("MyKeyProjectListAjx", "Project")",
      ajaxConfig: "POST",
      ajaxContentType: "json",

      ajaxResponse: function (url, params, response) {
        //url - the URL of the request
        //params - the parameters passed with the request
        //response - the JSON object returned in the body of the response.

        return response.list; //return the tableData property of a response json object
      },
      pagination: "local",
      paginationSize: 100,
      paginationSizeSelector: [10, 20, 30, 50, 100],
      paginationCounter: "rows",

    });
    document.getElementById("table-setdata").addEventListener("click", function () {
      table.setData("@Url.Action("MyKeyProjectListAjx", "Project")");
    });





  </script>

}