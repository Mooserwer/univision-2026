@section scripts {

    <script type="text/javascript">
        window.multi_api_hidden_pretext = "search."
        var callShareBtn;

        
    function MyProjectExcelDown(searchTxt, state, orderTxt, orderOption) {
        $.ajax({
            url: '@Url.Action("MyProjectListExcelDown", "Project")',
            data: {
                'search.searchTxt': searchTxt
                , 'search.state': state
                , 'search.orderTxt': orderTxt
                , 'search.orderOption': orderOption
            },
            dataType: 'json',
            type: 'POST',
            async: false,
            beforeSend: function () {

            }
        })
        .done(function (json) {

        })
        .always(function () {

        });
    }
    function call_MyProjectList() {

        showLoading('#myProject');
        $.ajax({
            url: '@Url.Action("MyProjectList", "Project")',
            data: $('#SearchForm').formSerialize(),
            dataType: 'html',
            type: 'POST',
            async: false,
            beforeSend: function () {
                
            }
        })
        .done(function (view) {
            hideLoading('#myProject');
            $('#myProject').html(view);
            
        })
        .fail(function (xhr, textStatus, errorThrown) {
        
            //JSErrorHandler(xhr);
            hideLoading('#myProject');
            ErrorAlert('Error' + errorThrown);
        })
        .always(function () {
            hideLoading('#myProject');
        });
        
    }
    function callMyProjectList(excelDown, page) {
        $('#page').val(page ? page : 1);
        $('#search_excelDown').val(excelDown ? excelDown : false);
        call_MyProjectList()
    }

    function callMyProjectList_nouse(pjt_type, searchTxt, startDt, endDt, state, orderTxt, orderOption, excelDown, page) {
        showLoading('#myProject');
        
        $.ajax({
            url: '@Url.Action("MyProjectList", "Project")',
            data: {
                 'search.pjt_type': pjt_type
                , 'search.searchTxt': searchTxt
                , 'search.startDt': startDt
                , 'search.endDt': endDt
                , 'search.state': state
                , 'search.orderTxt': orderTxt
                , 'search.orderOption': orderOption
                , 'search.excelDown': excelDown
                , page : page
            },
            dataType: 'html',
            type: 'POST',
            async: false,
            beforeSend: function () {
                
            }
        })
        .done(function (view) {
            hideLoading('#myProject');
            $('#myProject').html(view);
            
        })
        .fail(function (xhr, textStatus, errorThrown) {
        
            //JSErrorHandler(xhr);
            hideLoading('#myProject');
            ErrorAlert('Error' + errorThrown);
        })
        .always(function () {
            hideLoading('#myProject');
        });
        
    }

    call_MyProjectList()
    //callMyProjectList(0, '', '@Utils.ConvertDateTimeToString(Utils.NowKorea().AddDays(-365))', '@Utils.ConvertDateTimeToString(Utils.NowKorea().AddDays(1))', 1, 'P.create_dt', 'DESC', false, 1)
    //callMyProjectRepList('', '@Utils.ConvertDateTimeToString(Utils.NowKorea().AddDays(-365))', '@Utils.ConvertDateTimeToString(Utils.NowKorea().AddDays(1))', 1, 'P.create_dt', 'DESC', false, 1)

    </script>

