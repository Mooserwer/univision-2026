@model Univision.Main.Models.Project.MyProjectListModel

@{
    ViewBag.Title = "MyProjectList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/Libs/remark/base/assets/examples/css/apps/work.min599c.css?v4.0.4">

<style>

    .panel-info li {
        cursor: pointer;
    }

    #kpiTable th, td {
        text-align: center
    }

    #kpiTable tr:last-of-type td {
        font-weight: bold;
    }

    table th {
        text-align: center;
    }

       
    @@media (max-width:1300px) {
        .table.table-project thead th:nth-of-type(6) {
            display: none
        }
        .table.table-project tbody td:nth-of-type(6) {
            display: none
        }        
    }
    @@media (max-width:1100px) {
        .table.table-project thead th:nth-of-type(5) {
            display: none
        }
        .table.table-project tbody td:nth-of-type(5) {
            display: none
        }     
    }
    @@media (max-width:900px) {
        .table.table-project thead th:nth-of-type(1) {
            display: none
        }
        .table.table-project tbody td:nth-of-type(1) {
            display: none
        }     
    }
    @@media (max-width:500px) {
        .table.table-project thead th:nth-of-type(2) {
            display: none
        }
        .table.table-project tbody td:nth-of-type(2) {
            display: none
        }   
    }
</style>

<div class="page-content app-work">

    <div class="panel" id="myProject">

    </div>
