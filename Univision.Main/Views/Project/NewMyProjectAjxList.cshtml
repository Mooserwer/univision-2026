                        @data.title
                      </a>
                    </h5>
                  </div>
                  <div class="media-body align-self-center cd-border-list">
                    <h5 class="mt-0">
                      산업 : @data.business_names2 <br />
                      직무 : @data.job_names2
                    </h5>
                  </div>
                  <div class="media-body align-self-center cd-border-list">
                    AM: @Html.Raw(data.am_names)<br />
                    SM: @data.searcher_names
                  </div>
                  <div class="media-body align-self-center cd-border-list">
                    @Utils.ConvertDateTimeToString(data.modify_dt)<br />
                    <small>@Utils.ConvertDateTimeToString(data.create_dt) (Reg.)</small>
                  </div>


                </div>
              </li>
            }
          }
        </ul>
      *@
    </div>
  </div>
</div>
