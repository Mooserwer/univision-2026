@model Univision.Core.Models.DTO.Response.Project.ProjectListViewModel
@{
  Layout = null;
}
<div class="nav-tabs-horizontal nav-tabs-animate">

  <div class="dropdown page-user-sortlist">

    정렬 : <a class="dropdown-toggle inline-block" data-toggle="dropdown" href="#" aria-expanded="false">
      @if (Model.search.orderOption1 == "DESC")
      {
        <text>↓</text>
      }
      else
      {
        <text>↑</text>
      }

      @if (Model.search.orderTxt1 == "A.client_name_kor")
      {
        <text>고객사 국문명</text>
      }
      else if (Model.search.orderTxt1 == "A.title")
      {
        <text>구인제목</text>
      }
      else if (Model.search.orderTxt1 == "A.business_code2")
      {
        <text>주산업</text>
      }
      else if (Model.search.orderTxt1 == "A.job_code2")
      {
        <text>주직무</text>
      }

      else if (Model.search.orderTxt1 == "create_dt_idx")
      {
        <text>최초 등록일</text>
      }
      else if (Model.search.orderTxt1 == "A.modify_dt")
      {
        <text>최종 수정일</text>
      }
      else if (Model.search.orderTxt1 == "A.position_seq")
      {
        <text>Position</text>
      }


    </a>
    <div class="dropdown-menu animation-scale-up animation-top-right animation-duration-250"
         role="menu">
      <a class="active dropdown-item" href="javascript:cd_order_set('A.client_name_kor')">고객사</a>
      <a class="dropdown-item" href="javascript:cd_order_set('A.title')">구인제목</a>
      <a class="dropdown-item" href="javascript:cd_order_set('A.business_code2')">주산업</a>
      <a class="dropdown-item" href="javascript:cd_order_set('A.job_code2')">주직무</a>
      <a class="dropdown-item" href="javascript:cd_order_set('create_dt_idx')">최초 등록일</a>
      <a class="dropdown-item" href="javascript:cd_order_set('A.modify_dt')">최종 수정일</a>
      <a class="dropdown-item" href="javascript:cd_order_set('A.position_seq')">Position</a>
    </div>



  </div>
  <ul class="nav nav-tabs nav-tabs-line">
    <li class="nav-item" role="presentation">
      <a class="@(Model.search.state == 0 ? "active " : "")nav-link" data-toggle="tab" href="#all" onclick="javascript:cd_state_set(0);" aria-controls="0" role="tab">
        전체 <span class="badge badge-dark badge-outline badge-pill font-size-12">@Utils.ConvertMoneyToString(Model.cntData.allCnt)</span>
      </a>
    </li>
    <li class="nav-item" role="presentation">
      <a class="@(Model.search.state == 1 ? "active " : "")nav-link" data-toggle="tab" href="#prog" onclick="javascript:cd_state_set(1);" aria-controls="1" role="tab">
        진행  <span class="badge badge-primary badge-outline badge-pill font-size-12">@Utils.ConvertMoneyToString(Model.cntData.progressCnt)</span>
      </a>
    </li>
    <li class="nav-item" role="presentation">
      <a class="@(Model.search.state == 4 ? "active " : "")nav-link" data-toggle="tab" href="#comp" onclick="javascript:cd_state_set(4);" aria-controls="4" role="tab">
        완료  <span class="badge badge-info badge-outline badge-pill font-size-12">@Utils.ConvertMoneyToString(Model.cntData.completeCnt)</span>
      </a>
    </li>
    <li class="nav-item" role="presentation">
      <a class="@(Model.search.state == 5 ? "active " : "")nav-link" data-toggle="tab" href="#suc" onclick="javascript:cd_state_set(5);" aria-controls="5" role="tab">
        성공  <span class="badge badge-success badge-outline badge-pill font-size-12">@Utils.ConvertMoneyToString(Model.cntData.successCnt)</span>
      </a>
    </li>
    <li class="nav-item" role="presentation">
      <a class="@(Model.search.state == 2 ? "active " : "")nav-link" data-toggle="tab" href="#hold" onclick="javascript:cd_state_set(2);" aria-controls="2" role="tab">
        보류  <span class="badge badge-warning badge-outline badge-pill font-size-12">@Utils.ConvertMoneyToString(Model.cntData.waitCnt)</span>
      </a>
    </li>
    <li class="nav-item" role="presentation">
      <a class="@(Model.search.state == 3 ? "active " : "")nav-link" data-toggle="tab" href="#fail" onclick="javascript:cd_state_set(3);" aria-controls="3" role="tab">
        취소(실패) <span class="badge badge-danger badge-outline badge-pill font-size-12">@Utils.ConvertMoneyToString(Model.cntData.failCnt)</span>
      </a>
    </li>
  </ul>

  <div class="tab-content">
    <div class="tab-pane animation-fade active" id="all_contacts" role="tabpanel">
      <table class="table table-project-all">
        <thead>
          <tr>
            <th>Status</th>
            <th>Subject</th>
            <th>AM &amp; SM</th>
            <th class="text-center">Industry &amp; Job</th>
            <th class="text-center">Position</th>
            <!--<th class="text-center">Actions</th>-->
          </tr>
        </thead>
        <tbody>
          @if (Model.list.Count > 0)
          {
            foreach (var data in Model.list)
            {
              <tr>
                <td class="work-status">
                  @{
                    string badgeClass = "";
                    switch (data.pjt_status)
                    {
                      case 1:
                        badgeClass = "badge-primary";
                        break;
                      case 2:
                        badgeClass = "badge-warning";
                        break;
                      case 3:
                        badgeClass = "badge-danger";
                        break;
                      case 4:
                        badgeClass = "badge-info";
                        break;
                      case 5:
                        badgeClass = "badge-success";
                        break;
                    }
                  }
                  <h5>
                    <span class="badge badge-pill font-size-12 @badgeClass">@data.pjt_status_str</span>
                  </h5>
                </td>
                <td class="subject">
                  <div class="table-content">
                    <p>
                      <span class="cus-d-1000 badge badge-pill font-size-12 @badgeClass">@data.pjt_status_str</span>
                      @Html.Raw(data.company_name)
                      @if (data.is_pe == 1)
                      {
                      <span class="badge badge-secondary">PE</span>
                      }
                      <span class="cus-h-1000 text-right small blue-grey-400 float-right pr-10">
                        Update : @Utils.ConvertDateTimeToString(data.modify_dt)
                        <br />Reg. : @Utils.ConvertDateTimeToString(data.create_dt)
                      </span>
                      <br />

                      @{
                        string badgeClass_type = "";
                        switch (data.pjt_type)
                        {
                          case 1:
                            badgeClass_type = "badge-primary";
                            break;
                          default:
                            badgeClass_type = "badge-info ";
                            break;

                        }
                      }
                      <span class="badge badge-outline font-size-12 @badgeClass_type">@data.pjt_type_str</span>
                      @if (data.pjt_type == 1)
                      {
                        if (data.is_my_key == 1)
                        {
                          <i class="fa fa-key yellow-700" title="Key project"></i>
                        }
                        <a href="@Url.Action("ProjectDetail", "Project", new { @p_seq = data.p_seq })" title="@data.title" class="clearfix">
                          @Html.Raw(data.title)
                        </a>
                      }
                      else
                      {
                        <a href="@Url.Action("ProjectRepDetail", "Project", new { @p_seq = data.p_seq })" title="@data.title" class="clearfix">
                          @Html.Raw(data.title)
                        </a>
                      }

                      <div class="cus-d-1000">
                        <span class="badge badge-outline badge-primary font-size-12">
                          @data.business_names2
                        </span>
                        @if (!String.IsNullOrEmpty(data.sub_business_names2))
                        {
                          <span class="badge badge-outline badge-primary font-size-12">
                            @data.sub_business_names2
                          </span>
                        }
                        <span class="badge badge-outline badge-info font-size-12">
                          @data.job_names2
                        </span>
                        @if (!String.IsNullOrEmpty(data.sub_job_names2))
                        {
                          <span class="badge badge-outline badge-info font-size-12">
                            @data.sub_job_names2
                          </span>
                        }
                      </div>

                      <span class="cus-d-1000 text-right small blue-grey-400 float-right pr-10">
                        <br />Update : @Utils.ConvertDateTimeToString(data.modify_dt) / Reg. : @Utils.ConvertDateTimeToString(data.create_dt)
                      </span>
                    </p>




                  </div>
                </td>
                <td class="members">
                  <div class="table-content">
                    @if (!string.IsNullOrWhiteSpace(data.am_names))
                    {
                      <h5>

                        @{
                          string[] am_names_arr = data.am_names.Split('\n');
                          if (am_names_arr.Length > 0)
                          {
                            int am_cnt = 0;

                            foreach (var am in am_names_arr)
                            {

                              if (!string.IsNullOrWhiteSpace(am))
                              {


                                @Html.Raw(am.Replace("\r", ""))


                                am_cnt++;
                              }

                            }
                          }
                        }
                      </h5>
                    }

                    @if (!string.IsNullOrWhiteSpace(data.searcher_names))
                    {
                      <h5>

                        @{
                          string[] searcher_names_arr = data.searcher_names.Split('\n');
                          if (searcher_names_arr.Length > 0)
                          {
                            int searcher_cnt = 0;

                            foreach (var searcher in searcher_names_arr)
                            {

                              if (!string.IsNullOrWhiteSpace(searcher))
                              {
                                if (searcher_cnt > 0)
                                {
                                  <text>, </text>
                                }
                                @Html.Raw(searcher.Replace("\r", ""))

                                searcher_cnt++;
                              }

                            }

                          }
                        }
                      </h5>
                    }

                  </div>
                </td>
                <td>
                  <div>
                    <h5>
                      <span class="badge badge-outline badge-primary font-size-12">
                        @data.business_names2
                      </span>
                      @if (!String.IsNullOrEmpty(data.sub_business_names2))
                      {
                        <span class="badge badge-outline badge-primary font-size-12">
                          @data.sub_business_names2
                        </span>
                      }
                    </h5>
                    <h5>
                      <span class="badge badge-outline badge-info font-size-12">
                        @data.job_names2
                      </span>
                      @if (!String.IsNullOrEmpty(data.sub_job_names2))
                      {
                        <span class="badge badge-outline badge-info font-size-12">
                          @data.sub_job_names2
                        </span>
                      }
                    </h5>
                  </div>
                </td>
                <td class="text-center">
                  <div>
                    <h5>
                      @data.position_name
                    </h5>
                  </div>
                </td>
                <!--
                <td class="actions text-center">
                  <div class="table-content">
                    <i class="icon wb-menu" data-url="panel.tpl" data-toggle="slidePanel"></i>
                  </div>
                </td>
                  -->

              </tr>
            }
          }
        </tbody>
      </table>

      @*
        <ul class="list-group">
          @if (Model.list.Count > 0)
          {
            foreach (var data in Model.list)
