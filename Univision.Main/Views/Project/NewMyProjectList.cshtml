                  </div>
                  <div class="col-6 col-md-3">

                    <div class="checkbox-custom checkbox-default">
                      <input type="checkbox" id="exl_pjt_title" name="exl_pjt_sub" value="구인제목" checked autocomplete="off" />
                      <label for="exl_pjt_title">구인제목</label>
                    </div>
                    <div class="checkbox-custom checkbox-default">
                      <input type="checkbox" id="exl_pjt_salary" name="exl_pjt_sub" value="예상_연봉" checked autocomplete="off" />
                      <label for="exl_pjt_salary">연봉(예상)</label>
                    </div>
                    <div class="checkbox-custom checkbox-default">
                      <input type="checkbox" id="exl_pjt_feerate" name="exl_pjt_sub" value="수수료율" checked autocomplete="off" />
                      <label for="exl_pjt_salary">수수료율</label>
                    </div>
                    <div class="checkbox-custom checkbox-default">
                      <input type="checkbox" id="exl_pjt_position" name="exl_pjt_sub" value="포지션명" checked autocomplete="off" />
                      <label for="exl_pjt_position">포지션명</label>
                    </div>
                    <div class="checkbox-custom checkbox-default">
                      <input type="checkbox" id="exl_pjt_pos_seq" name="exl_pjt_sub" value="직급분류" checked autocomplete="off" />
                      <label for="exl_pjt_pos_seq">직급분류</label>
                    </div>
                  </div>
                  <div class="col-6 col-md-3">
                    <div class="checkbox-custom checkbox-default">
                      <input type="checkbox" id="exl_pjt_business1" name="exl_pjt_sub" value="주_산업_대분류" checked autocomplete="off" />
