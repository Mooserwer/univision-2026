@model Univision.Core.Models.DTO.Response.Project.ProjectListViewModel
@{

  ViewBag.Title = "My Project";
  Layout = "~/Views/Shared/_Layout.cshtml";
  ViewBag.noJqueryUi = false;



}

<style>
  .extend-box {
    position: absolute !important;
    top: 1.9em;
    right: 1em;
  }

  .panel-body .input-search .form-control {
    border-radius: 2px;
  }

  .panel-body .form-control-label {
    margin-bottom: 0px;
    padding-bottom: 0px;
  }

  .panel-body .form-group {
    margin-bottom: 3px;
  }

  .panel {
    margin-bottom: 1rem;
  }

  .table thead th {
    font-weight: bold;
  }

  .bg-warning {
    background-color: #ab8000 !important;
  }

  .cd-border-list {
    border-left: 1px solid #ddd;
    padding-left: 5px;
  }

  u {
    text-decoration-skip-ink: auto;
    text-decoration-style: double;
    text-decoration-thickness: 1px;
    text-decoration-color: #ff6a00;
    text-underline-offset: 3px;
  }

  .cus-d-1000 {
    display: none !important;
  }

  @@media (max-width:1000px) {
    .cus-d-1000 {
      display: inline-block !important;
    }

    .cus-h-1000 {
      display: none !important;
    }

    .table.table-project-all thead th:nth-of-type(1) {
      display: none
    }

    .table.table-project-all tbody td:nth-of-type(1) {
      display: none
    }

    .table.table-project-all thead th:nth-of-type(4) {
      display: none
    }

    .table.table-project-all tbody td:nth-of-type(4) {
      display: none
    }

    .table.table-project-all thead th:nth-of-type(5) {
      display: none
    }

    .table.table-project-all tbody td:nth-of-type(5) {
      display: none
    }
  }
</style>
<link href="~/Libs/bootstrap-select/css/bootstrap-select.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/Libs/remark/base/assets/examples/css/pages/user.min599c.css?v4.0.4">
<div class="page-user">
  <div class="page-content">
    @using (Html.BeginForm("NewMyProjectList", "Project", FormMethod.Get, new { @id = "SearchForm", @autocomplete = "off" }))
    {
      <div class="panel panel-primary panel-line animation-scale-up" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms;">
        <div class="panel-heading">
          <div class="panel-title">
            <i class="fas fa-clipboard-list"></i>
            'MY' PROJECT <small class="text-dark">(내 프로젝트 조회)</small>
          </div>
          <div class="panel-actions w-md-p30">



            @*
              <div class="panel-action input-search w-full">
                <button type="submit" class="input-search-btn pr-20">
                  <i class="icon wb-search" aria-hidden="true" title="Search"></i>
                </button>
                @Html.TextBoxFor(x => x.search.total, new { @class = "form-control", @placeholder = "Search - 검색어 입력 (고객사, 구인제목, AM, SM, 등)" })
              </div>
            *@
            @*PMS 오픈 관련 등록기능 제한*@
            @if ((Univision.Security.AppIdentity.ua_seq <= 3 && Univision.Security.AppIdentity.ua_seq > 0))
            {
              <div class="panel-action text-right w-full">
                <a href="@Url.Action("ProjectRepCreate", "Project")" class="btn btn-sm btn-info" title="컨설팅(Consulting) 프로젝트 등록">
                  <i class="icon wb-plus"></i>
                  New (기타 서비스)
                </a>
                <a href="@Url.Action("ProjectCreate", "Project")" class="btn btn-sm btn-primary" title="채용(Recruitment) 프로젝트 등록">
                  <i class="icon wb-plus"></i>
                  New (채용)
                </a>
              </div>
            }
          </div>

        </div>
        <div class="panel-body p-15 bg-blue-grey-200">
          <!--검색 Form -->
          @Html.HiddenFor(x => x.search.state)
          @Html.HiddenFor(x => x.search.orderTxt1)
          @Html.HiddenFor(x => x.search.orderOption1)
          @Html.HiddenFor(x => x.search.orderTxt2)
          @Html.HiddenFor(x => x.search.orderOption2)
          @Html.Hidden("CurrentPage", Model.PagingInfo.CurrentPage, new { @id = "SearchForm_CurrentPage" })
          @Html.Hidden("ItemsPerPage", Model.PagingInfo.ItemsPerPage)
          <!-- 검색 패널 시작 -->
          <hr class="d-md-none d-block" />
          <div class="row">
            <div class="col-12 col-md-6 col-lg-2">
              @Html.LabelFor(x => x.search.pjt_type, "프로젝트 구분 (Type)", new { @class = "form-control-label" })
              <select id="search_pjt_type" name="search.pjt_type" class="form-control form-control">
                <option value="0">[전체 (ALL)]</option>
                <option value="1" @(Model.search.pjt_type == 1 ? "selected" : "")>채용 (Recruitment)</option>
                <option value="2" @(Model.search.pjt_type == 2 ? "selected" : "")>평판조회 (Referrence Check)</option>
                <option value="3" @(Model.search.pjt_type == 3 ? "selected" : "")>재취업 (Outplacement)</option>
                <option value="4" @(Model.search.pjt_type == 4 ? "selected" : "")>채용대행 (RPO) </option>
                <option value="5" @(Model.search.pjt_type == 4 ? "selected" : "")>마켓매핑 (Long List) </option>
                <option value="6" @(Model.search.pjt_type == 4 ? "selected" : "")>사외이사 서비스 (Outside director) </option>
                <option value="9" @(Model.search.pjt_type == 9 ? "selected" : "")>기타 (Other consulting)</option>
              </select>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
              @Html.LabelFor(x => x.search.position_start, "직급 (Position)", new { @class = "form-control-label" })
              @{
                var positionList = new SelectList(Model.search.positionList, "p_code", "p_name").ToList();
                positionList.Insert(0, new SelectListItem { Value = "0", Text = "직급 전체 (All Position)" });
              }
              <div class="input-group">
                @Html.DropDownListFor(x => x.search.position_start, positionList, new { @class = "form-control form-control" })
                <span class="input-group-addon bg-transparent px-5">~</span>
                @Html.DropDownListFor(x => x.search.position_end, positionList, new { @class = "form-control form-control" })
              </div>
            </div>
            <div class="col-sm-12 col-md-8 col-lg-6">
              @Html.LabelFor(x => x.search.range_field, "기간 검색(Date)", new { @class = "form-control-label" })
              <div class="form-group">
                <div class="input-group">
                  <span class="input-group-prepend">
                    <select id="search_range_field" name="search.range_field" class="form-control form-control w-150">
                      <option value="A.create_dt_idx" @(Model.search.range_field == "A.create_dt_idx" ? "selected" : "")>등록일(Reg.)</option>
                      <option value="A.modify_dt_idx" @(Model.search.range_field == "A.modify_dt_idx" ? "selected" : "")>수정일(Update)</option>
                    </select>
                  </span>
                  @Html.TextBoxFor(x => x.search.dt_start, new { @class = "form-control date-time", @placeholder = "YYYY-MM-DD" })
                  <span class="input-group-addon bg-transparent px-5"> ~ </span>
                  @Html.TextBoxFor(x => x.search.dt_end, new { @class = "form-control date-time", @placeholder = "YYYY-MM-DD" })
                </div>
              </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
              @Html.LabelFor(x => x.search.client, "고객사 (Client)", new { @class = "form-control-label" })
              <div class="form-group">
                @Html.TextBoxFor(x => x.search.client, new { @class = "form-control form-control" })
              </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
              @Html.LabelFor(x => x.search.title, "구인제목 (Title)", new { @class = "form-control-label" })
              <div class="form-group">
                @Html.TextBoxFor(x => x.search.title, new { @class = "form-control form-control" })
              </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
              @Html.LabelFor(x => x.search.user_name, "AM/SM", new { @class = "form-control-label" })
              <div class="form-group">
                @Html.TextBoxFor(x => x.search.user_name, new { @class = "form-control" })
              </div>
            </div>
          </div>
          <!-- 검색조건 첫째줄 끝 -->
          <!-- 검색조건 넷째줄 시작 -->
          <div class="row">
            <div class="col-sm-12 col-md-5">
              <label class="form-control-label">
                산업(Industry)
              </label>
              <div class="input-group input-group redo-site" id="businessDiv">
                <div class="bg-white pl-5 pr-5 w-p100 form-inline codeBindDiv" id="busiCodeList">
                  @Html.Partial("PartialProjectSearchBusiList", Model.search)
                </div>
                <div class="input-group-btn">
                  <button type="button" class="btn btn-outline-primary" onclick="FindBusiness()">
                    <i class="fas fa-search"></i>
                  </button>
                </div>
                <div class="input-group-btn">
                  <button type="button" class="btn btn-outline-primary btn-redo-code">
                    <i class="fas fa-redo" placeholder="초기화"></i>
                  </button>
                </div>
              </div>

            </div>
            <div class="col-sm-12 col-md-5">
              <label class="form-control-label">
                직무(Job Functions)
              </label>
              <div class="input-group input-group redo-site" id="JobDiv">
                <div class="bg-white pl-5 pr-5 w-p100 form-inline codeBindDiv" id="jobCodeList">
                  @Html.Partial("PartialProjectSearchJobList", Model.search)
                </div>
                <div class="input-group-btn">
                  <button type="button" class="btn btn-outline-primary" onclick="javascript:FindJob()">
                    <i class="fas fa-search"></i>
                  </button>
                </div>
                <div class="input-group-btn">
                  <button type="button" class="btn btn-outline-primary btn-redo-code">
                    <i class="fas fa-redo" placeholder="초기화"></i>
                  </button>
                </div>
              </div>
            </div>
            <div class="col-sm-12 col-md-2">
              @Html.LabelFor(x => x.search.is_pe, "PE Portfolio", new { @class = "form-control-label small" })
              <select id="search_is_pe" name="search.is_pe" class="form-control form-control">
                <option value="9">[전체 (ALL)]</option>
                <option value="1" @(Model.search.is_pe == 1 ? "selected" : "")>PE 프로젝트만</option>
                <option value="0" @(Model.search.is_pe == 0 ? "selected" : "")>PE 프로젝트 제외</option>
              </select>
            </div>
          </div>
          <!-- 검색조건 넷째줄 끝 -->
          <!-- 검색조건 여섯째줄 시작 -->
          <div class="row pt-15">
            <div class="col-6">
              <div class="form-group text-left">
                <div class="input-group w-300">
                  <button type="button" id="btnReset" class="btn btn-outline-danger" title="검색조건 초기화">
                    <i class="fas fa-redo"></i>
                    Reset
                  </button>
                  <select id="search_is_key_first" name="search.is_key_first" class="form-control form-inline ">
                    <option value="1" @(Model.search.is_key_first == 1 ? "selected" : "")>Key 프로젝트 우선 표시 O</option>
                    <option value="0" @(Model.search.is_key_first != 1 ? "selected" : "")>Key 프로젝트 우선 표시 X</option>
                  </select>
                </div>
              </div>
            </div>
            <div class="col-6">
              <div class="form-group text-right">
                <a class="mr-10" data-toggle="collapse" href="#exampleCollapseExample"
                   aria-expanded="false" aria-controls="exampleCollapseExample">
                  <i class="fas fa-arrow-down"></i> 엑셀 다운로드 항목 선택
                </a>
                <button type="submit" id="btnSearch" class="btn btn-primary w-200" title="검색">
                  <i class="fas fa-search"></i>
                  Search
                </button>
              </div>
            </div>
          </div>
          <!-- 검색조건 여섯째줄 끝 -->



        </div>
      </div>
    }
    <div class="row">
      <div class="col">
        @using (Html.BeginForm("MyProjectExcelList", "Project", FormMethod.Post, new { @id = "SearchExcelForm", @autocomplete = "off" }))
        {


          <div class="collapse in" id="exampleCollapseExample">
