                      <label for="exl_pjt_client_eng">고객사 영문명</label>
                    </div>
                    <div class="checkbox-custom checkbox-default">
                      <input type="checkbox" id="exl_pjt_type" name="exl_pjt_sub" value="프로젝트_구분" checked autocomplete="off" />
                      <label for="exl_pjt_type">프로젝트 구분</label>
                    </div>
                    <div class="checkbox-custom checkbox-default">
                      <input type="checkbox" id="exl_pjt_status" name="exl_pjt_sub" value="프로젝트_진행상태" checked autocomplete="off" />
                      <label for="exl_pjt_status">프로젝트 진행상태</label>
                    </div>
                    <div class="checkbox-custom checkbox-default">
