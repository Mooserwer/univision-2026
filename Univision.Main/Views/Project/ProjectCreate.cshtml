                      var per_won = rst.data.per_won;
                      var per_rate = rst.data.ex_rate;
                      var org_money = uncomma2($('#exp_salary').val())
                      var result_won = ((org_money * per_won) / per_rate).toFixed(2);
                      $('#exp_salary_won').val(result_won.toString())
                      $('#exp_won_label').text("원화 환산 예상액 : 약 " + comma2(result_won.toString()) + "원");
                    } else {
                      $('#exp_won_label').text("환율 정보를 찾을 수 없습니다.");
                    }
