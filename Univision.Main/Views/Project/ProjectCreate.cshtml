              inputNumberFormat2(this);
            });

            //포지션이 변경되면 고객사와 수수료율 계약이 직급별 일때 수수료율 자동 변경.
            $("#position_seq").change(function () {

                if (feeType == "@ContractFeeType.position") {
                    var position = $("#position_seq").val();

                    for (var i = 0; i < feeRateList.length; i++) {
                        var data = feeRateList[i];

                        if (data.start_code_seq <= position && data.end_code_seq >= position) {
                            $("#fee_rate").val(data.rate);
                            return;
                        }
                    }
                }

            });

            //회사명이 변경되면 c_seq 초기화
            $("#company_name").change(function () {
