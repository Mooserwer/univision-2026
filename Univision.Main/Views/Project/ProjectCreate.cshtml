                //고객사의 수수료율 계약타입이 연봉별 일 경우,
                if (feeType == "@ContractFeeType.annual") {
                    var exp_salary = cf_getNumberOnly($("#exp_salary").val());

                    for (var i = 0; i < feeRateList.length; i++) {

                        var data = feeRateList[i];

                        if (data.start_income <= exp_salary && data.end_income >= exp_salary) {
                            $("#fee_rate").val(data.percentage);
                            return;
                        }
                    }
                }
            });

