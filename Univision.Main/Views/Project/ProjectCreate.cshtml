@model Univision.Main.Models.Project.ProjectCreateModel

@{
  ViewBag.Title = "프로젝트[채용] " + Model.title;
  Layout = "~/Views/Shared/_Layout.cshtml";
  string type = ViewBag.type;
}

<link rel="stylesheet" href="~/Libs/remark/global/vendor/bootstrap-tokenfield/bootstrap-tokenfield.min599c.css?v4.0.4">

<style>
  .placeDiv span {
    font-size: 15px;
  }

  .job_list {
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    width: 250px;
    display: inline-block;
  }
</style>

<div class="page-content">
  <!-- 클라이언트에서 넘어온 프로젝트 카피의 경우, 액션을 변경. -->
  @using (Html.BeginForm("ProjectCreate", "Project", FormMethod.Post, new { @id = "CreateForm" }))
  {
    @Html.HiddenFor(x => x.p_seq)
    @Html.HiddenFor(x => x.i_seq)
    @Html.HiddenFor(x => x.type)
    <div class="panel panel-primary panel-line animation-scale-up" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms;">
      <div class="panel-heading">
        <h3 class="panel-title">
          <i class="fas fa-newspaper"></i>
          Project Information [Recruitment]
        </h3>
        <div class="panel-actions">
          <a class="panel-action icon wb-minus" aria-expanded="true" data-toggle="panel-collapse" aria-hidden="true"></a>
        </div>
      </div>
      <div id="projectInfo" class="panel-body">
        @Html.Hidden("pjt_type", ProjectTypeCode.hire)
        @*<div class="form-group">
              <label class="form-control-label">프로젝트 구분</label>
              <div>
                  <div class="radio-custom radio-default radio-inline">
                      <input type="radio" id="hire" name="pjt_type" value="1" checked @(Model.pjt_type == 1 ? "checked" : "")>
                      <label for="hire">채용</label>
                  </div>
              </div>
          </div>*@
        <div class="row">
          <div class="form-group col-8 col-md-3">
            <label class="form-control-label" for="company_name">
              Client
              <span class="label-reqired">*</span>
            </label>
            @Html.HiddenFor(x => x.c_seq)
            <div class="input-group input-group-sm">
              @Html.TextBoxFor(x => x.company_name, new { @class = "form-control", @autocomplete = "off", @readonly = "true" })
              <span class="input-group-btn">
                <button type="button" class="btn btn-primary" id="btnClientSearch"><i class="fas fa-search" aria-hidden="true"></i></button>
              </span>
            </div>
          </div>
          <div class="form-group col-4 col-md-2">
            <label class="form-control-label" for="is_pe">PE project</label><span class="label-reqired">*</span>
            <div class="pl-5">
              <div class="radio-custom radio-default radio-inline">
                <input type="radio" id="is_pe_y" name="is_pe" value="1" @(Model.is_pe == 1 ? "checked" : "")>
                <label for="is_pe_y">Yes</label>
              </div>
              <div class="radio-custom radio-default radio-inline">
                <input type="radio" id="is_pe_n" name="is_pe" value="0" @(Model.is_pe != 1 ? "checked" : "")>
                <label for="is_pe_n">No</label>
              </div>
            </div>
          </div>
          <div class="form-group col-md-7">
            <label class="form-control-label" for="title">
              Title
              <span class="label-reqired">*</span> - <small> [국내 / 외국계 산업] 포지션명 직급 </small>
            </label>
            @Html.TextBoxFor(x => x.title, new { @class = "form-control form-control-sm", @autocomplete = "off", @placeholder = "[국내 / 외국계 산업] 포지션명 지급" })
            <input type="hidden" name="tmp_fix_title" id="tmp_fix_title" value="" />
          </div>
        </div>

        <div class="row">
          <div class="form-group col-md-4">
            <label class="form-control-label" for="AMDiv">
              AM
              <span class="label-reqired">*</span>
            </label>
            <div class="input-group input-group-sm">
              <div class="form-control" id="AMDiv" name="AMDiv" style="overflow-x:hidden; overflow-y:hidden" readonly>
                @if (Model.amList.Count > 0)
                {
                  foreach (var am in Model.amList)
                  {
                    <span class="category mr-5">
                      <span class="badge badge-outline badge-default bg-white cur_hand badge-lg" am_seq="@am.uv_seq">
                        @am.name
                        <i class="far fa-times-circle" onclick="removeBadge(this)"></i>
                      </span>
                    </span>
                  }
                }
              </div>
              <span class="input-group-btn">
                <button type="button" id="btnAm" class="btn btn-primary"><i class="fas fa-plus" aria-hidden="true"></i></button>
              </span>
            </div>

          </div>

          <div class="form-group col-md-8">
            <label class="form-control-label" for="Searcher">
              SM
              <span class="label-reqired">*</span>
            </label>
            <div class="input-group input-group-sm">
              <div class="form-control" id="Searcher" name="Searcher" readonly>
                @if (Model.searcherList.Count > 0)
                {
                  foreach (var searcher in Model.searcherList)
                  {
                    <span class="category mr-5">
                      <span class="badge badge-outline badge-default bg-white cur_hand badge-lg" searcher_seq="@searcher.uv_seq">
                        @searcher.name
                        <i class="far fa-times-circle" onclick="removeBadge(this)"></i>
                      </span>
                    </span>
                  }
                }
              </div>
              <span class="input-group-btn">
                <button type="button" id="btnSearcher" class="btn btn-primary"><i class="fas fa-plus" aria-hidden="true"></i></button>
              </span>

            </div>
          </div>
        </div>

        <div class="row">

          <div class="form-group col-md-6">
            <label class="form-control-label" for="businessCodeDiv">
              Main Industry  <i class="fas fa-info-circle text-info" title="후보자 자동제안 참조 항목"></i>
              <span class="label-reqired">*</span>
            </label>
            <div class="input-group input-group-sm" id="businessCodeDiv">
              @Html.HiddenFor(x => x.business_code1, new { @class = "busiCode1" })
              @Html.HiddenFor(x => x.business_code2, new { @class = "busiCode2" })
              @{
                string business_str = String.Empty;
                if (!String.IsNullOrEmpty(Model.business_name2))
                {
                  business_str = "" + Model.business_name1 + " > " + Model.business_name2 + "";
                }
              }
              @Html.TextBox("business_name2", business_str, new { @class = "form-control bg-white form-control-sm busiTargetText longLen", @readonly = "readonly", @placeholder = "주 산업" })
              <span class="input-group-btn">
                <button type="button" class="btn btn-primary" onclick="FindBusinessSingle('businessCodeDiv')"><i class="fas fa-search"></i></button>
              </span>
            </div>

            <div class="input-group input-group-sm" id="SubBusinessCodeDiv">
              @Html.HiddenFor(x => x.sub_business_code1, new { @class = "busiCode1" })
              @Html.HiddenFor(x => x.sub_business_code2, new { @class = "busiCode2" })
              @{
                string sub_business_str = String.Empty;
                if (!String.IsNullOrEmpty(Model.sub_business_name2))
                {
                  sub_business_str = "" + Model.sub_business_name1 + " > " + Model.sub_business_name2 + "";
                }
              }
              @Html.TextBox("sub_business_name2", sub_business_str, new { @class = "form-control bg-white form-control-sm busiTargetText longLen", @readonly = "readonly", @placeholder = "보조 산업" })
              <span class="input-group-btn">
                <button type="button" class="btn btn-secondary" onclick="RemoveBusiness('SubBusinessCodeDiv')"><i class="fas fa-times"></i></button>
                <button type="button" class="btn btn-primary" onclick="FindBusinessSingle('SubBusinessCodeDiv')"><i class="fas fa-search"></i></button>
              </span>
            </div>
          </div>
          <div class="form-group col-md-6">
            <label class="form-control-label" for="jobCodeDiv">
              Job function  <i class="fas fa-info-circle text-info" title="후보자 자동제안 참조 항목"></i>
              <span class="label-reqired">*</span>
            </label>

            <div class="input-group input-group-sm" id="jobCodeDiv">
              @Html.HiddenFor(x => x.job_code1, new { @class = "jobCode1" })
              @Html.HiddenFor(x => x.job_code2, new { @class = "jobCode2" })
              @{
                string job_str = String.Empty;
                if (!String.IsNullOrEmpty(Model.job_name2))
                {
                  job_str = "" + Model.job_name1 + " > " + Model.job_name2 + "";
                }
              }
              @Html.TextBox("job_name2", job_str, new { @class = "form-control bg-white jobTargetText form-control-sm", @readonly = "readonly", @placeholder = "주 직무" })
              <span class="input-group-btn">
                <button type="button" class="btn btn-primary" onclick="javascript:FindJobSingle('jobCodeDiv')"><i class="fas fa-search"></i></button>
              </span>

            </div>

            <div class="input-group input-group-sm" id="subjobCodeDiv">
              @Html.HiddenFor(x => x.sub_job_code1, new { @class = "jobCode1" })
              @Html.HiddenFor(x => x.sub_job_code2, new { @class = "jobCode2" })
              @{
                string sub_job_str = String.Empty;
                if (!String.IsNullOrEmpty(Model.sub_job_name2))
                {
                  sub_job_str = "" + Model.sub_job_name1 + " > " + Model.sub_job_name2 + "";
                }
              }
              @Html.TextBox("sub_job_name2", sub_job_str, new { @class = "form-control bg-white jobTargetText form-control-sm", @readonly = "readonly", @placeholder = "보조 직무" })
              <span class="input-group-btn">
                <button type="button" class="btn btn-secondary" onclick="RemoveJob('subjobCodeDiv')"><i class="fas fa-times"></i></button>
                <button type="button" class="btn btn-primary" onclick="javascript:FindJobSingle('subjobCodeDiv')"><i class="fas fa-search"></i></button>
              </span>
            </div>
          </div>
        </div>
        <div class="row">
          <div class="form-group col-md-4" id="exp_loading">
            <label class="form-control-label" for="exp_salary">
              Salary <span class="label-reqired">*</span>
              <span class="text-primary font-weight-900" id="exp_won_label">
                @if (Model.currency_cd != "KRW" && Model.exp_salary_won.HasValue)
                {
                  <text>(원화 환산 예상액 : 약 </text> @Utils.ConvertMoneyToString(Model.exp_salary_won) <text>원)</text>
                }

              </span>
            </label>
            <div class="input-group input-group-sm">
              @Html.HiddenFor(x => x.exp_salary_won)
              @Html.TextBoxFor(x => x.exp_salary, "{0:#,0.##}", new { @class = "form-control text-right", @autocomplete = "off" })
              <select name="currency_cd" id="currency_cd" class="form-control form-control-sm">
                <option value="KRW" @(Model.currency_cd == "KRW" ? "selected" : "")>KRW(원)</option>
                <option value="USD" @(Model.currency_cd == "USD" ? "selected" : "")>USD(달러)</option>
                <option value="HKD" @(Model.currency_cd == "HKD" ? "selected" : "")>HKD(홍콩달러)</option>
                <option value="JPY" @(Model.currency_cd == "JPY" ? "selected" : "")>JPY(엔화)</option>
                <option value="SGD" @(Model.currency_cd == "SGD" ? "selected" : "")>SGD(싱가폴 달러)</option>
                <option value="GBP" @(Model.currency_cd == "GBP" ? "selected" : "")>GBP(파운드)</option>
                <option value="DEM" @(Model.currency_cd == "DEM" ? "selected" : "")>DEM(마르크)</option>
                <option value="FRF" @(Model.currency_cd == "FRF" ? "selected" : "")>FRF(프랑스 프랑)</option>
                <option value="CHF" @(Model.currency_cd == "CHF" ? "selected" : "")>CHF(스위스 프랑)</option>
                <option value="EUR" @(Model.currency_cd == "EUR" ? "selected" : "")>EUR(유로)</option>
                <option value="CNY" @(Model.currency_cd == "CNY" ? "selected" : "")>CNY(위안)</option>
                <option value="AUD" @(Model.currency_cd == "AUD" ? "selected" : "")>AUD(호주달러)</option>
                <option value="NZD" @(Model.currency_cd == "NZD" ? "selected" : "")>NZD(뉴질랜드달러)</option>
                <option value="CAD" @(Model.currency_cd == "CAD" ? "selected" : "")>CAD(캐나다달러)</option>
                <option value="THB" @(Model.currency_cd == "THB" ? "selected" : "")>THB(태국 밧)</option>
                <option value="TWD" @(Model.currency_cd == "TWD" ? "selected" : "")>TWD(신타이완달러)</option>
                <option value="VND" @(Model.currency_cd == "VND" ? "selected" : "")>VND(베트남 동)</option>
              </select>
            </div>

          </div>
          <div class="form-group col-md-2">

            <label class="form-control-label" for="fee_rate">Fee rate <span class="label-reqired">*</span></label>
            <div class="input-group input-group-sm">
              @Html.TextBoxFor(x => x.fee_rate, "{0:0.#}", new { @type = "number", @min = "0", @max = "100", @step = "0.1", @class = "form-control form-control  text-right", @autocomplete = "off", @placeholder = "%" })
              <span class="input-group-addon">%</span>
            </div>
          </div>
          <div class="form-group col-md-2">
            <label class="form-control-label" for="position_seq">
              Position
              <span class="label-reqired">*</span>
            </label>
            @{
              var positionList = new SelectList(Model.positionList, "p_code", "p_name").ToList();
              positionList.Insert(0, new SelectListItem { Value = "", Text = "선택" });
            }
            @Html.DropDownListFor(x => x.position_seq, positionList, new { @class = "form-control form-control-sm" })
          </div>
          <div class="form-group col-md-2">

            <label class="form-control-label" for="position_str">포지션명 <span class="label-reqired">*</span></label>
            @Html.TextBoxFor(x => x.position_str, new { @class = "form-control form-control-sm", @autocomplete = "off", @placeholder = "" })

          </div>
          <div class="form-group col-md-2">
            <label class="form-control-label" for="expreience_number">
              Experience(Year)
              <span class="label-reqired">*</span>
            </label>
            <div class="input-group input-group-sm">
              @Html.TextBoxFor(x => x.expreience_number, new { @class = "form-control", @type = "number", @autocomplete = "off", @placeholder = "년 수" })
              <select class="form-control" id="experience_type" name="experience_type">
                <option value="1" @(Model.experience_type == 1 ? "selected" : "")>년 이상</option>
                <option value="2" @(Model.experience_type == 2 ? "selected" : "")>년 이하</option>
              </select>
            </div>
          </div>
        </div>
        <div class="row">
          <div class="form-group col">
            <label class="form-control-label" for="assign_task">
              내부 참고자료 <small class="text-info">(포스팅 시 공개되지 않는 내용입니다.)</small>
            </label>
            @{
              string edit_internal_contents = Model.internal_contents;
              if (!String.IsNullOrEmpty(edit_internal_contents))
              {
                edit_internal_contents = edit_internal_contents.Replace("&lt;", "<").Replace("&gt;", ">");
              }
            }
            @Html.TextArea("edit_internal_contents", edit_internal_contents, new { @class = "form-control summernote_jd" })
            @Html.HiddenFor(x => x.internal_contents)
          </div>
        </div>
        <div class="row">
          <div class="form-group col-md-6">
            <label class="form-control-label" for="assign_task">
              담당업무 <small class="text-secondary">(포스팅 시 공개되는 내용입니다.)</small>
              <span class="label-reqired">*</span>
            </label>
            @{
              string edit_assign_task = Model.assign_task;
              if (!String.IsNullOrEmpty(edit_assign_task))
              {
                edit_assign_task = edit_assign_task.Replace("&lt;", "<").Replace("&gt;", ">");
              }
            }
            @Html.TextArea("edit_assign_task", edit_assign_task, new { @class = "form-control summernote_jd", @placeholder = "담당업무를 입력해주세요. (포스팅 시 공개되는 내용입니다.)" })
            @Html.HiddenFor(x => x.assign_task)
          </div>
          <div class="form-group col-md-6">
            <label class="form-control-label" for="requirement">
              자격요건 <small class="text-secondary">(포스팅 시 공개되는 내용입니다.)</small>
              <span class="label-reqired">*</span>
            </label>
            @{
              string edit_requirement = Model.requirement;
              if (!String.IsNullOrEmpty(edit_requirement))
              {
                edit_requirement = edit_requirement.Replace("&lt;", "<").Replace("&gt;", ">");
              }
            }
            @Html.TextArea("edit_requirement", edit_requirement, new { @class = "form-control summernote_jd", @placeholder = "자격요건을 입력해주세요. (포스팅 시 공개되는 내용입니다.)" })
            @Html.HiddenFor(x => x.requirement)
          </div>
        </div>

        <div class="row">

          <div class="form-group col-md-2">
            <label class="form-control-label" for="recruit_number">
              모집인원
            </label>
            @Html.TextBoxFor(x => x.recruit_number, new { @class = "form-control form-control-sm", @type = "number", @autocomplete = "off" })
          </div>
          <div class="form-group col-md-3">
            <label class="form-control-label" for="edu_code">Education</label>
            <select class="form-control form-control-sm" id="edu_code" name="edu_code">
              <option value="0" @(Model.edu_code == 0 ? "selected" : "")>학력무관</option>
              <option value="1" @(Model.edu_code == 1 ? "selected" : "")>고등학교졸업</option>
              <option value="2" @(Model.edu_code == 2 ? "selected" : "")>대학졸업(2,3년)</option>
              <option value="3" @(Model.edu_code == 3 ? "selected" : "")>대학교졸업(4년)</option>
              <option value="4" @(Model.edu_code == 4 ? "selected" : "")>석사졸업</option>
              <option value="5" @(Model.edu_code == 5 ? "selected" : "")>박사졸업</option>
              <option value="6" @(Model.edu_code == 6 ? "selected" : "")>고등학교졸업이상</option>
              <option value="7" @(Model.edu_code == 7 ? "selected" : "")>대학졸업(2,3년)이상</option>
              <option value="8" @(Model.edu_code == 8 ? "selected" : "")>대학교졸업(4년)이상</option>
              <option value="9" @(Model.edu_code == 9 ? "selected" : "")>석사졸업이상</option>
            </select>
          </div>
          <div class="form-group col-md-3">
            <label class="form-control-label" for="foreign_lang">Language</label>
            <div class="input-group input-group-sm">
              @{
                var languageList = new SelectList(LanguageCode.LanguageCodes, "Key", "Value").ToList();
                languageList.Insert(0, new SelectListItem { Value = "00", Text = "외국어" });
              }
              @Html.DropDownListFor(x => x.foreign_lang, languageList, new { @class = "form-control form-control-sm" })

              @{
                var languageLevelList = new SelectList(LanguageLevelCode.LanguageLevelCodes, "Key", "Value").ToList();
                languageLevelList.Insert(0, new SelectListItem { Value = "0", Text = "능력" });
              }
              @Html.DropDownListFor(x => x.foreign_level, languageLevelList, new { @class = "form-control " })
            </div>
          </div>
          <div class="form-group col-md-4">
            <label class="form-control-label" for="place">Place</label><span class="label-reqired">*</span>
            <div class="input-group input-group-sm">
              <div class="form-control placeDiv" id="placeDiv" name="placeDiv">
                @if (Model.placeList.Count > 0)
                {
                  foreach (var place in Model.placeList)
                  {
                    <span class="badge badge-outline badge-primary placeRow" style="margin-right:3px;">
                      <input type="hidden" id="pp_seq" name="pp_seq" value="@place.pp_seq">
                      <input type="hidden" id="place_code1" name="place_code1" value="@place.code1">
                      <input type="hidden" id="place_area1" name="place_area1" value="@place.area1">
                      <input type="hidden" id="place_code2" name="place_code2" value="@place.code2">
                      <input type="hidden" id="place_area2" name="place_area2" value="@place.area2">
                      @if (place.code1 == place.code2)
                      {
                        @place.area2
                      }
                      else
                      {
                        @(place.area1 + " " + place.area2)
                      }
                      <i class="fas fa-times cur_hand" onclick="DeletePlace(this)"></i>
                    </span>
                  }
                }
              </div>
              <span class="input-group-btn">
                <button type="button" class="btn btn-success" onclick="FindPlace(this)"><i class="fas fa-plus" aria-hidden="true"></i></button>
              </span>
            </div>
          </div>
        </div>
        <div class="row">
          <div class="form-group col-md-3">
            <label class="form-control-label" for="is_posting">Homepage posting</label> <i class="fas fa-info-circle text-info" title="후보자 자동제안 참조 항목"></i> <span class="label-reqired">*</span>
            <div>

              <div class="radio-custom radio-default radio-inline">
                <input type="radio" id="hire" name="is_posting" value="1" @(Model.is_posting == 1 ? "checked" : "")>
                <label for="hire">Yes</label>
              </div>
              <div class="radio-custom radio-default radio-inline">
                <input type="radio" id="reputation" name="is_posting" value="0" @(Model.is_posting != 1 ? "checked" : "")>
                <label for="radio">No</label>
              </div>
            </div>
          </div>
          <div class="form-group col-md-9">
            <label class="form-control-label">Documents</label><span class="label-reqired">*</span>
            <div id="paperDiv" name="paperDiv" class="form-inline">
              <div class="checkbox-custom checkbox-custom-sm checkbox-primary">
                <input type="checkbox" id="is_kor_resume" value="1" @(Model.is_kor_resume == 1 ? "checked" : "")>
                <label for="is_kor_resume">국문이력서</label>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
              </div>
              <div class="checkbox-custom checkbox-custom-sm checkbox-primary">
                <input type="checkbox" id="is_eng_resume" value="1" @(Model.is_eng_resume == 1 ? "checked" : "")>
                <label for="is_eng_resume">영문이력서</label>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
              </div>
