    //공유 프로젝트
    function shareProject(obj, p_seq) {
      callShareBtn = obj;
      $.ajax({
        url: window.url_share_project_create,
        data: {
          p_seq: p_seq
        },
        dataType: 'html',
        type: 'GET',
        beforeSend: function () {
          $(".page").isLoading({
            text: "Loading",
            position: "overlay"
          });
        }
      })
        .done(function (json) {
          $(".page").isLoading("hide");

          $.fancybox.open({
            'content': json,
            'width': '400',
            'height': '385',
            'autoDimensions': false,
            'type': 'iframe',
            'autoSize': false,
            'title': '프로젝트 공유',
            helpers: {
              title: {
                type: 'inside',
                position: 'top'
              },
              overlay: {
                closeClick: false
              }
            }
          });
        })
        .fail(function (e) {
          $(".page").isLoading("hide");
          ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
        });
    }

    //공유 프로젝트 취소
    function cancelShareProject(obj, p_seq) {
      alertify.confirm()
        .set({
          'labels': { ok: '확인', cancel: '취소' },
          'onok': function () {

            callShareBtn = obj;

            $.ajax({
              url: window.url_share_project_cancel,
              data: {
                p_seq: p_seq
              },
              dataType: 'json',
              type: 'POST',
              beforeSend: function () {

              }
            })
              .done(function (json) {

                if (json.ok) {

                  NormalAlert(json.message);
                  $(callShareBtn).removeClass("btn-danger");
                  $(callShareBtn).addClass("btn-primary");
                  $(callShareBtn).text("Share");
                  $(callShareBtn).attr("onclick", "shareProject(this, " + p_seq + ")");

                } else {
                  ErrorAlert(json.message);
                }
              })
              .fail(function (e) {
                ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
              });
          },
          'oncancel': function () {

            return;
          },
        })
        .setHeader('<i class="fas fa-exclamation-triangle" style="color:#FFDC2E"></i>프로젝트 공유 취소')
        .setting({
          message: "해당 프로젝트의 공유를 취소하시겠습니까?",
        })
        .show();
    }

