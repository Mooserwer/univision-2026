    function BindProjectContactValidation() {

      var phoneValidator = {
        validators: {
          selector: "contact_phone",
          callback: {
            message: "전화번호 혹은 휴대폰 번호 중 한 개의 번호는 입력 하셔야 합니다.",
            callback: function (input) {

              var fv = $("#ProjectContactForm").data("formValidation");

              let isEmpty = true;

              if ($("#contact_phone").val() != "" || $("#contact_cell_phone").val() != "") {
                isEmpty = false;
              }

              if (!isEmpty) {
                // Update the status of callback validator for all fields
                fv.updateStatus('contact_phone', 'Valid', 'callback');
                fv.updateStatus('contact_cell_phone', 'Valid', 'callback');
                return true;
              }

              return false;
            }
          }
        }
      };



      $("#ProjectContactForm").formValidation({
        framework: "bootstrap4",
        button: {
          selector: "#btnNewContactSave",
          disabled: "disabled"
        },
        submitHandler: function () {
        },
        icon: null,
        fields: {
          contact_name: {
            validators: {
              notEmpty: {
                message: "이름은 필수 입력 항목 입니다."
              }
            }
          },
          contact_gender: {
            validators: {
              notEmpty: {
                message: "성별을 선택하세요."
              }
            }
          },
          contact_division: {
            validators: {
              notEmpty: {
                message: "부서명은 필수 입력 항목 입니다."
              }
            }
          },
          contact_position: {
            validators: {
              notEmpty: {
                message: "직함은 필수 입력 항목 입니다."
              }
            }
          },
          contact_email: {
            validators: {
              notEmpty: {
                message: "이메일은 필수 입력 항목 입니다."
              }
            }
          },
          contact_phone: phoneValidator,
          contact_cell_phone: phoneValidator,
        },
        err: {
          clazz: "invalid-feedback"
        },
        control: {
          valid: "is-valid",
          invalid: "is-invalid"
        },
        row: {
          invalid: "has-danger"
        }
      })
        .on('success.form.fv', function (e) {
          e.preventDefault();

          var formURL = $("#ProjectContactForm").attr("action");

          $.ajax({
            url: formURL,
            type: "POST",
            dataType: 'json',
            data: {
              c_seq: $("#c_seq").val()
              , p_seq: $("#p_seq").val()
              , name: $("#contact_name").val()
              , gender: $("input[name='contact_gender']:checked").val()
              , email: $("#contact_email").val()
              , phone: $("#contact_phone").val()
              , cell_phone: $("#contact_cell_phone").val()
              , division: $("#contact_division").val()
              , position: $("#contact_position").val()
            },
            beforeSend: function () {
              showLoading("#projectContact");
            },
            success: function (json) {
              hideLoading("#projectContact");

              if (json.ok) {
                location.reload();
              }
              else {
                ErrorAlert(json.message);
              }
            },
            error: function (jqXHR, textStatus, errorThrown) {
              hideLoading("#projectContact");

              ErrorAlert("알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요1.");
            }
          });
        });
    }

