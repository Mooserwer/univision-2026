    function ProjectSetSuggType(e, p_seq, busi, job) {
      e.preventDefault();

      $.ajax({
        url: window.url_project_set_sugg_type,
        data: {
          p_seq: p_seq,
          busi_type: busi,
          job_type: job
        },
        dataType: 'json',
        type: 'POST',
        beforeSend: function () {
          showLoading('#projectCandiSuggetion');
        }
      })
        .done(function (rst) {
          hideLoading('#projectCandiSuggetion');
          if (rst.ok) {
            var busi_tag = $('#no_business_type');
            var job_tag = $('#no_job_type');
            if (busi) {
              if (busi == 1) {
                busi_tag.removeClass().addClass("badge badge-lg badge-outline badge-primary").text("전체 산업에서 제안");
              } else if (busi == 2) {
                busi_tag.removeClass().addClass("badge badge-lg badge-outline badge-info").text("해당 산업대분류에서 제안");
              } else {
                busi_tag.removeClass().addClass("badge badge-lg badge-outline badge-dark").text("등록한 산업으로만 제안");
              }
            }

            if (job) {
              if (job == 1) {
                job_tag.removeClass().addClass("badge badge-lg badge-outline badge-primary").text("전체 직무에서 제안");
              } else if (job == 2) {
                job_tag.removeClass().addClass("badge badge-lg badge-outline badge-info").text("해당 직무대분류에서 제안");
              } else {
                job_tag.removeClass().addClass("badge badge-lg badge-outline badge-dark").text("등록한 직무로만 제안");
              }
            }
            callProjectCandiSuggetionList(rst.p_seq, 1)
          }
        })
        .always(function () {
          hideLoading('#projectCandiSuggetion');
        });
    }

