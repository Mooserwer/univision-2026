  <script type="text/javascript">
    function CreateInvoice(p_seq) {
      var win_tag = 'INVOICE_' + p_seq;
      var param = '?p_seq=' + p_seq
      var win = window.open(window.url_invoice_new_select + param, win_tag, 'width=993, height=800');
      win.focus();

    }


    if ($('#internal_label').text().trim() == '') {
      $('#internal_div').hide();
    }

    $('#switch-pjt-file-remove').change(function () {
      $('#PjtFileBody').removeClass('removal-lock')
      if (!$(this).prop('checked')) {
        $('#PjtFileBody').addClass('removal-lock')
      }
    })

    function callPjtFileList(p_seq) {
      if ($('#PjtFileBody').length == 0) {
        return;
      }
      ajxCall({
        url: window.url_project_file_list,
        data: {
          p_seq: p_seq
        },
        dataType: 'html',
        type: 'POST',
        loading: true,
        loading_target: "#PjtFileBody",
        suc: function (view) {
          $('#PjtFileBody').html(view);
        }
      });
    }

    $('#btn_progress_excel').click(function (e) {
      e.preventDefault();
      $('#excel_state').val($('#search_state_for_makeup').val());
      $('#excel_orderTxt').val($('#progress_orderTxt').val());
      $('#excel_stexcel_orderOptionate').val($('#progress_orderOption').val());

      $('#ExcelForm').submit();
    })

    function fChkContactInfo() {
      var valid_msg = ""
      if ($('#cc_seq').val() == 0 || $('#cc_seq').val() == "") {
        valid_msg += (valid_msg != "" ? "<br/>" : "") + "Contact(채용 및 인보이스 담당자) 정보가 없습니다. Contact(채용 및 인보이스 담당자)정보를 입력 후 진행하여 주시기 바랍니다."
      }
      if ($('#ctc_seq').val() == 0 || $('#ctc_seq').val() == "") {
        valid_msg += (valid_msg != "" ? "<br/>" : "") + "세금계산서 담당자 정보가 없습니다. 세금계산서 담당자 정보를 입력 후 진행하여 주시기 바랍니다."
      }

      if (valid_msg != "") {
        ErrorAlert(valid_msg);
        return false;
      }

      return true;
    }
    //슬라이드 형식 인보이스 발행화면
    $('#btnCreateRetainerInvoice1').click(function () {
      if (!fChkContactInfo()) {
        return;
      }

      $.slidePanel.show(
        {
          url: window.url_project_rt_invoice_create,
          settings: {
            data: {
              p_seq: window.model_p_seq
            },
            method: 'GET'
          }
        },
        {
          mouseDrag: false,
          touchDrag: false,
          pointerDrag: false,
        });

    });


    $('#btnCreateRetainerInvoice').click(function () {
      alert("화면 상단의 [인보이스 발행] 버튼을 통해 발행 부탁드립니다.");
      CreateInvoice(window.model_p_seq)
      return;

      if (!fChkContactInfo()) {
        return;
      }

      $.ajax({
        url: window.url_project_rt_invoice_create,
        data: {
          p_seq: window.model_p_seq
        },
        dataType: 'html',
        type: 'GET',
        beforeSend: function () {
          showLoading();
        }
      })
        .done(function (view) {
          hideLoading();

          //모달은 Invoice View 때문에 ProjectDetail.cshtml 페이지에 넣어둠.
          $("#InvoiceCreateModal .modal-body").html(view)
          $("#InvoiceCreateModal .modal-body").find('#client_contact_name').val($('#contact_name').val());
          $("#InvoiceCreateModal .modal-body").find('#client_contact_tel').val($('#contact_phone').val());
          $("#InvoiceCreateModal .modal-body").find('#client_contact_email').val($('#contact_email').val());
          $("#InvoiceCreateModal .modal-body").find('#client_etax_name').val($('#tax_deposit_manager').val());
          $("#InvoiceCreateModal .modal-body").find('#client_etax_tel').val($('#tax_phone').val());
          $("#InvoiceCreateModal .modal-body").find('#client_etax_email').val($('#tax_deposit_email').val());
          $('#InvoiceCreateModal').modal('toggle');

        })
        .fail(function (e) {
          hideLoading();
          ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
        });
    });

    $('#btnCreateRefundInvoice').click(function () {
