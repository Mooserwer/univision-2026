      var is_cowork = window.model_is_cowork;
      if (is_share == 1 || is_cowork == 1) {
        $("#sharePanel").css("display", "block");
        callBoardList($("#p_seq").val(), 1)
      }

      $(".token").find("a.close").remove();
      $(".token").find(".token-label").css("padding-right", "5px");

      //프로젝트 마감 버튼 클릭시
