@model Univision.Main.Models.Project.ProjectCreateModel
@using Univision.Security

@{
  string subTitle = "";
  if (Model.is_share_pjt == 1)
  {
    subTitle = "공유 ";
  }
  else if (Model.is_cowork == 1)
  {
    subTitle = "Co-work ";
  }

  ViewBag.Title = subTitle + "프로젝트[채용] " + Model.title;
  Layout = "~/Views/Shared/_Layout.cshtml";

  string tmp_txt = String.Empty;
}

<link rel="stylesheet" href="~/Libs/remark/global/vendor/bootstrap-tokenfield/bootstrap-tokenfield.min599c.css?v4.0.4">
<link rel="stylesheet" href="~/Libs/remark/base/assets/examples/css/pages/project.min599c.css?4.0.2" />
<link rel="stylesheet" href="~/Libs/bootstrap-toggle/css/bootstrap-toggle.min.css">
<style>
  .placeDiv span {
    font-size: 15px;
  }

  .job_list {
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    width: 250px;
    display: inline-block;
  }

  .font-weight-bold {
    font-weight: bold !important;
  }


  #PjtFileBody.removal-lock .btn-pjt-file-remove {
    display: none;
  }

  #PjtFileBody .link-pjt-file {
    width: 85%;
  }

  #PjtFileBody.removal-lock .link-pjt-file {
    width: 100% !important;
  }

  .file_rst > div:nth-child(1n+5) {
    display: none;
  }

  .file_rst > div:nth-child(1n+6).btn-more, .file_rst.more > div:nth-child(1n+4).btn-collapse {
    cursor: pointer;
    display: block;
  }

  .file_rst > div:nth-child(1n+6).btn-collapse, .file_rst.more > div:nth-child(1n+4).btn-more {
    display: none;
  }

  .file_rst.more > div.file_div {
    display: block !important;
  }

  .file_rst > div.btn-more, .file_rst > div.btn-collapse {
    display: none;
  }
</style>

<div class="page-content">
  @using (Html.BeginForm("ProjectProgressExcelList", "Project", FormMethod.Get, new { @id = "ExcelForm" }))
  {
    <input type="hidden" name="excel_p_seq" id="excel_p_seq" value="@Model.p_seq" />
    <input type="hidden" name="excel_state" id="excel_state" value="" />
    <input type="hidden" name="excel_orderTxt" id="excel_orderTxt" value="" />
    <input type="hidden" name="excel_orderOption" id="excel_orderOption" value="" />

  }
  @Html.HiddenFor(x => x.p_seq)

  <!-- 공유 프로젝트 시작-->
  <div id="sharePanel" class="panel panel-primary panel-line animation-scale-up" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms; display:none;">
    <div class="panel-heading">
      <h3 class="panel-title">
        <i class="fas fa-share"></i>
        공유 정보
      </h3>
      <div class="panel-actions">
        <a class="panel-action icon wb-minus" aria-expanded="true" data-toggle="panel-collapse" aria-hidden="true"></a>
      </div>
    </div>
    <div id="shareInfo" class="panel-body">
      <div class="row">
        <div class="col-md-12">
          <label class="form-control-label form-control-label-sm text-secondary" for="share_fee_rate">Fee Share</label>
          <p class="form-control-plaintext">
            @(Model.share_fee_rate)%
          </p>
        </div>
      </div>
      <div class="row">
        <div class="col-md-12">
          <label class="form-control-label form-control-label-sm text-secondary" for="share_comments">Comment</label>
          <p class="form-control-plaintext">

            @if (!String.IsNullOrWhiteSpace(Model.share_comments))
            {
              @Html.Raw(Model.share_comments.Replace("\r\n", "<br />").Replace("\n", "<br />").Replace("\r", "<br />"));
            }
          </p>
        </div>
      </div>

      <!--
        <div class="row">
            <div class="col-md-12">
                <label class="form-control-label form-control-label-sm text-secondary" for="secret_info">비공개정보</label>
                <p class="form-control-plaintext">
                    @Model.secret_info &nbsp;
                </p>
            </div>
        </div>
        <div id="commentList" class="card border border-primary">
        </div>
      -->
    </div>
  </div>
  <!-- 공유 프로젝트 끝-->
  @*PMS 오픈 관련 등록기능 제한*@
  @if (Univision.Security.AppIdentity.CanPmsEdit)
  {
    <div class="panel">
      <div class="panel-heading">
        <h3 class="panel-title"></h3>


        <div class="panel-actions">

          <div class="panel-action">
            @if (AppIdentity.ua_seq <= 3 || Model.amList.Where(x => x.uv_seq == AppIdentity.user_seq).FirstOrDefault() != null || Model.searcherList.Where(x => x.uv_seq == AppIdentity.user_seq).FirstOrDefault() != null)
            {
              if (Model.amList.Where(x => x.uv_seq == AppIdentity.user_seq).FirstOrDefault() != null || Model.searcherList.Where(x => x.uv_seq == AppIdentity.user_seq).FirstOrDefault() != null)
              {
                if (Model.is_my_key == 1)
                {
                  <button type="button" class="btn btn-sm btn-warning btn-outline" id="btnSetKeyPjt" onclick="cancelMyKeyProject(@Model.p_seq)" title="Remove from key project">
                    <i class="fa fa-key"></i>
                    Key 프로젝트 해제
                  </button>
                }
                else
                {
                  <button type="button" class="btn btn-sm btn-success btn-outline" id="btnSetKeyPjt" onclick="SetMyKeyProject(@Model.p_seq)" title="Set as key project">
                    <i class="fa fa-key"></i>
                    Key 프로젝트로 설정
                  </button>

                }
              }
              if (Model.pjt_status == 1)
              {

                <span class="pr-20">
                  @if (Model.is_share_3m == 1)
                  {
                    <button type="button" class="btn btn-sm btn-danger" onclick="cancelShareProject(this, @Model.p_seq)" title="공유 취소/마감">Cancel Share</button>

                  }
                  else
                  {
                    <button type="button" class="btn btn-sm btn-primary" onclick="shareProject(this, @Model.p_seq)" title="프로젝트 공유하기">Share</button>
                  }
                  @if (Model.is_cowork == 1)
                  {
                    <button type="button" class="btn btn-sm btn-warning" onclick="cancelCoWorkProject(this, @Model.p_seq)" title="Co-work 취소/마감">Cancel Cowork</button>
                  }
                  else
                  {
                    <button type="button" class="btn btn-sm btn-info" onclick="CoWorkAlram(@Model.p_seq)" title="Co-work 요청">Cowork</button>

                  }
                </span>
                <button type="button" class="btn btn-sm btn-primary" id="btnPjtState">프로젝트 상태변경</button>
                <a href="@Url.Action("ProjectCreate", "Project", new { @p_seq = Model.p_seq, @c_seq = Model.c_seq, @type = "pjtCopy" })" class="btn btn-sm btn-info" title="이 프로젝트 복사">
                  Copy
                </a>

              }
              else
              {
                @*PMS 오픈 관련 등록기능 제한*@
                if (Univision.Security.AppIdentity.CanPmsEdit)
                {
                  <button type="button" class="btn btn-sm btn-warning" id="btnPjtState">프로젝트 상태변경</button>
                  <a href="@Url.Action("ProjectCreate", "Project", new { @p_seq = Model.p_seq, @c_seq = Model.c_seq, @type = "pjtCopy" })" class="btn btn-sm btn-info" title="이 프로젝트 복사">
                    Copy
                  </a>
                }
              }
              <button type="button" class="btn btn-sm btn-success border-primary" id="btnCreateInvoice" onclick="CreateInvoice(@Model.p_seq)" title="인보이스 발행(채용, 선수금, 취소 등)">
                <i class="fa fa-file-invoice"></i>
                인보이스 발행 (Invoice)
              </button>
            }
            @if (AppIdentity.ua_seq <= 3 || Model.amList.Where(x => x.uv_seq == AppIdentity.user_seq).FirstOrDefault() != null || Model.searcherList.Where(x => x.uv_seq == AppIdentity.user_seq).FirstOrDefault() != null)
            {
              if (AppIdentity.ua_seq <= 3 || Model.pjt_status == 1 || Model.pjt_status == 4)
              {

                <a href="@Url.Action("ProjectCreate", "Project", new { @p_seq = Model.p_seq })" id="btnModify" class="btn btn-sm btn-secondary" title="프로젝트 정보 수정">수정 (Modify)</a>

              }
            }
            @if (Model.log_cnt > 0)
            {
              <a href="@Url.Action("ProjectLog", "Log", new { p_seq = Model.p_seq })" id="btnHisotry" class="btn btn-sm btn-default">Log</a>
            }
          </div>
        </div>
      </div>
    </div>
  }
  <div class="panel panel-primary panel-line animation-scale-up" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms;">
    <div class="panel-heading">
      <h3 class="panel-title">
        <i class="fas fa-newspaper"></i>
        Project Information [Recruitment]
        @{
          string classNm = "";
          string txt = "";

          switch (Model.pjt_status)
          {
            case 1:
              classNm = "badge-primary";
              txt = "진행";
              break;
            case 2:
              classNm = "badge-warning";
              txt = "보류";
              break;
            case 3:
              classNm = "badge-danger";
              txt = "종료";
              break;
            case 4:
              classNm = "badge-info";
              txt = "완료";
              break;
            case 5:
              classNm = "badge-success";
              txt = "성공";
              break;

          }
        }
        <span class="badge @classNm">@txt</span>
        <span style="font-size:12px; color:black">@Model.status_comment</span>
      </h3>
      <div class="panel-actions">

        <a class="panel-action icon wb-minus" aria-expanded="true" data-toggle="panel-collapse" aria-hidden="true"></a>
      </div>
    </div>
    <div id="projectInfo" class="panel-body">
      <div class="row">
        <div class="form-group col-md-4 col-6">
          <label class="form-control-label form-control-label-sm text-secondary" for="company_name">
            Client
            <a href="@Url.Action("ClientDetail", "Client", new { c_seq = Model.c_seq })" target="_blank" title="고객사 상세정보 열기">
              <i class="fas fa-external-link-alt"></i>
            </a>
          </label>
          @Html.HiddenFor(x => x.c_seq)
          <div class="input-group input-group-sm">
            <lable class="form-control-plaintext">
              @Model.company_name
            </lable>
          </div>
        </div>
        <div class="form-group col-md-8 col-12">
          <label class="form-control-label form-control-label-sm text-secondary" for="title">
            Title
          </label>
          <div class="input-group input-group-sm">
            <lable class="form-control-plaintext">
              @if (Model.is_pe == 1)
              {
                <span class="badge badge-info" title="PE Portfolio">PE</span>
              }
              @Model.title
            </lable>
          </div>
        </div>
      </div>

      <div class="row">
        <div class="form-group col-md-6 tbw50">
          <label class="form-control-label form-control-label-sm text-secondary" for="AMDiv">
            AM
          </label>
          @{
            tmp_txt = "";
            if (Model.amList.Count > 0)
            {
              foreach (var am in Model.amList)
              {
                tmp_txt += !String.IsNullOrEmpty(tmp_txt) ? "," + @am.name : "" + @am.name;

              }
            }
          }

          <div class="input-group input-group-sm">
            <lable class="form-control-plaintext">
              @tmp_txt
            </lable>
          </div>
        </div>

        <div class="form-group col-md-6 tbw50">
          <label class="form-control-label form-control-label-sm text-secondary" for="Searcher">
            SM

          </label>
          @{
            tmp_txt = "";
            if (Model.searcherList.Count > 0)
            {
              foreach (var searcher in Model.searcherList)
              {
                if (!String.IsNullOrEmpty(tmp_txt))
                {
                  tmp_txt += ",";
                }

                tmp_txt += searcher.name;
              }
            }

          }
          <div class="input-group input-group-sm">
            <lable class="form-control-plaintext">
              @tmp_txt
            </lable>
          </div>
        </div>
      </div>

      <div class="row">
        <div class="form-group col-6 tbw50">
          <label class="form-control-label form-control-label-sm text-secondary" for="businessCodeDiv">
            Industry  <i class="fas fa-info-circle text-info" title="후보자 자동제안 참조 항목"></i>
          </label>
          <div class="input-group input-group-sm" id="businessCodeDiv">
            <lable class="form-control-plaintext longLen">
              - @Model.business_name1 > @Model.business_name2 &nbsp;
            </lable>
          </div>
          @if (!String.IsNullOrEmpty(Model.sub_business_name2))
          {
            <div class="input-group input-group-sm pt-0" id="businessCodeDiv">
              <lable class="form-control-plaintext pt-0 longLen">
                - @Model.sub_business_name1 > @Model.sub_business_name2 &nbsp;
              </lable>
            </div>
          }
        </div>
        <div class="form-group col-6 tbw50">
          <label class="form-control-label form-control-label-sm text-secondary" for="jobCodeDiv">
            Job function  <i class="fas fa-info-circle text-info" title="후보자 자동제안 참조 항목"></i>

          </label>
          <div class="input-group input-group-sm pt-0" id="jobCodeDiv">
            <lable class="form-control-plaintext longLen">
              - @Model.job_name1 > @Model.job_name2 &nbsp;
            </lable>
          </div>
          @if (!String.IsNullOrEmpty(Model.sub_job_name2))
          {
            <div class="input-group input-group-sm pt-0" id="jobCodeDiv">
              <lable class="form-control-plaintext pt-0 longLen">
                - @Model.sub_job_name1 > @Model.sub_job_name2 &nbsp;
              </lable>
            </div>
          }
        </div>
      </div>

      <div class="row">
        <div class="form-group col-md-4 tbw50">
          <label class="form-control-label form-control-label-sm text-secondary" for="exp_salary">
            Salary
            @if (Model.currency_cd != "KRW" && Model.exp_salary_won.HasValue)
            {
              <span class="text-primary font-weight-900" id="exp_won_label">(원화 환산 예상액 : 약 @Utils.ConvertMoneyToString(Model.exp_salary_won)원)</span>
            }
          </label>
          <div class="input-group input-group-sm">
            <lable class="form-control-plaintext text-right">
              @Utils.ConvertMoneyToString(Model.exp_salary)
              @*Utils.ReturnCurrencyTxt(Model.currency_cd)*@
              [@Model.currency_cd]
              @Html.HiddenFor(x => x.exp_salary)
              <input type="hidden" id="pjt_currency_cd" value="@Model.currency_cd" />
            </lable>
          </div>
        </div>
        <div class="form-group col-md-2 tbw50">

          <label class="form-control-label form-control-label-sm text-secondary" for="fee_rate">Fee rate </label>
          <div class="input-group input-group-sm">
            <lable class="form-control-plaintext text-right">
              @String.Format("{0:0.#}", Model.fee_rate) %
            </lable>
            @*<span class="input-group-addon">%</span>*@
          </div>
        </div>
        <div class="form-group col-md-2 tbw50">
          <label class="form-control-label form-control-label-sm text-secondary" for="position_seq">
            Position
          </label>
          <div class="input-group input-group-sm">
            <label class="form-control-plaintext">
              @Utils.ReturnPositionCodeTxt(Model.position_seq)
            </label>
          </div>
        </div>
        <div class="form-group col-md-2 tbw50">
          <label class="form-control-label form-control-label-sm text-secondary" for="fee_rate">포지션명 </label>
          <div class="input-group input-group-sm">
            <label class="form-control-plaintext">
              @Model.position_str &nbsp;
            </label>
          </div>
        </div>
        <div class="form-group col-md-2">
          <label class="form-control-label form-control-label-sm text-secondary" for="expreience_number">
            Experience(Year)
          </label>
          <div class="input-group input-group-sm">
            <div class="input-group input-group-sm">
              @{
                string experience_type = "";
                switch (Model.experience_type)
                {
                  case 1:
                    experience_type = "년 이상";
                    break;
                  case 2:
                    experience_type = "년 이하";
                    break;
                  default:
                    experience_type = "";
                    break;
                }
              }
              <label class="form-control-plaintext">
                @Model.expreience_number @experience_type
              </label>
            </div>
          </div>
        </div>
      </div>
      <div class="row">
        <div class="form-group col-12 pb-10" id="internal_div">
          <label class="form-control-label form-control-label-sm text-secondary" for="requirement">
            내부 참고자료 <small class="text-info">(포스팅 시 공개되지 않는 내용입니다.)</small>
          </label>
          <div>
            <label class="form-control border-info" style="min-height:100px; height:auto" id="internal_label">
              @if (!String.IsNullOrEmpty(Model.internal_contents))
              {
                /*@Html.Raw(Model.requirement.Replace("\r\n", "<br />").Replace("\n", "<br />").Replace("\r", "<br />"))*/
                @Html.Raw(Model.internal_contents.Replace("&lt;", "<").Replace("&gt;", ">").Replace(System.Environment.NewLine, " <br />"))
              }
            </label>
          </div>

        </div>
        <div class="form-group col-md-6">
          <label class="form-control-label form-control-label-sm text-secondary" for="assign_task">
            담당업무 <small class="text-secondary">(포스팅 시 공개되는 내용입니다.)</small>
          </label>
          <div>
            <label class="form-control" style="min-height:100px; height:auto">
              @if (!String.IsNullOrEmpty(Model.assign_task))
              {
                /*@Html.Raw(Model.assign_task.Replace("\r\n", "<br />").Replace("\n", "<br />").Replace("\r", "<br />"))*/
                @Html.Raw(Model.assign_task.Replace("&lt;", "<").Replace("&gt;", ">").Replace(System.Environment.NewLine, " <br />"))
              }
              &nbsp;
            </label>
          </div>

        </div>
        <div class="form-group col-md-6">
          <label class="form-control-label form-control-label-sm text-secondary" for="requirement">
            자격요건 <small class="text-secondary">(포스팅 시 공개되는 내용입니다.)</small>
          </label>
          <div>
            <label class="form-control" style="min-height:100px; height:auto">
              @if (!String.IsNullOrEmpty(Model.requirement))
              {
                /*@Html.Raw(Model.requirement.Replace("\r\n", "<br />").Replace("\n", "<br />").Replace("\r", "<br />"))*/
                @Html.Raw(Model.requirement.Replace("&lt;", "<").Replace("&gt;", ">").Replace(System.Environment.NewLine, " <br />"))
              }
              &nbsp;
            </label>
          </div>

        </div>

        <div class="form-group col-12 pt-10">
          <h5 class="form-control-label form-control-label-sm text-secondary" title="파일 - JD 또는 참고서류 업로드.">
            <i class="fa fa-folder-open fa-fw"></i>
            파일 - JD 또는 참고서류 업로드.
            @if (AppIdentity.ua_seq <= 3 || Model.amList.Where(x => x.uv_seq == AppIdentity.user_seq).FirstOrDefault() != null || Model.searcherList.Where(x => x.uv_seq == AppIdentity.user_seq).FirstOrDefault() != null)
            {
              <label class="float-right checkbox-inline" title="삭제 할 파일이 있을 경우 잠금을 해제해 주세요">
                <input type="checkbox" id="switch-pjt-file-remove" data-size="mini" data-toggle="toggle" data-off="<i class='fa fa-lock'></i> Remove Lock" data-on="<i class='fa fa-unlock'></i> Remove Unlock">
              </label>
            }
          </h5>
          <div id="PjtFileBody" class="removal-lock">
          </div>
        </div>
      </div>
      <div class="row">

        <div class="form-group col-md-2 tbw50">
          <label class="form-control-label form-control-label-sm text-secondary" for="recruit_number">
            모집인원
          </label>
          <div class="input-group input-group-sm">
            <label class="form-control-plaintext">
              @Model.recruit_number &nbsp;
            </label>
          </div>
        </div>
        <div class="form-group col-md-3 tbw50">
          <label class="form-control-label form-control-label-sm text-secondary" for="edu_code">Education</label>
          <div class="input-group input-group-sm">
            <label class="form-control-plaintext">
              @Utils.ReturnEducationTxt(Model.edu_code) &nbsp;
            </label>
          </div>
        </div>
        <div class="form-group col-md-3 tbw50">
          <label class="form-control-label form-control-label-sm text-secondary" for="foreign_lang">Language</label>
          <div class="input-group input-group-sm">
            <label class="form-control-plaintext">
              @Utils.ReturnLanguageCodeTxt(Model.foreign_lang)
              @if (!string.IsNullOrWhiteSpace(Model.foreign_lang))
              {
                <text>[@Utils.ReturnLanguageLevelCodeTxt(Model.foreign_level)]</text>
              } &nbsp;
            </label>
          </div>
        </div>
        <div class="form-group col-md-4 tbw50">
          <label class="form-control-label form-control-label-sm text-secondary" for="place">
            Place
          </label>
          @{
            tmp_txt = "";
            if (Model.placeList.Count > 0)
            {
              foreach (var place in Model.placeList)
              {


                if (place.code1 == place.code2)
                {
                  if (!String.IsNullOrEmpty(tmp_txt))
                  {
                    tmp_txt += ", ";
                  }

                  tmp_txt += "[" + place.area2 + "]";

                  //tmp_txt += !String.IsNullOrEmpty(tmp_txt) ? "," : "" + "[" + place.area2 + "]";
                }
                else
                {
                  if (!String.IsNullOrEmpty(tmp_txt))
                  {
                    tmp_txt += ", ";
                  }

                  tmp_txt += "[" + (place.area1 + " " + place.area2) + "]";

                  //tmp_txt += !String.IsNullOrEmpty(tmp_txt) ? "," : "" + "[" + (place.area1 + " " + place.area2) + "]";
                }
              }
            }

          }
          <div class="input-group input-group-sm">
            <label class="form-control-plaintext">
              @tmp_txt &nbsp;
            </label>
          </div>
        </div>
      </div>
      <div class="row">
        <div class="form-group col-md-3">
          <label class="form-control-label  form-control-label-sm text-secondary" for="is_posting">Web posting</label>
          @if (Model.is_posting == 1 && Model.pjt_status == 1)
          {
