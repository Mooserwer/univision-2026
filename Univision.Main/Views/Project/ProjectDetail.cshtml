        ErrorAlert("메이크업할 후보자를 체크 후 진행하여 주십시오.");
        return;
      }

      param = 'p_seq=' + $('#p_seq').val()

      $('.chk_request_makeup:checked').each(function (p, a) {
        param += '&pic_seq=' + a.value;
      });
      url = window.url_makeup_gpt_new + '?' + param;

      var newWindow = window.open(url, '_blank', 'width=1105,height=600,scrollbars=yes,resizable=yes');
      if (newWindow) {
        // 팝업이 차단되지 않은 경우



        newWindow.focus();
      } else {
        // 팝업이 차단된 경우
        ErrorAlert('팝업이 차단되었습니다. 팝업 차단을 해제해주세요.');
        return;
      }
    });

    $("#btn_requestmakeup").click(function (e) {
      e.preventDefault();
      if ($('.chk_request_makeup:checked').length <= 0) {
        ErrorAlert("메이크업 요청할 후보자를 체크 후 진행하여 주십시오.");
        return;
      }

      //Modal 템플릿이 있고, 모달창이 열려있으면 넘어감
      if ($('#modal_request_makeup').length > 0) {
        $('#modal_request_makeup').parent().remove();
      }

      $('body').append($('<div>').load('/Modal/RequestMakeUpModal.html?v4.0.6', function () {

        $('#modal_request_makeup').modal('show');


      }));
    });

    function privacyReload() {
      callProjectProgress(window.model_p_seq, 0, 1)
    }
    callProjectProgress(window.model_p_seq, 0, 1)

    if (window.model_pjt_status == "1") {
      callProjectCandiSuggetionList(window.model_p_seq)
    }

    //callProjectSimpleCandidateList(window.model_p_seq, 1)
    callProjectInvoiceList(window.model_p_seq, 1)
    callMemoList(window.model_p_seq, 1)
    callPjtFileList(window.model_p_seq);

