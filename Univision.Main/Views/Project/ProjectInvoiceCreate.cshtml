@model Univision.Main.Models.Project.ProjectInvoiceCreateModel
@using Univision.Security
<style>
</style>

@using (Html.BeginForm("ProjectInvoiceCreate", "Project", FormMethod.Post, new { @id = "InvoiceCreateForm" }))
{
  @Html.HiddenFor(x => x.pii_seq)
  @Html.HiddenFor(x => x.client_seq)
  <div class="panel" style="margin-bottom:10px !important;">
    <div class="panel-heading">
      <h3 class="panel-title py-10">
        <i class="fas fa-newspaper"></i>
        Candidate &amp; Billing
      </h3>
      <div class="panel-actions">
        <a class="panel-action icon wb-minus" aria-expanded="true" data-toggle="panel-collapse" aria-hidden="true"></a>
      </div>
    </div>
    <div class="panel-body" style="padding: 5px 10px 5px 10px;">
      <div class="row no-side-space form-group mb-5">
        <div class="col-md-4">
          <label class="form-control-label" for="candidate_name" title="후보자명">Candidate Name</label> <i class="fa fa-info-circle" title="영문인보이스 발행 시 후보자 영문명 필수 입니다."></i>
          @Html.TextBoxFor(x => x.candidate_name, new { @class = "form-control form-control-sm", @autocomplete = "off", @readonly = "readonly" })
        </div>
        <div class=" col-md-3">
          <label class="form-control-label" for="join_dt">입사일자</label>
          @Html.TextBox("join_dt", Utils.ConvertDateTimeToString(Model.join_dt), new { @class = "form-control form-control-sm", @autocomplete = "off", @readonly = "readonly" })
        </div>
        <div class="col-md-5">
          <label class="form-control-label" for="expire_guarantee">보증종료일</label>
          <div class="input-group input-group-sm">
            @Html.TextBox("expire_guarantee", Utils.ConvertDateTimeToString(Model.expire_guarantee), new { @class = "form-control jDatePicker", @autocomplete = "off" })
            <span class="input-group-addon">
              <i class="fas fa-calendar-alt" aria-hidden="true"></i>
            </span>
            <span class="input-group-btn">
              <button type="button" class="btn btn-outline-secondary" title="입사일로 부터 90일 지정" onclick="javascript: fSetDate(90);">
                90일
              </button>
              <button type="button" class="btn btn-outline-secondary" title="입사일로 부터 180일 지정" onclick="javascript: fSetDate(180);">
                180일
              </button>
            </span>
          </div>
        </div>
      </div>
      <div class="row no-side-space form-group mb-5">
        <div class="col-md-4">
          <label class="form-control-label" for="billing_dt">빌링요청일자</label><span class="label-reqired">*</span>
          <div class="input-group input-group-sm">
            @Html.TextBox("billing_dt", Utils.ConvertDateTimeToString(Model.billing_dt.HasValue ? Model.billing_dt : Model.join_dt), new { @class = "form-control jDatePicker", @autocomplete = "off" })
            <span class="input-group-addon">
              <i class="fas fa-calendar-alt" aria-hidden="true"></i>
            </span>
          </div>
        </div>
        <div class=" col-md-4">
          <label class="form-control-label" for="ann_income">연봉</label><span class="label-reqired">*</span>
          <div class="input-group input-group-sm">
            @Html.TextBox("ann_income", Utils.ConvertMoneyToString(Model.ann_income), new { @class = "form-control text-right", @autocomplete = "off" })
            <span class="input-group-addon">
              @Html.HiddenFor(x => x.income_currency_cd)
              @Model.income_currency_cd
            </span>
          </div>
        </div>
        <div class="col-md-2 feeDiv">
          <label class="form-control-label" for="fee_rate_inv">수수료율</label><span class="label-reqired">*</span>
          <div class="input-group input-group-sm">
            <div class="input-group input-group-sm">
              @Html.TextBoxFor(x => x.fee_rate, new { @id = "fee_rate_inv", @class = "form-control form-control-sm text-right", @autocomplete = "off" })
              <span class="input-group-addon">
                %
              </span>
            </div>
          </div>
        </div>
        <div class="col-md-2 feeChkDiv">
          <label class="form-control-label" for="billing_type">&nbsp;</label>
          <span class="input-group">
            <div class="checkbox-custom checkbox-primary">
              <input type="checkbox" id="billing_type" name="billing_type" value="1" class="billing_type_change" />
              <label for="billing_type">정액</label>
            </div>
          </span>

        </div>
      </div>
      <div class="row no-side-space form-group mb-5 bill_exch">
        <div class="col-md-5">
          <label class="form-control-label" for="billing_money">빌링액</label><span class="label-reqired">*</span>
          <div class="input-group input-group-sm">
            @{
              double billing_money = (double)Model.ann_income * ((double)(Model.fee_rate == null ? 0 : Model.fee_rate) * 0.01);

            }
            @Html.TextBox("billing_money", Utils.ConvertMoneyToString(Math.Round(billing_money)), new { @class = "form-control text-right w-75 fee_change", @autocomplete = "off", @readonly = "readonly" })
            <select name="bill_currency_cd" id="bill_currency_cd" class="form-control form-control-sm w-25 fee_change">
              <option value="">[금액단위 선택]</option>
              <option value="KRW" @(Model.bill_currency_cd == "KRW" ? "selected" : "")>KRW(원)</option>
              <option value="USD" @(Model.bill_currency_cd == "USD" ? "selected" : "")>USD(달러)</option>
              <option value="HKD" @(Model.bill_currency_cd == "HKD" ? "selected" : "")>HKD(홍콩달러)</option>
              <option value="JPY" @(Model.bill_currency_cd == "JPY" ? "selected" : "")>JPY(엔화)</option>
              <option value="SGD" @(Model.bill_currency_cd == "SGD" ? "selected" : "")>SGD(싱가폴 달러)</option>
              <option value="GBP" @(Model.bill_currency_cd == "GBP" ? "selected" : "")>GBP(파운드)</option>
              <option value="DEM" @(Model.bill_currency_cd == "DEM" ? "selected" : "")>DEM(마르크)</option>
              <option value="FRF" @(Model.bill_currency_cd == "FRF" ? "selected" : "")>FRF(프랑스 프랑)</option>
              <option value="CHF" @(Model.bill_currency_cd == "CHF" ? "selected" : "")>CHF(스위스 프랑)</option>
              <option value="EUR" @(Model.bill_currency_cd == "EUR" ? "selected" : "")>EUR(유로)</option>
              <option value="CNY" @(Model.bill_currency_cd == "CNY" ? "selected" : "")>CNY(위안)</option>
              <option value="AUD" @(Model.bill_currency_cd == "AUD" ? "selected" : "")>AUD(호주달러)</option>
              <option value="NZD" @(Model.bill_currency_cd == "NZD" ? "selected" : "")>NZD(뉴질랜드달러)</option>
              <option value="CAD" @(Model.bill_currency_cd == "CAD" ? "selected" : "")>CAD(캐나다달러)</option>
              <option value="THB" @(Model.bill_currency_cd == "THB" ? "selected" : "")>THB(태국 밧)</option>
              <option value="TWD" @(Model.bill_currency_cd == "TWD" ? "selected" : "")>TWD(신타이완달러)</option>
              <option value="VND" @(Model.bill_currency_cd == "VND" ? "selected" : "")>VND(베트남 동)</option>
            </select>
          </div>
        </div>
        <div class="col-md-2">
          <label class="form-control-label" for="vat_type">VAT 포함</label>
          <div class="input-group input-group-sm">
            <select name="vat_type" id="vat_type" class="form-control form-control-sm fee_change">
              <option value="1" @(Model.vat_type == 1 ? "selected" : "")>VAT별도</option>
              <option value="3" @(Model.vat_type == 3 ? "selected" : "")>면세</option>
              <option value="0" @(Model.vat_type == 0 ? "selected" : "")>VAT포함</option>
              <option value="2" @(Model.vat_type == 2 ? "selected" : "")>영세율(0%)</option>
            </select>
          </div>
        </div>
        <div class="col-md-5">
          <label class="form-control-label" for="billing_money_">원화 환산 예상액</label>
          <div class="input-group input-group-sm">
            @Html.TextBox("billing_won", Utils.ConvertMoneyToString(Model.billing_won), new { @class = "form-control text-right", @placeholder = "기능 준비 중 입니다.", @autocomplete = "off", @readonly = "readonly" })
            <span class="input-group-addon">
              WON
            </span>
          </div>

        </div>
      </div>
      <div class="row no-side-space form-group mb-5">
        <div class="col-md-4">
          <div class="input-group input-group-sm">
            <span class="input-group-addon">
              총금액
            </span>
            @Html.TextBoxFor(x => x.billing_total, new { @class = "form-control text-right", @readonly = "true" })
          </div>
        </div>
        <div class="col-md-4">
          <div class="input-group input-group-sm">
            <span class="input-group-addon">
              공급가
            </span>
            @Html.TextBoxFor(x => x.billing_amt, new { @class = "form-control text-right", @readonly = "true" })
          </div>
        </div>
        <div class="col-md-4">
          <div class="input-group input-group-sm">
            <span class="input-group-addon">
              VAT
            </span>
            @Html.TextBoxFor(x => x.billing_vat, new { @class = "form-control text-right", @readonly = "true" })
          </div>
        </div>
        <div class="col-md-4">
          <div class="input-group input-group-sm">
            <span class="input-group-addon">
              선수금
            </span>
            @Html.TextBox("retainer_amt", Utils.ConvertMoneyToString(Model.retainer_amt), new { @class = "form-control text-right w-75 fee_change", @autocomplete = "off", @readonly = "readonly" })
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 매출배분 시작 -->
  <div class="panel" style="margin-bottom:10px !important;">
    <div class="panel-heading">
      <h3 class="panel-title" style="padding: 10px 30px 5px 30px">
        <i class="fas fa-won-sign"></i>
        Fee sharing
        <input type="hidden" id="inv_total_share_per" value="0" />
        <small id="total_share_per">
          (0%)
        </small>
      </h3>
      <div class="panel-actions">
        <a class="panel-action icon wb-minus" aria-expanded="true" data-toggle="panel-collapse" aria-hidden="true"></a>
      </div>
    </div>
    <div class="panel-body" id="salesList" name="salesList" style="padding: 5px 10px 5px 10px;">

      @if (Model.chargeList.Count > 0)
      {
        foreach (var data in Model.chargeList)
        {
          <div class="chargeRow pb-5">
            <div class="row form-inline no-side-space col-md-12 sts20">
              <div class="col-md-2 tbw20 text-center">
                @Html.HiddenFor(x => data.uv_seq)
                @Html.HiddenFor(x => data.ud_seq)
                @Html.HiddenFor(x => data.name)
                @data.name
              </div>
              <div class="col-md-2 tbw40">
                <div class="input-group input-group-sm">
                  @Html.TextBox("charge_fee_rate", data.sales_rate, new { @class = "form-control text-right fee_change", @type = "number", @autocomplete = "off", @max = 100, @min = 0, @step = "0.01", @onchange = "changeChargeFee(this)" })
                  <span class="input-group-addon">
                    %
                  </span>
                </div>
              </div>
              <div class="col-md-3 tbw40">
                <div class="input-group input-group-sm">
                  @Html.TextBox("charge_amt", data.sales_money, new { @class = "form-control text-right", @readonly = "@readonly", @autocomplete = "off" })
                </div>
              </div>
              <div class="col-md-4 tbw90 sts20">
                @Html.TextBox("charge_comments", data.comments, new { @class = "form-control form-control-sm tbw100", @placeholder = "Comment" })
              </div>
              <div class="col-md-1 tbw10 sts20 text-right">
                <button type="button" class="btn btn-xs btn-danger share_remove" title="Remove"><i class="fas fa-times"></i></button>
              </div>
            </div>
          </div>

        }
      }

    </div>
    <div class="panel-footer text-center">
      <button type="button" class="btn btn-xs btn-outline btn-success" id="btnAddCharge">
        <i class="fas fa-plus"></i>
        Add Consultant
      </button>
    </div>
  </div>
  <!-- 매출배분 끝 -->

  <!-- 수신정보 시작 -->
  <div class="panel" style="margin-bottom:10px !important;">
    <div class="panel-heading">
      <h3 class="panel-title" style="padding: 10px 30px 5px 30px">
        <i class="fas fa-envelope-open-text"></i>
        Client &amp; Invoice
      </h3>
      <div class="panel-actions">
        <a class="panel-action icon wb-minus" aria-expanded="true" data-toggle="panel-collapse" aria-hidden="true"></a>
      </div>
    </div>
    <div class="panel-body" style="padding: 5px 10px 5px 10px;">
      <div class="row no-side-space form-group mb-5">
        <div class=" col-md-4">
          <label class="form-control-label" for="client_name">고객사명</label><span class="label-reqired">*</span>
          @Html.TextBoxFor(x => x.client_name, new { @class = "form-control form-control-sm", @autocomplete = "off", @readonly = "readonly" })
        </div>
        <div class="col-md-4">
          <label class="form-control-label" for="ceo">대표자명</label>
          @Html.TextBoxFor(x => x.ceo, new { @class = "form-control form-control-sm", @autocomplete = "off", @readonly = "readonly" })
        </div>
        <div class="col-md-4">
          <label class="form-control-label" for="biz_code">사업자번호</label>
          @Html.TextBoxFor(x => x.biz_code, new { @class = "form-control form-control-sm", @autocomplete = "off", @readonly = "readonly" })
        </div>
      </div>

      <div class="row no-side-space form-group mb-5">
        <div class="col-md-12">
          <label class="form-control-label" for="addr">주소</label>
          @Html.TextBoxFor(x => x.addr, new { @class = "form-control form-control-sm", @autocomplete = "off", @readonly = "readonly" })
        </div>
      </div>
      <div class="row no-side-space form-group mb-5">
        <div class=" col-md-4">
          <label class="form-control-label" for="client_contact_name">Contact(인보이스 담당자)</label><span class="label-reqired">*</span>
          @Html.TextBox("client_contact_name", Model.client_contact_name, new { @class = "form-control form-control-sm", @autocomplete = "off", @readonly = "readonly" })
        </div>
        <div class="col-md-4">
          <label class="form-control-label" for="client_contact_tel">Contact Tel.</label>
          @Html.TextBox("client_contact_tel", Model.client_contact_tel, new { @class = "form-control form-control-sm", @autocomplete = "off", @readonly = "readonly" })

        </div>
        <div class="col-md-4">
          <label class="form-control-label" for="client_contact_email">Contact Email</label>
          @Html.TextBox("client_contact_email", Model.client_contact_email, new { @class = "form-control form-control-sm", @autocomplete = "off", @readonly = "readonly" })

        </div>
      </div>
      <div class="row no-side-space form-group mb-5">
        <div class=" col-md-4">
          <label class="form-control-label" for="client_etax_name">Tax Name</label><span class="label-reqired">*</span>
          @Html.TextBox("client_etax_name", Model.client_etax_name, new { @class = "form-control form-control-sm", @autocomplete = "off", @readonly = "readonly" })
        </div>
        <div class="col-md-4">
          <label class="form-control-label" for="client_etax_tel">Tax Tel.</label>
          @Html.TextBox("client_etax_tel", Model.client_etax_tel, new { @class = "form-control form-control-sm", @autocomplete = "off", @readonly = "readonly" })

        </div>
        <div class="col-md-4">
          <label class="form-control-label" for="client_etax_email">Tax Email</label>
          @Html.TextBox("client_etax_email", Model.client_etax_email, new { @class = "form-control form-control-sm", @autocomplete = "off", @readonly = "readonly" })
        </div>
      </div>

      <div class="row no-side-space form-group mb-5">
        <div class="col-md-4">
          <label class="form-control-label" for="is_open_name">후보자명 표시</label>
          <div>
            <div class="radio-custom radio-custom-sm radio-default radio-inline">
              <input type="radio" id="is_open_nameY" name="is_open_name" value="1" checked @(Model.is_open_name == 1 ? "checked" : "")>
              <label for="is_open_nameY">Yes</label>
            </div>
            <div class="radio-custom radio-custom-sm radio-default radio-inline">
              <input type="radio" id="is_open_nameN" name="is_open_name" value="0" @(Model.is_open_name == 0 ? "checked" : "")>
              <label for="is_open_nameN">No</label>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <label class="form-control-label" for="invoice_lang">인보이스 언어</label>
          <div>
            <div class="radio-custom radio-custom-sm radio-default radio-inline">
              <input type="radio" id="korInvoice" name="invoice_lang" value="0" checked @(Model.invoice_lang == 0 ? "checked" : "")>
              <label for="korInvoice" title="Korean">국문</label>
            </div>
            <div class="radio-custom radio-custom-sm  radio-default radio-inline">
              <input type="radio" id="engInvoice" name="invoice_lang" value="1" @(Model.invoice_lang == 1 ? "checked" : "")>
              <label for="engInvoice" title="English">영문</label>
            </div>
            <!--
            <div class="radio-custom radio-custom-sm  radio-default radio-inline">
                <input type="radio" id="expInvoice" name="invoice_lang" value="3" @(Model.invoice_lang == 2 ? "checked" : "")>
                <label for="expInvoice" title="Overseas">수출</label>
            </div>
                -->
          </div>
        </div>
        <div class="col-md-4">
          <label class="form-control-label" for="is_open_annual_income">후보자 연봉,Fee rate 표시</label>
          <div>
            <div class="radio-custom radio-custom-sm radio-default radio-inline">
              <input type="radio" id="is_open_annual_incomeY" name="is_open_annual_income" value="1" checked @(Model.is_open_annual_income == 1 ? "checked" : "")>
              <label for="is_open_annual_incomeY">Yes</label>
            </div>
            <div class="radio-custom radio-custom-sm radio-default radio-inline">
              <input type="radio" id="is_open_annual_incomeN" name="is_open_annual_income" value="0" @(Model.is_open_annual_income == 0 ? "checked" : "")>
              <label for="is_open_annual_incomeN">No</label>
            </div>
          </div>
        </div>
      </div>

      <div class="row no-side-space form-group mb-5">
        <div class="col-md-4">
          <label class="form-control-label" for="is_po_noY">PO No. 필요</label>
          <div>
            <div class="radio-custom radio-custom-sm radio-default radio-inline">
              <input type="radio" id="is_po_noY" name="is_po_no" value="1" checked @(Model.is_po_no == 1 ? "checked" : "")>
              <label for="is_po_noY">Yes</label>
            </div>
            <div class="radio-custom radio-custom-sm radio-default radio-inline">
              <input type="radio" id="is_po_noN" name="is_po_no" value="0" @(Model.is_po_no == 0 ? "checked" : "")>
              <label for="is_po_noN">No</label>
            </div>
          </div>
        </div>
        <div class="col-md-8">
          <label class="form-control-label" for="invoice_type">인보이스 종류</label>
          <div>
            <div class="radio-custom radio-custom-sm radio-default radio-inline">
              <input type="radio" id="Contingency" name="invoice_type" value="0" checked @(Model.invoice_type == 0 ? "checked" : "")>
              <label for="Contingency"><small>Contingency</small></label>
            </div>
            <div class="radio-custom radio-custom-sm radio-default radio-inline sts22">
              <input type="radio" id="Balance" name="invoice_type" value="2" @(Model.invoice_type == 2 ? "checked" : "")>
              <label for="Balance"><small>Retainer Balance</small></label>
            </div>
            <div class="radio-custom radio-custom-sm radio-default radio-inline">
              <input type="radio" id="Other" name="invoice_type" value="3" @(Model.invoice_type == 3 ? "checked" : "")>
              <label for="Other"><small>Other</small></label>
            </div>
          </div>
        </div>
      </div>

      <!--TODO 화요일 다시 살릴 예정-->

      <div class="row no-side-space form-group mb-5">
        <div class="col-md-4">
          <label class="form-control-label" for="candidate_source">
            후보자 소스 <small>[Canidate source]</small>
          </label><i class="fas fa-question-circle text-info" title="후보자 검색경로를 선택해주세요. 추후 통계에 활용될 예정입니다."></i><span class="label-reqired">*</span>
                                                                                                              <select name="candidate_source" id="candidate_source" class="form-control form-control-sm">
                                                                                                                <option value="" @(!Model.candidate_source.HasValue ? "selected" : "")>[선택]</option>
                                                                                                                <option value="10" @(Model.candidate_source == 10 ? "selected" : "")>[유니비전]</option>
                                                                                                                <option value="20" @(Model.candidate_source == 20 ? "selected" : "")>[직접지원]</option>
                                                                                                                <option value="30" @(Model.candidate_source == 30 ? "selected" : "")>[외부DB] - 링크드인</option>
                                                                                                                <option value="40" @(Model.candidate_source == 45 ? "selected" : "")>[외부DB] - 리멤버(제안)</option>
                                                                                                                <option value="40" @(Model.candidate_source == 40 ? "selected" : "")>[외부DB] - 리멤버(공고)</option>
                                                                                                                <option value="48" @(Model.candidate_source == 48 ? "selected" : "")>[외부DB] - 리멤버(PRIVATE)</option>
                                                                                                                <option value="50" @(Model.candidate_source == 50 ? "selected" : "")>[외부DB] - 사람인 </option>
                                                                                                                <option value="991" @(Model.candidate_source == 991 ? "selected" : "")>[외부DB] - 기타 잡포탈</option>
                                                                                                                <option value="70" @(Model.candidate_source == 70 ? "selected" : "")>[Target Search] - Referral, Cold call, Market Mapping 등</option>
                                                                                                                @*
    <option value="80" @(Model.candidate_source == 80 ? "selected" : "")>[Target Search] - Cold call</option>
