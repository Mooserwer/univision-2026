<script type="text/javascript">
  window.url_exchange_partial = "@Url.Action("FindExchangeApi", "Partial")";
  window.url_temp_invoice_create = "@Url.Action("ProjectTempInvoiceCreate", "Project")";

  function GetWonFee() {
    var cur_cd = $("#bill_currency_cd").val();
    if (cur_cd != "" && cur_cd != "KRW") {
      ajxCall({
        url: window.url_exchange_partial,
        data: {
          currency: cur_cd
        },
        type: 'POST',
        loading: true,
        loading_target: ".bill_exch",
        bef: function () {
        },
        suc: function (rst) {
          if (rst && rst.ok) {
            if (rst.data && rst.data.ex_seq > 0) {
              var per_won = rst.data.per_won;
              var per_rate = rst.data.ex_rate;
              var org_money = uncomma2($('#billing_money').val())
              var result_won = ((org_money * per_won) / per_rate).toFixed(2);
              $('#billing_won').val(comma2(result_won.toString()))
            }
          }
        }
      })
    } else {
      $('#billing_won').val($('#billing_money').val())
    }
  }

</script>
<script type="text/javascript">
  function DownTempInvoice() {
    alertify.confirm()
      .set({
        'labels': { ok: '확인', cancel: '취소' },
        'onok': function () {
          CreateTempInvoice();
        }
      })
      .setHeader('<i class="fas fa-exclamation-triangle" style="color:#FFDC2E"></i>인보이스 미리보기 다운로드')
      .setting({
        message: "인보이스 미리보기 파일을 다운로드 하시겠습니까? <br/><span class='text-bold text-danger'>(* 미리보기 파일은 정식 인보이스 파일이 아닙니다.)</span>",
      })
      .show();
  }

  function CreateTempInvoice() {

          var currentData = {
            p_seq: @Model.p_seq,
            c_seq: @Model.c_seq,
            prc_seq: @Model.prc_seq,
            join_dt: $("#join_dt").val(),
            billing_dt: $("#billing_dt").val(),
            annual_income: uncomma($("#annual_income").val()),
            ann_income: uncomma2($("#ann_income").val()),
            income_currency_cd: $("#income_currency_cd").val(),
            fee_rate: $("#fee_rate_inv").val(),
            billing_money: uncomma2($("#billing_money").val()),
            billing_total: uncomma2($("#billing_total").val()),
            billing_amt: uncomma2($("#billing_amt").val()),
            billing_vat: uncomma2($("#billing_vat").val()),
            billing_won: uncomma2($("#billing_won").val()),
            retainer_amt: uncomma2($("#retainer_amt").val()),
            bill_currency_cd: $("#bill_currency_cd").val(),
            vat_type: $("#vat_type").val(),
            billing_type: $("#billing_type").is(":checked") ? $("#billing_type").val() : 0,
            expire_guarantee: $("#expire_guarantee").val(),
            is_open_name: $("input[name=is_open_name]:checked").val(),
            is_open_annual_income: $("input[name=is_open_annual_income]:checked").val(),
            invoice_lang: $("input[name=invoice_lang]:checked").val(),
            invoice_type: $("input[name=invoice_type]:checked").val(),
            is_po_no: $("input[name=is_po_no]:checked").val(),
            candidate_source: $("#candidate_source").val(),
            candidate_source_txt: $("#candidate_source_txt").val(),
            candidate_position: $("#candidate_position").val(),
            candidate_position_txt: $("#candidate_position_txt").val(),
            remarks: $("#remarks").val(),
            isEngCandiSave: isEngCandiSave,
            isEngCompanySave: isEngCompanySave,
            candidate_name: $("#candidate_name").val(),
            client_seq: $("#client_seq").val(),
            client_name: $("#client_name").val(),
            client_ceo: $("#ceo").val(),
            client_biz_code: $("#biz_code").val(),
            client_addr1: $("#addr").val(),

            client_contact_name: $("#client_contact_name").val(),
            client_contact_tel: $("#client_contact_tel").val(),
            client_contact_email: $("#client_contact_email").val(),
            client_etax_name: $("#client_etax_name").val(),
            client_etax_tel: $("#client_etax_tel").val(),
            client_etax_email: $("#client_etax_email").val(),
          };



          $.ajax({
            url: window.url_temp_invoice_create,
            type: "POST",
            dataType: 'json',
            data: {
              data: currentData
            },
            beforeSend: function () {
              showLoading();
            },
            success: function (json) {
              hideLoading();
              if (json.ok) {
                console.log(json);
                downloadTempInv(json.file_url);
              }
              else {
                ErrorAlert(json.message);
              }
            },
            error: function (jqXHR, textStatus, errorThrown) {
              hideLoading();
              ErrorAlert("알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.");
            }
          });
  }


  function downloadTempInv(url){
    fetch(url)
      .then(response => response.blob())
      .then(blob => {
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.style.display = 'none';
        a.href = url;
        a.download = 'INVOICE(Preview).xlsx'; // Specify the file name
        document.body.appendChild(a);
        a.click();
        window.URL.revokeObjectURL(url);
      })
      .catch(error => console.error('Error downloading file:', error));
  }
</script>
<script type="text/javascript">
    var chargeArr = []
