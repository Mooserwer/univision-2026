        //console.log("#InvoiceCreateForm #billing_money,#InvoiceCreateForm  #ann_income).keyup");
        removeChar2(event);
        inputNumberFormat2(this);
      });

      $("#InvoiceCreateForm #billing_money,#InvoiceCreateForm  #ann_income").bind('keydown', function () {
        //console.log("#InvoiceCreateForm #billing_money,#InvoiceCreateForm  #ann_income).keydown");
        inputNumberFormat2(this);
      });



        //연봉 변경시
      $("#InvoiceCreateForm #ann_income").change(function () {
        //console.log("#InvoiceCreateForm #ann_income).change");
            //정액 체크가 안되어 있을 경우만 계산.
            if (!$("#billing_type").prop("checked")) {
                var income = parseInt(uncomma2($("#InvoiceCreateForm #ann_income").val()));
                var fee = parseFloat($("#InvoiceCreateForm #fee_rate_inv").val());

                var billing_money = comma(Math.round(income * (fee * 0.01)))

                $("#InvoiceCreateForm #billing_money").val(billing_money);
                changeTotalFee();
            }
        });

        //수수료율 변경시
        $("#InvoiceCreateForm #fee_rate_inv").change(function () {
