@model Univision.Main.Models.Project.ProjectInvoiceListModel

<div class="">
    <table class="block_table table table-striped table-hover">
        <thead class="text-center">
            <tr>
                <th class="tbw25">요청자</th>
                <th class="tbw25">요청일자</th>
                <th class="tbw25">후보자</th>
                <th class="tbw25">빌링액(수수료율)</th>
                <th class="hidden-sm-down">승인일자</th>
                <th class="hidden-sm-down">발송일자</th>
            </tr>
        </thead>
        <tbody class="text-center" style="vertical-align:middle;">
            @if (Model.list.Count > 0)
            {
                foreach (var data in Model.list)
                {
                    <tr>
                        <td>
                            <a href="javascript:void(0)" data-target="#InvoiceCreateModal" data-toggle="modal" onclick="ProjectInvoiceView('@data.p_seq', '@data.c_seq', '@data.pii_seq')">
                                @data.create_user_name
                            </a>
                        </td>
                        <td>
                            @Utils.ConvertDateTimeToString(data.create_dt)
                        </td>
                        <td>
                            @data.candidate_name
                        </td>
                        <td>
                            @(Utils.ConvertMoneyToString(data.billing_amt)) (@data.bill_currency_cd) (@data.fee_rate%)
                        </td>
                        <td class="hidden-sm-down">
                            @Utils.ConvertDateTimeToString(data.confirm_dt)
                        </td>
                        <td class="hidden-sm-down">
                            @Utils.ConvertDateTimeToString(data.send_dt)
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6">데이터가 없습니다.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
@Html.PageAjaxLinksWithFunction(Model.PagingInfo,
                            ViewContext.HttpContext.Request.Url.AbsoluteUri,
                            x => String.Format("javascript:callProjectInvoiceList({0}, {1})", Model.p_seq, x))
@if (Model.list.Count > 0)
{
<script type="text/javascript">
    if ($('#btnCreateRefundInvoice').length > 0) {
        $('#btnCreateRefundInvoice').css("display", "inline-block");
    }
    
</script>
}


<script type="text/javascript">
        function ProjectInvoiceView(p_seq, c_seq, pii_seq) {
        $.ajax({
            url: '@Url.Action("ProjectInvoiceView", "Project")',
            data: {
                p_seq: p_seq
                ,
                c_seq: c_seq
                ,
                pii_seq: pii_seq
            },
            dataType: 'html',
            type: 'GET',
            beforeSend: function ()
            {
                    showLoading();
                }
            })
        .done(function (view) {
            hideLoading();

            //모달은 Invoice View 때문에 ProjectDetail.cshtml 페이지에 넣어둠.
            $("#InvoiceCreateModal .modal-body").html(view)
            $('#InvoiceCreateModal').modal('toggle');

        })
        .fail(function (e) {
            hideLoading();
            ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
        });
    }
</script>