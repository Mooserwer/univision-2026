    function ProjectInvoiceCreate(p_seq, c_seq, pii_seq) {
      alert("화면 상단의 [인보이스 발행] 버튼을 통해 발행 부탁드립니다.");
      CreateInvoice(window.model_p_seq)
      return;

        var valid_msg = ""
        var focus_target = "";
        if ($('#ctc_seq').val() == 0 || $('#ctc_seq').val() == "") {
            valid_msg += (valid_msg != "" ? "<br />" : "") + "세금계산서 담당자 정보가 없습니다. 세금계산서 담당자 정보를 입력 후 진행하여 주시기 바랍니다."
            focus_target = "#tax_name";
        }
        if ($('#cc_seq').val() == 0 || $('#cc_seq').val() == "") {
            valid_msg += (valid_msg != "" ? "<br />" : "") + "Contact 정보가 없습니다. Contact정보를 입력 후 진행하여 주시기 바랍니다."
            focus_target = "#contact_name";
        }

        if (valid_msg != "") {
            if (focus_target != "") {
                $(focus_target).focus();
            }
            ErrorAlert(valid_msg);
            return;
        }

        $.ajax({
            url: '@Url.Action("ProjectInvoiceCreate", "Project")',
            data: {
                p_seq: p_seq
                ,
                c_seq: c_seq
                ,
                pii_seq: pii_seq
            },
            dataType: 'html',
            type: 'GET',
            beforeSend: function ()
            {
                showLoading();
            }
        })
        .done(function (view) {
            hideLoading();

            //모달은 Invoice View 때문에 ProjectDetail.cshtml 페이지에 넣어둠.
            $("#InvoiceCreateModal .modal-body").html(view)
            $("#InvoiceCreateModal .modal-body").find('#client_contact_name').val($('#contact_name').val() + " " + $('#contact_position').val());
            $("#InvoiceCreateModal .modal-body").find('#client_contact_tel').val($('#contact_phone').val());
            $("#InvoiceCreateModal .modal-body").find('#client_contact_email').val($('#contact_email').val());
            $("#InvoiceCreateModal .modal-body").find('#client_etax_name').val($('#tax_deposit_manager').val());
            $("#InvoiceCreateModal .modal-body").find('#client_etax_tel').val($('#tax_phone').val());
            $("#InvoiceCreateModal .modal-body").find('#client_etax_email').val($('#tax_deposit_email').val());
            $('#InvoiceCreateModal').modal('toggle');

        })
        .fail(function (e) {
            hideLoading();
            ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
        });
    }

