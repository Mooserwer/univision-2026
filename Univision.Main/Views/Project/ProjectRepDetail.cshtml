                                message: "이메일은 필수 입력 항목 입니다."
                            },
                            emailAddress: true
                        }
                    },
                    tax_phone: phoneValidator,
                    tax_cell_phone: phoneValidator,
                },
                err: {
                    clazz: "invalid-feedback"
                },
                control: {
                    valid: "is-valid",
                    invalid: "is-invalid"
                },
                row: {
                    invalid: "has-danger"
                }
            })
            .on('success.form.fv', function (e) {
                e.preventDefault();

                var formURL = $("#ProjectTaxForm").attr("action");

                $.ajax({
                    url: formURL,
                    type: "POST",
                    dataType: 'json',
                    data: {
                        c_seq: $("#c_seq").val()
                        ,p_seq: $("#p_seq").val()
                        ,division: $("#tax_division").val()
                        ,name: $("#tax_name").val()
                        ,email: $("#tax_email").val()
                        ,phone: $("#tax_phone").val()
                        ,cell_phone: $("#tax_cell_phone").val()
                        ,deposit_manager: $("#tax_deposit_manager").val()
                        ,deposit_email: $("#tax_deposit_email").val()
                    },
                    beforeSend: function () {
                        showLoading("#projectTax");
                    },
                    success: function (json) {
                        hideLoading("#projectTax");

                        if (json.ok) {
                            location.reload();
                        }
                        else {
                            ErrorAlert(json.message);
                        }
                    },
                    error: function (jqXHR, textStatus, errorThrown) {
                        hideLoading("#projectTax");

                        ErrorAlert("알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요1.");
                    }
                });
            });
        }

  </script>

}