@model Univision.Main.Models.Project.ProjectInvoiceCreateModel

<style>
</style>

@Html.HiddenFor(x => x.pii_seq)

<div class="panel" style="margin-bottom:10px !important;">
  <div class="panel-heading">
    <h3 class="panel-title" style="padding: 10px 30px 5px 30px">
      <i class="fas fa-newspaper"></i>
      기본정보
    </h3>
    <div class="panel-actions">
      <a class="panel-action icon wb-minus" aria-expanded="true" data-toggle="panel-collapse" aria-hidden="true"></a>
    </div>
  </div>
  <div class="panel-body" style="padding: 5px 10px 5px 10px;">
    <div class="row no-side-space form-group mb-5">

      <div class="col-md-4">
        <label class="form-control-label" for="billing_dt">빌링일자</label>
        <p class="form-control-plaintext">
          @Utils.ConvertDateTimeToString(Model.billing_dt)
        </p>
      </div>
      <div class="col-md-4">
        <label class="form-control-label" for="expire_guarantee">개런티 기간 만료일</label>
        <p class="form-control-plaintext">
          @Utils.ConvertDateTimeToString(Model.expire_guarantee)
        </p>
      </div>
      <div class=" col-md-4">
        <label class="form-control-label" for="join_dt">빌링액</label>

        <p class="form-control-plaintext">
          @(Utils.ConvertMoneyToString(Model.billing_money)) @Model.bill_currency_cd
          @if (Model.bill_currency_cd != "KRW")
          {
            <br /><span class="text-primary">(원화 환산 예상액 :약 @Utils.ConvertMoneyToString(Model.billing_won) 원)</span>
          }
        </p>
      </div>
    </div>

  </div>
</div>

<!-- 매출배분 시작 -->
<div class="panel" style="margin-bottom:10px !important;">
  <div class="panel-heading">
    <h3 class="panel-title" style="padding: 10px 30px 5px 30px">
      <i class="fas fa-won-sign"></i>
      매출배분
    </h3>
    <div class="panel-actions">
      <a class="panel-action icon wb-minus" aria-expanded="true" data-toggle="panel-collapse" aria-hidden="true"></a>
    </div>
  </div>
  <div class="panel-body" id="salesList" name="salesList" style="padding: 5px 10px 5px 10px;">

    @if (Model.chargeList.Count > 0)
    {
      foreach (var data in Model.chargeList)
      {
        <div class="chargeRow">
          <div class="row form-inline no-side-space col-md-12">
            <div class="col-md-3 text-center">
              <p class="form-control-plaintext">
                @(data.name)
              </p>
            </div>
            <div class="col-md-3 text-center">
              <p class="form-control-plaintext">
                @(data.sales_rate) %
              </p>
            </div>
            <div class="col-md-3 text-center">
              <p class="form-control-plaintext">
                @(Utils.ConvertMoneyToString(data.sales_money)) @Model.bill_currency_cd
              </p>
            </div>

            <div class="col-md-3 no-side-space mb-10">
              <p class="form-control-plaintext">
                @(data.comments)
              </p>
            </div>
          </div>
        </div>

      }
    }

  </div>
</div>
<!-- 매출배분 끝 -->
<!-- 수신정보 시작 -->
<div class="panel" style="margin-bottom:10px !important;">
  <div class="panel-heading">
    <h3 class="panel-title" style="padding: 10px 30px 5px 30px">
      <i class="fas fa-envelope-open-text"></i>
      수신정보
    </h3>
    <div class="panel-actions">
      <a class="panel-action icon wb-minus" aria-expanded="true" data-toggle="panel-collapse" aria-hidden="true"></a>
    </div>
  </div>
  <div class="panel-body" style="padding: 5px 10px 5px 10px;">
    <div class="row no-side-space form-group mb-5">
      <div class=" col-md-6">
        <label class="form-control-label" for="client_name">고객사명</label>
        <p class="form-control-plaintext">
          @(Model.client_name)
        </p>
      </div>
      <div class="col-md-6">
        <label class="form-control-label" for="ceo">대표자명</label>
        <p class="form-control-plaintext">
          @(Model.ceo)
        </p>
      </div>
    </div>

    <div class="row no-side-space form-group mb-5">
      <div class=" col-md-6">
        <label class="form-control-label" for="addr">주소</label>
        <p class="form-control-plaintext">
          @(Model.addr)
        </p>
      </div>
      <div class="col-md-6">
        <label class="form-control-label" for="billing_dt">사업자번호</label>
        <p class="form-control-plaintext">
          @(Model.biz_code)
        </p>
      </div>
    </div>

    <div class="row no-side-space form-group mb-5">

      <div class="col-md-4">
        <label class="form-control-label" for="invoice_lang">인보이스 언어</label>
        <div>
          <div class="radio-custom radio-default radio-inline">
            <input type="radio" id="korInvoice" name="invoice_lang" value="0" disabled @(Model.invoice_lang == 0 ? "checked" : "")>
            <label for="korInvoice">국문</label>
          </div>
          <div class="radio-custom radio-default radio-inline">
            <input type="radio" id="engInvoice" name="invoice_lang" value="1" disabled @(Model.invoice_lang == 1 ? "checked" : "")>
            <label for="engInvoicesn">영문</label>
          </div>
        </div>
      </div>

    </div>

    <div class="row no-side-space form-group mb-5">
      <div class="col-md-12">
        <label class="form-control-label" for="invoice_type">인보이스 종류</label>
        <div>
          <div class="radio-custom radio-default radio-inline">
            <input type="radio" id="Contingency" name="invoice_type" value="0" disabled @(Model.invoice_type == 0 ? "checked" : "")>
            <label for="Contingency">Contingency</label>
          </div>
          <div class="radio-custom radio-default radio-inline">
            <input type="radio" id="Retainer" name="invoice_type" value="1" disabled @(Model.invoice_type == 1 ? "checked" : "")>
            <label for="Retainer">Retainer</label>
          </div>
          <div class="radio-custom radio-default radio-inline ">
            <input type="radio" id="Balance" name="invoice_type" value="2" disabled @(Model.invoice_type == 2 ? "checked" : "")>
            <label for="Balance">Retainer Balance</label>
          </div>
          <div class="radio-custom radio-default radio-inline">
            <input type="radio" id="Other" name="invoice_type" value="3" disabled @(Model.invoice_type == 3 ? "checked" : "")>
            <label for="Other">Other</label>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<!-- 수신정보 끝 -->

<div class="panel" style="margin-bottom:10px !important;">
  <div class="panel-body" style="padding: 5px 10px 5px 10px;">
    <div class="row no-side-space form-group mb-5">
      <div class="col-md-12">
        <label class="form-control-label" for="remarks">비고</label>
        <p class="form-control-plaintext">
          @(Model.remarks)
        </p>
      </div>
    </div>
  </div>
</div>
@*PMS 오픈 관련 등록기능 제한*@
@if (Univision.Security.AppIdentity.CanPmsEdit)
{
  <div class="row col-md-12 no-side-space">
    <div class="col-md-6">

    </div>
    <div class="col-md-6 vertical-align text-right">
      <div class="vertical-align-bottom">
        <button type="button" class="btn btn-sm btn-warning" id="btnInvoiceDelete">삭제</button>
      </div>
    </div>
  </div>
}


<script type="text/javascript">

    $(document).ready(function () {

        //인보이스 삭제.
        $("#btnInvoiceDelete").click(function () {

            alertify.confirm()
                    .set({
                        'labels': { ok: '확인', cancel: '취소' },
                        'onok': function () {

                            $.ajax({
                               url: '@Url.Action("ProjectInvoiceDelete", "Project")',
                               data: {
                                   pii_seq: $("#pii_seq").val()
                               },
                               dataType: 'json',
                               type: 'POST',
                               beforeSend: function ()
                               {
                                   showLoading();
                               }
                            })
                            .done(function (json) {
                                hideLoading();
                                if (json.ok) {
                                    NormalAlert(json.message);
                                    $("#InvoiceCreateModal .modal-body").empty()
                                    $('#InvoiceCreateModal').modal('toggle');
                                    callProjectInvoiceList(@Model.p_seq, 1);
                                } else {
                                    ErrorAlert(json.message);
                                }
                            })
                            .fail(function (e) {
                                hideLoading();
                                ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
                            });
                        },
                        'oncancel': function () {

                            return;
                        },
                    })
                    .setHeader('<i class="fas fa-exclamation-triangle" style="color:#FFDC2E"></i>인보이스 삭제')
                    .setting({
                        message: "인보이스를 삭제 하시겠습니까?",
                    })
                .show();



        });

    });

</script>
