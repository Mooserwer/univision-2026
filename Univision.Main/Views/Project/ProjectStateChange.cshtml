
@{ 
    int p_seq = ViewBag.p_seq;
}

@using(Html.BeginForm("ProjectStateChange", "Project", FormMethod.Post, new { @id="PopCreateForm" }))
{
    <div class="panel" style="margin-bottom:0px !important;">
        <div id="projectState" class="panel-body" style="padding: 5px 10px 5px 10px; max-height:287px; overflow-y:auto">
            <div class="form-group">
                @Html.Hidden("p_seq", p_seq)

                @{
                    var stateList = new SelectList(ProjectStatusCode.ProjectStatusCodes, "Key", "Value").ToList();
                    stateList.Insert(0, new SelectListItem { Value = "0", Text = "선택" });
                }
                @Html.DropDownList("pjt_status", stateList, new { @class = "form-control" })
            </div>
            <div class="form-group">
                @Html.TextArea("status_comment", new { @class = "form-control" })
            </div>
            <div class="form-group text-right mb-0">
                <button type="submit" class="btn btn-sm btn-primary" id="btnPopSave">저장</button>
            </div>
        </div>
    </div>
}

<script type="text/javascript">

    $(document).ready(function(){

        $("#PopCreateForm").ajaxForm({
            dataType: 'json',
            beforeSubmit: function () {
                
                if ($("#pjt_status").val() == "0") {
                    ErrorAlert("프로젝트 상태를 선택하세요.")
                    return false;
                }

                if ($("#status_comment").val() == "") {
                    ErrorAlert("사유를 입력하세요.")
                    return false;
                }

                showLoading();
            },
            success: function (json) {
                hideLoading();
                if (json.ok) {
                    NormalAlert(json.message);
                    $.fancybox.close();
                    window.setTimeout(function () { location.reload() }, 500);
                }
                else {
                    ErrorAlert(json.message);
                }
            },
            error: function () {
                hideLoading();
            }
        });

    });


</script>