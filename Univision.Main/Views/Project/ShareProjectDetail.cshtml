            });

            //담당자 불러오기
            $("#btnContact").click(function () {

                if ($("#company_name").val() == "" || $("#c_seq").val() == 0) {
                    NormalAlert("고객사 명을 검색 하세요.")
                    return false;
                }

                $.ajax({
                    url: '@Url.Action("SearchProjectContact", "Project")',
                    data: {
                        c_seq: $("#c_seq").val()
                    },
                    dataType: 'html',
                    type: 'POST',
                    beforeSend: function ()
                    {
                        showLoading();
                    }
                })
                .done(function (json) {
                    hideLoading();

                    $.fancybox.open({
                        'content':json,
                        'width': '500',
                        'height': '385',
                        'autoDimensions':false,
                        'type':'iframe',
                        'autoSize': false,
                        'title': 'Contact 목록',
                        helpers: {
                            title : {
                                type: 'inside',
                                position : 'top'
                            },
                            overlay: {
                                closeClick: false
                            }
                        }
                    });
                })
                .fail(function (e) {
                    hideLoading();
                    ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
                });

            });

            //세금계산서 담당자 저장.
            $("#btnTaxSave").click(function () {

                $.ajax({
                   url: '@Url.Action("ProjectTaxContactSave", "Project")',
                   data: {
                       p_seq: $("#p_seq").val()
                       ,
                       ctc_seq : $("#ctc_seq").val()
                   },
                   dataType: 'json',
                   type: 'POST',
                   beforeSend: function ()
                   {
                       showLoading();
                   }
                })
                .done(function (json) {
                    hideLoading();
                    if (json.ok) {
                        NormalAlert(json.message);
                    } else {
                        ErrorAlert(json.message);
                    }
                })
                    .fail(function (e) {
                    hideLoading();
                    ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
                });

            });

            //프로젝트 담당자 저장
            $("#btnContactSave").click(function () {

                $.ajax({
                   url: '@Url.Action("ProjectContactSave", "Project")',
                   data: {
                       p_seq: $("#p_seq").val()
                       ,
                       cc_seq : $("#cc_seq").val()
                   },
                   dataType: 'json',
                   type: 'POST',
                   beforeSend: function ()
