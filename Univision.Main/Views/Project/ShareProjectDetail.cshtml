                })
                .done(function (json) {
                    hideLoading();
                    if (json.ok) {
                        NormalAlert(json.message);
                    } else {
                        ErrorAlert(json.message);
                    }
                })
                .fail(function (e) {
                    hideLoading();
                    ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
                });

            });
        });

        //프로젝트 진행사항
        function callProjectProgress(p_seq, state, page) {

            if(page == null || page == undefined)
                page = 1;

            $.ajax({
                url: '@Url.Action("ProjectProgressList", "Project")',
                data: {
                    p_seq: p_seq
                    , state: state
                    ,page : page
                },
                dataType: 'html',
                type: 'POST',
                beforeSend: function () {
                    showLoading('#projectProgress');
                }
            })
            .done(function (view) {
                hideLoading('#projectProgress');
                $('#projectProgress').html(view);

            })
            .always(function () {
                hideLoading('#projectProgress');
            });
        }

