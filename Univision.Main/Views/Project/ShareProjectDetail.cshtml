@model Univision.Main.Models.Project.ProjectCreateModel
@using Univision.Security

@{
    ViewBag.Title = "공유 프로젝트 상세보기";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string tmp_txt = String.Empty;
}

<link rel="stylesheet" href="~/Libs/remark/global/vendor/bootstrap-tokenfield/bootstrap-tokenfield.min599c.css?v4.0.4">
<link rel="stylesheet" href="~/Libs/remark/base/assets/examples/css/pages/project.min599c.css?4.0.2" />

<style>
    .placeDiv span {
        font-size: 15px;
    }

    .job_list {
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
        width: 250px;
        display: inline-block;
    }

</style>

<div class="page-content">
    @Html.HiddenFor(x => x.p_seq)

    <div class="panel panel-primary panel-line animation-scale-up" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms;">
        <div class="panel-heading">
            <h3 class="panel-title">
                <i class="fas fa-share"></i>
                공유 정보

            </h3>
            <div class="panel-actions">
                @if (AppIdentity.ua_seq < 3 || Model.amList.Where(x => x.uv_seq == AppIdentity.user_seq).FirstOrDefault() != null || Model.searcherList.Where(x => x.uv_seq == AppIdentity.user_seq).FirstOrDefault() != null)
                {
                    if (Model.pjt_status == 1)
                    {

                        <span class="pr-20">
                            @if (Model.is_share_pjt == 1)
                            {
                                <button type="button" class="btn btn-sm btn-danger" onclick="cancelShareProject(this, @Model.p_seq)" title="공유 취소/마감">Cancel Share</button>

                            }
                            else
                            {
                                <button type="button" class="btn btn-sm btn-primary" onclick="shareProject(this, @Model.p_seq)" title="프로젝트 공유하기">Share</button>
                            }
                            @if (Model.is_cowork == 1)
                            {
                                <button type="button" class="btn btn-sm btn-warning" onclick="cancelShareProject(this, @Model.p_seq)" title="Co-work 취소/마감">Cancel Cowork</button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-sm btn-info" onclick="CoWorkAlram(@Model.p_seq)" title="Co-work 요청">Cowork</button>

                            }
                        </span>

                    }
                }
                <a class="panel-action icon wb-minus" aria-expanded="true" data-toggle="panel-collapse" aria-hidden="true"></a>
            </div>
        </div>
        <div id="shareInfo" class="panel-body">
            <div class="row">
                <div class="col-md-12">
                    <label class="form-control-label font-weight-500" for="share_comments">공유사유</label>
                    <p class="form-control-plaintext border p-5">
                        @Model.share_comments
                    </p>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <label class="form-control-label font-weight-500" for="share_fee_rate">Fee Share</label>
                    <p class="form-control-plaintext">
                        @Model.share_fee_rate
                    </p>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <label class="form-control-label font-weight-500" for="secret_info">비공개정보</label>
                    <p class="form-control-plaintext">
                        @Model.secret_info
                    </p>
                </div>
            </div>
            <div id="commentList" class="card border border-primary">
            </div>
        </div>
    </div>

    <div class="panel panel-primary panel-line animation-scale-up" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms;">
        <div class="panel-heading">
            <h3 class="panel-title">
                <i class="fas fa-newspaper"></i>
                Project Information [Recruitment]
                @{
                    string classNm = "";
                    string txt = "";

                    switch (Model.pjt_status)
                    {
                        case 1:
                            classNm = "badge-primary";
                            txt = "진행";
                            break;
                        case 2:
                            classNm = "badge-warning";
                            txt = "보류";
                            break;
                        case 3:
                            classNm = "badge-danger";
                            txt = "종료";
                            break;
                        case 4:
                            classNm = "badge-info";
                            txt = "완료";
                            break;
                        case 5:
                            classNm = "badge-success";
                            txt = "성공";
                            break;

                    }
                }
                <span class="badge @classNm">@txt</span>
                <span style="font-size:12px; color:black">@Model.status_comment</span>
            </h3>
            <div class="panel-actions">

                @if (Model.amList.Where(x => x.uv_seq == AppIdentity.user_seq).FirstOrDefault() != null || Model.searcherList.Where(x => x.uv_seq == AppIdentity.user_seq).FirstOrDefault() != null)
                {
                    <button type="button" class="btn btn-sm btn-primary" id="btnPjtState">프로젝트 마감</button>
                }
                <a class="panel-action icon wb-minus" aria-expanded="true" data-toggle="panel-collapse" aria-hidden="true"></a>

            </div>
        </div>
        <div id="projectInfo" class="panel-body">
            <div class="row">
                <div class="form-group col-md-4">
                    <label class="form-control-label" for="company_name">
                        Client
                        <span class="label-reqired">*</span>
                    </label>
                    @Html.HiddenFor(x => x.c_seq)
                    <div class="input-group input-group-sm">
                        @Html.TextBoxFor(x => x.company_name, new { @class = "form-control", @autocomplete = "off", @readonly = "readonly" })
                    </div>
                </div>
                <div class="form-group col-md-8">
                    <label class="form-control-label" for="title">
                        Title
                        <span class="label-reqired">*</span>
                    </label>
                    @Html.TextBoxFor(x => x.title, new { @class = "form-control form-control-sm", @autocomplete = "off", @readonly = "readonly" })
                </div>
            </div>

            <div class="row">
                <div class="form-group col-md-4">
                    <label class="form-control-label" for="AMDiv">
                        AM
                        <span class="label-reqired">*</span>
                    </label>
                    @{
                        tmp_txt = "";
                        if (Model.amList.Count > 0)
                        {
                            foreach (var am in Model.amList)
                            {
                                tmp_txt += !String.IsNullOrEmpty(tmp_txt) ? "," : "" + @am.name;

                            }
                        }
                    }
                    <input type="text" value="@tmp_txt" class="form-control form-control-sm" readonly />

                </div>

                <div class="form-group col-md-8">
                    <label class="form-control-label" for="Searcher">
                        SM
                        <span class="label-reqired">*</span>
                    </label>
                    @{
                        tmp_txt = "";
                        if (Model.searcherList.Count > 0)
                        {
                            foreach (var searcher in Model.searcherList)
                            {
                                tmp_txt += !String.IsNullOrEmpty(tmp_txt) ? "," : "" + searcher.name;
                            }
                        }

                    }
                    <input type="text" value="@tmp_txt" class="form-control form-control-sm" readonly />
                </div>
            </div>

            <div class="row">
                <div class="form-group col-md-6">
                    <label class="form-control-label" for="businessCodeDiv">
                        Industry  <i class="fas fa-info-circle text-info" title="후보자 자동제안 참조 항목"></i>
                        <span class="label-reqired">*</span>
                    </label>
                    <div class="input-group input-group-sm" id="businessCodeDiv">
                        @Html.TextBoxFor(x => x.business_name2, new { @class = "form-control longLen", @readonly = "readonly", @placeholder = "산업" })
                    </div>
                </div>
                <div class="form-group col-md-6">
                    <label class="form-control-label" for="jobCodeDiv">
                        Job function  <i class="fas fa-info-circle text-info" title="후보자 자동제안 참조 항목"></i>
                        <span class="label-reqired">*</span>
                    </label>
                    <div class="input-group input-group-sm" id="jobCodeDiv">
                        @Html.TextBoxFor(x => x.job_name2, new { @class = "form-control longLen", @readonly = "readonly", @placeholder = "직무" })
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="form-group col-md-4">
                    <label class="form-control-label" for="expected_salary">Salary <span class="label-reqired">*</span></label>
                    <div class="input-group input-group-sm">
                        @Html.TextBoxFor(x => x.expected_salary, new { @class = "form-control text-right", @autocomplete = "off", @readonly = "readonly" })
                        <select name="currency_cd" id="currency_cd" class="form-control form-control-sm" disabled>
                            <option value="WON" @(Model.currency_cd == "WON" ? "selected" : "")>WON(원)</option>
                            <option value="USD" @(Model.currency_cd == "USD" ? "selected" : "")>USD(미국달러)</option>
                            <option value="HKD" @(Model.currency_cd == "HKD" ? "selected" : "")>HKD(홍콩달러)</option>
                            <option value="YEN" @(Model.currency_cd == "YEN" ? "selected" : "")>YEN(엔화)</option>
                            <option value="GBP" @(Model.currency_cd == "GBP" ? "selected" : "")>GBP(파운드)</option>
                            <option value="DEM" @(Model.currency_cd == "DEM" ? "selected" : "")>DEM(마르크)</option>
                            <option value="FRF" @(Model.currency_cd == "FRF" ? "selected" : "")>FRF(프랑스 프랑)</option>
                            <option value="CHF" @(Model.currency_cd == "CHF" ? "selected" : "")>CHF(스위스 프랑)</option>
                            <option value="EUR" @(Model.currency_cd == "EUR" ? "selected" : "")>EUR(유로)</option>
                            <option value="CNY" @(Model.currency_cd == "CNY" ? "selected" : "")>CNY(위안)</option>
                            <option value="AUD" @(Model.currency_cd == "AUD" ? "selected" : "")>AUD(호주달러)</option>
                            <option value="NZD" @(Model.currency_cd == "NZD" ? "selected" : "")>NZD(뉴질랜드달러)</option>
                            <option value="CAD" @(Model.currency_cd == "CAD" ? "selected" : "")>CAD(캐나다달러)</option>
                        </select>
                    </div>
                </div>
                <div class="form-group col-md-2">

                    <label class="form-control-label" for="fee_rate">Fee rate <span class="label-reqired">*</span></label>
                    <div class="input-group input-group-sm">
                        @Html.TextBoxFor(x => x.fee_rate, new { @class = "form-control form-control text-right", @autocomplete = "off", @placeholder = "%", @readonly = "readonly" })
                        <span class="input-group-addon">%</span>
                    </div>
                </div>
                <div class="form-group col-md-3">
                    <label class="form-control-label" for="position_seq">
                        Position
                        <span class="label-reqired">*</span>
                    </label>
                    <select id="position_seq" name="position_seq" class="form-control  form-control-sm" disabled>
                        <option value="">선택</option>
                        <option value="110" @(Model.position_seq == 110 ? "selected" : "")>프리랜서(비정규 전문직)</option>
                        <option value="100" @(Model.position_seq == 100 ? "selected" : "")>신입사원급</option>
                        <option value="90" @(Model.position_seq == 90 ? "selected" : "")>경력사원급</option>
                        <option value="80" @(Model.position_seq == 80 ? "selected" : "")>대리급</option>
                        <option value="70" @(Model.position_seq == 70 ? "selected" : "")>과장급</option>
                        <option value="60" @(Model.position_seq == 60 ? "selected" : "")>차장급</option>
                        <option value="50" @(Model.position_seq == 50 ? "selected" : "")>부장급</option>
                        <option value="40" @(Model.position_seq == 40 ? "selected" : "")>본부장/지사장</option>
                        <option value="30" @(Model.position_seq == 30 ? "selected" : "")>임원급</option>
                        <option value="20" @(Model.position_seq == 20 ? "selected" : "")>최고재무경영자</option>
                        <option value="10" @(Model.position_seq == 10 ? "selected" : "")>최고 경영자</option>
                    </select>
                </div>
                <div class="form-group col-md-3">
                    <label class="form-control-label" for="expreience_number">
                        Experience(Year)
                        <span class="label-reqired">*</span>
                    </label>
                    <div class="input-group input-group-sm">
                        @Html.TextBoxFor(x => x.expreience_number, new { @class = "form-control", @type = "number", @autocomplete = "off", @placeholder = "년 수", @readonly = "readonly" })
                        <select class="form-control" id="experience_type" name="experience_type" disabled>
                            <option value="1" @(Model.experience_type == 1 ? "selected" : "")>년 이상</option>
                            <option value="2" @(Model.experience_type == 2 ? "selected" : "")>년 이하</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="form-group col-md-6">
                    <label class="form-control-label" for="assign_task">
                        담당업무
                        <span class="label-reqired">*</span>
                    </label>
                    @Html.TextAreaFor(x => x.assign_task, new { @class = "form-control", @rows = "5", @readonly = "readonly" })
                </div>
                <div class="form-group col-md-6">
                    <label class="form-control-label" for="requirement">
                        자격요건
                        <span class="label-reqired">*</span>
                    </label>
                    @Html.TextAreaFor(x => x.requirement, new { @class = "form-control", @rows = "5", @readonly = "readonly" })
                </div>
            </div>
            <div class="row">

                <div class="form-group col-md-2">
                    <label class="form-control-label" for="recruit_number">
                        모집인원
                    </label>
                    @Html.TextBoxFor(x => x.recruit_number, new { @class = "form-control form-control-sm", @type = "number", @autocomplete = "off", @readonly = "readonly" })
                </div>
                <div class="form-group col-md-3">
                    <label class="form-control-label" for="edu_code">Education</label>
                    <select class="form-control form-control-sm" id="edu_code" name="edu_code" disabled>
                        <option value="0" @(Model.edu_code == 0 ? "selected" : "")>학력무관</option>
                        <option value="1" @(Model.edu_code == 1 ? "selected" : "")>고등학교졸업</option>
                        <option value="2" @(Model.edu_code == 2 ? "selected" : "")>대학졸업(2,3년)</option>
                        <option value="3" @(Model.edu_code == 3 ? "selected" : "")>대학교졸업(4년)</option>
                        <option value="4" @(Model.edu_code == 4 ? "selected" : "")>석사졸업</option>
                        <option value="5" @(Model.edu_code == 5 ? "selected" : "")>박사졸업</option>
                        <option value="6" @(Model.edu_code == 6 ? "selected" : "")>고등학교졸업이상</option>
                        <option value="7" @(Model.edu_code == 7 ? "selected" : "")>대학졸업(2,3년)이상</option>
                        <option value="8" @(Model.edu_code == 8 ? "selected" : "")>대학교졸업(4년)이상</option>
                        <option value="9" @(Model.edu_code == 9 ? "selected" : "")>석사졸업이상</option>
                    </select>
                </div>
                <div class="form-group col-md-3">
                    <label class="form-control-label" for="foreign_lang">Language</label>
                    <div class="input-group input-group-sm">
                        <select id="foreign_lang" name="foreign_lang" class="form-control form-control-sm" disabled>
                            <option value="00" @(Model.foreign_lang == "00" ? "selected" : "")>외국어</option>
                            <option value="01" @(Model.foreign_lang == "01" ? "selected" : "")>중국어</option>
                            <option value="02" @(Model.foreign_lang == "02" ? "selected" : "")>영어</option>
                            <option value="03" @(Model.foreign_lang == "03" ? "selected" : "")>불어</option>
                            <option value="04" @(Model.foreign_lang == "04" ? "selected" : "")>독일어</option>
                            <option value="05" @(Model.foreign_lang == "05" ? "selected" : "")>일본어</option>
                            <option value="06" @(Model.foreign_lang == "06" ? "selected" : "")>러시아어</option>
                            <option value="99" @(Model.foreign_lang == "99" ? "selected" : "")>기타</option>
                            <option value="07" @(Model.foreign_lang == "07" ? "selected" : "")>스페인어</option>
                        </select>
                        <select id="foreign_level" name="foreign_level" class="form-control" disabled>
                            <option value="0" @(Model.foreign_level == 0 ? "selected" : "")>능력</option>
                            <option value="1" @(Model.foreign_level == 1 ? "selected" : "")>상</option>
                            <option value="2" @(Model.foreign_level == 2 ? "selected" : "")>중</option>
                            <option value="3" @(Model.foreign_level == 3 ? "selected" : "")>하</option>
                        </select>
                    </div>
                </div>
                <div class="form-group col-md-4">
                    <label class="form-control-label" for="place">
                        Place
                        <span class="label-reqired">*</span>
                    </label>
                    @{
                        tmp_txt = "";
                        if (Model.placeList.Count > 0)
                        {
                            foreach (var place in Model.placeList)
                            {
                                if (place.code1 == place.code2)
                                {
                                    tmp_txt += !String.IsNullOrEmpty(tmp_txt) ? "," : "" + "[" + place.area2 + "]";
                                }
                                else
                                {
                                    tmp_txt += !String.IsNullOrEmpty(tmp_txt) ? "," : "" + "[" + (place.area1 + " " + place.area2) + "]";
                                }
                            }
                        }

                    }
                    <input type="text" value="@tmp_txt" class="form-control form-control-sm" readonly />
                </div>
            </div>
            <div class="row">
                <div class="form-group col-md-2">
                    <label class="form-control-label" for="is_posting">Web posting</label>
                    <div>
                        <div class="radio-custom radio-default radio-inline">
                            <input type="radio" id="hire" name="is_posting" value="1" @(Model.is_posting == 1 ? "checked" : "") disabled>
                            <label for="hire">Yes</label>
                        </div>
                        <div class="radio-custom radio-default radio-inline">
                            <input type="radio" id="reputation" name="is_posting" value="0" @(Model.is_posting == 0 ? "checked" : "") disabled>
                            <label for="radio">No</label>
                        </div>
                    </div>
                </div>
                <div class="form-group col-md-10">
                    <label class="form-control-label">
                        Documents
                        <span class="label-reqired">*</span>
                    </label>
                    <div id="paperDiv" name="paperDiv" class="form-inline">
                        <div class="checkbox-custom checkbox-primary">
                            <input type="checkbox" id="is_kor_resume" value="1" @(Model.is_kor_resume == 1 ? "checked" : "") disabled>
                            <label for="is_kor_resume">국문이력서</label>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                        </div>
                        <div class="checkbox-custom checkbox-primary">
                            <input type="checkbox" id="is_eng_resume" value="1" @(Model.is_eng_resume == 1 ? "checked" : "") disabled>
                            <label for="is_eng_resume">영문이력서</label>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                        </div>
                        <div class="checkbox-custom checkbox-primary">
                            <input type="checkbox" id="is_portfolio" value="1" @(Model.is_portfolio == 1 ? "checked" : "") disabled>
                            <label for="is_portfolio">포트폴리오</label>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                        </div>
                        <div class="checkbox-custom checkbox-primary">
                            <input type="checkbox" id="is_self_introduction" value="1" @(Model.is_self_introduction == 1 ? "checked" : "") disabled>
                            <label for="is_self_introduction">자기소개서</label>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                        </div>
                        <div class="checkbox-custom checkbox-primary">
                            <input type="checkbox" id="is_etc" value="1" @(Model.is_etc == 1 ? "checked" : "") disabled>
                            <label for="is_etc">기타</label>&nbsp;&nbsp;
                        </div>
                        @Html.TextBoxFor(x => x.etc_comment, new { @class = "form-control form-control-sm", @autocomplete = "off", @readonly = "readonly" })
                    </div>
                </div>
            </div>

            @if (Model.amList.Where(x => x.uv_seq == AppIdentity.user_seq).FirstOrDefault() != null || Model.searcherList.Where(x => x.uv_seq == AppIdentity.user_seq).FirstOrDefault() != null)
            {
                if (Model.pjt_status == 1 || Model.pjt_status == 4)
                {
                    <div class="row">
                        <div class="col-md-12 vertical-align text-right pt-10">
                            <div class="vertical-align-bottom">
                                <a href="@Url.Action("ProjectCreate", "Project", new { @p_seq = Model.p_seq })" id="btnModify" class="btn btn-success" title="프로젝트 정보 수정">Modify Project</a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- 프로젝트 부가정보 시작 -->
    <div class="panel panel-primary panel-line animation-scale-up" style="animation-fill-mode:backwards; animation-duration: 250ms; animation-delay: 0ms;">
        <div class="panel-heading">
            <h3 class="panel-title">
                <i class="fas fa-project-diagram"></i>
                Additional Information
            </h3>
            <div class="panel-actions">
                <a class="panel-action icon wb-minus" aria-expanded="true" data-toggle="panel-collapse" aria-hidden="true"></a>
            </div>
        </div>
        <div id="projectAdd" class="panel-body">
            <div class="row">

                <div class="form-group col-md-12">
                    <label class="form-control-label">구인절차</label>
                    <div class="form-inline">
                        <div class="checkbox-custom checkbox-primary">
                            <input type="checkbox" id="is_pre_interview" value="1" @(Model.is_pre_interview == 1 ? "checked" : "") disabled>
                            <label for="is_pre_interview">사전면접</label>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                        </div>

                        <div class="checkbox-custom checkbox-primary">
                            <input type="checkbox" id="is_number" value="1" @(Model.is_number == 1 ? "checked" : "") disabled>
                            <label></label>
                        </div>
                        <select class="form-control form-control-sm" id="interview_number" name="interview_number" disabled>
                            <option value="1" @(Model.interview_number == 1 ? "selected" : "")>1</option>
                            <option value="2" @(Model.interview_number == 2 ? "selected" : "")>2</option>
                            <option value="3" @(Model.interview_number == 3 ? "selected" : "")>3</option>
                            <option value="4" @(Model.interview_number == 4 ? "selected" : "")>4</option>
                            <option value="5" @(Model.interview_number == 5 ? "selected" : "")>5</option>
                        </select>
                        <label for="interview_number">차 면접</label>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;

                        <div class="checkbox-custom checkbox-primary">
