  function getAttendResult() {
    if ($("#attend_result").length > 0) {
      $.ajax({
        url: '@Url.Action("GetAttendResult", "Partial")',
        data: {
        },
        dataType: 'json',
        type: 'POST',
      }).done(function (json) {
        $("#attend_result").empty();
        if (json.ok) {

          if (json.attend >= 1) {
            $("#attend_result").removeClass("text-danger").removeClass("text-success").addClass("text-success");
            $("#attend_result").html("<i class='fas fa-check'></i> 출근 확인 완료")
          } else {
            $("#attend_result").removeClass("text-danger").removeClass("text-success").addClass("text-danger");
            $("#attend_result").html("<i class='fas fa-clock'></i> 출근 미확인")
            setTimeout(getAttendResult, 60000)
          }

        }
      })
    }
  }
    function chkReceiptAlert() {

        $.ajax({
               url: '@Url.Action("GetReceiptStatus", "Partial")',
               data: {
               },
                dataType: 'json',
                type: 'POST',
               beforeSend: function ()
               {

               }
        })
          .done(function (json) {
            $(".alertCnt2").empty();
            if (json.ok) {

                if (json.list.length > 0) {
                  $(".alertCnt2").html("!");
                  if ($("#ReceiptReady").length > 0) {

                    $("#receiptReadyList").empty();
                    var list_str = ""
                    for (var i = 0; i < json.list.length; i++) {
                      if (list_str != "") {
                        list_str += ", ";
                      }
                      list_str += json.list[i].r_type_name // + '(' + json.list[i].r_start + '~' + json.list[i].r_end + ')';
                    }
                    $("#receiptReadyList").html('(' + list_str + ')');
                    $("#ReceiptReady").removeClass("d-none");
                  }



                }
            }
        })
        .fail(function (e) {
            ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
        });

    }

    function chkAlertBadge() {

        $.ajax({
               url: '@Url.Action("GetNewAlram", "Partial")',
               data: {
               },
                dataType: 'json',
                type: 'POST',
               beforeSend: function ()
               {

               }
        })
        .done(function (json) {

            if (json.ok) {

                if (json.list.length > 0) {

                    var sb = new StringBuilder();

                    for (var i = 0; i < json.list.length; i++) {

                        var data = json.list[i];

                        var now = moment();
                        var msgTime = moment(data.create_dt);

                        var diff = moment.duration(now.diff(msgTime)).days();

                        var minTxt = "";
                        if (diff > 0) {
                            minTxt = diff + " 일 전"
                        }
                        else {

                            diff = moment.duration(now.diff(msgTime)).hours();

                            if (diff > 0) {
                                minTxt = diff + " 시간 전"
                            }
                            else {
                                diff = moment.duration(now.diff(msgTime)).minutes();
                                minTxt = diff + " 분 전"
                            }
                        }

                        sb.append("<a class='list-group-item dropdown-item cur_hand' href='javascript:void(0)' role='menuitem' onclick='AlarmConfirm(&#39;" + data.am_seq + "&#39;)'>");
                        sb.append("<div class='media'>");
                        sb.append("<div class='pr-10'>");
                        sb.append("<i class='icon wb-order bg-red-600 white icon-circle' aria-hidden='true'></i>");
                        sb.append("</div>");
                        sb.append("<div class='media-body'>");
                        sb.append("<h6 class='media-heading' title='" + data.message + "'>" + data.message + "</h6>");
                        sb.append("<time class='media-meta' datetime='" + data.create_dt + "'>" + minTxt + "</time>");
                        sb.append("</div>");
                        sb.append("</div>");
                        sb.append("</a>");
                    }
                    //debugger;
                    $("#alarm_content").empty();
                    $("#alarm_content").append(sb.toString());

                    $(".alertCnt").html(json.list.length);

                }
            } else {
                $("#alarm_content").empty();
                $("#alarm_content").append(errorItem);
            }
        })
        .fail(function (e) {
            ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
        });

    }

    function AlarmConfirm(am_seq) {

        $.ajax({
            url: '@Url.Action("AlarmConfirm", "Partial")',
            data: {
                am_seq: am_seq
            },
             dataType: 'json',
             type: 'POST',
            beforeSend: function ()
            {

            }
        })
        .done(function (json) {

            if (json.ok) {
                var url = decodeURIComponent(json.url);
                location.href = url;

            } else {
                ErrorAlert(json.message);
            }

            return true;
        })
        .fail(function (e) {
            ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
        });
    }

    function callPersonalModal() {
        $.ajax({
            url: '@Url.Action("PersonalModify", "Partial")',
            data: {

            },
            dataType: 'html',
            type: 'GET',
            beforeSend: function ()
            {
                $(".page").isLoading({
                    text: "Loading",
                    position: "overlay"
                });
            }
        })
        .done(function (view) {
            $(".page").isLoading("hide");

            $('#personalModal .modal-body').html(view)
            $('#personalModal').modal('toggle');
        })
        .fail(function (e) {
            $(".page").isLoading( "hide" );
            ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
        });
  }

  function callKpiModal() {
