            $('#kpiModal').modal('toggle');
        })
        .fail(function (e) {
            $(".page").isLoading( "hide" );
            ErrorAlert('알 수 없는 오류가 발생 했습니다.\n관리자에게 문의 하세요.');
        });
    }
