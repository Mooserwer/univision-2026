dle">          <div class="invoice-notes">            <label class="section-label-sm tx-gray-500">입금은행</label>            <p>- 은행 : 국민은행<br>- 계좌번호 : 389801-01-140852<br>- 예금주 : (주)유니코써치</p>          </div>        </td>        <td class="tx-right">소계</td>        <td colspan="2" class="tx-right">14,000,000 KRW</td>      </tr>      <tr>        <td class="tx-right">부가세</td>        <td colspan="2" class="tx-right">1,400,000 KRW</td>      </tr>      <tr>        <td class="tx-right tx-uppercase tx-bold tx-inverse">합계</td>        <td colspan="2" class="tx-right">          <span class="tx-primary tx-bold tx-indigo" id="inv_text_billing_money">15,400,000 KRW          </span>        </td>      </tr>    </tbody>  </table></div><!-- table-responsive --><hr class="mg-b-60">

