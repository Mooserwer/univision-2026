              </div>
            </div>

            <div class="col-md-1 offset-3">
              <button type="button" class="btn btn-sm btn-raised btn-primary btn-block" id="table-setdata">검색</button>
            </div>
          </div>
          <!-- block -->
        </div>

      </div>
    </div>
  </div>
  }

  <!-- //row -->
  <!-- row -->
  <div class="row" id="univision_activity_body">
    <div class="col-xl-12">
      <div class="panel custom1">
        <div class="panel-heading">
          <div class="panel-title">
            유니비전 주간 과정지표 데이터
          </div>
          <div class="panel-actions w-md-100">
            <div class="panel-action text-right w-full">
              <button type="button" class="btn btn-sm btn-raised btn-primary btn-block" id="download-xlsx">Excel</button>
            </div>
          </div>
        </div>
        
        <div class="panel-body p-10">
          <div id="projet_weekly_table" data-role="container">

          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- // row -->


</div>

@section scripts {
  <script type="text/javascript" src="https://oss.sheetjs.com/sheetjs/xlsx.full.min.js"></script>
  <script type="text/javascript">
        $(document).ready(function () {
            BindDatePicker($(".jDatePicker"));
        });

    function fSetDate(type) {
      var today = new Date();
      var today_str = getDateStr(today)
      $('#search_endDt').val(today_str);
      if (type == "day") {
        $('#search_startDt').val(today_str)

      } else if (type == "week") {
        $('#search_startDt').val(dateAdd(today_str, -7, "d"))
      } else if (type == "month") {
        $('#search_startDt').val(dateAdd(today_str, -1, "m"))
      }
    }

    function getDateStr(date) {
      // GET YYYY, MM AND DD FROM THE DATE OBJECT
      var yyyy = date.getFullYear().toString();
      var mm = (date.getMonth() + 1).toString();
      var dd = date.getDate().toString();

      // CONVERT mm AND dd INTO chars
      var mmChars = mm.split('');
      var ddChars = dd.split('');

      // CONCAT THE STRINGS IN YYYY-MM-DD FORMAT
      return yyyy + '-' + (mmChars[1] ? mm : "0" + mmChars[0]) + '-' + (ddChars[1] ? dd : "0" + ddChars[0]);

    }

    function dateAdd(sDate, v, t) {
      var yy = parseInt(sDate.substr(0, 4), 10);
      var mm = parseInt(sDate.substr(5, 2), 10);
      var dd = parseInt(sDate.substr(8), 10);

      if (t == "d") {
        d = new Date(yy, mm - 1, dd + v);
      } else if (t == "m") {
        d = new Date(yy, mm - 1 + v, dd);
      } else if (t == "y") {
        d = new Date(yy + v, mm - 1, dd);
      } else {
        d = new Date(yy, mm - 1, dd + v);
      }

      yy = d.getFullYear();
      mm = d.getMonth() + 1; mm = (mm < 10) ? '0' + mm : mm;
      dd = d.getDate(); dd = (dd < 10) ? '0' + dd : dd;

      return '' + yy + '-' + mm + '-' + dd;
    }

    var table = new Tabulator("#projet_weekly_table", {
      height: "500px",
      frozenRows: 0,
      columns: [
        { title: "프로젝트코드", field: "p_seq", sorter: "number", hozAlign: "right", editor: false, frozen: true},
        { title: "등록일자", field: "create_dt", sorter: "string",  hozAlign: "center", width:100 },
        { title: "종료일자", field: "close_dt", sorter: "string", hozAlign: "center", width: 100},
        //{ title: "종료/재진행사유", field: "status_comment", sorter: "string", width: 100 },
        { title: "고객사명", field: "client_kor_name", sorter: "string", width: 200, headerFilter: "input" },
        { title: "구인제목", field: "pjt_title", sorter: "string", headerFilter: "input" },
        { title: "프로젝트상태", field: "pjt_status_name", sorter: "string", hozAlign: "center", headerFilter: "list", headerFilterParams: { valuesLookup: true, clearable: true } },
        { title: "AM", field: "am", sorter: "string", headerFilter: "input" },
        { title: "SM", field: "sm", sorter: "string", headerFilter: "input" },
        { title: "후보자코드", field: "c_seq", sorter: "number" },
        { title: "후보자이름", field: "recan_name", sorter: "string", headerFilter: "input" },
        { title: "후보자상태", field: "recan_status", sorter: "string", headerFilter: "list", headerFilterParams: { valuesLookup: true, clearable: true } },
        { title: "상태일자", field: "recan_schedule_dt", sorter: "string", width: 100 },
        { title: "상태메모", field: "recan_memo", sorter: "string", width: 200, headerFilter: "input" },
        { title: "작업자", field: "recan_create_user_name", sorter: "string", headerFilter: "input" },
        { title: "작업일자", field: "recan_create_dt", sorter: "string", width: 100 }

      ],
      /*
      rowFormatter: function (row) {
        if (row.getData().pjt_status == 5) {
          row.getElement().classList.add("bg-success");
        } else if (row.getData().pjt_status == 4) {
          row.getElement().classList.add("bg-info");
        } else if (row.getData().pjt_status == 3 ) {
          row.getElement().classList.add("bg-danber");
        } else if (row.getData().pjt_status == 2) {
          row.getElement().classList.add("bg-waning");
        }
      },*/
      ajaxURL: "@Url.Action("ProjectActivityAjx", "Statistics")",
      ajaxConfig: "POST",
      ajaxContentType: "json",
      ajaxParams: function () {
        return { startDt: document.getElementById('search_startDt').value, endDt: document.getElementById('search_endDt').value } //ajax parameters
      },
      ajaxResponse: function (url, params, response) {
        //url - the URL of the request
        //params - the parameters passed with the request
        //response - the JSON object returned in the body of the response.

        return response.list; //return the tableData property of a response json object
      },
      pagination: "local",
      paginationSize: 100,
      paginationSizeSelector: [10, 20, 30, 50, 100],
      paginationCounter: "rows",

    });
    document.getElementById("table-setdata").addEventListener("click", function () {
      table.setData("@Url.Action("ProjectActivityAjx", "Statistics")");
    });

    document.getElementById("download-xlsx").addEventListener("click", function () {

      var range = document.getElementById('search_startDt').value.replace(/\-/gi, "") + "_" + document.getElementById('search_endDt').value.replace(/\-/gi, "")
      table.download("xlsx", "과정지표RAW데이터_" + range+".xlsx", { sheetName: "과정지표RAW데이터" });
    });

        function PopMemoList(from, to) {
            $.fancybox.open({
                href : "@Url.Action("UnivisionMemoList", "Statistics")",
                ajax : {
                    type: "post",
                    data: {
                        uv_seq: $('#search_uv_seq').val(),
                        from_month_str: from,
                        to_month_str : to
                    }
                },
                autoDimensions:false,
                type: 'ajax',
                padding: 5,
                scrolling : 'auto',
                autoSize: true,
                'title': '메모장 내역 (' + from + '~' + to+')',
                helpers: {
                    overlay: {
                        closeClick: false
                    }
                }
            });
        }

        function PopCandidateList(direct, from, to) {
