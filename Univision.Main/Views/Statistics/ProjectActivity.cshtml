                type: 'ajax',
                padding: 5,
                scrolling : 'auto',
                autoSize: false,
              'title': pop_title  + ' 후보자 현황 (' + from + '~' + to+')',
                helpers: {
                    overlay: {
                        closeClick: false
                    }
                }
            });
        }
    function PopHireList(status, from, to) {
      var pop_title = "채용";

            $.fancybox.open({
                href : "@Url.Action("UnivisionPjtHireCandidateList", "Statistics")",
                ajax : {
                    type: "post",
                    data: {
                      status: status,
                      uv_seq: $('#search_uv_seq').val(),
                      from_month_str: from,
                      to_month_str : to
                    }
                },
                autoDimensions:false,
                type: 'ajax',
                padding: 5,
                scrolling : 'auto',
                autoSize: false,
              'title': pop_title  + ' 후보자 현황 (' + from + '~' + to+')',
                helpers: {
                    overlay: {
                        closeClick: false
                    }
                }
            });
        }

        function PopCandidateUpdateList(from, to) {
            $.fancybox.open({
                href : "@Url.Action("UnivisionCandidateUpdateList", "Statistics")",
                ajax : {
                    type: "post",
                    data: {
                        uv_seq: $('#search_uv_seq').val(),
                        from_month_str: from,
                        to_month_str : to
                    }
                },
                autoDimensions:false,
                type: 'ajax',
                padding: 5,
                scrolling : 'auto',
                autoSize: false,
                'title': '후보자 업데이트현황 (' + from + '~' + to+')',
                helpers: {
