        }

        //권한별 부서, User select 제어
        function AuthControll(ua_seq) {
            var userDisabled = "";

            switch (ua_seq)
            {
                case 1:
                case 2:
                case 3:
                    userDisabled = "";
                    break;
                case 4:
                    userDisabled = "";
                    break;
                default:
                    userDisabled = "disabled";
                    break;

            }

            if (userDisabled != "")
                $("#search_uv_seq").attr("disabled", userDisabled);
        };


  </script>

}