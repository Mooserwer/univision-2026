              let timestamp = parseInt(dateString.match(/\d+/)[0]);
              let date = new Date(timestamp);

              // MM/d 형식으로 날짜 포맷
              let month = date.getMonth() + 1;  // getMonth()는 0부터 시작하므로 1을 더함
              let day = date.getDate();

              // 포맷이 'MM/d' 형식이 되도록 출력
              return `${month}/${day}`;
            } catch {
              return "";
            }
          },
        },
