@{
  Layout = null;
  string api_key = System.Configuration.ConfigurationManager.AppSettings["OpenAIApiMakeupKey"];
}
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>이력서 Makeup AI</title>
  <link rel="stylesheet" href="~/Libs/dropzone/css/dropzone_ai.css?v=1533562669" />
  <link rel="stylesheet" href="~/Libs/fontawesome/css/all.min.css?v4.1.0" />
  <script src="~/Scripts/jquery-3.3.1.min.js"></script>
  <script src="~/Libs/dropzone/js/dropzone.min.js?v=1533562669"></script>
  <style>
    /* ═══════════════════════════════════════════
     CSS 변수 (teal 팔레트)
    ═══════════════════════════════════════════ */
    *, *::before, *::after { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; height: 100%; }

    :root {
      --mu-primary:      #0d7377;
      --mu-primary-dark: #0b5e62;
      --mu-secondary:    #0e9090;
      --mu-success:      #10b981;
      --mu-danger:       #ef4444;
      --mu-warning:      #f59e0b;
      --mu-bg:           #f0f9f9;
      --mu-card:         #ffffff;
      --mu-border:       #b2d8d8;
      --mu-text:         #1e3a5f;
      --mu-muted:        #374151;
      --mu-radius:       14px;
      --mu-shadow:       0 4px 24px rgba(13,115,119,0.08);
      --mu-shadow-hover: 0 8px 32px rgba(13,115,119,0.16);
    }

    .mu-page {
      background: var(--mu-bg);
      min-height: 100vh;
      min-width: 780px;
      padding: 0 0 40px;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    /* ═══ 헤더 ══════════════════════════════════ */
    .mu-header {
      background: linear-gradient(135deg, #0d7377 0%, #0e9090 60%, #14b8a6 100%);
      padding: 20px 24px 16px;
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: 12px;
      position: relative; overflow: hidden;
      border-radius: 0 0 20px 20px; margin-bottom: 24px;
      box-shadow: 0 8px 32px rgba(13,115,119,0.3);
    }
    .mu-header::before {
      content: ''; position: absolute; top: -60px; right: -60px;
      width: 220px; height: 220px; border-radius: 50%;
      background: rgba(255,255,255,0.06); pointer-events: none;
    }
    .mu-header-left  { display: flex; align-items: center; gap: 12px; }
    .mu-header-icon  {
      width: 42px; height: 42px; background: rgba(255,255,255,0.18);
      border-radius: 10px; display: flex; align-items: center;
      justify-content: center; font-size: 20px; backdrop-filter: blur(4px); flex-shrink: 0;
    }
    .mu-header-title { color: #fff; font-size: 1.2rem; font-weight: 700; margin: 0; letter-spacing: -0.3px; text-shadow: 0 1px 4px rgba(0,0,0,0.15); }
    .mu-header-sub   { color: rgba(255,255,255,0.85); font-size: 0.88rem; margin: 2px 0 0; }
    .mu-v2-badge {
      display: inline-flex; align-items: center; gap: 4px;
      background: rgba(255,255,255,0.22); border: 1px solid rgba(255,255,255,0.35);
      color: #fff; border-radius: 20px; padding: 2px 10px;
      font-size: 0.75rem; font-weight: 700; letter-spacing: 0.05em;
      margin-left: 8px; vertical-align: middle;
    }
    .mu-header-right { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
    .mu-model-tag {
      display: inline-flex; align-items: center; gap: 7px;
      background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.28);
      color: rgba(255,255,255,0.95); border-radius: 8px;
      padding: 0 14px; font-size: 0.86rem; font-weight: 600;
      height: 34px; white-space: nowrap;
    }
    .mu-btn-reset {
      background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.25);
      color: rgba(255,255,255,0.9); border-radius: 8px; padding: 0 14px;
      font-size: 0.88rem; cursor: pointer; transition: background 0.2s, color 0.2s;
      text-decoration: none; display: inline-flex; align-items: center; gap: 7px;
      white-space: nowrap; height: 34px;
    }
    .mu-btn-reset:hover { background: rgba(255,255,255,0.25); color: #fff; text-decoration: none; }

    /* ═══ 2컬럼 ════════════════════════════════ */
    .mu-body { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; padding: 0 20px; align-items: start; }
    /* 최소 넓이 1100px 고정 — 1열 접힘 미디어쿼리 제거 */

    /* ═══ 업로드 카드 ═══════════════════════════ */
    .mu-upload-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
    @@media (max-width: 680px) { .mu-upload-grid { grid-template-columns: 1fr; } }

    .mu-upload-card {
      background: var(--mu-card); border-radius: var(--mu-radius);
      box-shadow: var(--mu-shadow); overflow: hidden; transition: box-shadow 0.25s;
    }
    .mu-upload-card:hover { box-shadow: var(--mu-shadow-hover); }
    .mu-upload-card-header {
      padding: 12px 16px 10px; display: flex; align-items: center; gap: 10px;
      border-bottom: 1px solid var(--mu-border);
    }
    .mu-lang-badge {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 4px 11px; border-radius: 20px; font-size: 0.88rem; font-weight: 700;
    }
    .mu-lang-badge.kr { background: linear-gradient(135deg, #ccf2f4, #b2e0e0); color: #0d7377; }
    .mu-lang-badge.en { background: linear-gradient(135deg, #fef3c7, #fde68a); color: #92400e; }
    .mu-upload-card-title { font-size: 0.97rem; font-weight: 600; color: var(--mu-text); }

    .mu-dropzone {
      border: 2px dashed var(--mu-border) !important; background: #f7fefe !important;
      border-radius: 0 !important; min-height: 130px !important;
      transition: border-color 0.25s, background 0.25s !important;
      margin: 0 !important; padding: 20px 14px !important;
      cursor: pointer !important;
    }
    .mu-dropzone:hover, .mu-dropzone.dz-drag-hover { border-color: var(--mu-primary) !important; background: #f0f9f9 !important; }
    .mu-dropzone .dz-message { text-align: center; margin: 0; }
    .mu-dz-icon { font-size: 1.8rem; margin-bottom: 6px; display: block; opacity: 0.4; }
    .mu-dz-text { font-size: 0.92rem; color: var(--mu-muted); line-height: 1.6; }
    .mu-dz-hint { font-size: 0.82rem; color: #4b5563; margin-top: 4px; display: block; }

    /* ═══ 안내 카드 ════════════════════════════ */
    .mu-notice-card {
      background: var(--mu-card); border-radius: var(--mu-radius);
      box-shadow: var(--mu-shadow); padding: 16px 18px; border-left: 4px solid var(--mu-primary);
      margin-top: 14px;
    }
    .mu-notice-title { font-size: 0.93rem; font-weight: 700; color: var(--mu-primary-dark); margin-bottom: 8px; display: flex; align-items: center; gap: 7px; }
    .mu-notice-list { list-style: none; margin: 0; padding: 0; }
    .mu-notice-list li { font-size: 0.88rem; color: var(--mu-muted); padding: 3px 0 3px 16px; position: relative; line-height: 1.6; }
    .mu-notice-list li::before { content: '–'; position: absolute; left: 0; color: #6b7280; }
    .mu-notice-list li.warn { color: #b45309; font-weight: 600; }
    .mu-notice-list li.warn::before { color: #f59e0b; }

    /* ═══ 사이드패널 ════════════════════════════ */
    .mu-sidebar { position: sticky; top: 20px; height: calc(100vh - 80px); display: flex; flex-direction: column; }
    .mu-panel { background: var(--mu-card); border-radius: var(--mu-radius); box-shadow: var(--mu-shadow); overflow: hidden; display: flex; flex-direction: column; flex: 1; min-height: 0; }
    .mu-panel-header {
      background: linear-gradient(135deg, #0d7377, #0e9090);
      padding: 13px 16px; display: flex; align-items: center; justify-content: space-between;
    }
    .mu-panel-title { color: #fff; font-size: 1rem; font-weight: 700; display: flex; align-items: center; gap: 8px; }
    .mu-panel-counts { display: flex; gap: 6px; }
    .mu-count-chip {
      padding: 3px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: 700;
      background: rgba(255,255,255,0.18); color: rgba(255,255,255,0.9); border: 1px solid rgba(255,255,255,0.2);
    }
    .mu-count-chip.done { background: rgba(16,185,129,0.3); color: #6ee7b7; border-color: rgba(16,185,129,0.4); }
    .mu-panel-empty { padding: 42px 18px; text-align: center; color: #4b5563; }
    .mu-panel-empty-icon { font-size: 2.5rem; opacity: 0.35; margin-bottom: 10px; display: block; }
    .mu-panel-empty-text { font-size: 0.92rem; line-height: 1.7; }
    .mu-jobs-list {
      flex: 1; overflow-y: auto; min-height: 0;
      padding: 10px; display: flex; flex-direction: column; gap: 10px;
    }
    .mu-jobs-list::-webkit-scrollbar       { width: 4px; }
    .mu-jobs-list::-webkit-scrollbar-track { background: #f1f5f9; }
    .mu-jobs-list::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }

    /* ═══ Job 카드 ══════════════════════════════ */
    .mu-job-card {
      background: #f8fafc; border: 1px solid var(--mu-border);
      border-radius: 10px; overflow: hidden;
      transition: box-shadow 0.2s, border-color 0.2s;
      animation: card-slide-in 0.3s ease-out;
      flex-shrink: 0;
    }
    .mu-job-card:hover { box-shadow: 0 2px 12px rgba(0,0,0,0.07); }
    .mu-job-card.is-complete { border-color: #10b981; background: linear-gradient(135deg, #f0fdf4, #f8fafc); box-shadow: 0 0 0 2px rgba(16,185,129,0.12); animation: job-complete-pop 0.5s ease-out; }
    .mu-job-card.is-error    { border-color: #ef4444; background: #fff5f5; }

    .mu-job-head { padding: 10px 12px 8px; display: flex; align-items: flex-start; gap: 8px; }
    .mu-job-lang { flex-shrink: 0; width: 28px; height: 28px; border-radius: 7px; display: flex; align-items: center; justify-content: center; font-size: 0.95rem; }
    .mu-job-lang.kr { background: #ccf2f4; }
    .mu-job-lang.en { background: #fef3c7; }
    .mu-job-info { flex: 1; min-width: 0; }
    .mu-job-name { font-size: 0.93rem; font-weight: 600; color: var(--mu-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .mu-job-status-text { font-size: 0.82rem; color: var(--mu-muted); margin-top: 2px; }
    .mu-job-badge { flex-shrink: 0; padding: 2px 8px; border-radius: 20px; font-size: 0.78rem; font-weight: 700; background: #e2e8f0; color: #1f2937; }
    .mu-job-badge.processing { background: #ccf2f4; color: #0d7377; animation: badge-pulse 2s ease-in-out infinite; }
    .mu-job-badge.done  { background: #d1fae5; color: #065f46; }
    .mu-job-badge.error { background: #fee2e2; color: #991b1b; }

    .mu-job-pbar-wrap  { padding: 0 12px 10px; }
    .mu-job-pbar-track { height: 5px; background: #e2e8f0; border-radius: 99px; overflow: hidden; }
    .mu-job-pbar-fill  {
      height: 100%; border-radius: 99px;
      background: linear-gradient(90deg, #0d7377, #14b8a6);
      transition: width 0.5s ease; position: relative;
    }
    .mu-job-pbar-fill::after { content: ''; position: absolute; top: 0; right: 0; width: 30px; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5)); animation: pbar-shine 1.5s linear infinite; }
    .mu-job-pbar-fill.is-done  { background: linear-gradient(90deg, #10b981, #34d399); }
    .mu-job-pbar-fill.is-done::after  { display: none; }
    .mu-job-pbar-fill.is-error { background: #ef4444; }
    .mu-job-pbar-fill.is-error::after { display: none; }
    .mu-job-pct { font-size: 0.8rem; color: var(--mu-muted); margin-top: 4px; }

    .mu-job-log-toggle { width: 100%; background: none; border: none; border-top: 1px dashed #e2e8f0; padding: 6px 12px; font-size: 0.82rem; color: #4b5563; cursor: pointer; text-align: left; display: flex; align-items: center; gap: 5px; transition: background 0.15s; }
    .mu-job-log-toggle:hover { background: #f1f5f9; }
    .mu-job-logs { display: none; padding: 8px 12px; background: #f8fafc; border-top: 1px solid #f1f5f9; max-height: 200px; overflow-y: auto; }
    .mu-job-logs.is-open { display: block; }

    .mu-download-area { padding: 12px; text-align: center; background: linear-gradient(135deg, #f0fdf4, #ecfdf5); border-top: 1px solid #a7f3d0; }
    .mu-download-btn {
      display: inline-flex; align-items: center; gap: 8px;
      background: linear-gradient(135deg, #10b981, #059669); color: #fff; border: none;
      border-radius: 10px; padding: 10px 22px; font-size: 0.97rem; font-weight: 700;
      cursor: pointer; text-decoration: none; box-shadow: 0 4px 14px rgba(16,185,129,0.4);
      transition: transform 0.2s, box-shadow 0.2s; animation: download-pulse 1.8s ease-in-out 3;
    }
    .mu-download-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(16,185,129,0.55); color: #fff; text-decoration: none; }
    .mu-download-btn.is-downloaded {
      background: linear-gradient(135deg, #94a3b8, #64748b);
      box-shadow: 0 3px 10px rgba(71,85,105,0.3); animation: none;
    }
    .mu-download-btn.is-downloaded:hover { box-shadow: 0 5px 16px rgba(71,85,105,0.45); }
    .mu-download-filename { font-size: 0.78rem; opacity: 0.85; display: block; font-weight: 400; margin-top: 2px; }

    .mu-log-item { display: flex; gap: 7px; padding: 5px 0; border-bottom: 1px solid #e9ecef; font-size: 0.86rem; }
    .mu-log-item:last-child { border-bottom: none; }
    .mu-log-icon { flex-shrink: 0; font-size: 0.8rem; margin-top: 1px; }
    .mu-log-body { flex: 1; min-width: 0; }
    .mu-log-time { color: #4b5563; font-size: 0.78rem; }
    .mu-log-text { flex: 1; min-width: 0; color: #1f2937; margin-top: 2px; word-break: break-word; }

    /* ═══ 애니메이션 ════════════════════════════ */
    @@keyframes pbar-shine {
      0%   { opacity: 0; transform: translateX(-20px); }
      50%  { opacity: 1; }
      100% { opacity: 0; transform: translateX(20px); }
    }
    @@keyframes badge-pulse {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.6; }
    }
    @@keyframes download-pulse {
      0%   { box-shadow: 0 4px 14px rgba(16,185,129,0.4); }
      50%  { box-shadow: 0 4px 28px rgba(16,185,129,0.75), 0 0 50px rgba(16,185,129,0.2); }
      100% { box-shadow: 0 4px 14px rgba(16,185,129,0.4); }
    }
    @@keyframes job-complete-pop {
      0%   { transform: scale(0.98); }
      50%  { transform: scale(1.015); }
      100% { transform: scale(1); }
    }
    @@keyframes card-slide-in {
      from { opacity: 0; transform: translateY(-10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @@keyframes spin { to { transform: rotate(360deg); } }
    @@keyframes sparkle-anim {
      0%   { opacity: 1; transform: scale(0); }
      60%  { opacity: 1; transform: scale(1); }
      100% { opacity: 0; transform: scale(0.8) translateY(-15px); }
    }

    /* ═══════════════════════════════════════════
     800px 팝업 최적화 오버라이드 (가로 2컬럼 유지)
    ═══════════════════════════════════════════ */
    .mu-header { padding: 12px 14px 10px; margin-bottom: 14px; border-radius: 0 0 14px 14px; gap: 8px; }
    .mu-header-icon  { width: 34px; height: 34px; font-size: 16px; }
    .mu-header-title { font-size: 1.02rem; }
    .mu-header-sub   { font-size: 0.78rem; }
    .mu-v2-badge     { font-size: 0.68rem; padding: 2px 8px; margin-left: 6px; }
    .mu-model-tag    { font-size: 0.78rem; padding: 0 10px; height: 30px; }
    .mu-btn-reset    { font-size: 0.8rem;  padding: 0 10px; height: 30px; }

    .mu-body { gap: 10px; padding: 0 10px; }

    /* 업로드 카드: 좌측 컬럼 안에서 세로 적재 */
    .mu-upload-grid { grid-template-columns: 1fr; gap: 10px; margin-bottom: 10px; }
    .mu-upload-card-header { padding: 9px 12px 8px; }
    .mu-upload-card-title  { font-size: 0.88rem; }
    .mu-lang-badge { font-size: 0.8rem; padding: 3px 9px; }
    .mu-dropzone { min-height: 90px !important; padding: 12px 10px !important; }
    .mu-dz-icon  { font-size: 1.4rem; margin-bottom: 4px; }
    .mu-dz-text  { font-size: 0.84rem; }
    .mu-dz-hint  { font-size: 0.75rem; }

    .mu-notice-card { padding: 12px 13px; margin-top: 10px; }
    .mu-notice-title { font-size: 0.86rem; }
    .mu-notice-list li { font-size: 0.8rem; }

    .mu-sidebar { top: 10px; height: calc(100vh - 60px); }
    .mu-panel-header { padding: 10px 12px; }
    .mu-panel-title  { font-size: 0.9rem; }
    .mu-jobs-list { padding: 8px; gap: 8px; }
    .mu-download-btn { padding: 8px 16px; font-size: 0.88rem; }
  </style>
</head>
<body>

<div class="mu-page">

  @* ▶ 헤더 *@
  <div class="mu-header">
    <div class="mu-header-left">
      <div class="mu-header-icon">✨</div>
      <div>
        <div class="mu-header-title">
          이력서 Makeup AI
          <span class="mu-v2-badge"><i class="fas fa-bolt" style="font-size:0.7rem;"></i> New</span>
        </div>
        <div class="mu-header-sub">GPT를 통해 이력서를 분석하고 Makeup을 진행합니다.</div>
      </div>
    </div>
    <div class="mu-header-right">
      <input type="hidden" id="gpt_model" value="gpt-5.4-mini" />
      <span class="mu-model-tag"><i class="fas fa-robot"></i> GPT-5.4 Mini</span>
      <a href="javascript:ResetUploadPage();" class="mu-btn-reset">
        <i class="fa fa-redo" style="font-size:0.72rem;"></i> 초기화
      </a>
    </div>
  </div>

  <!-- ▶ 메인 2컬럼 -->
  <div class="mu-body">

    <!-- 좌측: 업로드 영역 -->
    <div class="mu-upload-section">
      <div class="mu-upload-grid">

        <!-- 국문 -->
        <div class="mu-upload-card">
          <div class="mu-upload-card-header">
            <span class="mu-lang-badge kr">🇰🇷 국문</span>
            <span class="mu-upload-card-title">한국어 이력서</span>
          </div>
          <form id="form_makeup_kr" class="mu-dropzone">
            <div class="dz-message">
              <span class="mu-dz-icon">📄</span>
              <div class="mu-dz-text">파일을 드래그하거나<br>클릭하여 업로드</div>
              <span class="mu-dz-hint">PDF, DOCX, HWP 지원</span>
            </div>
          </form>
        </div>

        <!-- 영문 -->
        <div class="mu-upload-card">
          <div class="mu-upload-card-header">
            <span class="mu-lang-badge en">🌐 영문</span>
            <span class="mu-upload-card-title">English Resume</span>
          </div>
          <form id="form_makeup_en" class="mu-dropzone">
            <div class="dz-message">
              <span class="mu-dz-icon">📄</span>
              <div class="mu-dz-text">Drop file or<br>click to upload</div>
              <span class="mu-dz-hint">PDF, DOCX, HWP supported</span>
            </div>
          </form>
        </div>

      </div><!-- /upload-grid -->


      <!-- 안내사항 -->
      <div class="mu-notice-card">
        <div class="mu-notice-title">
          <i class="fas fa-exclamation-triangle" style="color:#f59e0b;"></i>
          GPT 분석 시 주의사항
        </div>
        <ul class="mu-notice-list">
          <li class="warn">GPT가 분석한 내용은 정확하지 않을 수 있습니다. 누락되거나 잘못된 정보가 포함될 수 있으므로 반드시 검수 후 사용하세요.</li>
          <li class="warn">학력/경력 기간, 경력 상세정보 들여쓰기, 자격증, 기타 사항 등을 꼭 확인해주세요.</li>
          <li>PDF·DOCX 파일은 GPT에 직접 업로드하여 더 정확하게 분석합니다.</li>
          <li>HWP 파일은 서버에서 텍스트를 추출하여 전달합니다.</li>
          <li>자기소개 내용은 생성하지 않습니다. (직접 붙여넣기 해주세요.)</li>
          <li>이미지로만 구성된 스캔 PDF는 텍스트 인식이 되지 않을 수 있습니다.</li>
        </ul>
      </div>

    </div><!-- /upload-section -->

    <!-- 우측: 사이드패널 -->
    <div class="mu-sidebar">
      <div class="mu-panel">
        <div class="mu-panel-header">
          <div class="mu-panel-title"><i class="fas fa-tasks"></i> 처리 현황</div>
          <div class="mu-panel-counts">
            <span class="mu-count-chip"      id="chip_total" style="display:none;"></span>
            <span class="mu-count-chip done" id="chip_done"  style="display:none;"></span>
          </div>
        </div>
        <div id="mu_empty_state" class="mu-panel-empty">
          <span class="mu-panel-empty-icon">📭</span>
          <div class="mu-panel-empty-text">
            아직 업로드된 파일이 없습니다.<br>
            좌측에서 이력서를 업로드해주세요.
          </div>
        </div>
        <div class="mu-jobs-list" id="mu_jobs_list" style="display:none;"></div>
      </div>
    </div><!-- /sidebar -->

  </div><!-- /mu-body -->
</div><!-- /mu-page -->

<!-- 스크립트: Scripts/gpt 폴더 (독립 경로) -->
<script src="~/Scripts/gpt/makeup_manager.js?a1"></script>
<script src="~/Scripts/gpt/makeup_prompts.js?a1"></script>
<script src="~/Scripts/gpt/makeup_schema.js?a1"></script>
<script src="~/Scripts/gpt/makeup_manager5.js?a2"></script>

<script type="text/javascript">
  const API_KEY                    = "@api_key";
  window.url_make_makeup2          = "@Url.Action("MakeMakeup2026",       "nGpt")";
  window.url_gpt_resume_upload     = "@Url.Action("GptResumeUpload",      "nGpt")";
  window.url_guh_create            = "@Url.Action("CreateGptUseHistory",  "nGpt")";
  window.url_guh_complete          = "@Url.Action("CompleteGptUseHistory","nGpt")";
  window.url_guh_fail              = "@Url.Action("FailGptUseHistory",    "nGpt")";
</script>

<script type="text/javascript">
  // ─────────────────────────────────────────────────────────
  //  시스템 프롬프트
  // ─────────────────────────────────────────────────────────
  // 프롬프트는 Scripts/gpt/makeup_prompts.js 에서 공용 관리
  // v5_kr_nc_prompt, v5_kr_oc_prompt, v5_en_nc_prompt, v5_en_oc_prompt

  // ─────────────────────────────────────────────────────────
  //  공통 카운터 UI
  // ─────────────────────────────────────────────────────────
  Dropzone.autoDiscover = false;

  let working_cnt = 0;
  let total_cnt   = 0;
  let done_cnt    = 0;

  function updateSidebarCounts() {
    var ct = document.getElementById('chip_total');
    var cd = document.getElementById('chip_done');
    if (total_cnt > 0) { ct.style.display = ''; ct.textContent = '전체 ' + total_cnt + '건'; }
    if (done_cnt  > 0) { cd.style.display = ''; cd.textContent = '✅ ' + done_cnt + '건 완료'; }
  }

  function showJobsList() {
    document.getElementById('mu_empty_state').style.display = 'none';
    document.getElementById('mu_jobs_list').style.display   = '';
  }

  // ─────────────────────────────────────────────────────────
  //  DB 이력 헬퍼
  // ─────────────────────────────────────────────────────────
  async function guhCreate(fileName, lang, model) {
    try {
      var res  = await fetch(window.url_guh_create, {
        method:  "POST",
        headers: { "Content-Type": "application/json" },
        body:    JSON.stringify({ use_type: 1, file_path: fileName, req_lang: lang, gpt_model: model })
      });
      var data = await res.json();
      return data.ok ? data.guh_seq : null;
    } catch { return null; }
  }

  async function guhComplete(guh_seq, ncJson, ocJson, outputFile, outputPath, procSec) {
    if (!guh_seq) return;
    var pathOnly = outputPath;
    if (pathOnly) {
      try { pathOnly = new URL(pathOnly).pathname; } catch (e) {}
    }
    try {
      await fetch(window.url_guh_complete, {
        method:  "POST",
        headers: { "Content-Type": "application/json" },
        body:    JSON.stringify({
          guh_seq,
          result_nc:   JSON.stringify(ncJson),
          result_oc:   JSON.stringify(ocJson),
          output_file: outputFile,
          output_path: pathOnly,
          proc_sec:    procSec
        })
      });
    } catch { }
  }

  async function guhFail(guh_seq, errorMsg) {
    if (!guh_seq) return;
    try {
      await fetch(window.url_guh_fail, {
        method:  "POST",
        headers: { "Content-Type": "application/json" },
        body:    JSON.stringify({ guh_seq, error_msg: errorMsg })
      });
    } catch { }
  }

  // ─────────────────────────────────────────────────────────
  //  공통 GPT 처리 (NC → OC → 파일 생성)
  // ─────────────────────────────────────────────────────────
  async function runGptProcess(worker, lang, fileName) {
    var startTime    = Date.now();
    var currentModel = document.getElementById('gpt_model').value;

    var guhPromise = guhCreate(fileName, lang, currentModel).catch(() => null);

    if (worker.useFileUpload) {
      worker.updateProgress(8, "OpenAI 파일 업로드 중");
      try {
        await worker._uploadToOpenAI();
      } catch (e) {
        worker.addLog("danger", e.message);
        guhPromise.then(function(seq) { guhFail(seq, e.message); }).catch(() => {});
        return;
      }
    }

    var isKR = (lang === "KR");

    worker.updateProgress(15, "기본정보 분석 중");
    var ncSchema = isKR ? gpt5_nc_schema2 : gpt5_nc_schema;
    var ncData   = await worker.fetchStructured(ncSchema, "resume_nc",
                     isKR ? v5_kr_nc_prompt : v5_en_nc_prompt, "기본정보");
    if (!ncData) {
      await worker._deleteFromOpenAI();
      guhPromise.then(function(seq) { guhFail(seq, "기본정보(NC) 분석 실패"); }).catch(() => {});
      return;
    }

    worker.updateProgress(55, "경력사항 분석 중");
    var ocData = await worker.fetchStructured(gpt5_oc_schema_simple, "resume_oc",
                   isKR ? v5_kr_oc_prompt : v5_en_oc_prompt, "경력사항");

    await worker._deleteFromOpenAI();

    if (!ocData) {
      guhPromise.then(function(seq) { guhFail(seq, "경력사항(OC) 분석 실패"); }).catch(() => {});
      return;
    }

    worker.updateProgress(80, "파일 생성 중");
    var finalModel = worker._buildModel(ncData, ocData);
    var fileResult = await worker.createResumeFile(finalModel);
    var procSec    = ((Date.now() - startTime) / 1000).toFixed(1);

    var guh_seq = await guhPromise;
    if (fileResult && fileResult.ok) {
      await guhComplete(guh_seq, ncData, ocData, fileResult.file_name, fileResult.file_url, parseFloat(procSec));
    } else {
      await guhFail(guh_seq, (fileResult && fileResult.message) || "파일 생성 실패");
    }
  }

  // ─────────────────────────────────────────────────────────
  //  PDF / DOCX / HWP — OpenAI 직접 처리
  // ─────────────────────────────────────────────────────────
  function handleDirectFile(lang, file) {
    working_cnt++; total_cnt++;
    showJobsList(); updateSidebarCounts();

    var currentModel = document.getElementById('gpt_model').value;
    var worker = new ResumeMakeupManager5(lang, working_cnt, currentModel, function() {
      done_cnt++; updateSidebarCounts();
    });

    if (!worker.initDirect(file)) return;
    runGptProcess(worker, lang, file.name);
  }

  // ─────────────────────────────────────────────────────────
  //  Dropzone 초기화
  // ─────────────────────────────────────────────────────────
  function makeDz(formId, lang) {
    try {
      var el = document.getElementById(formId);
      if (el && el.dropzone) el.dropzone.destroy();

      var dz = new Dropzone("#" + formId, {
        url:              "/dummy",
        autoProcessQueue: false,
        previewTemplate:  '<div style="display:none;"></div>'
      });

      dz.on("addedfile", function(file) {
        handleDirectFile(lang, file);
      });

      return dz;
    } catch (e) {
      console.error("[MakeupAI] Dropzone init error:", formId, e);
      return null;
    }
  }

  var myDropzoneKR = makeDz("form_makeup_kr", "KR");
  var myDropzoneEn = makeDz("form_makeup_en", "EN");

  function ResetUploadPage() {
    if (confirm("업로드 화면을 초기화 하시겠습니까?")) {
      location.reload();
    }
  }
</script>

</body>
</html>
