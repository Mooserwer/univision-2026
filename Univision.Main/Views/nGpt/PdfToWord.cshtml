@{
  Layout = null;
}
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PDF → Word 변환</title>
  <link rel="stylesheet" href="~/Libs/dropzone/css/dropzone_ai.css?v=1533562669" />
  <link rel="stylesheet" href="~/Libs/fontawesome/css/all.min.css?v4.1.0" />
  <script src="~/Scripts/jquery-3.3.1.min.js"></script>
  <script src="~/Libs/dropzone/js/dropzone.min.js?v=1533562669"></script>
  <style>
    *, *::before, *::after {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      padding: 0;
      height: 100%;
    }

    /* ═══════════════════════════════════════════
     CSS 변수
    ═══════════════════════════════════════════ */
    :root {
      --pw-primary: #0d7377;
      --pw-primary-dark: #0b5e62;
      --pw-secondary: #0e9090;
      --pw-success: #10b981;
      --pw-danger: #ef4444;
      --pw-bg: #f0f9f9;
      --pw-card: #ffffff;
      --pw-border: #b2d8d8;
      --pw-text: #1e3a5f;
      --pw-muted: #374151;
      --pw-radius: 14px;
      --pw-shadow: 0 4px 24px rgba(13,115,119,0.08);
      --pw-shadow-hover: 0 8px 32px rgba(13,115,119,0.16);
    }

    /* ═══ 페이지 래퍼 ═══════════════════════════ */
    .pw-page {
      background: var(--pw-bg);
      min-height: 100vh;
      min-width: 780px;
      padding: 0 0 40px;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    /* ═══ 헤더 ══════════════════════════════════ */
    .pw-header {
      background: linear-gradient(135deg, #0d7377 0%, #0e9090 60%, #14b8a6 100%);
      padding: 20px 24px 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
      position: relative;
      overflow: hidden;
      border-radius: 0 0 20px 20px;
      margin-bottom: 24px;
      box-shadow: 0 8px 32px rgba(13,115,119,0.3);
    }

      .pw-header::before {
        content: '';
        position: absolute;
        top: -60px;
        right: -60px;
        width: 220px;
        height: 220px;
        border-radius: 50%;
        background: rgba(255,255,255,0.06);
        pointer-events: none;
      }

    .pw-header-left {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .pw-header-icon {
      width: 42px;
      height: 42px;
      background: rgba(255,255,255,0.18);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      backdrop-filter: blur(4px);
      flex-shrink: 0;
    }

    .pw-header-title {
      color: #fff;
      font-size: 1.2rem;
      font-weight: 700;
      margin: 0;
      letter-spacing: -0.3px;
      text-shadow: 0 1px 4px rgba(0,0,0,0.15);
    }

    .pw-header-sub {
      color: rgba(255,255,255,0.85);
      font-size: 0.88rem;
      margin: 2px 0 0;
    }

    .pw-header-right {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .pw-btn-reset {
      background: rgba(255,255,255,0.15);
      border: 1px solid rgba(255,255,255,0.25);
      color: rgba(255,255,255,0.9);
      border-radius: 8px;
      padding: 0 14px;
      font-size: 0.88rem;
      cursor: pointer;
      transition: background 0.2s, color 0.2s;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 7px;
      white-space: nowrap;
      height: 34px;
    }

      .pw-btn-reset:hover {
        background: rgba(255,255,255,0.25);
        color: #fff;
        text-decoration: none;
      }

    /* ═══ 2컬럼 레이아웃 ════════════════════════ */
    .pw-body {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      padding: 0 20px;
      align-items: start;
    }
    /* 최소 넓이 780px 고정 — 1열 접힘 미디어쿼리 제거 */

    /* ═══ 업로드 카드 ═══════════════════════════ */
    .pw-upload-card {
      background: var(--pw-card);
      border-radius: var(--pw-radius);
      box-shadow: var(--pw-shadow);
      overflow: hidden;
      transition: box-shadow 0.25s;
      margin-bottom: 14px;
    }

      .pw-upload-card:hover {
        box-shadow: var(--pw-shadow-hover);
      }

    .pw-upload-card-header {
      padding: 12px 16px 10px;
      display: flex;
      align-items: center;
      gap: 10px;
      border-bottom: 1px solid var(--pw-border);
    }

    .pw-card-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 4px 11px;
      border-radius: 20px;
      font-size: 0.88rem;
      font-weight: 700;
      background: linear-gradient(135deg, #ccf2f4, #b2e0e0);
      color: #0d7377;
    }

    .pw-upload-card-title {
      font-size: 0.97rem;
      font-weight: 600;
      color: var(--pw-text);
    }

    /* Dropzone */
    .pw-dropzone {
      border: 2px dashed var(--pw-border) !important;
      background: #f7fefe !important;
      border-radius: 0 !important;
      min-height: 180px !important;
      transition: border-color 0.25s, background 0.25s !important;
      margin: 0 !important;
      padding: 32px 16px !important;
      cursor: pointer !important;
    }

      .pw-dropzone:hover, .pw-dropzone.dz-drag-hover {
        border-color: var(--pw-primary) !important;
        background: #f0f9f9 !important;
      }

      .pw-dropzone .dz-message {
        text-align: center;
        margin: 0;
      }

    .pw-dz-icon {
      font-size: 2.6rem;
      margin-bottom: 10px;
      display: block;
      opacity: 0.5;
    }

    .pw-dz-text {
      font-size: 0.93rem;
      color: var(--pw-muted);
      line-height: 1.7;
    }

    .pw-dz-hint {
      font-size: 0.83rem;
      color: #4b5563;
      margin-top: 4px;
      display: block;
    }

    /* ═══ 로고 삽입 카드 ═══════════════════════ */
    .pw-logo-card {
      background: var(--pw-card);
      border-radius: var(--pw-radius);
      box-shadow: var(--pw-shadow);
      overflow: hidden;
      margin-bottom: 14px;
    }

    .pw-logo-card-header {
      padding: 12px 16px 10px;
      display: flex;
      align-items: center;
      gap: 10px;
      border-bottom: 1px solid var(--pw-border);
      flex-wrap: wrap;
    }

    .pw-logo-hint {
      font-size: 0.8rem;
      color: #6b7280;
      margin-left: auto;
    }

    .pw-logo-opts {
      display: flex;
      align-items: center;
      gap: 22px;
      flex-wrap: wrap;
      padding: 10px 16px;
      border-bottom: 1px solid var(--pw-border);
      background: #fcfffe;
    }

    .pw-logo-opt-group {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .pw-logo-opt-label {
      font-size: 0.84rem;
      font-weight: 700;
      color: #6b7280;
      white-space: nowrap;
    }

    .pw-logo-seg {
      display: inline-flex;
      border: 1px solid #cfd8d8;
      border-radius: 8px;
      overflow: hidden;
    }

      .pw-logo-seg label {
        margin: 0;
        cursor: pointer;
      }

        .pw-logo-seg label + label {
          border-left: 1px solid #cfd8d8;
        }

      .pw-logo-seg input {
        display: none;
      }

      .pw-logo-seg span {
        display: inline-block;
        padding: 5px 14px;
        font-size: 0.84rem;
        font-weight: 600;
        color: #6b7280;
        background: #fff;
        transition: background 0.15s, color 0.15s;
      }

      .pw-logo-seg input:checked + span {
        background: #0d7377;
        color: #fff;
      }

    .pw-logo-dropzone {
      min-height: 110px !important;
      padding: 16px 12px !important;
    }

    /* ═══ 탭 (로고삽입 / 연락처삭제) ═══════════ */
    .pw-tabs {
      display: flex;
      border-bottom: 1px solid var(--pw-border);
      background: #f7fefe;
    }

    .pw-tab {
      flex: 1;
      border: none;
      background: transparent;
      cursor: pointer;
      padding: 11px 12px;
      font-size: 0.92rem;
      font-weight: 700;
      color: #6b7280;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      border-bottom: 2px solid transparent;
      transition: color 0.15s, border-color 0.15s, background 0.15s;
      font-family: inherit;
    }

      .pw-tab:hover {
        color: var(--pw-primary);
        background: #f0f9f9;
      }

      .pw-tab.active {
        color: var(--pw-primary-dark);
        border-bottom-color: var(--pw-primary);
        background: #fff;
      }

    .pw-tool-desc {
      padding: 10px 16px;
      font-size: 0.86rem;
      color: var(--pw-muted);
      line-height: 1.6;
      background: #fcfffe;
      border-bottom: 1px solid var(--pw-border);
    }

    .pw-logo-status {
      padding: 10px 14px;
      background: #f7fefe;
      border-top: 1px solid var(--pw-border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 10px;
    }

    .pw-logo-status-text {
      font-size: 0.9rem;
      color: var(--pw-muted);
    }

    .pw-logo-download-btn {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      background: linear-gradient(135deg, #0d7377, #0e9090);
      color: #fff;
      border-radius: 8px;
      padding: 7px 18px;
      font-size: 0.9rem;
      font-weight: 700;
      text-decoration: none;
      box-shadow: 0 3px 10px rgba(13,115,119,0.35);
      transition: transform 0.15s, box-shadow 0.15s;
    }

      .pw-logo-download-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 5px 16px rgba(13,115,119,0.5);
        color: #fff;
        text-decoration: none;
      }

    .pw-logo-spinner {
      display: inline-block;
      width: 14px;
      height: 14px;
      border: 2px solid #b2d8d8;
      border-top-color: #0d7377;
      border-radius: 50%;
      animation: pw-spin 0.7s linear infinite;
      vertical-align: middle;
      margin-right: 5px;
    }

    @@keyframes pw-spin {
      to {
        transform: rotate(360deg);
      }
    }

    /* ═══ 안내 카드 ════════════════════════════ */
    .pw-notice-card {
      background: var(--pw-card);
      border-radius: var(--pw-radius);
      box-shadow: var(--pw-shadow);
      padding: 16px 18px;
      border-left: 4px solid var(--pw-primary);
    }

    .pw-notice-title {
      font-size: 0.93rem;
      font-weight: 700;
      color: var(--pw-primary-dark);
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 7px;
    }

    .pw-notice-list {
      list-style: none;
      margin: 0;
      padding: 0;
    }

      .pw-notice-list li {
        font-size: 0.88rem;
        color: var(--pw-muted);
        padding: 3px 0 3px 16px;
        position: relative;
        line-height: 1.6;
      }

        .pw-notice-list li::before {
          content: '–';
          position: absolute;
          left: 0;
          color: #6b7280;
        }

        .pw-notice-list li.warn {
          color: #b45309;
          font-weight: 600;
        }

          .pw-notice-list li.warn::before {
            color: #f59e0b;
          }

    /* ═══ 사이드패널 ════════════════════════════ */
    .pw-sidebar {
      position: sticky;
      top: 20px;
      max-height: calc(100vh - 40px);
      display: flex;
      flex-direction: column;
    }

    .pw-panel {
      background: var(--pw-card);
      border-radius: var(--pw-radius);
      box-shadow: var(--pw-shadow);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      flex: 1;
      min-height: 0;
    }

    .pw-panel-header {
      background: linear-gradient(135deg, #0d7377, #0e9090);
      padding: 13px 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .pw-panel-title {
      color: #fff;
      font-size: 1rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .pw-panel-counts {
      display: flex;
      gap: 6px;
    }

    .pw-count-chip {
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: 700;
      background: rgba(255,255,255,0.18);
      color: rgba(255,255,255,0.9);
      border: 1px solid rgba(255,255,255,0.2);
    }

      .pw-count-chip.done {
        background: rgba(16,185,129,0.3);
        color: #6ee7b7;
        border-color: rgba(16,185,129,0.4);
      }

    .pw-panel-empty {
      padding: 42px 18px;
      text-align: center;
      color: #4b5563;
    }

    .pw-panel-empty-icon {
      font-size: 2.5rem;
      opacity: 0.35;
      margin-bottom: 10px;
      display: block;
    }

    .pw-panel-empty-text {
      font-size: 0.92rem;
      line-height: 1.7;
    }

    .pw-jobs-list {
      flex: 1;
      overflow-y: auto;
      min-height: 0;
      padding: 10px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

      .pw-jobs-list::-webkit-scrollbar {
        width: 4px;
      }

      .pw-jobs-list::-webkit-scrollbar-track {
        background: #f1f5f9;
      }

      .pw-jobs-list::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 4px;
      }

    /* ═══ Job 카드 ══════════════════════════════ */
    .pw-job-card {
      background: #f8fafc;
      border: 1px solid var(--pw-border);
      border-radius: 10px;
      overflow: hidden;
      transition: box-shadow 0.2s, border-color 0.2s;
      animation: pw-card-slide-in 0.3s ease-out;
      flex-shrink: 0;
    }

      .pw-job-card:hover {
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
      }

      .pw-job-card.is-complete {
        border-color: #10b981;
        background: linear-gradient(135deg, #f0fdf4, #f8fafc);
        box-shadow: 0 0 0 2px rgba(16,185,129,0.12);
      }

      .pw-job-card.is-error {
        border-color: #ef4444;
        background: #fff5f5;
      }

    .pw-job-head {
      padding: 10px 12px 8px;
      display: flex;
      align-items: flex-start;
      gap: 8px;
    }

    .pw-job-icon {
      flex-shrink: 0;
      width: 28px;
      height: 28px;
      border-radius: 7px;
      background: #ccf2f4;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.95rem;
    }

    .pw-job-info {
      flex: 1;
      min-width: 0;
    }

    .pw-job-name {
      font-size: 0.93rem;
      font-weight: 600;
      color: var(--pw-text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .pw-job-status-text {
      font-size: 0.82rem;
      color: var(--pw-muted);
      margin-top: 2px;
    }

    .pw-job-badge {
      flex-shrink: 0;
      padding: 2px 8px;
      border-radius: 20px;
      font-size: 0.78rem;
      font-weight: 700;
      background: #e2e8f0;
      color: #1f2937;
    }

      .pw-job-badge.processing {
        background: #ccf2f4;
        color: #0d7377;
        animation: pw-badge-pulse 2s ease-in-out infinite;
      }

      .pw-job-badge.done {
        background: #d1fae5;
        color: #065f46;
      }

      .pw-job-badge.error {
        background: #fee2e2;
        color: #991b1b;
      }

    /* 프로그레스 바 */
    .pw-job-pbar-wrap {
      padding: 0 12px 10px;
    }

    .pw-job-pbar-track {
      height: 5px;
      background: #e2e8f0;
      border-radius: 99px;
      overflow: hidden;
    }

    .pw-job-pbar-fill {
      height: 100%;
      border-radius: 99px;
      width: 100%;
      background: linear-gradient(90deg, #0d7377 0%, #14b8a6 50%, #0d7377 100%);
      background-size: 200% 100%;
      animation: pw-pbar-shimmer 1.5s linear infinite;
    }

      .pw-job-pbar-fill.is-done {
        background: linear-gradient(90deg, #10b981, #34d399);
        animation: none;
      }

      .pw-job-pbar-fill.is-error {
        background: #ef4444;
        animation: none;
      }

    /* 다운로드 영역 */
    .pw-download-area {
      padding: 12px;
      text-align: center;
      background: linear-gradient(135deg, #f0fdf4, #ecfdf5);
      border-top: 1px solid #a7f3d0;
    }

    .pw-download-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: linear-gradient(135deg, #10b981, #059669);
      color: #fff;
      border: none;
      border-radius: 10px;
      padding: 10px 22px;
      font-size: 0.97rem;
      font-weight: 700;
      cursor: pointer;
      text-decoration: none;
      box-shadow: 0 4px 14px rgba(16,185,129,0.4);
      transition: transform 0.2s, box-shadow 0.2s;
      animation: pw-download-pulse 1.8s ease-in-out 3;
    }

      .pw-download-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(16,185,129,0.55);
        color: #fff;
        text-decoration: none;
      }

    .pw-download-filename {
      font-size: 0.78rem;
      opacity: 0.85;
      display: block;
      font-weight: 400;
      margin-top: 2px;
    }

    /* ═══ 애니메이션 ════════════════════════════ */
    @@keyframes pw-pbar-shimmer {
      0% {
        background-position: 200% 0;
      }

      100% {
        background-position: -200% 0;
      }
    }

    @@keyframes pw-badge-pulse {
      0%, 100% {
        opacity: 1;
      }

      50% {
        opacity: 0.6;
      }
    }

    @@keyframes pw-card-slide-in {
      from {
        opacity: 0;
        transform: translateY(-10px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @@keyframes pw-download-pulse {
      0% {
        box-shadow: 0 4px 14px rgba(16,185,129,0.4);
      }

      50% {
        box-shadow: 0 4px 28px rgba(16,185,129,0.75), 0 0 50px rgba(16,185,129,0.2);
      }

      100% {
        box-shadow: 0 4px 14px rgba(16,185,129,0.4);
      }
    }

    /* ═══════════════════════════════════════════
     800px 팝업 최적화 오버라이드 (가로 2컬럼 유지)
    ═══════════════════════════════════════════ */
    .pw-header {
      padding: 12px 14px 10px;
      margin-bottom: 14px;
      border-radius: 0 0 14px 14px;
      gap: 8px;
    }

    .pw-header-icon {
      width: 34px;
      height: 34px;
      font-size: 16px;
    }

    .pw-header-title {
      font-size: 1.02rem;
    }

    .pw-header-sub {
      font-size: 0.78rem;
    }

    .pw-btn-reset {
      font-size: 0.8rem;
      padding: 0 10px;
      height: 30px;
    }

    .pw-body {
      gap: 10px;
      padding: 0 10px;
    }

    .pw-upload-card {
      margin-bottom: 10px;
    }

    .pw-upload-card-header {
      padding: 9px 12px 8px;
    }

    .pw-upload-card-title {
      font-size: 0.88rem;
    }

    .pw-card-badge {
      font-size: 0.8rem;
      padding: 3px 9px;
    }

    .pw-dropzone {
      min-height: 130px !important;
      padding: 20px 12px !important;
    }

    .pw-dz-icon {
      font-size: 2rem;
      margin-bottom: 6px;
    }

    .pw-dz-text {
      font-size: 0.86rem;
    }

    .pw-dz-hint {
      font-size: 0.76rem;
    }

    .pw-notice-card {
      padding: 12px 13px;
    }

    .pw-notice-title {
      font-size: 0.86rem;
    }

    .pw-notice-list li {
      font-size: 0.8rem;
    }

    .pw-logo-card {
      margin-bottom: 10px;
    }

    .pw-logo-card-header {
      padding: 9px 12px 8px;
    }

    .pw-logo-hint {
      display: none;
    }

    .pw-logo-opts {
      gap: 10px;
      padding: 8px 12px;
    }

    .pw-logo-opt-label {
      font-size: 0.78rem;
    }

    .pw-logo-seg span {
      padding: 4px 10px;
      font-size: 0.78rem;
    }

    .pw-logo-dropzone {
      min-height: 90px !important;
      padding: 12px 10px !important;
    }

    .pw-tab {
      padding: 9px 10px;
      font-size: 0.84rem;
    }

    .pw-tool-desc {
      padding: 8px 12px;
      font-size: 0.8rem;
    }

    .pw-sidebar {
      top: 10px;
      max-height: calc(100vh - 20px);
    }

    .pw-panel-header {
      padding: 10px 12px;
    }

    .pw-panel-title {
      font-size: 0.9rem;
    }

    .pw-jobs-list {
      padding: 8px;
      gap: 8px;
    }

    .pw-job-name {
      font-size: 0.86rem;
    }

    .pw-download-btn {
      padding: 8px 16px;
      font-size: 0.88rem;
    }
  </style>
</head>
<body>

  <div class="pw-page">

    @* ▶ 헤더 *@
    <div class="pw-header">
      <div class="pw-header-left">
        <div class="pw-header-icon">📄</div>
        <div>
          <div class="pw-header-title">PDF → Word 변환</div>
          <div class="pw-header-sub">PDF 파일을 업로드하면 Word(.docx) 파일로 자동 변환됩니다</div>
        </div>
      </div>
      <div class="pw-header-right">
        <a href="javascript:ResetPage();" class="pw-btn-reset">
          <i class="fa fa-redo" style="font-size:0.72rem;"></i> 초기화
        </a>
      </div>
    </div>

    @* ▶ 메인 2컬럼 *@
    <div class="pw-body">

      @* 좌측: 업로드 영역 *@
      <div class="pw-upload-section">
        <div class="pw-upload-card">
          <div class="pw-upload-card-header">
            <span class="pw-card-badge">📄 PDF</span>
            <span class="pw-upload-card-title">변환할 PDF 파일 업로드</span>
          </div>
          <form id="pdf-to-word" class="dropzone pw-dropzone">
            <div class="dz-message">
              <span class="pw-dz-icon">📂</span>
              <div class="pw-dz-text">파일을 드래그하거나<br>클릭하여 업로드</div>
              <span class="pw-dz-hint">PDF 파일만 지원 &nbsp;·&nbsp; 여러 파일 동시 업로드 가능</span>
            </div>
          </form>
        </div>

        @* PDF 도구 — 로고 삽입 / 연락처 삭제 (탭) *@
        <div class="pw-logo-card">
          <div class="pw-tabs">
            <button type="button" class="pw-tab active" data-tab="logo">🏢 로고 삽입</button>
            <button type="button" class="pw-tab" data-tab="contact">🛡️ 연락처 삭제</button>
          </div>

          @* 로고 삽입 탭 *@
          <div class="pw-tab-panel" id="tab_logo">
            <div class="pw-logo-opts">
              <div class="pw-logo-opt-group">
                <span class="pw-logo-opt-label">로고위치</span>
                <div class="pw-logo-seg">
                  <label><input type="radio" name="logo_position" value="left"><span>좌측 상단</span></label>
                  <label><input type="radio" name="logo_position" value="right" checked><span>우측 상단</span></label>
                </div>
              </div>
              <div class="pw-logo-opt-group">
                <span class="pw-logo-opt-label">페이지</span>
                <div class="pw-logo-seg">
                  <label><input type="radio" name="logo_pages" value="all" checked><span>모든 페이지</span></label>
                  <label><input type="radio" name="logo_pages" value="first"><span>첫 페이지만</span></label>
                </div>
              </div>
            </div>
            <form id="form_logo_insert" class="pw-dropzone pw-logo-dropzone">
              <div class="dz-message">
                <span class="pw-dz-icon">📎</span>
                <div class="pw-dz-text">PDF 파일을 드래그하거나<br>클릭하여 업로드</div>
                <span class="pw-dz-hint">PDF 상단에 유니코 로고를 자동 삽입합니다</span>
              </div>
            </form>
          </div>

          @* 연락처 삭제 탭 *@
          <div class="pw-tab-panel" id="tab_contact" style="display:none;">
            <div class="pw-tool-desc">
              업로드한 PDF에서 <b>이메일·전화번호</b>로 추정되는 정보를 자동으로 가린 후 다운로드합니다.
            </div>
            <form id="form_contact_remove" class="pw-dropzone pw-logo-dropzone">
              <div class="dz-message">
                <span class="pw-dz-icon">🛡️</span>
                <div class="pw-dz-text">PDF 파일을 드래그하거나<br>클릭하여 업로드</div>
                <span class="pw-dz-hint">이메일·전화번호 추정 텍스트를 자동 마스킹</span>
              </div>
            </form>
          </div>
        </div>

        @* 안내사항 *@
        <div class="pw-notice-card">
          <div class="pw-notice-title">
            <i class="fas fa-info-circle" style="color:#0d7377;"></i>
            변환 안내사항
          </div>
          <ul class="pw-notice-list">
            <li class="warn">변환 품질은 원본 PDF의 구조에 따라 다를 수 있습니다. 변환 후 반드시 내용을 확인해주세요.</li>
            <li class="warn">이미지로만 구성된 스캔 PDF는 텍스트 인식이 되지 않을 수 있습니다.</li>
            <li>표, 그래프 등 복잡한 레이아웃은 일부 깨질 수 있습니다.</li>
            <li>여러 파일을 동시에 드래그하면 각각 병렬로 변환됩니다.</li>
            <li>변환 완료 후 다운로드 버튼을 클릭하여 파일을 저장하세요.</li>
          </ul>
        </div>
      </div>

      @* 우측: 변환 현황 패널 *@
      <div class="pw-sidebar">
        <div class="pw-panel">
          <div class="pw-panel-header">
            <div class="pw-panel-title">
              <i class="fas fa-sync-alt"></i> 변환 현황
            </div>
            <div class="pw-panel-counts">
              <span class="pw-count-chip" id="chip_total" style="display:none;"></span>
              <span class="pw-count-chip done" id="chip_done" style="display:none;"></span>
            </div>
          </div>
          <div id="pw_empty_state" class="pw-panel-empty">
            <span class="pw-panel-empty-icon">📭</span>
            <div class="pw-panel-empty-text">
              아직 업로드된 파일이 없습니다.<br>
              좌측에서 PDF 파일을 업로드해주세요.
            </div>
          </div>
          <div class="pw-jobs-list" id="pw_jobs_list" style="display:none;"></div>
        </div>
      </div>

    </div>
  </div>

  <script type="text/javascript">
  window.url_pdf_to_word     = "@Url.Action("PdfToWord",            "nGpt")";
  window.url_insert_logo     = "@Url.Action("InsertLogoToPdf",      "nGpt")";
  window.url_remove_contacts = "@Url.Action("RemoveContactsFromPdf", "nGpt")";
  </script>

  <script type="text/javascript">
    // ─────────────────────────────────────────────────────────
    //  탭 전환 (로고 삽입 / 연락처 삭제) + 도구 Dropzone
    // ─────────────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', function () {
      // 탭 전환
      var tabs = document.querySelectorAll('.pw-tab');
      tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
          tabs.forEach(function (t) { t.classList.remove('active'); });
          tab.classList.add('active');
          var target = tab.getAttribute('data-tab');
          document.getElementById('tab_logo').style.display = (target === 'logo') ? '' : 'none';
          document.getElementById('tab_contact').style.display = (target === 'contact') ? '' : 'none';
        });
      });

      // 로고 삽입 Dropzone → 우측 변환현황 패널에 결과 표시
      var logoDz = new Dropzone("#form_logo_insert", {
        url: "/dummy",
        autoProcessQueue: false,
        previewTemplate: '<div style="display:none;"></div>'
      });
      logoDz.on("addedfile", function (file) {
        var ext = ('.' + file.name.split('.').pop()).toLowerCase();
        if (ext !== '.pdf') { alert('PDF 파일만 지원합니다.'); return; }
        runPdfTool(file, {
          url: window.url_insert_logo,
          fields: {
            position: document.querySelector('input[name="logo_position"]:checked').value,
            pages: document.querySelector('input[name="logo_pages"]:checked').value
          },
          icon: '🏢',
          procBadge: '삽입중',
          procText: '로고 삽입 중...',
          outSuffix: '_logo.pdf',
          dlIcon: 'fas fa-file-pdf'
        });
      });

      // 연락처 삭제 Dropzone → 우측 변환현황 패널에 결과 표시
      var contactDz = new Dropzone("#form_contact_remove", {
        url: "/dummy",
        autoProcessQueue: false,
        previewTemplate: '<div style="display:none;"></div>'
      });
      contactDz.on("addedfile", function (file) {
        var ext = ('.' + file.name.split('.').pop()).toLowerCase();
        if (ext !== '.pdf') { alert('PDF 파일만 지원합니다.'); return; }
        runPdfTool(file, {
          url: window.url_remove_contacts,
          fields: {},
          icon: '🛡️',
          procBadge: '처리중',
          procText: '연락처 마스킹 중...',
          outSuffix: '_redacted.pdf',
          dlIcon: 'fas fa-file-pdf'
        });
      });
    });

    // ── PDF 도구 공통 실행기 (로고 삽입 / 연락처 삭제) ──────
    async function runPdfTool(file, opts) {
      var seq = ++job_seq;
      total_cnt++;
      showJobsList();
      updateCounts();
      createJobCard(seq, file.name, opts.icon, opts.procBadge);
      document.getElementById('pw-job-status-' + seq).textContent = opts.procText;

      try {
        var fd = new FormData();
        fd.append('file', file, file.name);
        for (var k in opts.fields) fd.append(k, opts.fields[k]);

        var res = await fetch(opts.url, { method: 'POST', body: fd });

        var ct = res.headers.get('content-type') || '';
        if (!res.ok || ct.indexOf('application/json') !== -1) {
          var err = await res.json().catch(function () { return { message: 'HTTP ' + res.status + ' 오류' }; });
          updateJobError(seq, err.message || '처리에 실패했습니다.');
          return;
        }

        var blob = await res.blob();
        var outName = file.name.replace(/\.pdf$/i, opts.outSuffix);
        done_cnt++;
        updateCounts();
        updateJobDone(seq, blob, outName, opts.dlIcon);

      } catch (e) {
        updateJobError(seq, '네트워크 오류: ' + e.message);
      }
    }
  </script>

  <script type="text/javascript">
    Dropzone.autoDiscover = false;

    var total_cnt = 0;
    var done_cnt = 0;
    var job_seq = 0;

    /* ── 카운트 칩 업데이트 ─────────────────────────── */
    function updateCounts() {
      var chipTotal = document.getElementById('chip_total');
      var chipDone = document.getElementById('chip_done');
      if (total_cnt > 0) {
        chipTotal.style.display = '';
        chipTotal.textContent = '전체 ' + total_cnt + '건';
      }
      if (done_cnt > 0) {
        chipDone.style.display = '';
        chipDone.textContent = '✅ ' + done_cnt + '건 완료';
      }
    }

    /* ── 빈 상태 → 목록 전환 ────────────────────────── */
    function showJobsList() {
      document.getElementById('pw_empty_state').style.display = 'none';
      document.getElementById('pw_jobs_list').style.display = '';
    }

    /* ── Job 카드 생성 ──────────────────────────────── */
    function createJobCard(seq, fileName, icon, procBadge) {
      icon = icon || '📄';
      procBadge = procBadge || '변환중';
      var list = document.getElementById('pw_jobs_list');
      var card = document.createElement('div');
      card.className = 'pw-job-card';
      card.id = 'pw-job-' + seq;
      card.innerHTML =
        '<div class="pw-job-head">' +
        '<div class="pw-job-icon">' + icon + '</div>' +
        '<div class="pw-job-info">' +
        '<div class="pw-job-name" title="' + fileName + '">' + fileName + '</div>' +
        '<div class="pw-job-status-text" id="pw-job-status-' + seq + '">업로드 중...</div>' +
        '</div>' +
        '<span class="pw-job-badge processing" id="pw-job-badge-' + seq + '">' + procBadge + '</span>' +
        '</div>' +
        '<div class="pw-job-pbar-wrap">' +
        '<div class="pw-job-pbar-track">' +
        '<div class="pw-job-pbar-fill" id="pw-job-pbar-' + seq + '"></div>' +
        '</div>' +
        '</div>';
      list.prepend(card);
    }

    /* ── Job 완료 처리 ──────────────────────────────── */
    function updateJobDone(seq, blob, outputName, dlIcon) {
      dlIcon = dlIcon || 'fas fa-file-word';
      var card = document.getElementById('pw-job-' + seq);
      if (!card) return;

      card.classList.add('is-complete');
      document.getElementById('pw-job-status-' + seq).textContent = '완료!';
      document.getElementById('pw-job-status-' + seq).style.color = '#10b981';
      document.getElementById('pw-job-badge-' + seq).className = 'pw-job-badge done';
      document.getElementById('pw-job-badge-' + seq).textContent = '완료';
      document.getElementById('pw-job-pbar-' + seq).className = 'pw-job-pbar-fill is-done';

      var dlArea = document.createElement('div');
      dlArea.className = 'pw-download-area';
      var objUrl = URL.createObjectURL(blob);
      dlArea.innerHTML =
        '<a href="' + objUrl + '" download="' + outputName + '" class="pw-download-btn">' +
        '<i class="' + dlIcon + '"></i> 다운로드' +
        '<span class="pw-download-filename">' + outputName + '</span>' +
        '</a>';
      card.appendChild(dlArea);
    }

    /* ── Job 오류 처리 ──────────────────────────────── */
    function updateJobError(seq, message) {
      var card = document.getElementById('pw-job-' + seq);
      if (!card) return;
      card.classList.add('is-error');
      document.getElementById('pw-job-status-' + seq).textContent = message || '변환 실패';
      document.getElementById('pw-job-status-' + seq).style.color = '#ef4444';
      document.getElementById('pw-job-badge-' + seq).className = 'pw-job-badge error';
      document.getElementById('pw-job-badge-' + seq).textContent = '오류';
      document.getElementById('pw-job-pbar-' + seq).className = 'pw-job-pbar-fill is-error';
    }

    /* ── 파일 1개 변환 (fetch + blob 다운로드) ─────── */
    async function convertFile(file) {
      var seq = ++job_seq;
      total_cnt++;
      showJobsList();
      updateCounts();
      createJobCard(seq, file.name);

      var formData = new FormData();
      formData.append('file', file);

      try {
        document.getElementById('pw-job-status-' + seq).textContent = '서버에 업로드 중...';

        var response = await fetch(window.url_pdf_to_word, {
          method: 'POST',
          body: formData
        });

        document.getElementById('pw-job-status-' + seq).textContent = 'Word로 변환 중...';

        if (!response.ok) {
          updateJobError(seq, 'HTTP ' + response.status + ' 오류');
          return;
        }

        var contentType = response.headers.get('content-type') || '';
        if (contentType.indexOf('application/json') !== -1) {
          var json = await response.json();
          updateJobError(seq, json.message || '변환에 실패했습니다.');
          return;
        }

        var blob = await response.blob();
        var outputName = file.name.replace(/\.pdf$/i, '.docx');
        done_cnt++;
        updateCounts();
        updateJobDone(seq, blob, outputName);

      } catch (e) {
        updateJobError(seq, '네트워크 오류: ' + e.message);
      }
    }

    /* ── Dropzone 초기화 ────────────────────────────── */
    var myDropzone = new Dropzone("#pdf-to-word", {
      autoProcessQueue: false,
      url: window.url_pdf_to_word,
      method: "post"
    });

    myDropzone.on("addedfile", function (file) {
      this.removeFile(file);

      if (!file.name.toLowerCase().endsWith('.pdf') && file.type !== 'application/pdf') {
        alert('PDF 파일만 업로드 가능합니다.');
        return;
      }
      convertFile(file);
    });

    /* ── 초기화 ─────────────────────────────────────── */
    function ResetPage() {
      if (confirm("화면을 초기화 하시겠습니까?")) {
        location.reload();
      }
    }
  </script>

</body>
</html>
